# ==========================================================================
# 指标个体(含 FIBO 映射 + SQL)
# ==========================================================================

yql:Indicator_POST_AR_03 a yql:BadDebtLossAmount ;
    skos:notation "POST-AR-03" ;
    rdfs:label "【应收应付】坏账发生额"@zh ;
    skos:altLabel "坏账发生额"@zh ;
    dcterms:subject "应收应付"@zh ;
    yql:hasFormula "SUM(坏账损失金额)"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PostLoanMonitoring
  ; yql:usesTable ncc:ARAP_BDLOSS
  ; yql:mapsToField ncc:ARAP_BDLOSS__APPROVESTATUS, ncc:ARAP_BDLOSS__BILLDATE, ncc:ARAP_BDLOSS__LOSSLOCALMONEY, ncc:ARAP_BDLOSS__PK_ORG
  ; yql:hasSQL """-- POST-AR-03 坏账发生额 = SUM(本期坏账本币金额)
SELECT NVL(SUM(LOSSLOCALMONEY), 0) AS bad_debt_loss_amount
FROM ARAP_BDLOSS
WHERE PK_ORG = :org_id
  AND BILLDATE BETWEEN :start_date AND :asof_date
  AND NVL(DR, 0) = 0
  AND APPROVESTATUS = 1;  -- TODO #BDL-1: 已审批坏账,默认 1=通过"""
    .

yql:Indicator_POST_AR_04 a yql:BadDebtLossCount ;
    skos:notation "POST-AR-04" ;
    rdfs:label "【应收应付】坏账发生笔数"@zh ;
    skos:altLabel "坏账发生笔数"@zh ;
    dcterms:subject "应收应付"@zh ;
    yql:hasFormula "COUNT(坏账单据)"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PostLoanMonitoring
  ; yql:usesTable ncc:ARAP_BDLOSS
  ; yql:mapsToField ncc:ARAP_BDLOSS__APPROVESTATUS, ncc:ARAP_BDLOSS__BILLDATE, ncc:ARAP_BDLOSS__PK_ORG
  ; yql:hasSQL """-- POST-AR-04 坏账发生笔数
SELECT COUNT(*) AS bad_debt_loss_count
FROM ARAP_BDLOSS
WHERE PK_ORG = :org_id
  AND BILLDATE BETWEEN :start_date AND :asof_date
  AND NVL(DR, 0) = 0
  AND APPROVESTATUS = 1;"""
    .

yql:Indicator_POST_GUA_01 a yql:NewGuaranteeContractCount ;
    skos:notation "POST-GUA-01" ;
    rdfs:label "【担保变化】新增担保合同数"@zh ;
    skos:altLabel "新增担保合同数"@zh ;
    dcterms:subject "担保变化"@zh ;
    yql:hasFormula "COUNT where BILLMAKEDATE in 本期"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PostLoanMonitoring
  ; yql:usesTable ncc:GPMC_GUACONTRACT
  ; yql:mapsToField ncc:GPMC_GUACONTRACT__BILLMAKEDATE, ncc:GPMC_GUACONTRACT__PK_ORG
  ; yql:hasSQL """-- POST-GUA-01 新增担保合同数(本期内制单)
SELECT COUNT(*) AS new_guarantee_contract_count
FROM GPMC_GUACONTRACT
WHERE PK_ORG = :org_id
  AND BILLMAKEDATE BETWEEN :start_date AND :asof_date
  AND NVL(DR, 0) = 0;"""
    .

yql:Indicator_POST_REP_01 a yql:PlannedPrincipalRepayment ;
    skos:notation "POST-REP-01" ;
    rdfs:label "【还款表现】本期计划还本金额"@zh ;
    skos:altLabel "本期计划还本金额"@zh ;
    dcterms:subject "还款表现"@zh ;
    yql:hasFormula "SUM(计划还本)"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PostLoanMonitoring
  ; yql:usesTable ncc:CDMC_REPAYPRCPL
  ; yql:mapsToField ncc:CDMC_REPAYPRCPL__PK_ORG, ncc:CDMC_REPAYPRCPL__REPAYDATE, ncc:CDMC_REPAYPRCPL__REPAYMNY
  ; yql:hasSQL """-- POST-REP-01 本期计划还本金额 = SUM(REPAYMNY)
SELECT NVL(SUM(REPAYMNY), 0) AS planned_principal_repayment
FROM CDMC_REPAYPRCPL
WHERE PK_ORG = :org_id
  AND REPAYDATE BETWEEN :start_date AND :asof_date
  AND NVL(DR, 0) = 0;"""
    .

yql:Indicator_POST_REP_02 a yql:ActualPrincipalRepayment ;
    skos:notation "POST-REP-02" ;
    rdfs:label "【还款表现】本期实际还本金额"@zh ;
    skos:altLabel "本期实际还本金额"@zh ;
    dcterms:subject "还款表现"@zh ;
