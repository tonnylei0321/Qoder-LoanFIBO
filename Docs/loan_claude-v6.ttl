    yql:appliedInScenario scn:SupplyChainFinance
  ; yql:usesTable ncc:CDMC_CONTRACT
  ; yql:mapsToField ncc:CDMC_CONTRACT__BEGINDATE, ncc:CDMC_CONTRACT__PK_FINANCORG, ncc:CDMC_CONTRACT__PK_ORG
  ; yql:hasSQL """-- SCF-LOAN-01 融资机构数(去重)
SELECT COUNT(DISTINCT PK_FINANCORG) AS financing_institution_count
FROM CDMC_CONTRACT
WHERE PK_ORG = :org_id
  AND NVL(DR, 0) = 0
  AND BEGINDATE <= :asof_date;"""
    .

yql:Indicator_SCF_LOAN_02 a yql:FinancingChannelCount ;
    skos:notation "SCF-LOAN-02" ;
    rdfs:label "【融资行为】融资渠道数"@zh ;
    skos:altLabel "融资渠道数"@zh ;
    dcterms:subject "融资行为"@zh ;
    yql:hasFormula "DISTINCT(融资方式)"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:SupplyChainFinance
  ; yql:usesTable ncc:BATM_FINANCING, ncc:BOND_CONTRACT, ncc:CDMC_CONTRACT
  ; yql:mapsToField ncc:BATM_FINANCING__BEGINDATE, ncc:BATM_FINANCING__DR, ncc:BATM_FINANCING__FINANCING_ORG, ncc:BATM_FINANCING__PK_ORG,
      ncc:BOND_CONTRACT__DR, ncc:BOND_CONTRACT__ISSUERID, ncc:BOND_CONTRACT__ISSUESTARTDATE, ncc:BOND_CONTRACT__PK_ORG,
      ncc:CDMC_CONTRACT__BEGINDATE, ncc:CDMC_CONTRACT__DR, ncc:CDMC_CONTRACT__PK_FINANCORG, ncc:CDMC_CONTRACT__PK_ORG
  ; yql:hasSQL """-- SCF-LOAN-02 融资渠道数(合并 CDMC/BOND/BATM 各自去重方式后求和)
SELECT
  (SELECT COUNT(DISTINCT PK_FINANCORG) FROM CDMC_CONTRACT
   WHERE PK_ORG = :org_id AND NVL(DR, 0) = 0 AND BEGINDATE <= :asof_date)
+ (SELECT COUNT(DISTINCT ISSUERID) FROM BOND_CONTRACT
   WHERE PK_ORG = :org_id AND NVL(DR, 0) = 0 AND ISSUESTARTDATE <= :asof_date)
+ (SELECT COUNT(DISTINCT FINANCING_ORG) FROM BATM_FINANCING
   WHERE PK_ORG = :org_id AND NVL(DR, 0) = 0 AND BEGINDATE <= :asof_date)
  AS financing_channel_count
FROM dual;
-- TODO #SCFL-1: 如有跨表机构重复,需做全局去重(本 SQL 简化为各自去重后求和)"""
    .

