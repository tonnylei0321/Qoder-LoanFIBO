yql:Indicator_SCF_INV_02 a yql:AvgInventoryAmount ;
    skos:notation "SCF-INV-02" ;
    rdfs:label "【存货融资】平均存货余额"@zh ;
    skos:altLabel "平均存货余额"@zh ;
    dcterms:subject "存货融资"@zh ;
    yql:hasFormula "AVG(近12月存货)"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:SupplyChainFinance
  ; yql:usesTable ncc:IA_MONTHNAB
  ; yql:mapsToField ncc:IA_MONTHNAB__CACCOUNTPERIOD, ncc:IA_MONTHNAB__NABMNY, ncc:IA_MONTHNAB__PK_ORG
  ; yql:hasSQL """-- SCF-INV-02 平均存货余额 = 近12月存货月末均值
SELECT ROUND(AVG(NABMNY), 2) AS avg_inventory_amount FROM (
  SELECT CACCOUNTPERIOD, SUM(NABMNY) AS NABMNY
  FROM IA_MONTHNAB
  WHERE PK_ORG = :org_id
    AND CACCOUNTPERIOD >= TO_CHAR(ADD_MONTHS(TO_DATE(:year||LPAD(:period, 2, '0'),'YYYYMM'), -11), 'YYYYMM')
    AND CACCOUNTPERIOD <= :year||LPAD(:period, 2, '0')
    AND NVL(DR, 0) = 0
  GROUP BY CACCOUNTPERIOD
);"""
    .

yql:Indicator_SCF_LOAN_01 a yql:FinancingInstitutionCount ;
    skos:notation "SCF-LOAN-01" ;
    rdfs:label "【融资行为】融资机构数"@zh ;
    skos:altLabel "融资机构数"@zh ;
