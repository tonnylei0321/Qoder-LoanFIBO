    yql:hasFormula "应付总额/笔数"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:SupplyChainFinance
  ; yql:usesTable ncc:AP_PAYABLEBILL
  ; yql:mapsToField ncc:AP_PAYABLEBILL__BILLPERIOD, ncc:AP_PAYABLEBILL__BILLYEAR, ncc:AP_PAYABLEBILL__LOCAL_MONEY, ncc:AP_PAYABLEBILL__PK_ORG
  ; yql:hasSQL """-- SCF-UP-03 应付平均单笔金额
SELECT ROUND(NVL(SUM(LOCAL_MONEY), 0) / NULLIF(COUNT(*), 0), 2) AS avg_payable_amount
FROM AP_PAYABLEBILL
WHERE PK_ORG = :org_id
  AND BILLYEAR = :year AND BILLPERIOD = :period
  AND NVL(DR, 0) = 0;"""
    .

yql:Indicator_SCF_UP_05 a yql:LongTermSupplierCount ;
    skos:notation "SCF-UP-05" ;
    rdfs:label "【上游供应商】长期供应商数"@zh ;
    skos:altLabel "长期供应商数"@zh ;
    dcterms:subject "上游供应商"@zh ;
    yql:hasFormula "COUNT where BEGINDATE 早于 asof-1y"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:SupplyChainFinance
  ; yql:usesTable ncc:BD_SUPPLIER
  ; yql:mapsToField ncc:BD_SUPPLIER__BEGINDATE, ncc:BD_SUPPLIER__ENABLESTATE, ncc:BD_SUPPLIER__PK_ORG
  ; yql:hasSQL """-- SCF-UP-05 长期供应商数(开始日期早于 asof_date-1 年)
SELECT COUNT(*) AS long_term_supplier_count
FROM BD_SUPPLIER
WHERE PK_ORG = :org_id
  AND ENABLESTATE = 2
  AND BEGINDATE <= TO_CHAR(ADD_MONTHS(TO_DATE(:asof_date,'YYYY-MM-DD'), -12), 'YYYY-MM-DD HH24:MI:SS')
  AND NVL(DR, 0) = 0;"""
    .

# ==========================================================================
# SPARQL 查询示例(作为注释,便于代理服务调用)
# ==========================================================================
#
# 1. 查某场景下所有指标名和 SQL:
#   SELECT ?label ?sql WHERE {
#     ?i a yql:Indicator ; yql:appliedInScenario scn:PreLoanDD ;
#        rdfs:label ?label ; yql:hasSQL ?sql .
#   }
#
# 2. 查某表的所有指标:
#   SELECT ?label WHERE {
#     ?i yql:usesTable ncc:GL_BALANCE ; rdfs:label ?label .
#   }
#
# 3. 查所有比率类指标:
#   SELECT ?label WHERE {
#     ?i a ?cls ; rdfs:label ?label .
#     ?cls rdfs:subClassOf yql:RatioIndicator .
#   }
