      ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG
  ; yql:usesAccount acc:Account_1, acc:Account_1231, acc:Account_1407, acc:Account_1471, acc:Account_1602, acc:Account_1702
  ; yql:hasSQL """-- PRE-SCALE-01 总资产规模
  WITH bal AS (
    SELECT ACCOUNTCODE,
           SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
