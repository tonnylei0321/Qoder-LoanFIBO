# ==========================================================================
# 信贷指标本体 v1.3 - 76 个简单指标(难度=1)
# 生成日期: 2026-04-22
# 场景覆盖:贷前尽调 / 贷后监控 / 供应链金融
# FIBO 映射:Ratio / MonetaryAmount / Contract / Counterparty /
#            Debt / DebtInstrument / PaymentObligation(共 7 类)
# SQL 内嵌:yql:hasSQL,字段已 100% 对齐 YonBIP NCC 真实 DDL
# ==========================================================================

@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix fibo-fbc-dae-dbt: <https://spec.edmcouncil.org/fibo/ontology/FBC/DebtAndEquities/Debt/> .
@prefix fibo-fbc-pas-fpas: <https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/FinancialProductsAndServices/> .
@prefix fibo-fnd-acc-cur: <https://spec.edmcouncil.org/fibo/ontology/FND/Accounting/CurrencyAmount/> .
@prefix fibo-fnd-agr-ctr: <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/> .
@prefix fibo-fnd-arr-rt: <https://spec.edmcouncil.org/fibo/ontology/FND/Arrangements/Ratios/> .
@prefix fibo-fnd-pas-psch: <https://spec.edmcouncil.org/fibo/ontology/FND/ProductsAndServices/PaymentsAndSchedules/> .
@prefix yql: <http://yql.example.com/ontology/credit-risk/> .
@prefix ncc: <http://yql.example.com/ontology/ncc-mapping/> .
@prefix scn: <http://yql.example.com/ontology/scenario/> .
@prefix acc: <http://yql.example.com/ontology/account-code/> .

<http://yql.example.com/ontology/credit-risk/v1.3> a owl:Ontology ;
    rdfs:label "信贷风控指标本体 v1.3"@zh ;
    rdfs:comment "基于用友 YonBIP NCC 真实 DDL 的 76 个难度=1 简单指标,映射到 FIBO 白名单类"@zh ;
    dcterms:created "2026-04-22"^^xsd:date ;
    owl:versionInfo "1.3" .

# ==========================================================================
# 顶层类(yql 命名空间)
# ==========================================================================

yql:Indicator a owl:Class ;
    rdfs:label "指标"@zh ;
    rdfs:comment "所有信贷指标的父类"@zh .

yql:RatioIndicator a owl:Class ;
    rdfs:subClassOf yql:Indicator ;
    rdfs:label "比率指标"@zh ;
    skos:closeMatch fibo-fnd-arr-rt:Ratio .

yql:AmountIndicator a owl:Class ;
    rdfs:subClassOf yql:Indicator ;
    rdfs:label "金额指标"@zh ;
    skos:closeMatch fibo-fnd-acc-cur:MonetaryAmount .

yql:CountIndicator a owl:Class ;
    rdfs:subClassOf yql:Indicator ;
    rdfs:label "计数指标"@zh ;
    rdfs:comment "FIBO 无通用计数类,采用 yql 自定义"@zh .

yql:NCCTable a owl:Class ;
    rdfs:label "NCC 数据表"@zh .

yql:NCCField a owl:Class ;
    rdfs:label "NCC 字段"@zh .

yql:Scenario a owl:Class ;
    rdfs:label "应用场景"@zh .

yql:AccountCode a owl:Class ;
    rdfs:label "会计科目"@zh .

# ==========================================================================
# 对象属性与数据属性
# ==========================================================================

yql:appliedInScenario a owl:ObjectProperty ;
    rdfs:label "应用于场景"@zh ;
    rdfs:domain yql:Indicator ;
    rdfs:range yql:Scenario .

yql:usesTable a owl:ObjectProperty ;
    rdfs:label "使用表"@zh ;
    rdfs:domain yql:Indicator ;
    rdfs:range yql:NCCTable .

yql:mapsToField a owl:ObjectProperty ;
    rdfs:label "映射到字段"@zh ;
    rdfs:domain yql:Indicator ;
    rdfs:range yql:NCCField .

yql:usesAccount a owl:ObjectProperty ;
    rdfs:label "使用会计科目"@zh ;
    rdfs:domain yql:Indicator ;
    rdfs:range yql:AccountCode .

yql:hasFormula a owl:DatatypeProperty ;
    rdfs:label "公式"@zh ;
    rdfs:domain yql:Indicator ;
    rdfs:range xsd:string .

yql:hasSQL a owl:DatatypeProperty ;
    rdfs:label "SQL 查询"@zh ;
    rdfs:domain yql:Indicator ;
    rdfs:range xsd:string .

yql:complexityTier a owl:DatatypeProperty ;
    rdfs:label "复杂度"@zh ;
    rdfs:comment "1=简单单表/2=双表或双期/3=多表"@zh ;
    rdfs:range xsd:integer .

yql:inTable a owl:ObjectProperty ;
    rdfs:label "归属表"@zh ;
    rdfs:domain yql:NCCField ;
    rdfs:range yql:NCCTable .

# ==========================================================================
# 场景
# ==========================================================================

scn:PreLoanDD a yql:Scenario ;
    rdfs:label "贷前尽调"@zh ;
    rdfs:comment "贷款发放前的企业财务与经营尽职调查"@zh .

scn:PostLoanMonitoring a yql:Scenario ;
    rdfs:label "贷后监控"@zh ;
    rdfs:comment "贷款发放后的持续经营与还款监测"@zh .

scn:SupplyChainFinance a yql:Scenario ;
    rdfs:label "供应链金融"@zh ;
    rdfs:comment "基于核心企业上下游交易的融资决策"@zh .

# ==========================================================================
