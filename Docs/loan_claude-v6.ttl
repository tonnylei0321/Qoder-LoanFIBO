  ; yql:mapsToField ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__PK_ORG
  ; yql:hasSQL """-- PRE-CUST-01 活跃客户数 = 近 12 个月有应收业务的 DISTINCT 客户数
