FROM AP_PAYABLEITEM
WHERE PK_ORG = :org_id
  AND BILLDATE >= TO_CHAR(ADD_MONTHS(TO_DATE(:asof_date,'YYYY-MM-DD'), -12), 'YYYY-MM-DD HH24:MI:SS')
  AND BILLDATE <= :asof_date||' 23:59:59';"""
