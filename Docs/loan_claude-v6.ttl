yql:Indicator_PRE_SOLV_01 a yql:CurrentRatio ;
    skos:notation "PRE-SOLV-01" ;
    rdfs:label "【偿债能力】流动比率"@zh ;
    skos:altLabel "流动比率"@zh ;
    dcterms:subject "偿债能力"@zh ;
    yql:hasFormula "流动资产/流动负债"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PreLoanDD
  ; yql:usesTable ncc:GL_BALANCE
  ; yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD,
      ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG
  ; yql:usesAccount acc:Account_1001, acc:Account_1002, acc:Account_1012, acc:Account_1101, acc:Account_1121, acc:Account_1122, acc:Account_1123, acc:Account_1125, acc:Account_1126, acc:Account_1131, acc:Account_1132, acc:Account_1221, acc:Account_1231, acc:Account_1401, acc:Account_1402, acc:Account_1403, acc:Account_1404, acc:Account_1405, acc:Account_1406, acc:Account_1407, acc:Account_1408, acc:Account_1411, acc:Account_1471, acc:Account_2001, acc:Account_2101, acc:Account_2201, acc:Account_2202, acc:Account_2203, acc:Account_2204, acc:Account_2211, acc:Account_2221, acc:Account_2241
  ; yql:hasSQL """-- PRE-SOLV-01 流动比率 = 流动资产/流动负债
-- TODO #GL-1: 确认 LOCALDEBIT/CREDITAMOUNT 为"累计余额"口径
-- TODO #GL-2: 确认 GL_BALANCE 仅含末级科目
  WITH bal AS (
    SELECT ACCOUNTCODE,
           SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
           SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
    FROM GL_BALANCE
    WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
      AND YEAR = :year AND PERIOD = :period
    GROUP BY ACCOUNTCODE
  )
  SELECT ROUND((NVL((SELECT SUM(net_debit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '1001%' OR ACCOUNTCODE LIKE '1002%' OR ACCOUNTCODE LIKE '1012%'
 OR ACCOUNTCODE LIKE '1101%' OR ACCOUNTCODE LIKE '1121%' OR ACCOUNTCODE LIKE '1122%'
 OR ACCOUNTCODE LIKE '1123%' OR ACCOUNTCODE LIKE '1131%' OR ACCOUNTCODE LIKE '1132%'
 OR ACCOUNTCODE LIKE '1221%' OR ACCOUNTCODE LIKE '1401%' OR ACCOUNTCODE LIKE '1402%'
 OR ACCOUNTCODE LIKE '1403%' OR ACCOUNTCODE LIKE '1404%' OR ACCOUNTCODE LIKE '1405%'
 OR ACCOUNTCODE LIKE '1406%' OR ACCOUNTCODE LIKE '1408%' OR ACCOUNTCODE LIKE '1411%'
 OR ACCOUNTCODE LIKE '1125%' OR ACCOUNTCODE LIKE '1126%'), 0)
 - NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE
    ACCOUNTCODE LIKE '1231%' OR ACCOUNTCODE LIKE '1407%' OR ACCOUNTCODE LIKE '1471%'), 0)
 + NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal > 0), 0)) / NULLIF((NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE
    ACCOUNTCODE LIKE '2001%' OR ACCOUNTCODE LIKE '2101%' OR ACCOUNTCODE LIKE '2201%'
 OR ACCOUNTCODE LIKE '2202%' OR ACCOUNTCODE LIKE '2203%' OR ACCOUNTCODE LIKE '2204%'
 OR ACCOUNTCODE LIKE '2211%' OR ACCOUNTCODE LIKE '2241%'), 0)
 + NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal < 0), 0)), 0), 4) AS current_ratio FROM dual;"""
    .

