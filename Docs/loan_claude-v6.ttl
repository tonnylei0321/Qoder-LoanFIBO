  )
  SELECT (NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1%'), 0)
 - NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE
    ACCOUNTCODE LIKE '1231%' OR ACCOUNTCODE LIKE '1407%' OR ACCOUNTCODE LIKE '1471%'
 OR ACCOUNTCODE LIKE '1602%' OR ACCOUNTCODE LIKE '1702%'), 0)) AS total_assets FROM dual;"""
    .

