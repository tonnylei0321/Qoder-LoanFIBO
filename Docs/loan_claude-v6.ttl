 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%' OR ACCOUNTCODE LIKE '6403%'
 OR ACCOUNTCODE LIKE '6601%' OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6603%'
 OR ACCOUNTCODE LIKE '6604%' OR ACCOUNTCODE LIKE '6701%' OR ACCOUNTCODE LIKE '6702%'), 0)
 + NVL((SELECT SUM(net_credit_bal) FROM bal WHERE
