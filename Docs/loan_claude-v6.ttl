yql:Indicator_PRE_PROF_01 a yql:GrossMargin ;
    skos:notation "PRE-PROF-01" ;
    rdfs:label "【盈利能力】毛利率"@zh ;
    skos:altLabel "毛利率"@zh ;
    dcterms:subject "盈利能力"@zh ;
    yql:hasFormula "(营收-营业成本)/营收"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PreLoanDD
  ; yql:usesTable ncc:GL_BALANCE
  ; yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD,
      ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG
  ; yql:usesAccount acc:Account_6001, acc:Account_6051, acc:Account_6401, acc:Account_6402
  ; yql:hasSQL """-- PRE-PROF-01 毛利率 = (营收-营业成本)/营收
  WITH bal AS (
    SELECT ACCOUNTCODE,
           SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
           SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
    FROM GL_BALANCE
    WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
      AND YEAR = :year AND PERIOD = :period
    GROUP BY ACCOUNTCODE
  )
  SELECT ROUND(((NVL((SELECT SUM(net_credit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'), 0)) - (NVL((SELECT SUM(net_debit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%'), 0))) / NULLIF((NVL((SELECT SUM(net_credit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'), 0)), 0), 4) AS gross_margin FROM dual;"""
    .

yql:Indicator_PRE_PROF_02 a yql:NetProfitMargin ;
    skos:notation "PRE-PROF-02" ;
    rdfs:label "【盈利能力】净利率"@zh ;
    skos:altLabel "净利率"@zh ;
    dcterms:subject "盈利能力"@zh ;
    yql:hasFormula "净利润/营收"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PreLoanDD
  ; yql:usesTable ncc:GL_BALANCE
  ; yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD,
      ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG
  ; yql:usesAccount acc:Account_6001, acc:Account_6051, acc:Account_6111, acc:Account_6117, acc:Account_6301, acc:Account_6401, acc:Account_6402, acc:Account_6403, acc:Account_6601, acc:Account_6602, acc:Account_6603, acc:Account_6604, acc:Account_6701, acc:Account_6702, acc:Account_6711, acc:Account_6801
  ; yql:hasSQL """-- PRE-PROF-02 净利率 = 净利润/营收
  WITH bal AS (
    SELECT ACCOUNTCODE,
           SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
           SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
    FROM GL_BALANCE
    WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
      AND YEAR = :year AND PERIOD = :period
    GROUP BY ACCOUNTCODE
  )
  SELECT ROUND((NVL((SELECT SUM(net_credit_bal) FROM bal WHERE ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'), 0)
 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%' OR ACCOUNTCODE LIKE '6403%'
 OR ACCOUNTCODE LIKE '6601%' OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6603%'
 OR ACCOUNTCODE LIKE '6604%' OR ACCOUNTCODE LIKE '6701%' OR ACCOUNTCODE LIKE '6702%'
 OR ACCOUNTCODE LIKE '6711%' OR ACCOUNTCODE LIKE '6801%'), 0)
 + NVL((SELECT SUM(net_credit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%' OR ACCOUNTCODE LIKE '6301%'), 0)) / NULLIF((NVL((SELECT SUM(net_credit_bal) FROM bal WHERE
    ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'), 0)), 0), 4) AS net_profit_margin FROM dual;"""
    .

