# ==========================================================================
# NCC 表个体
# ==========================================================================

ncc:AP_PAYABLEBILL a yql:NCCTable ;
    rdfs:label "应付单主表"@zh ;
    skos:notation "AP_PAYABLEBILL" .

ncc:AP_PAYABLEITEM a yql:NCCTable ;
    rdfs:label "应付单明细表"@zh ;
    skos:notation "AP_PAYABLEITEM" .

ncc:ARAP_BALANCE a yql:NCCTable ;
    rdfs:label "往来余额表"@zh ;
    skos:notation "ARAP_BALANCE" .

ncc:ARAP_BDLOSS a yql:NCCTable ;
    rdfs:label "坏账损失主表"@zh ;
    skos:notation "ARAP_BDLOSS" .

ncc:AR_RECBILL a yql:NCCTable ;
    rdfs:label "应收单主表"@zh ;
    skos:notation "AR_RECBILL" .

ncc:AR_RECITEM a yql:NCCTable ;
    rdfs:label "应收单明细表"@zh ;
    skos:notation "AR_RECITEM" .

ncc:BATM_FINANCING a yql:NCCTable ;
    rdfs:label "融资台账表"@zh ;
