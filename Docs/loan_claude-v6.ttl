    yql:hasFormula "SUM(剩余本金)"@zh ;
    yql:complexityTier 1 ;
    yql:appliedInScenario scn:PreLoanDD
  ; yql:usesTable ncc:CDMC_CONTRACT
  ; yql:mapsToField ncc:CDMC_CONTRACT__AVAILABLEMNY, ncc:CDMC_CONTRACT__BEGINDATE, ncc:CDMC_CONTRACT__BUSISTATUS, ncc:CDMC_CONTRACT__CCMNY,
      ncc:CDMC_CONTRACT__ENDDATE, ncc:CDMC_CONTRACT__PK_ORG
  ; yql:hasSQL """-- PRE-LOAN-02 当前融资余额 = SUM(CCMNY-AVAILABLEMNY) 即已使用额度
-- TODO #LOAN-1: CCMNY=信用金额,AVAILABLEMNY=可用额度,差值=已用。业务方确认口径
SELECT NVL(SUM(CCMNY - AVAILABLEMNY), 0) AS current_loan_balance
FROM CDMC_CONTRACT
WHERE PK_ORG = :org_id
  AND NVL(DR, 0) = 0
  AND BUSISTATUS IN (1, 2)  -- TODO #LOAN-2: 有效合同状态
  AND BEGINDATE <= :asof_date
  AND (ENDDATE IS NULL OR ENDDATE >= :asof_date);"""
    .

