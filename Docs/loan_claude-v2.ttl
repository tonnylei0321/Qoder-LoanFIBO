# ============================================================
# 71 个指标个体 + 字段映射
# ============================================================

### POST-D2-01 · 应收账龄恶化速率
yql:Indicator_POST_D2_01 a yql:ARAgingDeteriorationRate ;
    rdfs:label "应收账龄恶化速率"@zh ;
    skos:prefLabel "POST-D2-01" ;
    skos:definition "60 天以上应收占比的环比恶化幅度,警示坏账加速"@zh ;
    yql:hasFormula "(AROver60DRatio_current - AROver60DRatio_prior) / AROver60DRatio_prior" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<10%" ;
    yql:amberThreshold "10-30%" ;
    yql:redThreshold ">30%" ;
    yql:timeOperator "QoQChange" ;
    yql:baseIndicator yql:Indicator_PRE_D3_02 ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### POST-D2-02 · 关联方交易突增告警
yql:Indicator_POST_D2_02 a yql:RelatedPartyTransactionSpike ;
    rdfs:label "关联方交易突增告警"@zh ;
    skos:prefLabel "POST-D2-02" ;
    skos:definition "识别关联方交易突增,可能是利益输送或套现信号"@zh ;
    yql:hasFormula "IF (RP_TxnAmt_QoQ_Growth > 20%) THEN TRIGGERED" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:ControllingInterest ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:scoringModel "{'rule': '关联方季度交易额环比增长 > 20% 触发关注;> 50% 触发预警'}" ;
    yql:mapsToField ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__PK_ORG, ncc:AP_PAYABLEITEM__SUPPLIER, ncc:AP_PAYABLEITEM__LOCAL_MONEY_CR, ncc:AP_PAYABLEITEM__BILLDATE, ncc:AP_PAYABLEITEM__PK_ORG, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__DBILLDATE, ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__DBILLDATE, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__INNERPROFITCENTER .

### POST-D2-03 · 三表一致性校验
yql:Indicator_POST_D2_03 a yql:ThreeStatementConsistencyCheck ;
    rdfs:label "三表一致性校验"@zh ;
    skos:prefLabel "POST-D2-03" ;
    skos:definition "利润表/资产负债表/现金流量表三表勾稽关系校验"@zh ;
    yql:hasFormula "Boolean: ALL(Rule1, Rule2, Rule3) where Rule1: NetIncome_IS = (RetainedEarnings_End - RetainedEarnings_Begin + Dividends), Rule2: CashFlow_NetIncrease = CashEnd - CashBegin, Rule3: CFO_indirect_reconciliation_starts_from_NetIncome" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:hasInput acc:NetIncome, acc:RetainedEarnings, acc:CashAndEquivalents, acc:OperatingCashFlow ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CURRTYPE, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_CASHFLOWCASE__PK_DETAIL, ncc:GL_VOUCHER__PK_VOUCHER, ncc:GL_VOUCHER__TOTALDEBIT, ncc:GL_VOUCHER__TOTALCREDIT, ncc:GL_VOUCHER__PERIOD, ncc:GL_VOUCHER__YEAR, ncc:GL_VOUCHER__APPROVESTATUS .

### POST-D2-05 · 财报提交及时性
yql:Indicator_POST_D2_05 a yql:FinancialReportTimeliness ;
    rdfs:label "财报提交及时性"@zh ;
    skos:prefLabel "POST-D2-05" ;
    skos:definition "财务报表实际提交相对约定截止日的延迟天数"@zh ;
    yql:hasFormula "IF (ActualSubmissionDate <= AgreedDeadline) THEN PASS ELSE DelayDays = ActualSubmissionDate - AgreedDeadline" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Reporter ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "0" ;
    yql:amberThreshold "1-15" ;
    yql:redThreshold ">15" ;
.

### POST-D3-01 · 营收同比增速
yql:Indicator_POST_D3_01 a yql:RevenueYoYGrowth ;
    rdfs:label "营收同比增速"@zh ;
    skos:prefLabel "POST-D3-01" ;
    skos:definition "营业收入同比增长率"@zh ;
    yql:hasFormula "(Revenue_current_period - Revenue_same_period_lastyear) / Revenue_same_period_lastyear" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=5%" ;
    yql:amberThreshold "-5%-5%" ;
    yql:redThreshold "<-5%" ;
    yql:timeOperator "YoY" ;
    yql:hasInput acc:Revenue ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### POST-D3-02 · 毛利率环比变化
yql:Indicator_POST_D3_02 a yql:GrossMarginQoQChange ;
    rdfs:label "毛利率环比变化"@zh ;
    skos:prefLabel "POST-D3-02" ;
    skos:definition "毛利率相对上一季度的变化幅度(百分点)"@zh ;
    yql:hasFormula "GrossProfitMargin_current_quarter - GrossProfitMargin_prior_quarter (变化量,百分点)" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:unit "percentage_points" ;
    yql:greenThreshold ">=-1pp" ;
    yql:amberThreshold "-3pp 到 -1pp" ;
    yql:redThreshold "<-3pp" ;
    yql:timeOperator "QoQChange" ;
    yql:baseIndicator yql:Indicator_PRE_D2_04 ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### POST-D3-03 · 经营现金流同比变化
yql:Indicator_POST_D3_03 a yql:OperatingCashFlowYoYChange ;
    rdfs:label "经营现金流同比变化"@zh ;
    skos:prefLabel "POST-D3-03" ;
    skos:definition "经营活动现金流的同比变化率"@zh ;
    yql:hasFormula "(CFO_current - CFO_same_period_lastyear) / ABS(CFO_same_period_lastyear)" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=0%" ;
    yql:amberThreshold "-20%-0%" ;
    yql:redThreshold "<-20%" ;
    yql:timeOperator "YoY" ;
    yql:hasInput acc:OperatingCashFlow ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CURRTYPE, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_CASHFLOWCASE__PK_DETAIL .

### POST-D3-04 · EBITDA利润率趋势
yql:Indicator_POST_D3_04 a yql:EBITDAMarginTrend ;
    rdfs:label "EBITDA利润率趋势"@zh ;
    skos:prefLabel "POST-D3-04" ;
    skos:definition "过去 4 个季度 EBITDA 利润率的线性回归斜率"@zh ;
    yql:hasFormula "LinearRegressionSlope(EBITDAMargin over last 4 quarters)" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:unit "pp_per_quarter" ;
    yql:greenThreshold ">=0" ;
    yql:amberThreshold "-0.5pp/Q 到 0" ;
    yql:redThreshold "<-0.5pp/Q" ;
    yql:timeOperator "Slope4Q" ;
    yql:baseIndicator yql:Indicator_PRE_D2_01 ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### POST-D3-05 · 在手合同金额
yql:Indicator_POST_D3_05 a yql:ContractBacklogAmount ;
    rdfs:label "在手合同金额"@zh ;
    skos:prefLabel "POST-D3-05" ;
    skos:definition "已签订未执行合同的累计剩余金额(订单储备)"@zh ;
    yql:hasFormula "SUM(SignedContract.RemainingAmount where Status IN [Active, Pending Execution])" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures fibo-fnd-agr-ctr:Contract ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:unit "CNY" ;
    yql:greenThreshold ">=2 * AnnualRevenue" ;
    yql:amberThreshold "1-2 * Revenue" ;
    yql:redThreshold "<1 * Revenue" ;
    yql:hasInput acc:ContractAmount ;
    yql:mapsToField ncc:CT_SALE__PK_CT_SALE, ncc:CT_SALE__VBILLCODE, ncc:CT_SALE__CTNAME, ncc:CT_SALE__PK_CUSTOMER, ncc:CT_SALE__NTOTALORIGMNY, ncc:CT_SALE__VALDATE, ncc:CT_SALE__INVALLIDATE, ncc:CT_SALE__ACTUALVALIDATE, ncc:CT_SALE__ACTUALINVALIDATE, ncc:CT_SALE__FSTATUSFLAG, ncc:CT_SALE__PK_ORG, ncc:CT_SALE_EXEC__PK_CT_SALE, ncc:CT_SALE_EXEC__VEXECDATE, ncc:CT_SALE_EXEC__VEXECFLOW .

### POST-D4-01 · 非银融资占比变化
yql:Indicator_POST_D4_01 a yql:NonBankFinancingRatioChange ;
    rdfs:label "非银融资占比变化"@zh ;
    skos:prefLabel "POST-D4-01" ;
    skos:definition "非银渠道融资占比的环比变化(上升过快暗示传统银行融资受限)"@zh ;
    yql:hasFormula "NonBankFinancing_Ratio_current - NonBankFinancing_Ratio_prior, where Ratio = NonBankFinancing / TotalInterestBearingDebt" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:FinancialServiceProvider ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:unit "percentage_points" ;
    yql:greenThreshold "<=2pp" ;
    yql:amberThreshold "2-5pp" ;
    yql:redThreshold ">5pp" ;
    yql:timeOperator "QoQChange" ;
    yql:hasInput acc:NonBankFinancing, acc:TotalInterestBearingDebt ;
    yql:mapsToField ncc:CDMC_CONTRACT__PK_CONTRACT, ncc:CDMC_CONTRACT__LOANMNY, ncc:CDMC_CONTRACT__PK_FININSTITUTIONTYPE, ncc:CDMC_CONTRACT__PK_BANKTYPE, ncc:CDMC_CONTRACT__BEGINDATE, ncc:CDMC_CONTRACT__ENDDATE, ncc:CDMC_CONTRACT__PK_ORG, ncc:BATM_FINANCING__PK_FINANCING, ncc:BATM_FINANCING__BALANCE, ncc:BATM_FINANCING__FINANCING_VARIETY, ncc:BATM_FINANCING__FINANCING_WAY, ncc:BATM_FINANCING__BEGINDATE, ncc:BATM_FINANCING__ENDDATE, ncc:BATM_FINANCING__PK_ORG, ncc:BOND_CONTRACT__PK_BONDCONTRACT, ncc:BOND_CONTRACT__REGISTMNY, ncc:BOND_CONTRACT__PK_ORG, ncc:ICDMC_CONTRACT__PK_CONTRACT_ICDMC, ncc:ICDMC_CONTRACT__LOANMNY, ncc:ICDMC_CONTRACT__PK_ORG .

### POST-D4-02 · 授信使用率
yql:Indicator_POST_D4_02 a yql:CreditLineUsageRatio ;
    rdfs:label "授信使用率"@zh ;
    skos:prefLabel "POST-D4-02" ;
    skos:definition "已用授信占总授信额度的比例"@zh ;
    yql:hasFormula "UsedCreditAmount / TotalCreditFacility" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures fibo-fbc-dae-dbt:DebtInstrument ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:greenThreshold "<70%" ;
    yql:amberThreshold "70-90%" ;
    yql:redThreshold ">90%" ;
    yql:hasInput acc:UsedCreditAmount, acc:TotalCreditFacility ;
    yql:mapsToField ncc:CDMC_CONTRACT__PK_CONTRACT, ncc:CDMC_CONTRACT__LOANMNY, ncc:CDMC_CONTRACT__AVAILABLEMNY, ncc:CDMC_CONTRACT__CREDITCC, ncc:CDMC_CONTRACT__PK_ORG, ncc:CDMC_CONTRACT__PK_FINANCORG, ncc:CDMC_FINEXECUTE__LEFTREPAYAMOUNT, ncc:CDMC_FINEXECUTE__FIN_REPAYAMOUNT, ncc:CDMC_FINEXECUTE__PK_FINANCEPAY, ncc:BGM_OPENREGISTER__PK_OPENREGISTER, ncc:BGM_OPENREGISTER__GUARANTEEAMOUNT, ncc:BGM_OPENREGISTER__BEGINDATE, ncc:BGM_OPENREGISTER__ENDDATE, ncc:BGM_OPENREGISTER__PK_APPLYORG, ncc:BGM_OPENREGISTER__BUSISTATUS, ncc:BATM_FINANCING__PK_FINANCING, ncc:BATM_FINANCING__BALANCE, ncc:BATM_FINANCING__CCAMOUNT, ncc:BATM_FINANCING__PK_ORG .

### POST-D4-03 · 资产负债率变化
yql:Indicator_POST_D4_03 a yql:DebtToAssetRatioChange ;
    rdfs:label "资产负债率变化"@zh ;
    skos:prefLabel "POST-D4-03" ;
    skos:definition "资产负债率的环比变化(快速攀升提示过度举债)"@zh ;
    yql:hasFormula "DebtToAssetRatio_current - DebtToAssetRatio_prior" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:unit "percentage_points" ;
    yql:greenThreshold "<=2pp" ;
    yql:amberThreshold "2-5pp" ;
    yql:redThreshold ">5pp" ;
    yql:timeOperator "QoQChange" ;
    yql:baseIndicator yql:Indicator_PRE_D3_03 ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### POST-D5-01 · 应收账款质押覆盖率
yql:Indicator_POST_D5_01 a yql:PledgedARCoverageRatio ;
    rdfs:label "应收账款质押覆盖率"@zh ;
    skos:prefLabel "POST-D5-01" ;
    skos:definition "质押应收账款的合格价值对在贷余额的覆盖倍数"@zh ;
    yql:hasFormula "PledgedAR_Eligible_Value / OutstandingLoanBalance" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Collateral ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold ">=130%" ;
    yql:amberThreshold "110-130%" ;
    yql:redThreshold "<110%" ;
    yql:hasInput acc:PledgedAR, acc:LoanBalance ;
    yql:mapsToField ncc:GPMC_GUACONTRACT__PK_GUACONTRACT, ncc:GPMC_GUACONTRACT__VBILLNO, ncc:GPMC_GUACONTRACT__CONTRACTNO, ncc:GPMC_GUACONTRACT__DEBTOR, ncc:GPMC_GUACONTRACT__CREDITOR, ncc:GPMC_GUACONTRACT__GUARANTOR, ncc:GPMC_GUACONTRACT__GUATYPE, ncc:GPMC_GUACONTRACT__DEBTAMOUNT, ncc:GPMC_GUACONTRACT__GUAAMOUNT, ncc:GPMC_GUACONTRACT__PLEAMOUNT, ncc:GPMC_GUACONTRACT__MORAMOUNT, ncc:GPMC_GUACONTRACT__STARTDATE, ncc:GPMC_GUACONTRACT__ENDDATE, ncc:GPMC_GUACONTRACT__PK_ORG, ncc:GPMC_GUACONTRACT__BUSISTATUS, ncc:GPMC_GUAPLEINF__PK_GUAPLEDGEINFO_B, ncc:GPMC_GUAPLEINF__PK_GUACONTRACT, ncc:GPMC_GUAPLEINF__PLEDGENAME, ncc:GPMC_GUAPLEINF__PLEDGENO, ncc:GPMC_GUAPLEINF__TOTALPLEDGE, ncc:GPMC_GUAPLEINF__MAXPLEDGE, ncc:GPMC_GUAPLEINF__USINGAMOUNT, ncc:GPMC_GUAPLEINF__RESTPLEDGE, ncc:GPMC_GUAPLEINF__PARTNERID, ncc:GPMC_GUAPLEINF__UNITNAME, ncc:GPMC_GUAPLEINF__PK_ORG, ncc:CDMC_CONTRACT__PK_CONTRACT, ncc:CDMC_CONTRACT__LOANMNY, ncc:CDMC_FINEXECUTE__LEFTREPAYAMOUNT, ncc:CDMC_FINEXECUTE__PK_FINANCEPAY, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE .

### POST-D5-02 · 质押应收质量评分
yql:Indicator_POST_D5_02 a yql:PledgedARQualityScore ;
    rdfs:label "质押应收质量评分"@zh ;
    skos:prefLabel "POST-D5-02" ;
    skos:definition "质押应收的综合可回收性评分(账龄+买方信用双维度)"@zh ;
    yql:hasFormula "SUM(PledgedAR_i.Balance * AgingWeight_i * BuyerCreditWeight_i) / TotalPledgedAR * 100" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Collateral ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:unit "score(0-100)" ;
    yql:greenThreshold ">=80" ;
    yql:amberThreshold "60-80" ;
    yql:redThreshold "<60" ;
    yql:scoringModel "{'description': '账龄系数 × 买方信用系数双维度加权', 'aging_weights': {'0-30D': 1.0, '31-60D': 0.85, '61-90D': 0.6, '91-180D': 0.3, '>180D': 0.0}, 'buyer_credit_weights': {'AAA': 1.0, 'AA': 0.9, 'A': 0.8, 'BBB': 0.65, 'BB': 0.4, 'B及以下': 0.1}}" ;
    yql:mapsToField ncc:GPMC_GUACONTRACT__PK_GUACONTRACT, ncc:GPMC_GUACONTRACT__VBILLNO, ncc:GPMC_GUACONTRACT__CONTRACTNO, ncc:GPMC_GUACONTRACT__DEBTOR, ncc:GPMC_GUACONTRACT__CREDITOR, ncc:GPMC_GUACONTRACT__GUARANTOR, ncc:GPMC_GUACONTRACT__GUATYPE, ncc:GPMC_GUACONTRACT__DEBTAMOUNT, ncc:GPMC_GUACONTRACT__GUAAMOUNT, ncc:GPMC_GUACONTRACT__PLEAMOUNT, ncc:GPMC_GUACONTRACT__MORAMOUNT, ncc:GPMC_GUACONTRACT__STARTDATE, ncc:GPMC_GUACONTRACT__ENDDATE, ncc:GPMC_GUACONTRACT__PK_ORG, ncc:GPMC_GUACONTRACT__BUSISTATUS, ncc:GPMC_GUAPLEINF__PK_GUAPLEDGEINFO_B, ncc:GPMC_GUAPLEINF__PK_GUACONTRACT, ncc:GPMC_GUAPLEINF__PLEDGENAME, ncc:GPMC_GUAPLEINF__PLEDGENO, ncc:GPMC_GUAPLEINF__TOTALPLEDGE, ncc:GPMC_GUAPLEINF__MAXPLEDGE, ncc:GPMC_GUAPLEINF__USINGAMOUNT, ncc:GPMC_GUAPLEINF__RESTPLEDGE, ncc:GPMC_GUAPLEINF__PARTNERID, ncc:GPMC_GUAPLEINF__UNITNAME, ncc:GPMC_GUAPLEINF__PK_ORG, ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### POST-D5-03 · 质押应收集中度
yql:Indicator_POST_D5_03 a yql:PledgedARConcentration ;
    rdfs:label "质押应收集中度"@zh ;
    skos:prefLabel "POST-D5-03" ;
    skos:definition "前 N 大买方质押应收占总质押的比例"@zh ;
    yql:hasFormula "SUM(TopN_Buyer_PledgedAR) / TotalPledgedAR (默认 N=3)" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:measures yql:Collateral ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold "<50%" ;
    yql:amberThreshold "50-70%" ;
    yql:redThreshold ">70%" ;
    yql:mapsToField ncc:GPMC_GUACONTRACT__PK_GUACONTRACT, ncc:GPMC_GUACONTRACT__VBILLNO, ncc:GPMC_GUACONTRACT__CONTRACTNO, ncc:GPMC_GUACONTRACT__DEBTOR, ncc:GPMC_GUACONTRACT__CREDITOR, ncc:GPMC_GUACONTRACT__GUARANTOR, ncc:GPMC_GUACONTRACT__GUATYPE, ncc:GPMC_GUACONTRACT__DEBTAMOUNT, ncc:GPMC_GUACONTRACT__GUAAMOUNT, ncc:GPMC_GUACONTRACT__PLEAMOUNT, ncc:GPMC_GUACONTRACT__MORAMOUNT, ncc:GPMC_GUACONTRACT__STARTDATE, ncc:GPMC_GUACONTRACT__ENDDATE, ncc:GPMC_GUACONTRACT__PK_ORG, ncc:GPMC_GUACONTRACT__BUSISTATUS, ncc:GPMC_GUAPLEINF__PK_GUAPLEDGEINFO_B, ncc:GPMC_GUAPLEINF__PK_GUACONTRACT, ncc:GPMC_GUAPLEINF__PLEDGENAME, ncc:GPMC_GUAPLEINF__PLEDGENO, ncc:GPMC_GUAPLEINF__TOTALPLEDGE, ncc:GPMC_GUAPLEINF__MAXPLEDGE, ncc:GPMC_GUAPLEINF__USINGAMOUNT, ncc:GPMC_GUAPLEINF__RESTPLEDGE, ncc:GPMC_GUAPLEINF__PARTNERID, ncc:GPMC_GUAPLEINF__UNITNAME, ncc:GPMC_GUAPLEINF__PK_ORG, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME .

### PRE-D1-01 · 速动比率
yql:Indicator_PRE_D1_01 a yql:QuickRatio ;
    rdfs:label "速动比率"@zh ;
    skos:prefLabel "PRE-D1-01" ;
    skos:definition "衡量企业立即变现资产偿付短期债务能力的稳健性指标"@zh ;
    yql:hasFormula "(CurrentAssets - Inventory - PrepaidExpenses) / CurrentLiabilities" ;
    yql:appliedInScenario scn:PreLoanDD, scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold ">=1.0" ;
    yql:amberThreshold "0.7-1.0" ;
    yql:redThreshold "<0.7" ;
    yql:hasInput acc:CurrentAssets, acc:Inventory, acc:PrepaidExpenses, acc:CurrentLiabilities ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D1-02 · 流动比率
yql:Indicator_PRE_D1_02 a yql:CurrentRatio ;
    rdfs:label "流动比率"@zh ;
    skos:prefLabel "PRE-D1-02" ;
    skos:definition "短期偿债能力基础指标"@zh ;
    yql:hasFormula "CurrentAssets / CurrentLiabilities" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold ">=2.0" ;
    yql:amberThreshold "1.0-2.0" ;
    yql:redThreshold "<1.0" ;
    yql:hasInput acc:CurrentAssets, acc:CurrentLiabilities ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D1-03 · 利息覆盖倍数 ICR
yql:Indicator_PRE_D1_03 a yql:InterestCoverageRatio ;
    rdfs:label "利息覆盖倍数 ICR"@zh ;
    skos:prefLabel "PRE-D1-03" ;
    skos:definition "营业利润对利息费用的保障倍数"@zh ;
    yql:hasFormula "EBIT / InterestExpense, where EBIT = NetIncome + InterestExpense + IncomeTax" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold ">=3.0" ;
    yql:amberThreshold "1.5-3.0" ;
    yql:redThreshold "<1.5" ;
    yql:hasInput acc:NetIncome, acc:InterestExpense, acc:IncomeTax ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:GL_DETAIL__PK_ACCOUNT, ncc:GL_DETAIL__LOCALDEBITAMOUNT, ncc:GL_DETAIL__LOCALCREDITAMOUNT, ncc:GL_DETAIL__EXPLANATION, ncc:GL_DETAIL__PERIODV, ncc:GL_DETAIL__YEARV .

### PRE-D1-04 · 偿债覆盖率 DSCR
yql:Indicator_PRE_D1_04 a yql:DebtServiceCoverageRatio ;
    rdfs:label "偿债覆盖率 DSCR"@zh ;
    skos:prefLabel "PRE-D1-04" ;
    skos:definition "企业现金流对偿债总额的覆盖倍数(银行通用口径,使用 EBITDA 替代地产业的 NOI)"@zh ;
    yql:hasFormula "EBITDA / (PrincipalDue + InterestDue) for the period" ;
    yql:appliedInScenario scn:PreLoanDD, scn:PostLoanMonitoring ;
    yql:measures fibo-fbc-dae-dbt:Debt ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold ">=1.25" ;
    yql:amberThreshold "1.0-1.25" ;
    yql:redThreshold "<1.0" ;
    yql:hasInput acc:EBITDA, acc:PrincipalDue, acc:InterestDue ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:CDMC_CONTRACT__PK_CONTRACT, ncc:CDMC_CONTRACT__LOANMNY, ncc:CDMC_CONTRACT__OLCRATE, ncc:CDMC_CONTRACT__PK_ORG, ncc:CDMC_REPAYPRCPL__PK_REPAYPRCPL, ncc:CDMC_REPAYPRCPL__REPAYDATE, ncc:CDMC_REPAYPRCPL__REPAYMNY, ncc:CDMC_REPAYPRCPL__INTERESTMNY, ncc:CDMC_REPAYPRCPL__PK_CONTRACT, ncc:CDMC_REPINTEREST__PK_REPAYINTST, ncc:CDMC_REPINTEREST__PAYINTMONEY, ncc:CDMC_REPINTEREST__PK_CONTRACT, ncc:BOND_REPAYPLAN__REPAYMENTPRINCIPALMNY, ncc:BOND_REPAYPLAN__REPAYMENTINTERESTMNY, ncc:BOND_REPAYPLAN__REPAYMENTDATE .

### PRE-D1-05 · 净债务/EBITDA
yql:Indicator_PRE_D1_05 a yql:NetDebtToEBITDARatio ;
    rdfs:label "净债务/EBITDA"@zh ;
    skos:prefLabel "PRE-D1-05" ;
    skos:definition "企业净有息负债需要多少年 EBITDA 才能偿还"@zh ;
    yql:hasFormula "NetDebt / EBITDA, where NetDebt = TotalInterestBearingDebt - CashAndEquivalents - TradingFinancialAssets" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures fibo-fbc-dae-dbt:Debt ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<=3.0" ;
    yql:amberThreshold "3.0-5.0" ;
    yql:redThreshold ">5.0" ;
    yql:hasInput acc:TotalInterestBearingDebt, acc:CashAndEquivalents, acc:TradingFinancialAssets, acc:EBITDA ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:CDMC_CONTRACT__PK_CONTRACT, ncc:CDMC_CONTRACT__LOANMNY, ncc:CDMC_FINEXECUTE__LEFTREPAYAMOUNT, ncc:CDMC_FINEXECUTE__PK_FINANCEPAY, ncc:BOND_CONTRACT__PK_BONDCONTRACT, ncc:BOND_CONTRACT__REGISTMNY, ncc:BATM_FINANCING__BALANCE, ncc:BATM_FINANCING__PK_ORG .

### PRE-D1-06 · 现金覆盖天数
yql:Indicator_PRE_D1_06 a yql:CashCoverageDays ;
    rdfs:label "现金覆盖天数"@zh ;
    skos:prefLabel "PRE-D1-06" ;
    skos:definition "现金及等价物可支撑日常经营运转的天数(已剔除折摊等非现金成本)"@zh ;
    yql:hasFormula "CashAndEquivalents / ((TotalOperatingCost - DepreciationAmortization) / 365)" ;
    yql:appliedInScenario scn:PreLoanDD, scn:PostLoanMonitoring ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold ">=30" ;
    yql:amberThreshold "15-30" ;
    yql:redThreshold "<15" ;
    yql:hasInput acc:CashAndEquivalents, acc:TotalOperatingCost, acc:DepreciationAmortization ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D2-01 · EBITDA利润率
yql:Indicator_PRE_D2_01 a yql:EBITDAMargin ;
    rdfs:label "EBITDA利润率"@zh ;
    skos:prefLabel "PRE-D2-01" ;
    skos:definition "剔除融资和折摊影响的核心经营利润率"@zh ;
    yql:hasFormula "EBITDA / Revenue" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=15%" ;
    yql:amberThreshold "5-15%" ;
    yql:redThreshold "<5%" ;
    yql:hasInput acc:EBITDA, acc:Revenue ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D2-02 · 现金流/净利润比
yql:Indicator_PRE_D2_02 a yql:OperatingCashFlowToNetIncomeRatio ;
    rdfs:label "现金流/净利润比"@zh ;
    skos:prefLabel "PRE-D2-02" ;
    skos:definition "利润含金量;持续<1 提示利润被应收/存货占用"@zh ;
    yql:hasFormula "OperatingCashFlow / NetIncome" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=1.0" ;
    yql:amberThreshold "0.7-1.0" ;
    yql:redThreshold "<0.7" ;
    yql:hasInput acc:OperatingCashFlow, acc:NetIncome ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK .

### PRE-D2-03 · 收入3年CAGR
yql:Indicator_PRE_D2_03 a yql:RevenueCAGR3Y ;
    rdfs:label "收入3年CAGR"@zh ;
    skos:prefLabel "PRE-D2-03" ;
    skos:definition "过去 3 年营业收入的复合年均增长率"@zh ;
    yql:hasFormula "POW(Revenue_T / Revenue_T-3, 1/3) - 1" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=10%" ;
    yql:amberThreshold "0-10%" ;
    yql:redThreshold "<0%" ;
    yql:hasInput acc:Revenue ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D2-04 · 毛利率
yql:Indicator_PRE_D2_04 a yql:GrossMargin ;
    rdfs:label "毛利率"@zh ;
    skos:prefLabel "PRE-D2-04" ;
    skos:definition "主营业务的初步盈利能力"@zh ;
    yql:hasFormula "(Revenue - COGS) / Revenue" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=25%" ;
    yql:amberThreshold "10-25%" ;
    yql:redThreshold "<10%" ;
    yql:hasInput acc:Revenue, acc:COGS ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D2-05 · 净利润率
yql:Indicator_PRE_D2_05 a yql:NetProfitMargin ;
    rdfs:label "净利润率"@zh ;
    skos:prefLabel "PRE-D2-05" ;
    skos:definition "扣除全部成本费用税金后的最终盈利能力"@zh ;
    yql:hasFormula "NetIncome / Revenue" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=8%" ;
    yql:amberThreshold "3-8%" ;
    yql:redThreshold "<3%" ;
    yql:hasInput acc:NetIncome, acc:Revenue ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D3-01 · 应收账款质量评分
yql:Indicator_PRE_D3_01 a yql:ARQualityScore ;
    rdfs:label "应收账款质量评分"@zh ;
    skos:prefLabel "PRE-D3-01" ;
    skos:definition "对应收账款基于账龄分布的可回收性综合评分"@zh ;
    yql:hasFormula "100 * SUM(AgeBucket_i.Balance * Weight_i) / TotalAR" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:unit "score(0-100)" ;
    yql:greenThreshold ">=80" ;
    yql:amberThreshold "60-80" ;
    yql:redThreshold "<60" ;
    yql:scoringModel "{'description': '账龄加权评分,系数随账龄递减', 'weights': {'0-30D': 1.0, '31-60D': 0.85, '61-90D': 0.6, '91-180D': 0.3, '>180D': 0.0}, 'method': 'weighted_average'}" ;
    yql:hasInput acc:AccountsReceivable ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### PRE-D3-02 · 60天以上应收占比
yql:Indicator_PRE_D3_02 a yql:AR60DaysOverdueRatio ;
    rdfs:label "60天以上应收占比"@zh ;
    skos:prefLabel "PRE-D3-02" ;
    skos:definition "账龄超过 60 天的应收账款占总应收的比例"@zh ;
    yql:hasFormula "AR_AgeOver60D / TotalAR" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold "<10%" ;
    yql:amberThreshold "10-20%" ;
    yql:redThreshold ">20%" ;
    yql:hasInput acc:AccountsReceivable ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### PRE-D3-03 · 资产负债率
yql:Indicator_PRE_D3_03 a yql:DebtToAssetRatio ;
    rdfs:label "资产负债率"@zh ;
    skos:prefLabel "PRE-D3-03" ;
    skos:definition "企业总杠杆水平"@zh ;
    yql:hasFormula "TotalLiabilities / TotalAssets" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold "<60%" ;
    yql:amberThreshold "60-70%" ;
    yql:redThreshold ">70%" ;
    yql:hasInput acc:TotalLiabilities, acc:TotalAssets ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D3-04 · 有效净资产
yql:Indicator_PRE_D3_04 a yql:EffectiveNetAssets ;
    rdfs:label "有效净资产"@zh ;
    skos:prefLabel "PRE-D3-04" ;
    skos:definition "剔除虚资产和关联方应收后的可变现净资产口径"@zh ;
    yql:hasFormula "StockholdersEquity - IntangibleAssets - Goodwill - LongTermDeferredExpenses - DeferredTaxAssets - RelatedPartyAR" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures fibo-fnd-acc-cur:MonetaryAmount ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:unit "CNY" ;
    yql:hasInput acc:StockholdersEquity, acc:IntangibleAssets, acc:Goodwill, acc:LongTermDeferredExpenses, acc:DeferredTaxAssets, acc:RelatedPartyAR ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__PK_ORG .

### PRE-D3-05 · 存货周转天数
yql:Indicator_PRE_D3_05 a yql:DaysInventoryOutstanding ;
    rdfs:label "存货周转天数"@zh ;
    skos:prefLabel "PRE-D3-05" ;
    skos:definition "DIO,存货从采购到售出平均所需天数"@zh ;
    yql:hasFormula "AvgInventory / COGS * 365, where AvgInventory = (BeginInventory + EndInventory) / 2" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<60" ;
    yql:amberThreshold "60-90" ;
    yql:redThreshold ">90" ;
    yql:hasInput acc:Inventory, acc:COGS ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:IA_MONTHNAB__CMONTHNABID, ncc:IA_MONTHNAB__CINVENTORYID, ncc:IA_MONTHNAB__CACCOUNTPERIOD, ncc:IA_MONTHNAB__NABMNY, ncc:IA_MONTHNAB__NABNUM, ncc:IA_MONTHNAB__PK_ORG, ncc:IA_MONTHNAB__PK_BOOK .

### PRE-D4-01 · 自由现金流 FCF
yql:Indicator_PRE_D4_01 a yql:FreeCashFlow ;
    rdfs:label "自由现金流 FCF"@zh ;
    skos:prefLabel "PRE-D4-01" ;
    skos:definition "企业可自由支配的现金流量;采用 FCFF 口径(若需 FCFE 加 NetBorrowing)"@zh ;
    yql:hasFormula "OperatingCashFlow - CapitalExpenditures (FCFF口径)" ;
    yql:appliedInScenario scn:PreLoanDD, scn:PostLoanMonitoring ;
    yql:measures fibo-fnd-acc-cur:MonetaryAmount ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:unit "CNY" ;
    yql:greenThreshold ">0" ;
    yql:amberThreshold "-1000-0万" ;
    yql:redThreshold "<-1000万" ;
    yql:hasInput acc:OperatingCashFlow, acc:CapitalExpenditures ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CURRTYPE, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_CASHFLOWCASE__PK_DETAIL, ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D4-02 · 经营现金流稳定性
yql:Indicator_PRE_D4_02 a yql:CFOStability ;
    rdfs:label "经营现金流稳定性"@zh ;
    skos:prefLabel "PRE-D4-02" ;
    skos:definition "过去 8 个季度经营现金流的变异系数,值越小越稳定"@zh ;
    yql:hasFormula "STDEV(CFO_last_8_quarters) / AVG(CFO_last_8_quarters) (变异系数 CV)" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:greenThreshold "<0.3" ;
    yql:amberThreshold "0.3-0.5" ;
    yql:redThreshold ">0.5" ;
    yql:hasInput acc:OperatingCashFlow ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CURRTYPE, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_CASHFLOWCASE__PK_DETAIL .

### PRE-D4-03 · 资本支出/营收比
yql:Indicator_PRE_D4_03 a yql:CapExToRevenueRatio ;
    rdfs:label "资本支出/营收比"@zh ;
    skos:prefLabel "PRE-D4-03" ;
    skos:definition "资本开支强度;过高可能挤压自由现金流"@zh ;
    yql:hasFormula "CapitalExpenditures / Revenue" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:greenThreshold "<10%" ;
    yql:amberThreshold "10-20%" ;
    yql:redThreshold ">20%" ;
    yql:hasInput acc:CapitalExpenditures, acc:Revenue ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CURRTYPE, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_CASHFLOWCASE__PK_DETAIL, ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D4-04 · 三类现金流结构
yql:Indicator_PRE_D4_04 a yql:CashFlowStructurePattern ;
    rdfs:label "三类现金流结构"@zh ;
    skos:prefLabel "PRE-D4-04" ;
    skos:definition "经营/投资/筹资三类现金流的符号组合,识别企业所处生命周期"@zh ;
    yql:hasFormula "SIGN(CFO):SIGN(CFI):SIGN(CFF) → 8 种枚举模式" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:scoringModel "{'description': '根据 CFO/CFI/CFF 符号组合判断企业生命周期', 'enum': {'+--': '成熟期(健康)', '++-': '重组/扩张', '+-+': '成长期(融资支撑扩张)', '+++': '罕见,可能资产剥离', '-++': '初创期或困境融资', '-+-': '重大资产剥离偿债', '--+': '初创期烧钱', '---': '危机/破产前兆'}}" ;
    yql:hasInput acc:OperatingCashFlow, acc:InvestingCashFlow, acc:FinancingCashFlow ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_CASHFLOW, ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__MONEYMAIN, ncc:GL_CASHFLOWCASE__FLAG, ncc:GL_CASHFLOWCASE__PREPAREDDATE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CURRTYPE, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_CASHFLOWCASE__PK_DETAIL .

### PRE-D4-05 · 现金比率
yql:Indicator_PRE_D4_05 a yql:CashRatio ;
    rdfs:label "现金比率"@zh ;
    skos:prefLabel "PRE-D4-05" ;
    skos:definition "最严格的短期偿债能力指标"@zh ;
    yql:hasFormula "(CashAndEquivalents + TradingFinancialAssets) / CurrentLiabilities" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.15"^^xsd:decimal ;
    yql:greenThreshold ">=0.3" ;
    yql:amberThreshold "0.1-0.3" ;
    yql:redThreshold "<0.1" ;
    yql:hasInput acc:CashAndEquivalents, acc:TradingFinancialAssets, acc:CurrentLiabilities ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D5-01 · 现金转换周期 CCC
yql:Indicator_PRE_D5_01 a yql:CashConversionCycle ;
    rdfs:label "现金转换周期 CCC"@zh ;
    skos:prefLabel "PRE-D5-01" ;
    skos:definition "企业从付款给供应商到收到客户回款的净周期"@zh ;
    yql:hasFormula "DSO + DIO - DPO" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<60" ;
    yql:amberThreshold "60-90" ;
    yql:redThreshold ">90" ;
.

### PRE-D5-02 · 应收账款周转天数 DSO
yql:Indicator_PRE_D5_02 a yql:DaysSalesOutstanding ;
    rdfs:label "应收账款周转天数 DSO"@zh ;
    skos:prefLabel "PRE-D5-02" ;
    skos:definition "平均回款周期"@zh ;
    yql:hasFormula "AvgAR / Revenue * 365" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<45" ;
    yql:amberThreshold "45-60" ;
    yql:redThreshold ">60" ;
    yql:hasInput acc:AccountsReceivable, acc:Revenue ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE, ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D5-03 · 总资产周转率
yql:Indicator_PRE_D5_03 a yql:TotalAssetTurnover ;
    rdfs:label "总资产周转率"@zh ;
    skos:prefLabel "PRE-D5-03" ;
    skos:definition "总资产创造收入的效率"@zh ;
    yql:hasFormula "Revenue / AvgTotalAssets" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold ">=1.0" ;
    yql:amberThreshold "0.5-1.0" ;
    yql:redThreshold "<0.5" ;
    yql:hasInput acc:Revenue, acc:TotalAssets ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D5-04 · 净资产收益率 ROE
yql:Indicator_PRE_D5_04 a yql:ReturnOnEquity ;
    rdfs:label "净资产收益率 ROE"@zh ;
    skos:prefLabel "PRE-D5-04" ;
    skos:definition "股东权益的回报率(分母用平均口径而非期末单点)"@zh ;
    yql:hasFormula "NetIncome / AvgStockholdersEquity, where Avg = (Begin + End) / 2" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold ">=12%" ;
    yql:amberThreshold "5-12%" ;
    yql:redThreshold "<5%" ;
    yql:hasInput acc:NetIncome, acc:StockholdersEquity ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### PRE-D6-01 · 客户集中度
yql:Indicator_PRE_D6_01 a yql:CustomerConcentration ;
    rdfs:label "客户集中度"@zh ;
    skos:prefLabel "PRE-D6-01" ;
    skos:definition "前 N 大客户营收占比,反映客户依赖风险"@zh ;
    yql:hasFormula "SUM(TopN_Customer_Revenue) / TotalRevenue (默认 N=3 或 N=5)" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures fibo-fbc-pas-fpas:Counterparty ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold "<30%" ;
    yql:amberThreshold "30-50%" ;
    yql:redThreshold ">50%" ;
    yql:hasInput acc:Revenue ;
    yql:mapsToField ncc:SO_SALEINVOICE__PK_INVOICE, ncc:SO_SALEINVOICE__CSALEINVOICEID, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__DBILLDATE, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__FSTATUSFLAG, ncc:SO_SALEINVOICE__PK_ORG, ncc:SO_SALEINVOICE__CORIGCURRENCYID, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### PRE-D6-02 · 供应商集中度
yql:Indicator_PRE_D6_02 a yql:SupplierConcentration ;
    rdfs:label "供应商集中度"@zh ;
    skos:prefLabel "PRE-D6-02" ;
    skos:definition "前 N 大供应商采购占比,反映供应链依赖风险"@zh ;
    yql:hasFormula "SUM(TopN_Supplier_Purchase) / TotalPurchase" ;
    yql:appliedInScenario scn:PreLoanDD, scn:SupplyChainFinance ;
    yql:measures fibo-fbc-pas-fpas:Counterparty ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold "<40%" ;
    yql:amberThreshold "40-60%" ;
    yql:redThreshold ">60%" ;
    yql:hasInput acc:PurchaseAmount ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__NTOTALORIGMNY, ncc:PO_ORDER__PK_ORG, ncc:PO_INVOICE__PK_INVOICE, ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__DBILLDATE, ncc:AP_PAYABLEITEM__SUPPLIER, ncc:AP_PAYABLEITEM__LOCAL_MONEY_CR, ncc:AP_PAYABLEITEM__PK_ORG, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__NAME, ncc:BD_SUPPLIER__CODE .

### PRE-D6-03 · 关联方应收占比
yql:Indicator_PRE_D6_03 a yql:RelatedPartyARRatio ;
    rdfs:label "关联方应收占比"@zh ;
    skos:prefLabel "PRE-D6-03" ;
    skos:definition "关联方应收占应收总额比例,过高提示利润操纵或资金占用风险"@zh ;
    yql:hasFormula "RelatedParty_AR_Balance / Total_AR_Balance" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:measures yql:ControllingInterest ;
    yql:dimensionWeight "0.1"^^xsd:decimal ;
    yql:greenThreshold "<10%" ;
    yql:amberThreshold "10-30%" ;
    yql:redThreshold ">30%" ;
    yql:hasInput acc:AccountsReceivable, acc:RelatedPartyAR ;
    yql:mapsToField ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:BD_CUSTOMER__PK_SUPPLIER, ncc:BD_CUSTOMER__PK_GROUP, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__PK_ORG .

### SCF-D1-01 · 发票-订单匹配率
yql:Indicator_SCF_D1_01 a yql:InvoiceOrderMatchRate ;
    rdfs:label "发票-订单匹配率"@zh ;
    skos:prefLabel "SCF-D1-01" ;
    skos:definition "发票数据与采购订单的三要素匹配率"@zh ;
    yql:hasFormula "MatchedInvoiceCount / TotalInvoiceCount, where Match = (InvoiceNo↔OrderNo匹配 AND |InvoiceAmt-OrderAmt|/OrderAmt < 1% AND TaxNo一致)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-agr-ctr:Contract ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:greenThreshold ">=95%" ;
    yql:amberThreshold "85-95%" ;
    yql:redThreshold "<85%" ;
    yql:hasInput acc:Invoice, acc:PurchaseOrder ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__VBILLCODE, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__NTOTALORIGMNY, ncc:PO_ORDER__PK_ORG, ncc:PO_ORDER__FORDERSTATUS, ncc:PO_ORDER_B__PK_ORDER_B, ncc:PO_ORDER_B__PK_ORDER, ncc:PO_ORDER_B__PK_MATERIAL, ncc:PO_ORDER_B__NNUM, ncc:PO_ORDER_B__NORIGMNY, ncc:PO_ORDER_B__NORIGTAXMNY, ncc:PO_ORDER_B__NACCUMARRVNUM, ncc:PO_ORDER_B__NACCUMSTORENUM, ncc:PO_ORDER_B__NACCUMINVOICEMNY, ncc:PO_ORDER_B__DPLANARRVDATE, ncc:PO_INVOICE__PK_INVOICE, ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__DBILLDATE, ncc:PO_INVOICE__VVATCODE, ncc:PO_INVOICE__VVENDORVATCODE, ncc:PO_INVOICE__PK_ORG, ncc:PO_ARRIVEORDER__PK_ARRIVEORDER, ncc:PO_ARRIVEORDER__PK_SUPPLIER, ncc:PO_ARRIVEORDER__DBILLDATE, ncc:PO_ARRIVEORDER__NTOTALASTNUM, ncc:PO_ARRIVEORDER__NTOTALTAXMNY, ncc:PO_ARRIVEORDER_B__PK_ARRIVEORDER_B, ncc:PO_ARRIVEORDER_B__PK_ORDER, ncc:PO_ARRIVEORDER_B__PK_ORDER_B, ncc:PO_ARRIVEORDER_B__NNUM, ncc:IC_PURCHASEIN_H__CGENERALHID, ncc:IC_PURCHASEIN_H__DBILLDATE, ncc:IC_PURCHASEIN_H__CVENDORID, ncc:IC_PURCHASEIN_H__NTOTALNUM, ncc:IC_PURCHASEIN_H__FBILLFLAG, ncc:IC_PURCHASEIN_H__PK_ORG, ncc:IC_PURCHASEIN_B__CGENERALBID, ncc:IC_PURCHASEIN_B__CGENERALHID, ncc:IC_PURCHASEIN_B__CMATERIALOID, ncc:IC_PURCHASEIN_B__NNUM, ncc:IC_PURCHASEIN_B__CFIRSTBILLHID, ncc:IC_PURCHASEIN_B__CFIRSTBILLBID, ncc:SO_SALEORDER__CSALEORDERID, ncc:SO_SALEORDER__CCUSTOMERID, ncc:SO_SALEORDER__DBILLDATE, ncc:SO_SALEORDER__NTOTALORIGMNY, ncc:SO_SALEORDER__NTOTALNUM, ncc:SO_SALEORDER__FSTATUSFLAG, ncc:SO_SALEORDER__PK_ORG, ncc:SO_SALEINVOICE__CSALEINVOICEID, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__DBILLDATE, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__PK_ORG, ncc:SO_SALEINVOICE_B__CSALEINVOICEBID, ncc:SO_SALEINVOICE_B__CSALEINVOICEID, ncc:SO_SALEINVOICE_B__CMATERIALID, ncc:SO_SALEINVOICE_B__NNUM, ncc:SO_SALEINVOICE_B__NORIGMNY, ncc:SO_DELIVERY__CDELIVERYID, ncc:SO_DELIVERY__DBILLDATE, ncc:SO_DELIVERY__PK_ORG, ncc:SO_DELIVERY_B__CDELIVERYBID, ncc:SO_DELIVERY_B__CDELIVERYID, ncc:SO_DELIVERY_B__NNUM, ncc:SO_DELIVERY_B__CRECEIVECUSTID, ncc:SO_DELIVERY_B__CSRCID, ncc:SO_DELIVERY_B__CSRCBID, ncc:SO_DELIVERY_B__DSENDDATE, ncc:SO_DELIVERY_B__DRECEIVEDATE, ncc:CT_PU__PK_CT_PU, ncc:CT_PU__CVENDORID, ncc:CT_PU__NTOTALORIGMNY, ncc:CT_PU__VALDATE, ncc:CT_PU__INVALLIDATE, ncc:CT_PU__ACTUALVALIDATE, ncc:CT_PU__ACTUALINVALIDATE, ncc:CT_PU__PK_ORG, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__NAME, ncc:BD_SUPPLIER__TAXPAYERID, ncc:BD_SUPPLIER__VATCODE, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__TAXPAYERID .

### SCF-D1-02 · 货物交付完整性
yql:Indicator_SCF_D1_02 a yql:DeliveryCompleteness ;
    rdfs:label "货物交付完整性"@zh ;
    skos:prefLabel "SCF-D1-02" ;
    skos:definition "已交付数量对订单总量的完成率"@zh ;
    yql:hasFormula "SUM(DeliveredQuantity) / SUM(OrderQuantity) (按金额加权)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:ContractualCommitment ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:greenThreshold ">=98%" ;
    yql:amberThreshold "90-98%" ;
    yql:redThreshold "<90%" ;
    yql:hasInput acc:GoodsReceipt, acc:PurchaseOrder ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__VBILLCODE, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__NTOTALORIGMNY, ncc:PO_ORDER__PK_ORG, ncc:PO_ORDER__FORDERSTATUS, ncc:PO_ORDER_B__PK_ORDER_B, ncc:PO_ORDER_B__PK_ORDER, ncc:PO_ORDER_B__PK_MATERIAL, ncc:PO_ORDER_B__NNUM, ncc:PO_ORDER_B__NORIGMNY, ncc:PO_ORDER_B__NORIGTAXMNY, ncc:PO_ORDER_B__NACCUMARRVNUM, ncc:PO_ORDER_B__NACCUMSTORENUM, ncc:PO_ORDER_B__NACCUMINVOICEMNY, ncc:PO_ORDER_B__DPLANARRVDATE, ncc:PO_INVOICE__PK_INVOICE, ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__DBILLDATE, ncc:PO_INVOICE__VVATCODE, ncc:PO_INVOICE__VVENDORVATCODE, ncc:PO_INVOICE__PK_ORG, ncc:PO_ARRIVEORDER__PK_ARRIVEORDER, ncc:PO_ARRIVEORDER__PK_SUPPLIER, ncc:PO_ARRIVEORDER__DBILLDATE, ncc:PO_ARRIVEORDER__NTOTALASTNUM, ncc:PO_ARRIVEORDER__NTOTALTAXMNY, ncc:PO_ARRIVEORDER_B__PK_ARRIVEORDER_B, ncc:PO_ARRIVEORDER_B__PK_ORDER, ncc:PO_ARRIVEORDER_B__PK_ORDER_B, ncc:PO_ARRIVEORDER_B__NNUM, ncc:IC_PURCHASEIN_H__CGENERALHID, ncc:IC_PURCHASEIN_H__DBILLDATE, ncc:IC_PURCHASEIN_H__CVENDORID, ncc:IC_PURCHASEIN_H__NTOTALNUM, ncc:IC_PURCHASEIN_H__FBILLFLAG, ncc:IC_PURCHASEIN_H__PK_ORG, ncc:IC_PURCHASEIN_B__CGENERALBID, ncc:IC_PURCHASEIN_B__CGENERALHID, ncc:IC_PURCHASEIN_B__CMATERIALOID, ncc:IC_PURCHASEIN_B__NNUM, ncc:IC_PURCHASEIN_B__CFIRSTBILLHID, ncc:IC_PURCHASEIN_B__CFIRSTBILLBID, ncc:SO_SALEORDER__CSALEORDERID, ncc:SO_SALEORDER__CCUSTOMERID, ncc:SO_SALEORDER__DBILLDATE, ncc:SO_SALEORDER__NTOTALORIGMNY, ncc:SO_SALEORDER__NTOTALNUM, ncc:SO_SALEORDER__FSTATUSFLAG, ncc:SO_SALEORDER__PK_ORG, ncc:SO_SALEINVOICE__CSALEINVOICEID, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__DBILLDATE, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__PK_ORG, ncc:SO_SALEINVOICE_B__CSALEINVOICEBID, ncc:SO_SALEINVOICE_B__CSALEINVOICEID, ncc:SO_SALEINVOICE_B__CMATERIALID, ncc:SO_SALEINVOICE_B__NNUM, ncc:SO_SALEINVOICE_B__NORIGMNY, ncc:SO_DELIVERY__CDELIVERYID, ncc:SO_DELIVERY__DBILLDATE, ncc:SO_DELIVERY__PK_ORG, ncc:SO_DELIVERY_B__CDELIVERYBID, ncc:SO_DELIVERY_B__CDELIVERYID, ncc:SO_DELIVERY_B__NNUM, ncc:SO_DELIVERY_B__CRECEIVECUSTID, ncc:SO_DELIVERY_B__CSRCID, ncc:SO_DELIVERY_B__CSRCBID, ncc:SO_DELIVERY_B__DSENDDATE, ncc:SO_DELIVERY_B__DRECEIVEDATE, ncc:CT_PU__PK_CT_PU, ncc:CT_PU__CVENDORID, ncc:CT_PU__NTOTALORIGMNY, ncc:CT_PU__VALDATE, ncc:CT_PU__INVALLIDATE, ncc:CT_PU__ACTUALVALIDATE, ncc:CT_PU__ACTUALINVALIDATE, ncc:CT_PU__PK_ORG, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__NAME, ncc:BD_SUPPLIER__TAXPAYERID, ncc:BD_SUPPLIER__VATCODE, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__TAXPAYERID .

### SCF-D1-03 · 交易对手一致性
yql:Indicator_SCF_D1_03 a yql:CounterpartyConsistencyCheck ;
    rdfs:label "交易对手一致性"@zh ;
    skos:prefLabel "SCF-D1-03" ;
    skos:definition "发票方/合同方/收货方/付款方四方法人主体一致性校验"@zh ;
    yql:hasFormula "Boolean: InvoiceParty.LEI = ContractParty.LEI = LogisticsConsignee.LEI = BankPayer.LEI AND 统一社会信用代码全部一致" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fbc-pas-fpas:Counterparty ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__VBILLCODE, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__NTOTALORIGMNY, ncc:PO_ORDER__PK_ORG, ncc:PO_ORDER__FORDERSTATUS, ncc:PO_ORDER_B__PK_ORDER_B, ncc:PO_ORDER_B__PK_ORDER, ncc:PO_ORDER_B__PK_MATERIAL, ncc:PO_ORDER_B__NNUM, ncc:PO_ORDER_B__NORIGMNY, ncc:PO_ORDER_B__NORIGTAXMNY, ncc:PO_ORDER_B__NACCUMARRVNUM, ncc:PO_ORDER_B__NACCUMSTORENUM, ncc:PO_ORDER_B__NACCUMINVOICEMNY, ncc:PO_ORDER_B__DPLANARRVDATE, ncc:PO_INVOICE__PK_INVOICE, ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__DBILLDATE, ncc:PO_INVOICE__VVATCODE, ncc:PO_INVOICE__VVENDORVATCODE, ncc:PO_INVOICE__PK_ORG, ncc:PO_ARRIVEORDER__PK_ARRIVEORDER, ncc:PO_ARRIVEORDER__PK_SUPPLIER, ncc:PO_ARRIVEORDER__DBILLDATE, ncc:PO_ARRIVEORDER__NTOTALASTNUM, ncc:PO_ARRIVEORDER__NTOTALTAXMNY, ncc:PO_ARRIVEORDER_B__PK_ARRIVEORDER_B, ncc:PO_ARRIVEORDER_B__PK_ORDER, ncc:PO_ARRIVEORDER_B__PK_ORDER_B, ncc:PO_ARRIVEORDER_B__NNUM, ncc:IC_PURCHASEIN_H__CGENERALHID, ncc:IC_PURCHASEIN_H__DBILLDATE, ncc:IC_PURCHASEIN_H__CVENDORID, ncc:IC_PURCHASEIN_H__NTOTALNUM, ncc:IC_PURCHASEIN_H__FBILLFLAG, ncc:IC_PURCHASEIN_H__PK_ORG, ncc:IC_PURCHASEIN_B__CGENERALBID, ncc:IC_PURCHASEIN_B__CGENERALHID, ncc:IC_PURCHASEIN_B__CMATERIALOID, ncc:IC_PURCHASEIN_B__NNUM, ncc:IC_PURCHASEIN_B__CFIRSTBILLHID, ncc:IC_PURCHASEIN_B__CFIRSTBILLBID, ncc:SO_SALEORDER__CSALEORDERID, ncc:SO_SALEORDER__CCUSTOMERID, ncc:SO_SALEORDER__DBILLDATE, ncc:SO_SALEORDER__NTOTALORIGMNY, ncc:SO_SALEORDER__NTOTALNUM, ncc:SO_SALEORDER__FSTATUSFLAG, ncc:SO_SALEORDER__PK_ORG, ncc:SO_SALEINVOICE__CSALEINVOICEID, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__DBILLDATE, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__PK_ORG, ncc:SO_SALEINVOICE_B__CSALEINVOICEBID, ncc:SO_SALEINVOICE_B__CSALEINVOICEID, ncc:SO_SALEINVOICE_B__CMATERIALID, ncc:SO_SALEINVOICE_B__NNUM, ncc:SO_SALEINVOICE_B__NORIGMNY, ncc:SO_DELIVERY__CDELIVERYID, ncc:SO_DELIVERY__DBILLDATE, ncc:SO_DELIVERY__PK_ORG, ncc:SO_DELIVERY_B__CDELIVERYBID, ncc:SO_DELIVERY_B__CDELIVERYID, ncc:SO_DELIVERY_B__NNUM, ncc:SO_DELIVERY_B__CRECEIVECUSTID, ncc:SO_DELIVERY_B__CSRCID, ncc:SO_DELIVERY_B__CSRCBID, ncc:SO_DELIVERY_B__DSENDDATE, ncc:SO_DELIVERY_B__DRECEIVEDATE, ncc:CT_PU__PK_CT_PU, ncc:CT_PU__CVENDORID, ncc:CT_PU__NTOTALORIGMNY, ncc:CT_PU__VALDATE, ncc:CT_PU__INVALLIDATE, ncc:CT_PU__ACTUALVALIDATE, ncc:CT_PU__ACTUALINVALIDATE, ncc:CT_PU__PK_ORG, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__NAME, ncc:BD_SUPPLIER__TAXPAYERID, ncc:BD_SUPPLIER__VATCODE, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__TAXPAYERID, ncc:AP_PAYABLEITEM__SUPPLIER, ncc:AP_PAYABLEITEM__LOCAL_MONEY_CR, ncc:AP_PAYABLEITEM__PK_ORG .

### SCF-D1-04 · 合同履约时间偏差
yql:Indicator_SCF_D1_04 a yql:ContractPerformanceTimeDeviation ;
    rdfs:label "合同履约时间偏差"@zh ;
    skos:prefLabel "SCF-D1-04" ;
    skos:definition "实际交付日相对合同约定日的偏差天数"@zh ;
    yql:hasFormula "ActualDeliveryDate - ContractDeliveryDate" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-agr-ctr:Contract ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<=3" ;
    yql:amberThreshold "3-10" ;
    yql:redThreshold ">10" ;
    yql:hasInput acc:Contract, acc:GoodsReceipt ;
    yql:mapsToField ncc:CT_PU__PK_CT_PU, ncc:CT_PU__VALDATE, ncc:CT_PU__INVALLIDATE, ncc:CT_PU__ACTUALVALIDATE, ncc:CT_PU__ACTUALINVALIDATE, ncc:CT_PU__NTOTALORIGMNY, ncc:CT_PU__CVENDORID, ncc:CT_PU__PK_ORG, ncc:CT_PU_EXEC__PK_CT_PU, ncc:CT_PU_EXEC__VEXECDATE, ncc:CT_SALE__PK_CT_SALE, ncc:CT_SALE__VALDATE, ncc:CT_SALE__INVALLIDATE, ncc:CT_SALE__ACTUALVALIDATE, ncc:CT_SALE__ACTUALINVALIDATE, ncc:CT_SALE_EXEC__PK_CT_SALE, ncc:CT_SALE_EXEC__VEXECDATE, ncc:IC_PURCHASEIN_H__DBILLDATE, ncc:IC_PURCHASEIN_H__CVENDORID, ncc:SO_DELIVERY__DBILLDATE, ncc:SO_DELIVERY_B__DSENDDATE .

### SCF-D1-05 · 物流凭证三方验证
yql:Indicator_SCF_D1_05 a yql:LogisticsThreeWayMatch ;
    rdfs:label "物流凭证三方验证"@zh ;
    skos:prefLabel "SCF-D1-05" ;
    skos:definition "物流单/发票/ERP 入库三方数据一致性校验"@zh ;
    yql:hasFormula "Boolean: LogisticsRecord ⊆ InvoiceRecord ∩ ERPGoodsReceipt AND |LogisticsDate - InvoiceDate| <= 7 days" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-agr-ctr:Contract ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:mapsToField ncc:PO_ARRIVEORDER__PK_ARRIVEORDER, ncc:PO_ARRIVEORDER__DBILLDATE, ncc:PO_ARRIVEORDER__PK_SUPPLIER, ncc:PO_ARRIVEORDER__PK_ORG, ncc:IC_PURCHASEIN_H__CGENERALHID, ncc:IC_PURCHASEIN_H__DBILLDATE, ncc:IC_PURCHASEIN_H__CVENDORID, ncc:IC_PURCHASEIN_B__CGENERALBID, ncc:IC_PURCHASEIN_B__NNUM, ncc:PO_INVOICE__PK_INVOICE, ncc:PO_INVOICE__DBILLDATE, ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY .

### SCF-D1-07 · 关联方交易占比
yql:Indicator_SCF_D1_07 a yql:RelatedPartyTransactionRatio ;
    rdfs:label "关联方交易占比"@zh ;
    skos:prefLabel "SCF-D1-07" ;
    skos:definition "关联方交易额占总交易额比例"@zh ;
    yql:hasFormula "RelatedParty_TxnAmt / Total_TxnAmt" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:ControllingInterest ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:greenThreshold "<20%" ;
    yql:amberThreshold "20-40%" ;
    yql:redThreshold ">40%" ;
    yql:hasInput acc:RelatedPartyTransaction, acc:TotalTransaction ;
    yql:mapsToField ncc:PO_INVOICE__PK_SUPPLIER, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__DBILLDATE, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__DBILLDATE, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__INNERPROFITCENTER .

### SCF-D1-08 · 四流合一验证得分
yql:Indicator_SCF_D1_08 a yql:FourFlowIntegrityCheck ;
    rdfs:label "四流合一验证得分"@zh ;
    skos:prefLabel "SCF-D1-08" ;
    skos:definition "中国 SCF 特有的\"四流合一\"综合评分"@zh ;
    yql:hasFormula "25 * IF(ContractFlow_OK) + 25 * IF(LogisticsFlow_OK) + 25 * IF(CashFlow_OK) + 25 * IF(InvoiceFlow_OK)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-agr-ctr:Contract ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:unit "score(0-100)" ;
    yql:greenThreshold ">=90" ;
    yql:amberThreshold "70-90" ;
    yql:redThreshold "<70" ;
    yql:scoringModel "{'description': '四流(合同流/物流/资金流/发票流)各 25 分,匹配则得分', 'sub_dimensions': {'ContractFlow': '合同与订单一致', 'LogisticsFlow': '物流凭证与货物交付一致', 'CashFlow': '银行流水与发票收款一致', 'InvoiceFlow': '金税系统真实可查'}}" ;
.

### SCF-D1-11 · 历史交易频率稳定性
yql:Indicator_SCF_D1_11 a yql:TransactionFrequencyStability ;
    rdfs:label "历史交易频率稳定性"@zh ;
    skos:prefLabel "SCF-D1-11" ;
    skos:definition "近 24 月每月订单数稳定性,CV 越小越稳定"@zh ;
    yql:hasFormula "1 - (STDEV(MonthlyOrderCount_24M) / AVG(MonthlyOrderCount_24M)) (1 - CV)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.28"^^xsd:decimal ;
    yql:greenThreshold ">=0.7" ;
    yql:amberThreshold "0.5-0.7" ;
    yql:redThreshold "<0.5" ;
    yql:hasInput acc:PurchaseOrder ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__PK_ORG, ncc:SO_SALEORDER__CSALEORDERID, ncc:SO_SALEORDER__CCUSTOMERID, ncc:SO_SALEORDER__DBILLDATE, ncc:SO_SALEORDER__PK_ORG .

### SCF-D2-01 · 应收账款账龄评分
yql:Indicator_SCF_D2_01 a yql:ARAgingScore ;
    rdfs:label "应收账款账龄评分"@zh ;
    skos:prefLabel "SCF-D2-01" ;
    skos:definition "应收账款账龄分布加权评分(SCF 场景版)"@zh ;
    yql:hasFormula "100 * SUM(AgeBucket_i.Balance * AgingWeight_i) / TotalAR" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:unit "score(0-100)" ;
    yql:greenThreshold ">=80" ;
    yql:amberThreshold "60-80" ;
    yql:redThreshold "<60" ;
    yql:scoringModel "{'description': '供应链场景的应收账龄加权评分(系数与 PRE-D3-01 一致)', 'weights': {'0-30D': 1.0, '31-60D': 0.85, '61-90D': 0.6, '91-180D': 0.3, '>180D': 0.0}}" ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### SCF-D2-02 · 90天以上应收占比
yql:Indicator_SCF_D2_02 a yql:AR90DaysOverdueRatio ;
    rdfs:label "90天以上应收占比"@zh ;
    skos:prefLabel "SCF-D2-02" ;
    skos:definition "账龄超过 90 天的应收账款占比"@zh ;
    yql:hasFormula "AR_AgeOver90D / TotalAR" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<5%" ;
    yql:amberThreshold "5-15%" ;
    yql:redThreshold ">15%" ;
    yql:hasInput acc:AccountsReceivable ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### SCF-D2-03 · 应收账款集中度
yql:Indicator_SCF_D2_03 a yql:ARConcentration ;
    rdfs:label "应收账款集中度"@zh ;
    skos:prefLabel "SCF-D2-03" ;
    skos:definition "前 N 大买方应收余额占总应收的比例"@zh ;
    yql:hasFormula "SUM(TopN_Customer_AR) / TotalAR (默认 N=3)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fbc-pas-fpas:Counterparty ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<40%" ;
    yql:amberThreshold "40-60%" ;
    yql:redThreshold ">60%" ;
    yql:hasInput acc:AccountsReceivable ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE .

### SCF-D2-04 · 供应链DSO
yql:Indicator_SCF_D2_04 a yql:SupplyChainDSO ;
    rdfs:label "供应链DSO"@zh ;
    skos:prefLabel "SCF-D2-04" ;
    skos:definition "供应链场景应收周转天数(与 PRE-D5-02 同公式,只是观察主体不同)"@zh ;
    yql:hasFormula "AvgAR / Revenue * 365 (供应链场景下,通常按核心企业生态测算)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<45" ;
    yql:amberThreshold "45-60" ;
    yql:redThreshold ">60" ;
    yql:hasInput acc:AccountsReceivable, acc:Revenue ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE, ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### SCF-D2-05 · 应收账款争议率
yql:Indicator_SCF_D2_05 a yql:ARDisputeRate ;
    rdfs:label "应收账款争议率"@zh ;
    skos:prefLabel "SCF-D2-05" ;
    skos:definition "存在争议的应收账款金额占比"@zh ;
    yql:hasFormula "Disputed_AR_Amount / Total_AR_Amount (依据工单系统标记)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<2%" ;
    yql:amberThreshold "2-5%" ;
    yql:redThreshold ">5%" ;
    yql:hasInput acc:AccountsReceivable, acc:DisputeRecord ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__APPROVESTATUS, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__PK_CURRTYPE, ncc:AR_RECITEM__PK_RECITEM, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__BUSIDATE, ncc:AR_RECITEM__MONEY_DE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__CONTRACTNO, ncc:AR_RECITEM__PK_ORG, ncc:ARAP_BALANCE__PK_BALANCE, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__MONEY_DE, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__ACCMONTH, ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME, ncc:BD_CUSTOMER__CODE, ncc:AR_RECBILL__ISREFUND .

### SCF-D2-06 · 应收账款质量分级
yql:Indicator_SCF_D2_06 a yql:ARQualityGrade ;
    rdfs:label "应收账款质量分级"@zh ;
    skos:prefLabel "SCF-D2-06" ;
    skos:definition "将 ARQualityScore 离散化为 A/B/C/D 四级"@zh ;
    yql:hasFormula "ENUM_LOOKUP(SCF-D2-01 score) → A/B/C/D" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:scoringModel "{'description': '按账龄评分阈值分级', 'grade_thresholds': {'A': 'score>=80', 'B': '60<=score<80', 'C': '40<=score<60', 'D': 'score<40'}}" ;
.

### SCF-D2-07 · 历史坏账率
yql:Indicator_SCF_D2_07 a yql:HistoricalBadDebtRate ;
    rdfs:label "历史坏账率"@zh ;
    skos:prefLabel "SCF-D2-07" ;
    skos:definition "近 24 个月累计核销坏账占同期应收发生额比例"@zh ;
    yql:hasFormula "Cumulative_WrittenOff_AR_24M / Cumulative_AR_Generated_24M" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<1%" ;
    yql:amberThreshold "1-3%" ;
    yql:redThreshold ">3%" ;
    yql:hasInput acc:WrittenOffAR, acc:AccountsReceivable ;
    yql:mapsToField ncc:ARAP_BDLOSS__PK_BDLOSS, ncc:ARAP_BDLOSS__BILLDATE, ncc:ARAP_BDLOSS__LOSSMONEY, ncc:ARAP_BDLOSS__LOSSLOCALMONEY, ncc:ARAP_BDLOSS__LOSSREASON, ncc:ARAP_BDLOSS__PK_ORG, ncc:ARAP_BDLOSS_D__PK_BDLOSS, ncc:ARAP_BDLOSS_D__PK_BDLOSS_D, ncc:ARAP_BDLOSS_D__PK_BILL, ncc:ARAP_BDLOSS_D__LOSSLOCALMONEY, ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:ARAP_VERIFY__PK_VERIFY, ncc:ARAP_VERIFY__BUSIDATE, ncc:ARAP_VERIFY__LOCAL_MONEY_CR, ncc:ARAP_VERIFY__PK_ORG .

### SCF-D2-09 · 应收可回收性评分
yql:Indicator_SCF_D2_09 a yql:ARRecoverabilityScore ;
    rdfs:label "应收可回收性评分"@zh ;
    skos:prefLabel "SCF-D2-09" ;
    skos:definition "综合买方信用、账龄、历史回款的应收可回收性评分"@zh ;
    yql:hasFormula "0.4 * BuyerCreditScore + 0.3 * ARAgingScore + 0.3 * HistoricalCollectionRate" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:unit "score(0-100)" ;
    yql:greenThreshold ">=75" ;
    yql:amberThreshold "50-75" ;
    yql:redThreshold "<50" ;
    yql:scoringModel "{'description': '多维度复合评分', 'weights': {'BuyerCredit': 0.4, 'ARAging': 0.3, 'HistoricalCollectionRate': 0.3}}" ;
.

### SCF-D2-10 · ERP应收与银行一致性
yql:Indicator_SCF_D2_10 a yql:ERPBankReconciliationRate ;
    rdfs:label "ERP应收与银行一致性"@zh ;
    skos:prefLabel "SCF-D2-10" ;
    skos:definition "ERP 记账回款与银行实际流水的一致性校验"@zh ;
    yql:hasFormula "ABS(ERP_RecordedCollection - BankFlowCollection) / ERP_RecordedCollection <= 0.5%" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Payment ;
    yql:dimensionWeight "0.25"^^xsd:decimal ;
    yql:greenThreshold "<=0.3%" ;
    yql:amberThreshold "0.3-1%" ;
    yql:redThreshold ">1%" ;
    yql:hasInput acc:Collection, acc:BankFlow ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__PK_ORG, ncc:AR_GATHERBILL__PK_GATHERBILL, ncc:AR_GATHERBILL__BILLDATE, ncc:AR_GATHERBILL__MONEY, ncc:AR_GATHERBILL__LOCAL_MONEY, ncc:AR_GATHERBILL__PK_ORG, ncc:AR_GATHERITEM__PK_GATHERBILL, ncc:AR_GATHERITEM__MONEY_CR, ncc:AR_GATHERITEM__LOCAL_MONEY_CR, ncc:AR_GATHERITEM__CUSTOMER, ncc:AR_GATHERITEM__BUSIDATE, ncc:FTS_GATHERING__PK_GATHERING, ncc:FTS_GATHERING__BILLDATE, ncc:FTS_GATHERING__GATHERINGDATE, ncc:FTS_GATHERING__TOTALAMOUNT, ncc:FTS_GATHERING__OLCTOTALAMOUNT, ncc:FTS_GATHERING__PK_ORG, ncc:FTS_ACCOUNT_DAILYDETAIL__PK_DAILYDETAIL, ncc:FTS_ACCOUNT_DAILYDETAIL__BUSDATE, ncc:FTS_ACCOUNT_DAILYDETAIL__INMONEY, ncc:FTS_ACCOUNT_DAILYDETAIL__OLCINMONEY, ncc:FTS_ACCOUNT_DAILYDETAIL__PK_ACCOUNT, ncc:FTS_ACCOUNT_DAILYDETAIL__PK_ORG, ncc:FTS_ACCOUNT_DETAIL__PK_ACCOUNT_DETAIL, ncc:FTS_ACCOUNT_DETAIL__TALLYDATE, ncc:FTS_ACCOUNT_DETAIL__INMONEY, ncc:FTS_ACCOUNT_DETAIL__PK_ACCOUNT, ncc:FTS_ACCOUNT_DETAIL__VBILLNO .

### SCF-D3-02 · 买方付款准时率
yql:Indicator_SCF_D3_02 a yql:BuyerPaymentOnTimeRate ;
    rdfs:label "买方付款准时率"@zh ;
    skos:prefLabel "SCF-D3-02" ;
    skos:definition "买方按期付款笔数占比"@zh ;
    yql:hasFormula "OnTimePaymentCount / TotalPaymentCount, where OnTime = ActualPayDate <= ContractDueDate" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Payment ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold ">=95%" ;
    yql:amberThreshold "85-95%" ;
    yql:redThreshold "<85%" ;
    yql:hasInput acc:Payment, acc:Contract ;
    yql:mapsToField ncc:AR_RECBILL__PK_RECBILL, ncc:AR_RECBILL__BILLDATE, ncc:AR_RECBILL__MONEY, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECITEM__PK_RECBILL, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__PK_PAYTERM, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_GATHERBILL__PK_GATHERBILL, ncc:AR_GATHERBILL__BILLDATE, ncc:AR_GATHERBILL__PAYDATE, ncc:AR_GATHERBILL__PK_ORG, ncc:AR_GATHERITEM__PK_GATHERBILL, ncc:AR_GATHERITEM__CUSTOMER, ncc:AR_GATHERITEM__MONEY_CR, ncc:AR_GATHERITEM__BUSIDATE, ncc:AR_GATHERITEM__PAYDATE, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME .

### SCF-D3-04 · 买方逾期应付占比
yql:Indicator_SCF_D3_04 a yql:BuyerOverdueAPRatio ;
    rdfs:label "买方逾期应付占比"@zh ;
    skos:prefLabel "SCF-D3-04" ;
    skos:definition "买方应付账款中逾期部分占比(从买方 ERP 获取)"@zh ;
    yql:hasFormula "Buyer_Overdue_AP / Buyer_Total_AP" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-pas-psch:PaymentObligation ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:greenThreshold "<5%" ;
    yql:amberThreshold "5-15%" ;
    yql:redThreshold ">15%" ;
    yql:hasInput acc:AccountsPayable ;
    yql:mapsToField ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME .

### SCF-D3-09 · 核心企业确认意愿
yql:Indicator_SCF_D3_09 a yql:CoreEnterpriseConfirmationWillingness ;
    rdfs:label "核心企业确认意愿"@zh ;
    skos:prefLabel "SCF-D3-09" ;
    skos:definition "核心企业是否对应付账款做出书面确认"@zh ;
    yql:hasFormula "Boolean: 已取得核心企业书面确认函(签章+回执)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fnd-agr-ctr:Contract ;
    yql:dimensionWeight "0.2"^^xsd:decimal ;
    yql:mapsToField ncc:CT_SALE__PK_CT_SALE, ncc:CT_SALE__PK_CUSTOMER, ncc:CT_SALE__VBILLCODE, ncc:CT_SALE__VALDATE, ncc:CT_SALE__FSTATUSFLAG, ncc:CT_SALE__PK_ORG, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_CUSTOMER__NAME .

### SCF-D4-01 · 供应商关系稳定性
yql:Indicator_SCF_D4_01 a yql:SupplierRelationshipStability ;
    rdfs:label "供应商关系稳定性"@zh ;
    skos:prefLabel "SCF-D4-01" ;
    skos:definition "年度供应商保留率,反映供应链稳定性"@zh ;
    yql:hasFormula "Suppliers_Both_Years / Suppliers_Prior_Year (年度保留率)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fbc-pas-fpas:Counterparty ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:greenThreshold ">=90%" ;
    yql:amberThreshold "75-90%" ;
    yql:redThreshold "<75%" ;
    yql:hasInput acc:Supplier, acc:PurchaseOrder ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__NTOTALORIGMNY, ncc:PO_ORDER__PK_ORG, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__NAME, ncc:BD_SUPPLIER__ESTABLISHDATE, ncc:BD_SUPPLIER__BEGINDATE .

### SCF-D4-03 · ERP系统集成深度
yql:Indicator_SCF_D4_03 a yql:ERPIntegrationDepth ;
    rdfs:label "ERP系统集成深度"@zh ;
    skos:prefLabel "SCF-D4-03" ;
    skos:definition "ERP 系统与融资平台的集成深度等级"@zh ;
    yql:hasFormula "ENUM_LOOKUP(API_Coverage, Update_Frequency, Writeback_Capability) → L1-L5" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:greenThreshold ">=L3" ;
    yql:amberThreshold "L2" ;
    yql:redThreshold "L1" ;
    yql:scoringModel "{'description': '按 API 接入广度/数据更新频率/数据回写能力评级', 'levels': {'L1': '仅手工导入', 'L2': '文件批量', 'L3': 'API 单向只读', 'L4': 'API 双向实时', 'L5': '深度集成含主数据治理'}}" ;
.

### SCF-D4-04 · 供应链库存周转天数
yql:Indicator_SCF_D4_04 a yql:SupplyChainInventoryDays ;
    rdfs:label "供应链库存周转天数"@zh ;
    skos:prefLabel "SCF-D4-04" ;
    skos:definition "供应链场景的库存周转天数(与 PRE-D3-05 同公式,观察主体扩到链路)"@zh ;
    yql:hasFormula "AvgInventory / COGS * 365 (供应链全链路视角)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<45" ;
    yql:amberThreshold "45-60" ;
    yql:redThreshold ">60" ;
    yql:hasInput acc:Inventory, acc:COGS ;
    yql:mapsToField ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT, ncc:IA_MONTHNAB__CMONTHNABID, ncc:IA_MONTHNAB__CINVENTORYID, ncc:IA_MONTHNAB__CACCOUNTPERIOD, ncc:IA_MONTHNAB__NABMNY, ncc:IA_MONTHNAB__NABNUM, ncc:IA_MONTHNAB__PK_ORG .

### SCF-D4-05 · 订单履行率
yql:Indicator_SCF_D4_05 a yql:OrderFulfillmentRate ;
    rdfs:label "订单履行率"@zh ;
    skos:prefLabel "SCF-D4-05" ;
    skos:definition "按时按量履行的订单占比(OTIF: On-Time-In-Full)"@zh ;
    yql:hasFormula "OnTimeAndFullOrderCount / TotalOrderCount (OTIF)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:ContractualCommitment ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:greenThreshold ">=95%" ;
    yql:amberThreshold "85-95%" ;
    yql:redThreshold "<85%" ;
    yql:hasInput acc:PurchaseOrder, acc:GoodsReceipt ;
    yql:mapsToField ncc:PO_ORDER__PK_ORDER, ncc:PO_ORDER__DBILLDATE, ncc:PO_ORDER__NTOTALORIGMNY, ncc:PO_ORDER__PK_SUPPLIER, ncc:PO_ORDER__PK_ORG, ncc:PO_ORDER_B__PK_ORDER, ncc:PO_ORDER_B__NNUM, ncc:PO_ORDER_B__NACCUMARRVNUM, ncc:PO_ORDER_B__NACCUMSTORENUM, ncc:PO_ORDER_B__DPLANARRVDATE, ncc:IC_PURCHASEIN_H__CGENERALHID, ncc:IC_PURCHASEIN_H__DBILLDATE, ncc:IC_PURCHASEIN_B__CFIRSTBILLHID, ncc:IC_PURCHASEIN_B__CFIRSTBILLBID, ncc:SO_SALEORDER__CSALEORDERID, ncc:SO_SALEORDER__DBILLDATE, ncc:SO_SALEORDER__NTOTALORIGMNY, ncc:SO_SALEORDER__PK_ORG, ncc:SO_DELIVERY__CDELIVERYID, ncc:SO_DELIVERY__DBILLDATE, ncc:SO_DELIVERY_B__CSRCID, ncc:SO_DELIVERY_B__CSRCBID, ncc:SO_DELIVERY_B__NNUM .

### SCF-D4-06 · 供应链DPO
yql:Indicator_SCF_D4_06 a yql:SupplyChainDPO ;
    rdfs:label "供应链DPO"@zh ;
    skos:prefLabel "SCF-D4-06" ;
    skos:definition "应付账款周转天数 DPO"@zh ;
    yql:hasFormula "AvgAP / COGS * 365" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:unit "days" ;
    yql:greenThreshold "<60" ;
    yql:amberThreshold "60-90" ;
    yql:redThreshold ">90 (压款)" ;
    yql:hasInput acc:AccountsPayable, acc:COGS ;
    yql:mapsToField ncc:AP_PAYABLEBILL__PK_PAYABLEBILL, ncc:AP_PAYABLEBILL__BILLDATE, ncc:AP_PAYABLEBILL__MONEY, ncc:AP_PAYABLEBILL__LOCAL_MONEY, ncc:AP_PAYABLEBILL__PK_ORG, ncc:AP_PAYABLEITEM__PK_PAYABLEBILL, ncc:AP_PAYABLEITEM__SUPPLIER, ncc:AP_PAYABLEITEM__MONEY_CR, ncc:AP_PAYABLEITEM__MONEY_BAL, ncc:AP_PAYABLEITEM__LOCAL_MONEY_CR, ncc:AP_PAYABLEITEM__LOCAL_MONEY_BAL, ncc:AP_PAYABLEITEM__BUSIDATE, ncc:AP_PAYABLEITEM__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNT, ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__YEAR, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_CURRTYPE, ncc:BD_ACCOUNT__PK_ACCOUNT, ncc:BD_ACCOUNT__CODE, ncc:BD_ACCOUNT__NAME, ncc:BD_ACCOUNT__ACCPROPERTY, ncc:BD_ACCOUNT__BALANORIENT .

### SCF-D4-07 · 供应链融资历史
yql:Indicator_SCF_D4_07 a yql:SupplyChainFinancingHistory ;
    rdfs:label "供应链融资历史"@zh ;
    skos:prefLabel "SCF-D4-07" ;
    skos:definition "历史供应链融资交易记录的结构化档案"@zh ;
    yql:hasFormula "复合记录:{TxnCount, CumulativeAmount, DefaultCount, OverdueCount, MaxYearsOfCooperation}" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fbc-dae-dbt:Debt ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:mapsToField ncc:CDMC_CONTRACT__PK_CONTRACT, ncc:CDMC_CONTRACT__LOANMNY, ncc:CDMC_CONTRACT__BEGINDATE, ncc:CDMC_CONTRACT__ENDDATE, ncc:CDMC_CONTRACT__PK_ORG, ncc:CDMC_FINEXECUTE__PK_FINANCEPAY, ncc:CDMC_FINEXECUTE__FIN_REPAYAMOUNT, ncc:CDMC_FINEXECUTE__FIN_PAYINTEREST, ncc:CDMC_REPAYPRCPL__PK_CONTRACT, ncc:CDMC_REPAYPRCPL__REPAYDATE, ncc:CDMC_REPAYPRCPL__REPAYMNY, ncc:CDMC_REPAYPRCPL__OVERDUEFLAG, ncc:CDMC_REPINTEREST__PK_CONTRACT, ncc:CDMC_REPINTEREST__PAYINTMONEY, ncc:CDMC_REPINTEREST__LOANDATE .

### SCF-D4-08 · 数字化平台评分
yql:Indicator_SCF_D4_08 a yql:DigitalPlatformScore ;
    rdfs:label "数字化平台评分"@zh ;
    skos:prefLabel "SCF-D4-08" ;
    skos:definition "接入的数字化供应链平台综合能力评分"@zh ;
    yql:hasFormula "0.3*DataQuality + 0.25*RealTimeCapability + 0.25*Coverage + 0.2*Security" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures yql:Indicator ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:unit "score(0-100)" ;
    yql:greenThreshold ">=80" ;
    yql:amberThreshold "60-80" ;
    yql:redThreshold "<60" ;
    yql:scoringModel "{'description': '平台综合能力评分', 'sub_dimensions': {'DataQuality': '数据质量(完整性/准确性/时效性)', 'RealTimeCapability': '实时数据接入能力', 'Coverage': '业务环节覆盖广度', 'Security': '信息安全和合规水平'}}" ;
.

### SCF-D4-09 · 供应链层级深度
yql:Indicator_SCF_D4_09 a yql:SupplyChainTierDepth ;
    rdfs:label "供应链层级深度"@zh ;
    skos:prefLabel "SCF-D4-09" ;
    skos:definition "从核心企业向下追溯的供应商层级数"@zh ;
    yql:hasFormula "MAX_TIER(SupplierGraph from CoreEnterprise)" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:measures fibo-fbc-pas-fpas:Counterparty ;
    yql:dimensionWeight "0.14"^^xsd:decimal ;
    yql:unit "levels" ;
    yql:greenThreshold "<=2" ;
    yql:amberThreshold "3" ;
    yql:redThreshold ">=4" ;
    yql:mapsToField ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:BD_SUPPLIER__NAME, ncc:BD_SUPPLIER__PK_SUPPLIERCLASS, ncc:PO_ORDER__PK_SUPPLIER .

