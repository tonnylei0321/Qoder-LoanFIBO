# loan_v1.ttl
# 信贷指标本体 · FIBO (白名单受控) + yql 自定义 + NCC 映射
# 用途:导入 GraphDB → SPARQL 查询 → 代理服务生成 SQL → NCC Oracle 执行
#
# 【本版本关键特性】
# - FIBO 类/属性严格白名单控制:仅保留经 web_search 核验存在的 7 个 FIBO 类、8 个 FIBO 属性
# - 未核实的 FIBO 类/属性本地化为 yql: 自定义,用 skos:closeMatch 保留候选 FIBO IRI 作为人工对齐参考
# - 全部前缀 IRI 与 FIBO 官方仓库(github.com/edmcouncil/fibo、spec.edmcouncil.org)对齐
# - NCC 字段引用 0 幻觉(经 database_ddl_all.sql 逐一核验)
# ============================================================

@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:     <http://purl.org/dc/terms/> .

# ---- 自定义命名空间 ----
@prefix yql:     <http://yql.example.com/ontology/credit-risk/> .
@prefix acc:     <http://yql.example.com/ontology/accounting/> .
@prefix scn:     <http://yql.example.com/ontology/scenario/> .
@prefix ncc:     <http://yql.example.com/ontology/ncc-mapping/> .

# ---- FIBO 标准本体前缀(仅核实过的)----
@prefix fibo-fbc-dae-dbt:    <https://spec.edmcouncil.org/fibo/ontology/FBC/DebtAndEquities/Debt/> .
@prefix fibo-fbc-pas-fpas:   <https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/FinancialProductsAndServices/> .
@prefix fibo-fnd-acc-cur:    <https://spec.edmcouncil.org/fibo/ontology/FND/Accounting/CurrencyAmount/> .
@prefix fibo-fnd-agr-ctr:    <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/> .
@prefix fibo-fnd-arr-rt:     <https://spec.edmcouncil.org/fibo/ontology/FND/Arrangements/Ratios/> .
@prefix fibo-fnd-dt-fd:      <https://spec.edmcouncil.org/fibo/ontology/FND/DatesAndTimes/FinancialDates/> .
@prefix fibo-fnd-pas-psch:   <https://spec.edmcouncil.org/fibo/ontology/FND/ProductsAndServices/PaymentsAndSchedules/> .

# ============================================================
# 本体元数据
# ============================================================

<http://yql.example.com/ontology/credit-risk/loan_v1> a owl:Ontology ;
    dct:title "信贷风险指标本体 v1"@zh ;
    dct:description "71 项贷前/贷后/供应链金融指标 → FIBO + yql 自定义本体 → NCC 表字段映射"@zh ;
    owl:versionInfo "1.1 (FIBO 白名单受控版)" ;
    dct:creator "信贷风控建模团队" ;
    rdfs:comment "由 GraphDB 驱动的指标→SPARQL→SQL 推理链路,对接用友 YonBIP V3.0 NCC 数据库"@zh .

# ============================================================
# FIBO 标准类引用(白名单,已核实存在)
# ============================================================

fibo-fbc-dae-dbt:Debt a owl:Class .
fibo-fbc-dae-dbt:DebtInstrument a owl:Class .
fibo-fbc-pas-fpas:Counterparty a owl:Class .
fibo-fnd-acc-cur:MonetaryAmount a owl:Class .
fibo-fnd-agr-ctr:Contract a owl:Class .
fibo-fnd-pas-psch:PaymentObligation a owl:Class .

fibo-fbc-dae-dbt:hasInterestRate a owl:ObjectProperty .
fibo-fbc-dae-dbt:hasPrincipalAmount a owl:ObjectProperty .
fibo-fbc-pas-fpas:isACounterpartyIn a owl:ObjectProperty .
fibo-fnd-acc-cur:hasAmount a owl:ObjectProperty .
fibo-fnd-acc-cur:hasCurrency a owl:ObjectProperty .
fibo-fnd-agr-ctr:hasContractParty a owl:ObjectProperty .
fibo-fnd-dt-fd:hasEndDate a owl:ObjectProperty .
fibo-fnd-dt-fd:hasStartDate a owl:ObjectProperty .

# ============================================================
# yql 本体顶层类
# ============================================================

yql:Indicator a owl:Class ;
    rdfs:label "信贷指标"@zh ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/IND/Indicators/Indicators/Indicator> ;
    rdfs:comment "所有信贷风控指标的根类。skos:closeMatch 指向 FIBO IND:Indicator 作为候选对齐(需导入 FIBO TBox 人工验证)"@zh .

yql:Ratio a owl:Class ;
    rdfs:label "比率型指标"@zh ;
    rdfs:subClassOf yql:Indicator , fibo-fnd-arr-rt:Ratio .

yql:Score a owl:Class ;
    rdfs:label "评分型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:Days a owl:Class ;
    rdfs:label "天数型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:CheckResult a owl:Class ;
    rdfs:label "核验结果型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:ChangeRate a owl:Class ;
    rdfs:label "变化率型指标"@zh ;
    rdfs:subClassOf yql:Indicator , fibo-fnd-arr-rt:Ratio .

yql:Concentration a owl:Class ;
    rdfs:label "集中度型指标"@zh ;
    rdfs:subClassOf yql:Indicator , fibo-fnd-arr-rt:Ratio .

yql:Alert a owl:Class ;
    rdfs:label "预警型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:Grade a owl:Class ;
    rdfs:label "分级型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:Trend a owl:Class ;
    rdfs:label "趋势型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:Pattern a owl:Class ;
    rdfs:label "模式型指标"@zh ;
    rdfs:subClassOf yql:Indicator .

yql:Atomic a owl:Class ;
    rdfs:label "原子型指标(金额/计数)"@zh ;
    rdfs:subClassOf yql:Indicator .

# ---- NCC 映射类 ----
yql:NCCTable a owl:Class ;
    rdfs:label "NCC 数据库表"@zh .

yql:NCCField a owl:Class ;
    rdfs:label "NCC 字段"@zh .

# ---- 业务场景 ----
scn:Scenario a owl:Class ;
    rdfs:label "业务场景"@zh .

# ============================================================
# 本地化 yql 类(替代未核实的 FIBO 类,用 skos:closeMatch 保留候选对齐)
# ============================================================

yql:Collateral a owl:Class ;
    rdfs:label "Collateral" ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FBC/DebtAndEquities/Debt/Collateral> ;
    rdfs:comment "本地化类,skos:closeMatch 指向 FIBO 候选 IRI,需人工验证对齐"@zh .

yql:ContractualCommitment a owl:Class ;
    rdfs:label "ContractualCommitment" ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/ContractualCommitment> ;
    rdfs:comment "本地化类,skos:closeMatch 指向 FIBO 候选 IRI,需人工验证对齐"@zh .

yql:ControllingInterest a owl:Class ;
    rdfs:label "ControllingInterest" ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/Control/ControllingInterest> ;
    rdfs:comment "本地化类,skos:closeMatch 指向 FIBO 候选 IRI,需人工验证对齐"@zh .

yql:FinancialServiceProvider a owl:Class ;
    rdfs:label "FinancialServiceProvider" ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/FinancialProductsAndServices/FinancialServiceProvider> ;
    rdfs:comment "本地化类,skos:closeMatch 指向 FIBO 候选 IRI,需人工验证对齐"@zh .

yql:Payment a owl:Class ;
    rdfs:label "Payment" ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FND/ProductsAndServices/PaymentsAndSchedules/Payment> ;
    rdfs:comment "本地化类,skos:closeMatch 指向 FIBO 候选 IRI,需人工验证对齐"@zh .

yql:Reporter a owl:Class ;
    rdfs:label "Reporter" ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FND/Arrangements/Reporting/Reporter> ;
    rdfs:comment "本地化类,skos:closeMatch 指向 FIBO 候选 IRI,需人工验证对齐"@zh .

# ============================================================
# yql 属性声明
# ============================================================

yql:hasInput a owl:ObjectProperty ;
    rdfs:label "输入数据项"@zh ;
    rdfs:comment "指标计算的输入字段/科目"@zh .

yql:appliedInScenario a owl:ObjectProperty ;
    rdfs:label "适用场景"@zh ;
    rdfs:comment "指标应用的业务场景"@zh .

yql:baseIndicator a owl:ObjectProperty ;
    rdfs:label "基础指标"@zh ;
    rdfs:comment "派生/复用指标所依赖的基础指标"@zh .

yql:mapsToField a owl:ObjectProperty ;
    rdfs:label "映射到 NCC 字段"@zh ;
    rdfs:comment "指标引用的底层 NCC 字段"@zh .

yql:belongsToTable a owl:ObjectProperty ;
    rdfs:label "属于 NCC 表"@zh ;
    rdfs:comment "字段所在的表"@zh .

yql:reusedBy a owl:ObjectProperty ;
    rdfs:label "被复用到"@zh ;
    rdfs:comment "跨场景复用关系"@zh .

yql:measures a owl:ObjectProperty ;
    rdfs:label "度量对象"@zh ;
    rdfs:comment "指标所度量的 FIBO 或 yql 实体"@zh .

yql:hasControllingParty a owl:ObjectProperty ;
    rdfs:label "有控股方"@zh ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/Control/hasControllingParty> ;
    rdfs:comment "本地化自 FIBO hasControllingParty"@zh .

yql:secures a owl:ObjectProperty ;
    rdfs:label "担保"@zh ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FBC/DebtAndEquities/Guarantees/secures> ;
    rdfs:comment "本地化自 FIBO secures"@zh .

yql:hasPayer a owl:ObjectProperty ;
    rdfs:label "付款方"@zh ;
    skos:closeMatch <https://spec.edmcouncil.org/fibo/ontology/FND/ProductsAndServices/PaymentsAndSchedules/hasPayer> ;
    rdfs:comment "本地化自 FIBO hasPayer"@zh .

yql:hasFormula a owl:DatatypeProperty ;
    rdfs:label "计算公式"@zh ;
    rdfs:range xsd:string .

yql:dimensionWeight a owl:DatatypeProperty ;
    rdfs:label "维度权重"@zh ;
    rdfs:range xsd:decimal .

yql:greenThreshold a owl:DatatypeProperty ;
    rdfs:label "绿色阈值(健康)"@zh ;
    rdfs:range xsd:string .

yql:amberThreshold a owl:DatatypeProperty ;
    rdfs:label "黄色阈值(警示)"@zh ;
    rdfs:range xsd:string .

yql:redThreshold a owl:DatatypeProperty ;
    rdfs:label "红色阈值(危险)"@zh ;
    rdfs:range xsd:string .

yql:scoringModel a owl:DatatypeProperty ;
    rdfs:label "评分模型定义"@zh ;
    rdfs:range xsd:string .

yql:gradeScale a owl:DatatypeProperty ;
    rdfs:label "分级标尺"@zh ;
    rdfs:range xsd:string .

yql:timeOperator a owl:DatatypeProperty ;
    rdfs:label "时间算子"@zh ;
    rdfs:range xsd:string .

yql:patternDefinition a owl:DatatypeProperty ;
    rdfs:label "模式定义"@zh ;
    rdfs:range xsd:string .

yql:checkRule a owl:DatatypeProperty ;
    rdfs:label "核验规则"@zh ;
    rdfs:range xsd:string .

yql:unit a owl:DatatypeProperty ;
    rdfs:label "单位"@zh ;
    rdfs:range xsd:string .

yql:fieldType a owl:DatatypeProperty ;
    rdfs:label "字段数据类型"@zh ;
    rdfs:range xsd:string .

yql:fieldSemantics a owl:DatatypeProperty ;
    rdfs:label "字段中文语义"@zh ;
    rdfs:range xsd:string .

yql:tableNameZh a owl:DatatypeProperty ;
    rdfs:label "表中文名"@zh ;
    rdfs:range xsd:string .

# ============================================================
# 业务场景
# ============================================================

scn:PreLoanDD a scn:Scenario ;
    rdfs:label "贷前尽职调查"@zh ;
    skos:definition "对借款主体进行偿债能力、盈利、资产质量等全面评估"@zh .

scn:PostLoanMonitoring a scn:Scenario ;
    rdfs:label "贷后监控"@zh ;
    skos:definition "放款后持续跟踪借款人财务行为、经营状况、负债结构、抵质押物"@zh .

scn:SupplyChainFinance a scn:Scenario ;
    rdfs:label "供应链金融"@zh ;
    skos:definition "基于应收账款、订单、贸易真实性的融资场景"@zh .

# ============================================================
# yql 指标子类
# ============================================================

yql:ARAgingDeteriorationRate a owl:Class ;
    rdfs:label "应收账龄恶化速率"@zh ;
    rdfs:subClassOf yql:ChangeRate, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "60 天以上应收占比的环比恶化幅度,警示坏账加速"@zh .

yql:RelatedPartyTransactionSpike a owl:Class ;
    rdfs:label "关联方交易突增告警"@zh ;
    rdfs:subClassOf yql:Alert ;
    skos:definition "识别关联方交易突增,可能是利益输送或套现信号"@zh .

yql:ThreeStatementConsistencyCheck a owl:Class ;
    rdfs:label "三表一致性校验"@zh ;
    rdfs:subClassOf yql:CheckResult ;
    skos:definition "利润表/资产负债表/现金流量表三表勾稽关系校验"@zh .

yql:FinancialReportTimeliness a owl:Class ;
    rdfs:label "财报提交及时性"@zh ;
    rdfs:subClassOf yql:CheckResult ;
    skos:definition "财务报表实际提交相对约定截止日的延迟天数"@zh .

yql:RevenueYoYGrowth a owl:Class ;
    rdfs:label "营收同比增速"@zh ;
    rdfs:subClassOf yql:ChangeRate ;
    skos:definition "营业收入同比增长率"@zh .

yql:GrossMarginQoQChange a owl:Class ;
    rdfs:label "毛利率环比变化"@zh ;
    rdfs:subClassOf yql:ChangeRate ;
    skos:definition "毛利率相对上一季度的变化幅度(百分点)"@zh .

yql:OperatingCashFlowYoYChange a owl:Class ;
    rdfs:label "经营现金流同比变化"@zh ;
    rdfs:subClassOf yql:ChangeRate ;
    skos:definition "经营活动现金流的同比变化率"@zh .

yql:EBITDAMarginTrend a owl:Class ;
    rdfs:label "EBITDA利润率趋势"@zh ;
    rdfs:subClassOf yql:Trend ;
    skos:definition "过去 4 个季度 EBITDA 利润率的线性回归斜率"@zh .

yql:ContractBacklogAmount a owl:Class ;
    rdfs:label "在手合同金额"@zh ;
    rdfs:subClassOf yql:Atomic, fibo-fnd-agr-ctr:Contract ;
    skos:definition "已签订未执行合同的累计剩余金额(订单储备)"@zh .

yql:NonBankFinancingRatioChange a owl:Class ;
    rdfs:label "非银融资占比变化"@zh ;
    rdfs:subClassOf yql:ChangeRate ;
    skos:definition "非银渠道融资占比的环比变化(上升过快暗示传统银行融资受限)"@zh .

yql:CreditLineUsageRatio a owl:Class ;
    rdfs:label "授信使用率"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fbc-dae-dbt:DebtInstrument ;
    skos:definition "已用授信占总授信额度的比例"@zh .

yql:DebtToAssetRatioChange a owl:Class ;
    rdfs:label "资产负债率变化"@zh ;
    rdfs:subClassOf yql:ChangeRate ;
    skos:definition "资产负债率的环比变化(快速攀升提示过度举债)"@zh .

yql:PledgedARCoverageRatio a owl:Class ;
    rdfs:label "应收账款质押覆盖率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "质押应收账款的合格价值对在贷余额的覆盖倍数"@zh .

yql:PledgedARQualityScore a owl:Class ;
    rdfs:label "质押应收质量评分"@zh ;
    rdfs:subClassOf yql:Score ;
    skos:definition "质押应收的综合可回收性评分(账龄+买方信用双维度)"@zh .

yql:PledgedARConcentration a owl:Class ;
    rdfs:label "质押应收集中度"@zh ;
    rdfs:subClassOf yql:Concentration ;
    skos:definition "前 N 大买方质押应收占总质押的比例"@zh .

yql:QuickRatio a owl:Class ;
    rdfs:label "速动比率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "衡量企业立即变现资产偿付短期债务能力的稳健性指标"@zh .

yql:CurrentRatio a owl:Class ;
    rdfs:label "流动比率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "短期偿债能力基础指标"@zh .

yql:InterestCoverageRatio a owl:Class ;
    rdfs:label "利息覆盖倍数 ICR"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "营业利润对利息费用的保障倍数"@zh .

yql:DebtServiceCoverageRatio a owl:Class ;
    rdfs:label "偿债覆盖率 DSCR"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fbc-dae-dbt:Debt ;
    skos:definition "企业现金流对偿债总额的覆盖倍数(银行通用口径,使用 EBITDA 替代地产业的 NOI)"@zh .

yql:NetDebtToEBITDARatio a owl:Class ;
    rdfs:label "净债务/EBITDA"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fbc-dae-dbt:Debt ;
    skos:definition "企业净有息负债需要多少年 EBITDA 才能偿还"@zh .

yql:CashCoverageDays a owl:Class ;
    rdfs:label "现金覆盖天数"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "现金及等价物可支撑日常经营运转的天数(已剔除折摊等非现金成本)"@zh .

yql:EBITDAMargin a owl:Class ;
    rdfs:label "EBITDA利润率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "剔除融资和折摊影响的核心经营利润率"@zh .

yql:OperatingCashFlowToNetIncomeRatio a owl:Class ;
    rdfs:label "现金流/净利润比"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "利润含金量;持续<1 提示利润被应收/存货占用"@zh .

yql:RevenueCAGR3Y a owl:Class ;
    rdfs:label "收入3年CAGR"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "过去 3 年营业收入的复合年均增长率"@zh .

yql:GrossMargin a owl:Class ;
    rdfs:label "毛利率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "主营业务的初步盈利能力"@zh .

yql:NetProfitMargin a owl:Class ;
    rdfs:label "净利润率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "扣除全部成本费用税金后的最终盈利能力"@zh .

yql:ARQualityScore a owl:Class ;
    rdfs:label "应收账款质量评分"@zh ;
    rdfs:subClassOf yql:Score, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "对应收账款基于账龄分布的可回收性综合评分"@zh .

yql:AR60DaysOverdueRatio a owl:Class ;
    rdfs:label "60天以上应收占比"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "账龄超过 60 天的应收账款占总应收的比例"@zh .

yql:DebtToAssetRatio a owl:Class ;
    rdfs:label "资产负债率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "企业总杠杆水平"@zh .

yql:EffectiveNetAssets a owl:Class ;
    rdfs:label "有效净资产"@zh ;
    rdfs:subClassOf yql:Atomic, fibo-fnd-acc-cur:MonetaryAmount ;
    skos:definition "剔除虚资产和关联方应收后的可变现净资产口径"@zh .

yql:DaysInventoryOutstanding a owl:Class ;
    rdfs:label "存货周转天数"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "DIO,存货从采购到售出平均所需天数"@zh .

yql:FreeCashFlow a owl:Class ;
    rdfs:label "自由现金流 FCF"@zh ;
    rdfs:subClassOf yql:Atomic, fibo-fnd-acc-cur:MonetaryAmount ;
    skos:definition "企业可自由支配的现金流量;采用 FCFF 口径(若需 FCFE 加 NetBorrowing)"@zh .

yql:CFOStability a owl:Class ;
    rdfs:label "经营现金流稳定性"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "过去 8 个季度经营现金流的变异系数,值越小越稳定"@zh .

yql:CapExToRevenueRatio a owl:Class ;
    rdfs:label "资本支出/营收比"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "资本开支强度;过高可能挤压自由现金流"@zh .

yql:CashFlowStructurePattern a owl:Class ;
    rdfs:label "三类现金流结构"@zh ;
    rdfs:subClassOf yql:Pattern ;
    skos:definition "经营/投资/筹资三类现金流的符号组合,识别企业所处生命周期"@zh .

yql:CashRatio a owl:Class ;
    rdfs:label "现金比率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "最严格的短期偿债能力指标"@zh .

yql:CashConversionCycle a owl:Class ;
    rdfs:label "现金转换周期 CCC"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "企业从付款给供应商到收到客户回款的净周期"@zh .

yql:DaysSalesOutstanding a owl:Class ;
    rdfs:label "应收账款周转天数 DSO"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "平均回款周期"@zh .

yql:TotalAssetTurnover a owl:Class ;
    rdfs:label "总资产周转率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "总资产创造收入的效率"@zh .

yql:ReturnOnEquity a owl:Class ;
    rdfs:label "净资产收益率 ROE"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "股东权益的回报率(分母用平均口径而非期末单点)"@zh .

yql:CustomerConcentration a owl:Class ;
    rdfs:label "客户集中度"@zh ;
    rdfs:subClassOf yql:Concentration, fibo-fbc-pas-fpas:Counterparty ;
    skos:definition "前 N 大客户营收占比,反映客户依赖风险"@zh .

yql:SupplierConcentration a owl:Class ;
    rdfs:label "供应商集中度"@zh ;
    rdfs:subClassOf yql:Concentration, fibo-fbc-pas-fpas:Counterparty ;
    skos:definition "前 N 大供应商采购占比,反映供应链依赖风险"@zh .

yql:RelatedPartyARRatio a owl:Class ;
    rdfs:label "关联方应收占比"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "关联方应收占应收总额比例,过高提示利润操纵或资金占用风险"@zh .

yql:InvoiceOrderMatchRate a owl:Class ;
    rdfs:label "发票-订单匹配率"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fnd-agr-ctr:Contract ;
    skos:definition "发票数据与采购订单的三要素匹配率"@zh .

yql:DeliveryCompleteness a owl:Class ;
    rdfs:label "货物交付完整性"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "已交付数量对订单总量的完成率"@zh .

yql:CounterpartyConsistencyCheck a owl:Class ;
    rdfs:label "交易对手一致性"@zh ;
    rdfs:subClassOf yql:CheckResult, fibo-fbc-pas-fpas:Counterparty ;
    skos:definition "发票方/合同方/收货方/付款方四方法人主体一致性校验"@zh .

yql:ContractPerformanceTimeDeviation a owl:Class ;
    rdfs:label "合同履约时间偏差"@zh ;
    rdfs:subClassOf yql:Atomic, fibo-fnd-agr-ctr:Contract ;
    skos:definition "实际交付日相对合同约定日的偏差天数"@zh .

yql:LogisticsThreeWayMatch a owl:Class ;
    rdfs:label "物流凭证三方验证"@zh ;
    rdfs:subClassOf yql:CheckResult, fibo-fnd-agr-ctr:Contract ;
    skos:definition "物流单/发票/ERP 入库三方数据一致性校验"@zh .

yql:RelatedPartyTransactionRatio a owl:Class ;
    rdfs:label "关联方交易占比"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "关联方交易额占总交易额比例"@zh .

yql:FourFlowIntegrityCheck a owl:Class ;
    rdfs:label "四流合一验证得分"@zh ;
    rdfs:subClassOf yql:Score, fibo-fnd-agr-ctr:Contract ;
    skos:definition "中国 SCF 特有的\"四流合一\"综合评分"@zh .

yql:TransactionFrequencyStability a owl:Class ;
    rdfs:label "历史交易频率稳定性"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "近 24 月每月订单数稳定性,CV 越小越稳定"@zh .

yql:ARAgingScore a owl:Class ;
    rdfs:label "应收账款账龄评分"@zh ;
    rdfs:subClassOf yql:Score, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "应收账款账龄分布加权评分(SCF 场景版)"@zh .

yql:AR90DaysOverdueRatio a owl:Class ;
    rdfs:label "90天以上应收占比"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "账龄超过 90 天的应收账款占比"@zh .

yql:ARConcentration a owl:Class ;
    rdfs:label "应收账款集中度"@zh ;
    rdfs:subClassOf yql:Concentration, fibo-fbc-pas-fpas:Counterparty ;
    skos:definition "前 N 大买方应收余额占总应收的比例"@zh .

yql:SupplyChainDSO a owl:Class ;
    rdfs:label "供应链DSO"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "供应链场景应收周转天数(与 PRE-D5-02 同公式,只是观察主体不同)"@zh .

yql:ARDisputeRate a owl:Class ;
    rdfs:label "应收账款争议率"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "存在争议的应收账款金额占比"@zh .

yql:ARQualityGrade a owl:Class ;
    rdfs:label "应收账款质量分级"@zh ;
    rdfs:subClassOf yql:Grade, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "将 ARQualityScore 离散化为 A/B/C/D 四级"@zh .

yql:HistoricalBadDebtRate a owl:Class ;
    rdfs:label "历史坏账率"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "近 24 个月累计核销坏账占同期应收发生额比例"@zh .

yql:ARRecoverabilityScore a owl:Class ;
    rdfs:label "应收可回收性评分"@zh ;
    rdfs:subClassOf yql:Score, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "综合买方信用、账龄、历史回款的应收可回收性评分"@zh .

yql:ERPBankReconciliationRate a owl:Class ;
    rdfs:label "ERP应收与银行一致性"@zh ;
    rdfs:subClassOf yql:CheckResult ;
    skos:definition "ERP 记账回款与银行实际流水的一致性校验"@zh .

yql:BuyerPaymentOnTimeRate a owl:Class ;
    rdfs:label "买方付款准时率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "买方按期付款笔数占比"@zh .

yql:BuyerOverdueAPRatio a owl:Class ;
    rdfs:label "买方逾期应付占比"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fnd-pas-psch:PaymentObligation ;
    skos:definition "买方应付账款中逾期部分占比(从买方 ERP 获取)"@zh .

yql:CoreEnterpriseConfirmationWillingness a owl:Class ;
    rdfs:label "核心企业确认意愿"@zh ;
    rdfs:subClassOf yql:CheckResult, fibo-fnd-agr-ctr:Contract ;
    skos:definition "核心企业是否对应付账款做出书面确认"@zh .

yql:SupplierRelationshipStability a owl:Class ;
    rdfs:label "供应商关系稳定性"@zh ;
    rdfs:subClassOf yql:Ratio, fibo-fbc-pas-fpas:Counterparty ;
    skos:definition "年度供应商保留率,反映供应链稳定性"@zh .

yql:ERPIntegrationDepth a owl:Class ;
    rdfs:label "ERP系统集成深度"@zh ;
    rdfs:subClassOf yql:Grade ;
    skos:definition "ERP 系统与融资平台的集成深度等级"@zh .

yql:SupplyChainInventoryDays a owl:Class ;
    rdfs:label "供应链库存周转天数"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "供应链场景的库存周转天数(与 PRE-D3-05 同公式,观察主体扩到链路)"@zh .

yql:OrderFulfillmentRate a owl:Class ;
    rdfs:label "订单履行率"@zh ;
    rdfs:subClassOf yql:Ratio ;
    skos:definition "按时按量履行的订单占比(OTIF: On-Time-In-Full)"@zh .

yql:SupplyChainDPO a owl:Class ;
    rdfs:label "供应链DPO"@zh ;
    rdfs:subClassOf yql:Days ;
    skos:definition "应付账款周转天数 DPO"@zh .

yql:SupplyChainFinancingHistory a owl:Class ;
    rdfs:label "供应链融资历史"@zh ;
    rdfs:subClassOf yql:Atomic, fibo-fbc-dae-dbt:Debt ;
    skos:definition "历史供应链融资交易记录的结构化档案"@zh .

yql:DigitalPlatformScore a owl:Class ;
    rdfs:label "数字化平台评分"@zh ;
    rdfs:subClassOf yql:Score ;
    skos:definition "接入的数字化供应链平台综合能力评分"@zh .

yql:SupplyChainTierDepth a owl:Class ;
    rdfs:label "供应链层级深度"@zh ;
    rdfs:subClassOf yql:Atomic, fibo-fbc-pas-fpas:Counterparty ;
    skos:definition "从核心企业向下追溯的供应商层级数"@zh .

