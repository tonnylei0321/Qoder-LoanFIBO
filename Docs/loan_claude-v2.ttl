#   ?ind skos:prefLabel "PRE-D1-01" ;
#        yql:hasFormula ?formula ;
#        yql:mapsToField ?field .
#   ?field yql:belongsToTable ?table ;
#          yql:fieldSemantics ?semantics .
# }
#
# --- 示例 2: 查询指定场景下所有指标 ---
