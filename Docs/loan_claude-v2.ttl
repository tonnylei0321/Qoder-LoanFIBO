#   ?ind yql:appliedInScenario scn:SupplyChainFinance ;
#        rdfs:label ?label ;
#        yql:hasFormula ?formula .
# }
#
# --- 示例 3: 反向查询某字段被哪些指标引用 ---
# SELECT ?ind ?label WHERE {
#   ?ind yql:mapsToField ncc:ARAP_BALANCE__LOCAL_MONEY_DE ;
#        rdfs:label ?label .
# }
#
# --- 示例 4: 查询跨模块复用关系 ---
