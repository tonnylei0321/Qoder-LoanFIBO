# -------------------- NCC 表 --------------------
ncc:AP_PAYABLEITEM a yql:NCCTable ;
    rdfs:label "应付单明细表"@zh ;
    skos:prefLabel "应付单明细表"@zh ;
    yql:tableCode "AP_PAYABLEITEM" .
