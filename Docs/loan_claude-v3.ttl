# -------------------- 指标个体(34 个,含 SQL)--------------------

yql:Indicator_POST_D2_03 a yql:ThreeStatementConsistency, yql:Indicator ;
    rdfs:label "三表一致性校验"@zh ;
    skos:notation "POST-D2-03" ;
    skos:definition """利润表/资产负债表/现金流量表三表勾稽关系校验""" ;
    yql:hasFormula """Boolean: ALL(Rule1, Rule2, Rule3) where Rule1: NetIncome_IS = (RetainedEarnings_End - RetainedEarnings_Begin + Dividends), Rule2: CashFlow_NetIncrease = CashEnd - CashBegin, Rule3: CFO_indirect_reconciliation_starts_from_NetIncome""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- POST-D2-03 三表一致性校验
-- 核对利润表净利润 vs 资产负债表"未分配利润"变动
WITH ni_pnl AS (
  SELECT
    (NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'
                  THEN LOCALCREDITAMOUNT - LOCALDEBITAMOUNT END), 0)
   - NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '64%' OR ACCOUNTCODE LIKE '66%'
                     OR ACCOUNTCODE LIKE '67%' OR ACCOUNTCODE LIKE '68%'
                  THEN LOCALDEBITAMOUNT - LOCALCREDITAMOUNT END), 0)
   + NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%'
                     OR ACCOUNTCODE LIKE '6301%'
                  THEN LOCALCREDITAMOUNT - LOCALDEBITAMOUNT END), 0)
    ) AS amount
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
),
ni_bs AS (
  SELECT NVL(SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT), 0) AS amount
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
    AND ACCOUNTCODE LIKE '4104%'
)
SELECT
  ni_pnl.amount AS ni_from_pnl,
  ni_bs.amount AS ni_from_bs,
  ABS(ni_pnl.amount - ni_bs.amount) AS diff,
  CASE WHEN ABS(ni_pnl.amount - ni_bs.amount) < 0.01 THEN 1 ELSE 0 END AS is_consistent
FROM ni_pnl, ni_bs;
-- TODO #TSC-1: 完整三表核对还需现金流量表"净利润"调节项,需附表数据
""" .

yql:Indicator_POST_D3_01 a yql:RevenueYoYGrowth, yql:Indicator ;
    rdfs:label "营收同比增速"@zh ;
    skos:notation "POST-D3-01" ;
    skos:definition """营业收入同比增长率""" ;
    yql:hasFormula """(Revenue_current_period - Revenue_same_period_lastyear) / Revenue_same_period_lastyear""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=5%" ;
    yql:amberThreshold "-5%-5%" ;
    yql:redThreshold "<-5%" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- POST-D3-01 营收同比增速
-- 公式: (本期营收 - 上年同期) / 上年同期
SELECT
  ROUND((cur.rev - prev.rev) / NULLIF(ABS(prev.rev), 0), 4) AS revenue_yoy_growth
FROM
  (SELECT NVL(SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT), 0) AS rev
   FROM GL_BALANCE
   WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
     AND YEAR = :year AND PERIOD = :period
     AND (ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%')) cur,
  (SELECT NVL(SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT), 0) AS rev
   FROM GL_BALANCE
   WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
     AND YEAR = :year - 1 AND PERIOD = :period
     AND (ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%')) prev;
""" .

yql:Indicator_POST_D3_02 a yql:GrossMarginQoQChange, yql:Indicator ;
    rdfs:label "毛利率环比变化"@zh ;
    skos:notation "POST-D3-02" ;
    skos:definition """毛利率相对上一季度的变化幅度(百分点)""" ;
    yql:hasFormula """GrossProfitMargin_current_quarter - GrossProfitMargin_prior_quarter (变化量,百分点)""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=-1pp" ;
    yql:amberThreshold "-3pp 到 -1pp" ;
    yql:redThreshold "<-3pp" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- POST-D3-02 毛利率环比变化
WITH pm AS (
  SELECT
    PERIOD,
    ROUND(
      (NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'
                     THEN LOCALCREDITAMOUNT - LOCALDEBITAMOUNT END), 0)
     - NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%'
                     THEN LOCALDEBITAMOUNT - LOCALCREDITAMOUNT END), 0)) /
      NULLIF(NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%'
                          THEN LOCALCREDITAMOUNT - LOCALDEBITAMOUNT END), 0), 0),
      4
    ) AS margin
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year
    AND PERIOD IN (:period, LPAD(TO_CHAR(TO_NUMBER(:period) - 1), 2, '0'))
  GROUP BY PERIOD
)
SELECT
  MAX(CASE WHEN PERIOD = :period THEN margin END) -
  MAX(CASE WHEN PERIOD = LPAD(TO_CHAR(TO_NUMBER(:period) - 1), 2, '0') THEN margin END)
  AS gross_margin_qoq_change
FROM pm;
-- TODO :period='01' 跨年时上期为上年 12 月
""" .

yql:Indicator_POST_D3_03 a yql:CFOYoYChange, yql:Indicator ;
    rdfs:label "经营现金流同比变化"@zh ;
    skos:notation "POST-D3-03" ;
    skos:definition """经营活动现金流的同比变化率""" ;
    yql:hasFormula """(CFO_current - CFO_same_period_lastyear) / ABS(CFO_same_period_lastyear)""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "A" ;
    yql:greenThreshold ">=0%" ;
    yql:amberThreshold "-20%-0%" ;
    yql:redThreshold "<-20%" ;
    yql:usesTable ncc:GL_CASHFLOWCASE, ncc:GL_VOUCHER ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_VOUCHER__PERIOD, ncc:GL_VOUCHER__PK_VOUCHER, ncc:GL_VOUCHER__YEAR ;
    yql:hasSQL """
-- POST-D3-03 经营现金流同比变化
-- 公式: (本年 CFO - 上年 CFO) / ABS(上年 CFO)
-- 数据源: GL_CASHFLOWCASE + GL_VOUCHER(GL_CASHFLOWCASE 无期间字段,需 join 凭证取期间)
-- TODO #CF-1: PK_CASHFLOWCASE 区分"经营/投资/筹资"的编码规则?需查 BD_CASHFLOW
WITH cfo_amount AS (
  SELECT gv.YEAR, NVL(SUM(gc.MONEY), 0) AS amount
  FROM GL_CASHFLOWCASE gc
  JOIN GL_VOUCHER gv ON gc.PK_VOUCHER = gv.PK_VOUCHER
  WHERE gc.PK_ORG = :org_id
    AND gc.PK_ACCOUNTINGBOOK = :book_id
    AND gv.YEAR IN (:year, :year - 1)
    AND gv.PERIOD = :period
    /* TODO #CF-2: 根据 PK_CASHFLOWCASE 过滤"经营活动",需 join BD_CASHFLOW 判断 */
  GROUP BY gv.YEAR
)
SELECT
  ROUND(
    (MAX(CASE WHEN YEAR = :year THEN amount END) -
     MAX(CASE WHEN YEAR = :year - 1 THEN amount END)) /
    NULLIF(ABS(MAX(CASE WHEN YEAR = :year - 1 THEN amount END)), 0),
    4
  ) AS cfo_yoy_change
FROM cfo_amount;
""" .

yql:Indicator_POST_D3_05 a yql:OnHandContract, yql:Indicator ;
    rdfs:label "在手合同金额"@zh ;
    skos:notation "POST-D3-05" ;
    skos:definition """已签订未执行合同的累计剩余金额(订单储备)""" ;
    yql:hasFormula """SUM(SignedContract.RemainingAmount where Status IN [Active, Pending Execution])""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=2 * AnnualRevenue" ;
    yql:amberThreshold "1-2 * Revenue" ;
    yql:redThreshold "<1 * Revenue" ;
    yql:usesTable ncc:CT_SALE ;
    yql:mapsToField ncc:CT_SALE__FSTATUSFLAG, ncc:CT_SALE__INVALLIDATE, ncc:CT_SALE__NTOTALORIGMNY, ncc:CT_SALE__PK_ORG, ncc:CT_SALE__VALDATE ;
    yql:hasSQL """
-- POST-D3-05 在手合同金额
-- 执行中合同的合同总额(CT_SALE_EXEC 只有日期,无执行金额字段,只能取合同总额)
-- TODO #CT-1: CT_SALE.FSTATUSFLAG 具体状态值?假设 =1 表示已生效
-- TODO #CT-2: "已执行金额"无法从 CT_SALE_EXEC 直接取得(该表只有日期流水),
--             需要 join 发票/发货表计算实际执行金额
SELECT NVL(SUM(NTOTALORIGMNY), 0) AS on_hand_contract_amount
FROM CT_SALE
WHERE PK_ORG = :org_id
  AND FSTATUSFLAG = 1
  AND VALDATE <= :asof_date
  AND (INVALLIDATE IS NULL OR INVALLIDATE >= :asof_date);
""" .

yql:Indicator_POST_D4_01 a yql:NonBankFinancingRatio, yql:Indicator ;
    rdfs:label "非银融资占比变化"@zh ;
    skos:notation "POST-D4-01" ;
    skos:definition """非银渠道融资占比的环比变化(上升过快暗示传统银行融资受限)""" ;
    yql:hasFormula """NonBankFinancing_Ratio_current - NonBankFinancing_Ratio_prior, where Ratio = NonBankFinancing / TotalInterestBearingDebt""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<=2pp" ;
    yql:amberThreshold "2-5pp" ;
    yql:redThreshold ">5pp" ;
    yql:usesTable ncc:BATM_FINANCING, ncc:BOND_CONTRACT, ncc:CDMC_CONTRACT, ncc:ICDMC_CONTRACT ;
    yql:hasSQL """
-- POST-D4-01 非银融资占比变化
-- 公式: (本期非银占比) - (上期非银占比)
-- 非银 = 非银行类融资(含债券、委托、关联借款等)
-- 本 SQL 仅取本期快照,"变化"部分建议代理服务 2 次调用对比
WITH all_financing AS (
  /* 对外融资合同 */
  SELECT BILLTYPE AS ftype, NVL(LOANMNY, 0) AS amt, DAPPROVEDATE AS dt
  FROM CDMC_CONTRACT WHERE PK_ORG = :org_id AND DAPPROVEDATE <= :asof_date
  UNION ALL
  /* 内部融资合同 */
  SELECT NULL, NVL(LOANMNY, 0), DAPPROVEDATE
  FROM ICDMC_CONTRACT WHERE PK_ORG = :org_id AND DAPPROVEDATE <= :asof_date
  UNION ALL
  /* 债券 */
  SELECT NULL, NVL(REGISTMNY, 0), ISSUESTARTDATE
  FROM BOND_CONTRACT WHERE PK_ORG = :org_id AND ISSUESTARTDATE <= :asof_date
  UNION ALL
  /* 融资台账 */
  SELECT FINANCING_WAY, NVL(BALANCE, 0), BEGINDATE
  FROM BATM_FINANCING WHERE PK_ORG = :org_id AND BEGINDATE <= :asof_date
)
SELECT
  NVL(SUM(CASE WHEN ftype NOT IN ('BANK_LOAN') THEN amt END), 0) / NULLIF(SUM(amt), 0)
    AS non_bank_ratio
FROM all_financing;
-- TODO #NB-1: CDMC_CONTRACT.BILLTYPE 的"银行贷款"编码?BOND/ICDMC/BATM 默认算非银
-- TODO #NB-2: "变化"需两期对比,请代理服务对 :asof_date 和 :asof_date - 1 月分别调用
""" .

yql:Indicator_POST_D4_03 a yql:DARChange, yql:Indicator ;
    rdfs:label "资产负债率变化"@zh ;
    skos:notation "POST-D4-03" ;
    skos:definition """资产负债率的环比变化(快速攀升提示过度举债)""" ;
    yql:hasFormula """DebtToAssetRatio_current - DebtToAssetRatio_prior""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<=2pp" ;
    yql:amberThreshold "2-5pp" ;
    yql:redThreshold ">5pp" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- POST-D4-03 资产负债率变化
-- 公式: 本期资产负债率 - 上期
WITH r AS (
  SELECT
    PERIOD AS p,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '2%' AND LOCALCREDITAMOUNT > LOCALDEBITAMOUNT
                 THEN LOCALCREDITAMOUNT - LOCALDEBITAMOUNT END), 0) /
    NULLIF(NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '1%'
                          AND ACCOUNTCODE NOT LIKE '1231%' AND ACCOUNTCODE NOT LIKE '1407%'
                          AND ACCOUNTCODE NOT LIKE '1471%' AND ACCOUNTCODE NOT LIKE '1602%'
                          AND ACCOUNTCODE NOT LIKE '1702%'
                         THEN LOCALDEBITAMOUNT - LOCALCREDITAMOUNT END), 0), 0) AS ratio
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year
    AND PERIOD IN (:period, LPAD(TO_CHAR(TO_NUMBER(:period) - 1), 2, '0'))
  GROUP BY PERIOD
)
SELECT
  MAX(CASE WHEN p = :period THEN ratio END) -
  MAX(CASE WHEN p = LPAD(TO_CHAR(TO_NUMBER(:period) - 1), 2, '0') THEN ratio END)
  AS dar_change
FROM r;
""" .

yql:Indicator_POST_D5_03 a yql:PledgedARConcentration, yql:Indicator ;
    rdfs:label "质押应收集中度"@zh ;
    skos:notation "POST-D5-03" ;
    skos:definition """前 N 大买方质押应收占总质押的比例""" ;
    yql:hasFormula """SUM(TopN_Buyer_PledgedAR) / TotalPledgedAR (默认 N=3)""" ;
    yql:appliedInScenario scn:PostLoanMonitoring ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<50%" ;
    yql:amberThreshold "50-70%" ;
    yql:redThreshold ">70%" ;
    yql:usesTable ncc:AR_RECITEM, ncc:GPMC_GUACONTRACT, ncc:GPMC_GUAPLEINF ;
    yql:mapsToField ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__PK_ORG, ncc:AR_RECITEM__PK_RECITEM, ncc:GPMC_GUACONTRACT__BUSISTATUS, ncc:GPMC_GUACONTRACT__PK_GUACONTRACT, ncc:GPMC_GUAPLEINF__PK_GUACONTRACT, ncc:GPMC_GUAPLEINF__PK_SRCBILLROWID ;
    yql:hasSQL """
-- POST-D5-03 质押应收集中度(前3大质押应收客户占比)
-- 数据源: AR_RECITEM + BD_CUSTOMER + GPMC_GUACONTRACT + GPMC_GUAPLEINF
-- TODO #PL-1: GPMC_GUAPLEINF 与 AR_RECITEM 的关联字段?GUAPLEINF 有 PK_SRCBILL/PK_SRCBILLROWID,
--             需要 PK_SRCBILLROWID = AR_RECITEM.PK_RECITEM 且 PK_SRCBILLTYPEID = AR 单据类型
-- TODO #PL-2: 合同状态字段为 BUSISTATUS(数值)或 VBILLSTATUS(字符),枚举未知
WITH pledged_ar AS (
  SELECT ri.CUSTOMER, SUM(ri.LOCAL_MONEY_DE - ri.LOCAL_MONEY_BAL) AS amt
  FROM AR_RECITEM ri
  JOIN GPMC_GUAPLEINF gi ON gi.PK_SRCBILLROWID = ri.PK_RECITEM
  JOIN GPMC_GUACONTRACT gc ON gi.PK_GUACONTRACT = gc.PK_GUACONTRACT
  WHERE ri.PK_ORG = :org_id
    AND ri.BILLDATE <= LAST_DAY(TO_DATE(:year||'-'||:period||'-01','YYYY-MM-DD'))
    AND gc.BUSISTATUS = 1
  GROUP BY ri.CUSTOMER
),
top3 AS (SELECT CUSTOMER, amt FROM pledged_ar ORDER BY amt DESC FETCH FIRST 3 ROWS ONLY),
total AS (SELECT NVL(SUM(amt),0) AS amt FROM pledged_ar)
SELECT ROUND((SELECT NVL(SUM(amt),0) FROM top3) / NULLIF(total.amt, 0), 4)
  AS pledged_ar_concentration
FROM total;
""" .

yql:Indicator_PRE_D1_01 a yql:QuickRatio, yql:Indicator ;
    rdfs:label "速动比率"@zh ;
    skos:notation "PRE-D1-01" ;
    skos:definition """衡量企业立即变现资产偿付短期债务能力的稳健性指标""" ;
    yql:hasFormula """(CurrentAssets - Inventory - PrepaidExpenses) / CurrentLiabilities""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=1.0" ;
    yql:amberThreshold "0.7-1.0" ;
    yql:redThreshold "<0.7" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__CREDITAMOUNT, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D1-01 速动比率
-- 公式: (流动资产 - 存货 - 预付账款) / 流动负债
-- 数据源: GL_BALANCE + BD_ACCOUNT
-- 按客户提供的"流动资产完整规则"计算
-- TODO #GL-1: LOCALDEBITAMOUNT/CREDITAMOUNT 为累计余额(贵司确认为默认口径)
-- TODO #GL-2: GL_BALANCE 仅存末级明细(贵司确认的默认口径)
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
SELECT
  ROUND(
    (/* 流动资产(按客户规则)*/
NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1001%'
     OR ACCOUNTCODE LIKE '1002%' OR ACCOUNTCODE LIKE '1012%'
     OR ACCOUNTCODE LIKE '1101%' OR ACCOUNTCODE LIKE '1121%'
     OR ACCOUNTCODE LIKE '1122%' OR ACCOUNTCODE LIKE '1123%'
     OR ACCOUNTCODE LIKE '1131%' OR ACCOUNTCODE LIKE '1132%'
     OR ACCOUNTCODE LIKE '1221%' OR ACCOUNTCODE LIKE '1401%'
     OR ACCOUNTCODE LIKE '1402%' OR ACCOUNTCODE LIKE '1403%'
     OR ACCOUNTCODE LIKE '1404%' OR ACCOUNTCODE LIKE '1405%'
     OR ACCOUNTCODE LIKE '1406%' OR ACCOUNTCODE LIKE '1408%'
     OR ACCOUNTCODE LIKE '1411%' OR ACCOUNTCODE LIKE '1125%'
     OR ACCOUNTCODE LIKE '1126%'), 0)
- NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '1231%'
     OR ACCOUNTCODE LIKE '1407%' OR ACCOUNTCODE LIKE '1471%'), 0)
+ NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '3101%' AND net_debit_bal > 0), 0)
+ NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal > 0), 0)
    -
    /* 存货(按客户规则)*/
NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1401%'
     OR ACCOUNTCODE LIKE '1402%' OR ACCOUNTCODE LIKE '1403%' OR ACCOUNTCODE LIKE '1405%'
     OR ACCOUNTCODE LIKE '1406%' OR ACCOUNTCODE LIKE '1408%' OR ACCOUNTCODE LIKE '1411%'
     OR ACCOUNTCODE LIKE '1125%' OR ACCOUNTCODE LIKE '1126%'), 0)
+ NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1404%'), 0)
- NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '1407%' OR ACCOUNTCODE LIKE '1471%'), 0)
    -
    NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1123%'), 0)
    ) /
    NULLIF(/* 流动负债 */
NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2001%'
     OR ACCOUNTCODE LIKE '2101%' OR ACCOUNTCODE LIKE '2201%' OR ACCOUNTCODE LIKE '2202%'
     OR ACCOUNTCODE LIKE '2203%' OR ACCOUNTCODE LIKE '2204%' OR ACCOUNTCODE LIKE '2211%'
     OR ACCOUNTCODE LIKE '2241%'), 0)
+ NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal < 0), 0), 0),
    4
  ) AS quick_ratio
FROM dual;
-- TODO #CA-1: [1124] 流动部分需按到期日拆分
-- TODO #CA-2: 一年内到期非流动资产需 join CDMC/BOND 合同表
-- TODO #CA-3: 2202 供应商借方重分类到预付;1122 客户贷方重分类到流动负债
""" .

yql:Indicator_PRE_D1_02 a yql:CurrentRatio, yql:Indicator ;
    rdfs:label "流动比率"@zh ;
    skos:notation "PRE-D1-02" ;
    skos:definition """短期偿债能力基础指标""" ;
    yql:hasFormula """CurrentAssets / CurrentLiabilities""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=2.0" ;
    yql:amberThreshold "1.0-2.0" ;
    yql:redThreshold "<1.0" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D1-02 流动比率
-- 公式: 流动资产 / 流动负债
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
SELECT
  ROUND(
    (/* 流动资产(按客户规则)*/
NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1001%'
     OR ACCOUNTCODE LIKE '1002%' OR ACCOUNTCODE LIKE '1012%'
     OR ACCOUNTCODE LIKE '1101%' OR ACCOUNTCODE LIKE '1121%'
     OR ACCOUNTCODE LIKE '1122%' OR ACCOUNTCODE LIKE '1123%'
     OR ACCOUNTCODE LIKE '1131%' OR ACCOUNTCODE LIKE '1132%'
     OR ACCOUNTCODE LIKE '1221%' OR ACCOUNTCODE LIKE '1401%'
     OR ACCOUNTCODE LIKE '1402%' OR ACCOUNTCODE LIKE '1403%'
     OR ACCOUNTCODE LIKE '1404%' OR ACCOUNTCODE LIKE '1405%'
     OR ACCOUNTCODE LIKE '1406%' OR ACCOUNTCODE LIKE '1408%'
     OR ACCOUNTCODE LIKE '1411%' OR ACCOUNTCODE LIKE '1125%'
     OR ACCOUNTCODE LIKE '1126%'), 0)
- NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '1231%'
     OR ACCOUNTCODE LIKE '1407%' OR ACCOUNTCODE LIKE '1471%'), 0)
+ NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '3101%' AND net_debit_bal > 0), 0)
+ NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal > 0), 0)) /
    NULLIF(/* 流动负债 */
NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2001%'
     OR ACCOUNTCODE LIKE '2101%' OR ACCOUNTCODE LIKE '2201%' OR ACCOUNTCODE LIKE '2202%'
     OR ACCOUNTCODE LIKE '2203%' OR ACCOUNTCODE LIKE '2204%' OR ACCOUNTCODE LIKE '2211%'
     OR ACCOUNTCODE LIKE '2241%'), 0)
+ NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal < 0), 0), 0),
    4
  ) AS current_ratio
FROM dual;
-- TODO 同 PRE-D1-01
""" .

yql:Indicator_PRE_D1_03 a yql:InterestCoverageRatio, yql:Indicator ;
    rdfs:label "利息覆盖倍数 ICR"@zh ;
    skos:notation "PRE-D1-03" ;
    skos:definition """营业利润对利息费用的保障倍数""" ;
    yql:hasFormula """EBIT / InterestExpense, where EBIT = NetIncome + InterestExpense + IncomeTax""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=3.0" ;
    yql:amberThreshold "1.5-3.0" ;
    yql:redThreshold "<1.5" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D1-03 利息覆盖倍数 ICR
-- 公式: EBIT / 利息费用 = (净利润 + 利息费用 + 所得税) / 利息费用
-- 利息费用:默认取 6603(财务费用),精确口径应取 6603 下利息子科目
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
, pnl AS (
  SELECT
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0) AS revenue,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%' THEN net_debit_bal END), 0) AS cogs,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6403%' OR ACCOUNTCODE LIKE '6601%'
                   OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6604%' THEN net_debit_bal END), 0) AS op_exp,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6603%' THEN net_debit_bal END), 0) AS fin_exp,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6701%' OR ACCOUNTCODE LIKE '6702%' THEN net_debit_bal END), 0) AS impair,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%'
                   OR ACCOUNTCODE LIKE '6301%' THEN net_credit_bal END), 0) AS other_income,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6711%' THEN net_debit_bal END), 0) AS non_op_exp,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6801%' THEN net_debit_bal END), 0) AS income_tax
  FROM bal
)
SELECT ROUND(
  ((revenue - cogs - op_exp - fin_exp - impair + other_income - non_op_exp - income_tax) + fin_exp + income_tax)
  / NULLIF(fin_exp, 0), 4
) AS interest_coverage_ratio
FROM pnl;
-- TODO #IC-1: 利息费用精确口径需取 6603 下"利息支出"子科目(需查 GL_DETAIL)
""" .

yql:Indicator_PRE_D1_06 a yql:CashCoverageDays, yql:Indicator ;
    rdfs:label "现金覆盖天数"@zh ;
    skos:notation "PRE-D1-06" ;
    skos:definition """现金及等价物可支撑日常经营运转的天数(已剔除折摊等非现金成本)""" ;
    yql:hasFormula """CashAndEquivalents / ((TotalOperatingCost - DepreciationAmortization) / 365)""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=30" ;
    yql:amberThreshold "15-30" ;
    yql:redThreshold "<15" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D1-06 现金覆盖天数
-- 公式: 货币资金 / 日均现金支出
-- 日均现金支出 = (营业成本 + 期间费用 - 折旧摊销) / 365
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
SELECT ROUND(
  NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1001%'
       OR ACCOUNTCODE LIKE '1002%' OR ACCOUNTCODE LIKE '1012%'), 0)
  /
  NULLIF(
    (NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '6401%'
          OR ACCOUNTCODE LIKE '6402%' OR ACCOUNTCODE LIKE '6403%'
          OR ACCOUNTCODE LIKE '6601%' OR ACCOUNTCODE LIKE '6602%'
          OR ACCOUNTCODE LIKE '6603%' OR ACCOUNTCODE LIKE '6604%'), 0)
    - NVL((SELECT SUM(net_credit_bal) FROM bal
           WHERE ACCOUNTCODE LIKE '1602%' OR ACCOUNTCODE LIKE '1702%'), 0)
    ) / 365, 0),
  2
) AS cash_coverage_days
FROM dual;
-- TODO #CCD-1: 折旧摊销用 1602(累计折旧)+1702(累计摊销)贷方发生额近似
""" .

yql:Indicator_PRE_D2_01 a yql:EBITDAMargin, yql:Indicator ;
    rdfs:label "EBITDA利润率"@zh ;
    skos:notation "PRE-D2-01" ;
    skos:definition """剔除融资和折摊影响的核心经营利润率""" ;
    yql:hasFormula """EBITDA / Revenue""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=15%" ;
    yql:amberThreshold "5-15%" ;
    yql:redThreshold "<5%" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D2-01 EBITDA 利润率
-- EBITDA = 净利润 + 所得税 + 利息费用 + 折旧摊销
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
, pnl AS (
  SELECT
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0) AS revenue,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%' THEN net_debit_bal END), 0) AS cogs,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6403%' OR ACCOUNTCODE LIKE '6601%'
                   OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6604%' THEN net_debit_bal END), 0) AS op_exp,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6701%' OR ACCOUNTCODE LIKE '6702%' THEN net_debit_bal END), 0) AS impair,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%'
                   OR ACCOUNTCODE LIKE '6301%' THEN net_credit_bal END), 0) AS other_income,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6711%' THEN net_debit_bal END), 0) AS non_op_exp,
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '1602%' OR ACCOUNTCODE LIKE '1702%' THEN net_credit_bal END), 0) AS da
  FROM bal
)
SELECT ROUND(
  (revenue - cogs - op_exp - impair + other_income - non_op_exp + da)
  / NULLIF(revenue, 0), 4
) AS ebitda_margin
FROM pnl;
""" .

yql:Indicator_PRE_D2_02 a yql:CFOtoNIRatio, yql:Indicator ;
    rdfs:label "现金流/净利润比"@zh ;
    skos:notation "PRE-D2-02" ;
    skos:definition """利润含金量;持续<1 提示利润被应收/存货占用""" ;
    yql:hasFormula """OperatingCashFlow / NetIncome""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=1.0" ;
    yql:amberThreshold "0.7-1.0" ;
    yql:redThreshold "<0.7" ;
    yql:usesTable ncc:GL_BALANCE, ncc:GL_CASHFLOWCASE, ncc:GL_VOUCHER ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_VOUCHER__PERIOD, ncc:GL_VOUCHER__PK_VOUCHER, ncc:GL_VOUCHER__YEAR ;
    yql:hasSQL """
-- PRE-D2-02 经营现金流 / 净利润比
-- 公式: CFO / 净利润
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
, cfo AS (
  SELECT NVL(SUM(gc.MONEY), 0) AS amount
  FROM GL_CASHFLOWCASE gc
  JOIN GL_VOUCHER gv ON gc.PK_VOUCHER = gv.PK_VOUCHER
  WHERE gc.PK_ORG = :org_id AND gc.PK_ACCOUNTINGBOOK = :book_id
    AND gv.YEAR = :year AND gv.PERIOD = :period
  /* TODO #CF-2: PK_CASHFLOWCASE 经营活动识别 */
),
ni AS (
  SELECT
    (NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0)
   - NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%'
                    OR ACCOUNTCODE LIKE '6403%' OR ACCOUNTCODE LIKE '6601%'
                    OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6603%'
                    OR ACCOUNTCODE LIKE '6604%' OR ACCOUNTCODE LIKE '6701%'
                    OR ACCOUNTCODE LIKE '6702%' OR ACCOUNTCODE LIKE '6711%'
                    OR ACCOUNTCODE LIKE '6801%' THEN net_debit_bal END), 0)
   + NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%'
                    OR ACCOUNTCODE LIKE '6301%' THEN net_credit_bal END), 0)
    ) AS amount
  FROM bal
)
SELECT ROUND(cfo.amount / NULLIF(ni.amount, 0), 4) AS cfo_to_ni_ratio
FROM cfo, ni;
""" .

yql:Indicator_PRE_D2_04 a yql:GrossMargin, yql:Indicator ;
    rdfs:label "毛利率"@zh ;
    skos:notation "PRE-D2-04" ;
    skos:definition """主营业务的初步盈利能力""" ;
    yql:hasFormula """(Revenue - COGS) / Revenue""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=25%" ;
    yql:amberThreshold "10-25%" ;
    yql:redThreshold "<10%" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D2-04 毛利率
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
SELECT ROUND(
  (NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0)
 - NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%' THEN net_debit_bal END), 0)) /
  NULLIF(NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0), 0),
  4
) AS gross_margin
FROM bal;
""" .

yql:Indicator_PRE_D2_05 a yql:NetProfitMargin, yql:Indicator ;
    rdfs:label "净利润率"@zh ;
    skos:notation "PRE-D2-05" ;
    skos:definition """扣除全部成本费用税金后的最终盈利能力""" ;
    yql:hasFormula """NetIncome / Revenue""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=8%" ;
    yql:amberThreshold "3-8%" ;
    yql:redThreshold "<3%" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D2-05 净利润率
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
, pnl AS (
  SELECT
    NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0) AS revenue,
    (NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0)
   - NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%'
                    OR ACCOUNTCODE LIKE '6403%' OR ACCOUNTCODE LIKE '6601%'
                    OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6603%'
                    OR ACCOUNTCODE LIKE '6604%' OR ACCOUNTCODE LIKE '6701%'
                    OR ACCOUNTCODE LIKE '6702%' OR ACCOUNTCODE LIKE '6711%'
                    OR ACCOUNTCODE LIKE '6801%' THEN net_debit_bal END), 0)
   + NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%'
                    OR ACCOUNTCODE LIKE '6301%' THEN net_credit_bal END), 0)
    ) AS net_income
  FROM bal
)
SELECT ROUND(net_income / NULLIF(revenue, 0), 4) AS net_profit_margin FROM pnl;
""" .

yql:Indicator_PRE_D3_03 a yql:DebtToAssetRatio, yql:Indicator ;
    rdfs:label "资产负债率"@zh ;
    skos:notation "PRE-D3-03" ;
    skos:definition """企业总杠杆水平""" ;
    yql:hasFormula """TotalLiabilities / TotalAssets""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<60%" ;
    yql:amberThreshold "60-70%" ;
    yql:redThreshold ">70%" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D3-03 资产负债率
-- 公式: 总负债 / 总资产
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
SELECT ROUND(
  /* 总负债 = 2xxx 贷方余额 */
  NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2%' AND net_debit_bal < 0), 0)
  /
  NULLIF(
    /* 总资产 = 1xxx 借方净余额 - 坏账/跌价/商品差价(这些是减项)*/
    (NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1%'
          AND ACCOUNTCODE NOT LIKE '1231%' AND ACCOUNTCODE NOT LIKE '1407%'
          AND ACCOUNTCODE NOT LIKE '1471%' AND ACCOUNTCODE NOT LIKE '1602%'
          AND ACCOUNTCODE NOT LIKE '1702%'), 0)
    - NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal
           WHERE ACCOUNTCODE LIKE '1231%' OR ACCOUNTCODE LIKE '1407%'
              OR ACCOUNTCODE LIKE '1471%'), 0)), 0),
  4
) AS debt_to_asset_ratio FROM dual;
""" .

yql:Indicator_PRE_D3_04 a yql:EffectiveNetAssets, yql:Indicator ;
    rdfs:label "有效净资产"@zh ;
    skos:notation "PRE-D3-04" ;
    skos:definition """剔除虚资产和关联方应收后的可变现净资产口径""" ;
    yql:hasFormula """StockholdersEquity - IntangibleAssets - Goodwill - LongTermDeferredExpenses - DeferredTaxAssets - RelatedPartyAR""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:usesTable ncc:AR_RECITEM, ncc:BD_CUSTOMER, ncc:GL_BALANCE ;
    yql:mapsToField ncc:AR_RECITEM__BILLDATE, ncc:AR_RECITEM__CUSTOMER, ncc:AR_RECITEM__LOCAL_MONEY_BAL, ncc:AR_RECITEM__LOCAL_MONEY_DE, ncc:AR_RECITEM__PK_ORG, ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:BD_CUSTOMER__PK_CUSTOMER ;
    yql:hasSQL """
-- PRE-D3-04 有效净资产
-- 公式: 所有者权益 - 无形资产 - 商誉 - 长期待摊 - 递延税 - 关联方应收
-- TODO #RP-1: 关联方识别:BD_CUSTOMER 无专用"关联方"字段,默认用 DEF1='1' 或 INNERPROFITCENTER='Y'
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
, related_ar AS (
  SELECT NVL(SUM(ri.LOCAL_MONEY_DE - ri.LOCAL_MONEY_BAL), 0) AS amount
  FROM AR_RECITEM ri
  JOIN BD_CUSTOMER c ON ri.CUSTOMER = c.PK_CUSTOMER
  WHERE ri.PK_ORG = :org_id
    AND ri.BILLDATE <= LAST_DAY(TO_DATE(:year || '-' || :period || '-01', 'YYYY-MM-DD'))
    AND c.INNERPROFITCENTER = 'Y'
    /* TODO #RP-1: 关联方标识字段实际为?DEF1/DEF2/INNERPROFITCENTER 或需外部主数据 */
)
SELECT
  (NVL((SELECT SUM(net_credit_bal) FROM bal
        WHERE ACCOUNTCODE LIKE '4001%' OR ACCOUNTCODE LIKE '4002%'
           OR ACCOUNTCODE LIKE '4101%' OR ACCOUNTCODE LIKE '4104%'), 0)
 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '4201%'), 0)
 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1701%'
        OR ACCOUNTCODE LIKE '1702%' OR ACCOUNTCODE LIKE '1703%'), 0)
 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1711%'), 0)
 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1801%'), 0)
 - NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1811%'), 0)
 - rp.amount
  ) AS effective_net_assets
FROM related_ar rp;
""" .

yql:Indicator_PRE_D3_05 a yql:DaysInventoryOutstanding, yql:Indicator ;
    rdfs:label "存货周转天数"@zh ;
    skos:notation "PRE-D3-05" ;
    skos:definition """DIO,存货从采购到售出平均所需天数""" ;
    yql:hasFormula """AvgInventory / COGS * 365, where AvgInventory = (BeginInventory + EndInventory) / 2""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<60" ;
    yql:amberThreshold "60-90" ;
    yql:redThreshold ">90" ;
    yql:usesTable ncc:GL_BALANCE, ncc:IA_MONTHNAB ;
    yql:hasSQL """
-- PRE-D3-05 存货周转天数
-- 公式: 平均存货 / 营业成本 × 365
-- 数据源: IA_MONTHNAB(按 CACCOUNTPERIOD='YYYYMM' 取月末) + GL_BALANCE
WITH inv_end AS (
  SELECT NVL(SUM(NABMNY), 0) AS amount
  FROM IA_MONTHNAB
  WHERE PK_ORG = :org_id
    AND CACCOUNTPERIOD = :year || :period
),
inv_begin AS (
  SELECT NVL(SUM(NABMNY), 0) AS amount
  FROM IA_MONTHNAB
  WHERE PK_ORG = :org_id
    AND CACCOUNTPERIOD = TO_CHAR(ADD_MONTHS(TO_DATE(:year || :period, 'YYYYMM'), -1), 'YYYYMM')
),
cogs AS (
  SELECT NVL(SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT), 0) AS amount
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
    AND (ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%')
)
SELECT ROUND(((inv_end.amount + inv_begin.amount) / 2) / NULLIF(cogs.amount, 0) * 365, 2)
  AS days_inventory_outstanding
FROM inv_end, inv_begin, cogs;
-- TODO #INV-1: IA_MONTHNAB.CACCOUNTPERIOD 格式假设为 'YYYYMM',需贵司确认
""" .

yql:Indicator_PRE_D4_01 a yql:FreeCashFlow, yql:Indicator ;
    rdfs:label "自由现金流 FCF"@zh ;
    skos:notation "PRE-D4-01" ;
    skos:definition """企业可自由支配的现金流量;采用 FCFF 口径(若需 FCFE 加 NetBorrowing)""" ;
    yql:hasFormula """OperatingCashFlow - CapitalExpenditures (FCFF口径)""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">0" ;
    yql:amberThreshold "-1000-0万" ;
    yql:redThreshold "<-1000万" ;
    yql:usesTable ncc:GL_CASHFLOWCASE, ncc:GL_VOUCHER ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_CASHFLOWCASE, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_VOUCHER__PERIOD, ncc:GL_VOUCHER__PK_VOUCHER, ncc:GL_VOUCHER__YEAR ;
    yql:hasSQL """
-- PRE-D4-01 自由现金流 FCF
-- 公式: CFO - CapEx
-- 数据源: GL_CASHFLOWCASE + GL_VOUCHER
-- TODO #FCF-1: 需区分经营/投资/筹资活动,BD_CASHFLOW 表定义现金流项目分类
WITH all_cf AS (
  SELECT gc.PK_CASHFLOWCASE, NVL(SUM(gc.MONEY), 0) AS amount
  FROM GL_CASHFLOWCASE gc
  JOIN GL_VOUCHER gv ON gc.PK_VOUCHER = gv.PK_VOUCHER
  WHERE gc.PK_ORG = :org_id AND gc.PK_ACCOUNTINGBOOK = :book_id
    AND gv.YEAR = :year AND gv.PERIOD = :period
  GROUP BY gc.PK_CASHFLOWCASE
)
SELECT NVL(SUM(amount), 0) AS free_cash_flow
FROM all_cf;
-- TODO #FCF-2: 需基于 BD_CASHFLOW 表拆分 CFO 和 CapEx(CapEx 是投资活动下的"购建长期资产"子项)
-- 本 SQL 暂聚合所有现金流,具体拆分待补 BD_CASHFLOW 编码
""" .

yql:Indicator_PRE_D4_03 a yql:CapExToRevenueRatio, yql:Indicator ;
    rdfs:label "资本支出/营收比"@zh ;
    skos:notation "PRE-D4-03" ;
    skos:definition """资本开支强度;过高可能挤压自由现金流""" ;
    yql:hasFormula """CapitalExpenditures / Revenue""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<10%" ;
    yql:amberThreshold "10-20%" ;
    yql:redThreshold ">20%" ;
    yql:usesTable ncc:GL_BALANCE, ncc:GL_CASHFLOWCASE, ncc:GL_VOUCHER ;
    yql:mapsToField ncc:GL_CASHFLOWCASE__MONEY, ncc:GL_CASHFLOWCASE__PK_ACCOUNTINGBOOK, ncc:GL_CASHFLOWCASE__PK_ORG, ncc:GL_CASHFLOWCASE__PK_VOUCHER, ncc:GL_VOUCHER__PERIOD, ncc:GL_VOUCHER__PK_VOUCHER, ncc:GL_VOUCHER__YEAR ;
    yql:hasSQL """
-- PRE-D4-03 资本支出 / 营收比
-- 同 PRE-D4-01 的 TODO,CapEx 需基于 BD_CASHFLOW 分类
WITH capex AS (
  SELECT NVL(SUM(gc.MONEY), 0) AS amount
  FROM GL_CASHFLOWCASE gc
  JOIN GL_VOUCHER gv ON gc.PK_VOUCHER = gv.PK_VOUCHER
  WHERE gc.PK_ORG = :org_id AND gc.PK_ACCOUNTINGBOOK = :book_id
    AND gv.YEAR = :year AND gv.PERIOD = :period
  /* TODO: PK_CASHFLOWCASE 筛选"购建固定/无形/其他长期资产"相关项目 */
),
rev AS (
  SELECT NVL(SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT), 0) AS amount
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
    AND (ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%')
)
SELECT ROUND(capex.amount / NULLIF(rev.amount, 0), 4) AS capex_to_revenue_ratio
FROM capex, rev;
""" .

yql:Indicator_PRE_D4_05 a yql:CashRatio, yql:Indicator ;
    rdfs:label "现金比率"@zh ;
    skos:notation "PRE-D4-05" ;
    skos:definition """最严格的短期偿债能力指标""" ;
    yql:hasFormula """(CashAndEquivalents + TradingFinancialAssets) / CurrentLiabilities""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=0.3" ;
    yql:amberThreshold "0.1-0.3" ;
    yql:redThreshold "<0.1" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D4-05 现金比率
WITH bal AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE
  WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
)
SELECT ROUND(
  NVL((SELECT SUM(net_debit_bal) FROM bal WHERE ACCOUNTCODE LIKE '1001%'
       OR ACCOUNTCODE LIKE '1002%' OR ACCOUNTCODE LIKE '1012%'
       OR ACCOUNTCODE LIKE '1101%'), 0)
  / NULLIF(/* 流动负债 */
NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2001%'
     OR ACCOUNTCODE LIKE '2101%' OR ACCOUNTCODE LIKE '2201%' OR ACCOUNTCODE LIKE '2202%'
     OR ACCOUNTCODE LIKE '2203%' OR ACCOUNTCODE LIKE '2204%' OR ACCOUNTCODE LIKE '2211%'
     OR ACCOUNTCODE LIKE '2241%'), 0)
+ NVL((SELECT SUM(ABS(net_debit_bal)) FROM bal WHERE ACCOUNTCODE LIKE '2221%' AND net_debit_bal < 0), 0), 0),
  4
) AS cash_ratio FROM dual;
""" .

yql:Indicator_PRE_D5_03 a yql:TotalAssetTurnover, yql:Indicator ;
    rdfs:label "总资产周转率"@zh ;
    skos:notation "PRE-D5-03" ;
    skos:definition """总资产创造收入的效率""" ;
    yql:hasFormula """Revenue / AvgTotalAssets""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=1.0" ;
    yql:amberThreshold "0.5-1.0" ;
    yql:redThreshold "<0.5" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D5-03 总资产周转率
-- 公式: 营业收入 / 平均总资产
WITH end_ta AS (
  SELECT NVL(SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT), 0) AS amount
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period AND ACCOUNTCODE LIKE '1%'
    AND ACCOUNTCODE NOT LIKE '1231%' AND ACCOUNTCODE NOT LIKE '1407%'
    AND ACCOUNTCODE NOT LIKE '1471%' AND ACCOUNTCODE NOT LIKE '1602%'
    AND ACCOUNTCODE NOT LIKE '1702%'
),
begin_ta AS (
  SELECT NVL(SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT), 0) AS amount
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = LPAD(TO_CHAR(TO_NUMBER(:period) - 1), 2, '0')
    AND ACCOUNTCODE LIKE '1%'
    AND ACCOUNTCODE NOT LIKE '1231%' AND ACCOUNTCODE NOT LIKE '1407%'
    AND ACCOUNTCODE NOT LIKE '1471%' AND ACCOUNTCODE NOT LIKE '1602%'
    AND ACCOUNTCODE NOT LIKE '1702%'
),
rev AS (
  SELECT NVL(SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT), 0) AS amount
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
    AND (ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%')
)
SELECT ROUND(rev.amount / NULLIF((end_ta.amount + begin_ta.amount) / 2, 0), 4)
  AS total_asset_turnover
FROM end_ta, begin_ta, rev;
-- TODO #TURN-1: :period='01' 时期初应取上年 12 月(本 SQL 未处理跨年)
""" .

yql:Indicator_PRE_D5_04 a yql:ROE, yql:Indicator ;
    rdfs:label "净资产收益率 ROE"@zh ;
    skos:notation "PRE-D5-04" ;
    skos:definition """股东权益的回报率(分母用平均口径而非期末单点)""" ;
    yql:hasFormula """NetIncome / AvgStockholdersEquity, where Avg = (Begin + End) / 2""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=12%" ;
    yql:amberThreshold "5-12%" ;
    yql:redThreshold "<5%" ;
    yql:usesTable ncc:GL_BALANCE ;
    yql:mapsToField ncc:GL_BALANCE__ACCOUNTCODE, ncc:GL_BALANCE__LOCALCREDITAMOUNT, ncc:GL_BALANCE__LOCALDEBITAMOUNT, ncc:GL_BALANCE__PERIOD, ncc:GL_BALANCE__PK_ACCOUNTINGBOOK, ncc:GL_BALANCE__PK_ORG, ncc:GL_BALANCE__YEAR ;
    yql:hasSQL """
-- PRE-D5-04 净资产收益率 ROE
-- 公式: 净利润 / 平均所有者权益
WITH bal_end AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT) AS net_debit_bal,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
  GROUP BY ACCOUNTCODE
),
bal_begin AS (
  SELECT ACCOUNTCODE,
         SUM(LOCALCREDITAMOUNT - LOCALDEBITAMOUNT) AS net_credit_bal
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = LPAD(TO_CHAR(TO_NUMBER(:period) - 1), 2, '0')
  GROUP BY ACCOUNTCODE
),
ni AS (
  SELECT
    (NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6001%' OR ACCOUNTCODE LIKE '6051%' THEN net_credit_bal END), 0)
   - NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%'
                    OR ACCOUNTCODE LIKE '6403%' OR ACCOUNTCODE LIKE '6601%'
                    OR ACCOUNTCODE LIKE '6602%' OR ACCOUNTCODE LIKE '6603%'
                    OR ACCOUNTCODE LIKE '6604%' OR ACCOUNTCODE LIKE '6701%'
                    OR ACCOUNTCODE LIKE '6702%' OR ACCOUNTCODE LIKE '6711%'
                    OR ACCOUNTCODE LIKE '6801%' THEN net_debit_bal END), 0)
   + NVL(SUM(CASE WHEN ACCOUNTCODE LIKE '6111%' OR ACCOUNTCODE LIKE '6117%'
                    OR ACCOUNTCODE LIKE '6301%' THEN net_credit_bal END), 0)
    ) AS amount
  FROM bal_end
)
SELECT ROUND(
  ni.amount /
  NULLIF(((NVL((SELECT SUM(net_credit_bal) FROM bal_end WHERE ACCOUNTCODE LIKE '4%'), 0)
          + NVL((SELECT SUM(net_credit_bal) FROM bal_begin WHERE ACCOUNTCODE LIKE '4%'), 0)) / 2), 0),
  4
) AS roe FROM ni;
""" .

yql:Indicator_PRE_D6_01 a yql:CustomerConcentration, yql:Indicator ;
    rdfs:label "客户集中度"@zh ;
    skos:notation "PRE-D6-01" ;
    skos:definition """前 N 大客户营收占比,反映客户依赖风险""" ;
    yql:hasFormula """SUM(TopN_Customer_Revenue) / TotalRevenue (默认 N=3 或 N=5)""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<30%" ;
    yql:amberThreshold "30-50%" ;
    yql:redThreshold ">50%" ;
    yql:usesTable ncc:SO_SALEINVOICE ;
    yql:mapsToField ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__CINVOICECUSTVID, ncc:SO_SALEINVOICE__DBILLDATE, ncc:SO_SALEINVOICE__FSTATUSFLAG, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__PK_ORG ;
    yql:hasSQL """
-- PRE-D6-01 客户集中度(前5大客户销售额占比)
-- 数据源: SO_SALEINVOICE(发票主表)+ BD_CUSTOMER
-- TODO #CC-1: 客户ID字段为 CINVOICECUSTID(开票客户);另有 CINVOICECUSTVID(版本)
WITH sales_by_cust AS (
  SELECT si.CINVOICECUSTID AS cust_id, SUM(si.NTOTALORIGMNY) AS amt
  FROM SO_SALEINVOICE si
  WHERE si.PK_ORG = :org_id
    AND si.DBILLDATE BETWEEN TO_DATE(:year||'-01-01','YYYY-MM-DD') AND :asof_date
    AND si.FSTATUSFLAG = 1  /* 已审核,TODO #CC-2: 贵司 FSTATUSFLAG 具体枚举 */
  GROUP BY si.CINVOICECUSTID
),
top5 AS (SELECT cust_id, amt FROM sales_by_cust ORDER BY amt DESC FETCH FIRST 5 ROWS ONLY),
total AS (SELECT NVL(SUM(amt),0) AS amt FROM sales_by_cust)
SELECT ROUND((SELECT NVL(SUM(amt),0) FROM top5) / NULLIF(total.amt, 0), 4) AS customer_concentration
FROM total;
-- TODO #CC-3: NTOTALORIGMNY 为原币含税金额,本币口径建议取其他字段或 join 汇率
""" .

yql:Indicator_PRE_D6_02 a yql:SupplierConcentration, yql:Indicator ;
    rdfs:label "供应商集中度"@zh ;
    skos:notation "PRE-D6-02" ;
    skos:definition """前 N 大供应商采购占比,反映供应链依赖风险""" ;
    yql:hasFormula """SUM(TopN_Supplier_Purchase) / TotalPurchase""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<40%" ;
    yql:amberThreshold "40-60%" ;
    yql:redThreshold ">60%" ;
    yql:usesTable ncc:PO_INVOICE ;
    yql:mapsToField ncc:PO_INVOICE__DBILLDATE, ncc:PO_INVOICE__FBILLSTATUS, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__PK_ORG, ncc:PO_INVOICE__PK_SUPPLIER ;
    yql:hasSQL """
-- PRE-D6-02 供应商集中度(前5大供应商采购占比)
-- 数据源: PO_INVOICE + BD_SUPPLIER
WITH purch_by_sup AS (
  SELECT pi.PK_SUPPLIER AS sup_id, SUM(pi.NTOTALORIGMNY) AS amt
  FROM PO_INVOICE pi
  WHERE pi.PK_ORG = :org_id
    AND pi.DBILLDATE BETWEEN TO_DATE(:year||'-01-01','YYYY-MM-DD') AND :asof_date
    AND pi.FBILLSTATUS = 1  /* 已审核,TODO 贵司状态值 */
  GROUP BY pi.PK_SUPPLIER
),
top5 AS (SELECT sup_id, amt FROM purch_by_sup ORDER BY amt DESC FETCH FIRST 5 ROWS ONLY),
total AS (SELECT NVL(SUM(amt),0) AS amt FROM purch_by_sup)
SELECT ROUND((SELECT NVL(SUM(amt),0) FROM top5) / NULLIF(total.amt, 0), 4) AS supplier_concentration
FROM total;
""" .

yql:Indicator_PRE_D6_03 a yql:RelatedPartyARRatio, yql:Indicator ;
    rdfs:label "关联方应收占比"@zh ;
    skos:notation "PRE-D6-03" ;
    skos:definition """关联方应收占应收总额比例,过高提示利润操纵或资金占用风险""" ;
    yql:hasFormula """RelatedParty_AR_Balance / Total_AR_Balance""" ;
    yql:appliedInScenario scn:PreLoanDD ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<10%" ;
    yql:amberThreshold "10-30%" ;
    yql:redThreshold ">30%" ;
    yql:usesTable ncc:ARAP_BALANCE, ncc:BD_CUSTOMER ;
    yql:mapsToField ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__LOCAL_MONEY_CR, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__PK_ORG, ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:BD_CUSTOMER__PK_CUSTOMER ;
    yql:hasSQL """
-- PRE-D6-03 关联方应收占比
-- 公式: 关联方应收余额 / 总应收余额
-- TODO #RP-1: 关联方识别通过 BD_CUSTOMER.INNERPROFITCENTER='Y' 近似
WITH related_ar AS (
  SELECT NVL(SUM(ab.LOCAL_MONEY_DE - ab.LOCAL_MONEY_CR), 0) AS amount
  FROM ARAP_BALANCE ab
  JOIN BD_CUSTOMER c ON ab.CUSTOMER = c.PK_CUSTOMER
  WHERE ab.PK_ORG = :org_id
    AND ab.ACCYEAR = :year AND ab.ACCPERIOD = :period
    AND ab.BILLCLASS = 'AR'
    AND c.INNERPROFITCENTER = 'Y'
),
total_ar AS (
  SELECT NVL(SUM(LOCAL_MONEY_DE - LOCAL_MONEY_CR), 0) AS amount
  FROM ARAP_BALANCE
  WHERE PK_ORG = :org_id AND ACCYEAR = :year AND ACCPERIOD = :period
    AND BILLCLASS = 'AR'
)
SELECT ROUND(related_ar.amount / NULLIF(total_ar.amount, 0), 4) AS related_party_ar_ratio
FROM related_ar, total_ar;
-- TODO #RP-2: LOCAL_MONEY_BAL 为本币余额,LOCAL_MONEY_DE 为借方发生额
-- 应收余额应为 LOCAL_MONEY_DE - LOCAL_MONEY_CR 还是直接 LOCAL_MONEY_BAL?需核实
""" .

yql:Indicator_SCF_D1_07 a yql:RelatedPartyTxRatio, yql:Indicator ;
    rdfs:label "关联方交易占比"@zh ;
    skos:notation "SCF-D1-07" ;
    skos:definition """关联方交易额占总交易额比例""" ;
    yql:hasFormula """RelatedParty_TxnAmt / Total_TxnAmt""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<20%" ;
    yql:amberThreshold "20-40%" ;
    yql:redThreshold ">40%" ;
    yql:usesTable ncc:BD_CUSTOMER, ncc:BD_SUPPLIER, ncc:PO_INVOICE, ncc:SO_SALEINVOICE ;
    yql:mapsToField ncc:BD_CUSTOMER__INNERPROFITCENTER, ncc:BD_CUSTOMER__PK_CUSTOMER, ncc:BD_SUPPLIER__INNERPROFITCENTER, ncc:BD_SUPPLIER__PK_SUPPLIER, ncc:PO_INVOICE__DBILLDATE, ncc:PO_INVOICE__NTOTALORIGMNY, ncc:PO_INVOICE__PK_ORG, ncc:PO_INVOICE__PK_SUPPLIER, ncc:SO_SALEINVOICE__CINVOICECUSTID, ncc:SO_SALEINVOICE__DBILLDATE, ncc:SO_SALEINVOICE__NTOTALORIGMNY, ncc:SO_SALEINVOICE__PK_ORG ;
    yql:hasSQL """
-- SCF-D1-07 关联方交易占比
-- 公式: (关联方销售 + 关联方采购) / (总销售 + 总采购)
-- TODO #RP-1: 关联方识别用 INNERPROFITCENTER='Y' 近似
WITH sale AS (
  SELECT
    SUM(CASE WHEN c.INNERPROFITCENTER = 'Y' THEN si.NTOTALORIGMNY END) AS related,
    SUM(si.NTOTALORIGMNY) AS total
  FROM SO_SALEINVOICE si
  LEFT JOIN BD_CUSTOMER c ON si.CINVOICECUSTID = c.PK_CUSTOMER
  WHERE si.PK_ORG = :org_id
    AND si.DBILLDATE BETWEEN TO_DATE(:year||'-01-01','YYYY-MM-DD') AND :asof_date
),
purch AS (
  SELECT
    SUM(CASE WHEN s.INNERPROFITCENTER = 'Y' THEN pi.NTOTALORIGMNY END) AS related,
    SUM(pi.NTOTALORIGMNY) AS total
  FROM PO_INVOICE pi
  LEFT JOIN BD_SUPPLIER s ON pi.PK_SUPPLIER = s.PK_SUPPLIER
  WHERE pi.PK_ORG = :org_id
    AND pi.DBILLDATE BETWEEN TO_DATE(:year||'-01-01','YYYY-MM-DD') AND :asof_date
)
SELECT ROUND((NVL(sale.related,0) + NVL(purch.related,0)) /
             NULLIF(NVL(sale.total,0) + NVL(purch.total,0), 0), 4)
  AS related_party_transaction_ratio
FROM sale, purch;
""" .

yql:Indicator_SCF_D2_03 a yql:ARConcentration, yql:Indicator ;
    rdfs:label "应收账款集中度"@zh ;
    skos:notation "SCF-D2-03" ;
    skos:definition """前 N 大买方应收余额占总应收的比例""" ;
    yql:hasFormula """SUM(TopN_Customer_AR) / TotalAR (默认 N=3)""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<40%" ;
    yql:amberThreshold "40-60%" ;
    yql:redThreshold ">60%" ;
    yql:usesTable ncc:ARAP_BALANCE ;
    yql:mapsToField ncc:ARAP_BALANCE__ACCPERIOD, ncc:ARAP_BALANCE__ACCYEAR, ncc:ARAP_BALANCE__BILLCLASS, ncc:ARAP_BALANCE__CUSTOMER, ncc:ARAP_BALANCE__LOCAL_MONEY_CR, ncc:ARAP_BALANCE__LOCAL_MONEY_DE, ncc:ARAP_BALANCE__PK_ORG ;
    yql:hasSQL """
-- SCF-D2-03 应收账款集中度(前5大客户应收占比)
WITH ar_by_cust AS (
  SELECT CUSTOMER, SUM(LOCAL_MONEY_DE - LOCAL_MONEY_CR) AS amt
  FROM ARAP_BALANCE
  WHERE PK_ORG = :org_id AND ACCYEAR = :year AND ACCPERIOD = :period AND BILLCLASS = 'AR'
  GROUP BY CUSTOMER
),
top5 AS (SELECT CUSTOMER, amt FROM ar_by_cust ORDER BY amt DESC FETCH FIRST 5 ROWS ONLY),
total AS (SELECT NVL(SUM(amt),0) AS amt FROM ar_by_cust)
SELECT ROUND((SELECT NVL(SUM(amt),0) FROM top5) / NULLIF(total.amt, 0), 4) AS ar_concentration
FROM total;
-- TODO: ARAP_BALANCE 的"余额"字段验证(LOCAL_MONEY_DE 为借方发生,LOCAL_MONEY_BAL 为余额),
-- 应收余额= DE - BAL 还是直接取 BAL?需测试数据验证
""" .

yql:Indicator_SCF_D2_05 a yql:ARDisputeRate, yql:Indicator ;
    rdfs:label "应收账款争议率"@zh ;
    skos:notation "SCF-D2-05" ;
    skos:definition """存在争议的应收账款金额占比""" ;
    yql:hasFormula """Disputed_AR_Amount / Total_AR_Amount (依据工单系统标记)""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<2%" ;
    yql:amberThreshold "2-5%" ;
    yql:redThreshold ">5%" ;
    yql:usesTable ncc:AR_RECBILL ;
    yql:mapsToField ncc:AR_RECBILL__BILLPERIOD, ncc:AR_RECBILL__BILLSTATUS, ncc:AR_RECBILL__BILLYEAR, ncc:AR_RECBILL__DEF1, ncc:AR_RECBILL__LOCAL_MONEY, ncc:AR_RECBILL__PK_ORG, ncc:AR_RECBILL__SCOMMENT ;
    yql:hasSQL """
-- SCF-D2-05 应收账款争议率
-- TODO #DR-1: AR_RECBILL 无专用"争议"字段。候选方案:
--   A) BILLSTATUS 某些值表示争议(需贵司枚举字典)
--   B) DEF1-80 某列标注为"争议标志"
--   C) SCOMMENT 文本匹配关键词(不推荐)
-- 本 SQL 先以 BILLSTATUS NOT IN (1, 2) 作为"异常/争议"占位
WITH ar_by_status AS (
  SELECT
    SUM(CASE WHEN rb.BILLSTATUS NOT IN (1, 2) THEN rb.LOCAL_MONEY END) AS dispute_amt,
    SUM(rb.LOCAL_MONEY) AS total_amt
  FROM AR_RECBILL rb
  WHERE rb.PK_ORG = :org_id
    AND rb.BILLYEAR = :year AND rb.BILLPERIOD = :period
)
SELECT ROUND(NVL(dispute_amt,0) / NULLIF(NVL(total_amt,0), 0), 4) AS ar_dispute_rate
FROM ar_by_status;
-- TODO #DR-2: 本 SQL 只是占位逻辑,待贵司确认真正的"争议"标识字段后重写
""" .

yql:Indicator_SCF_D4_01 a yql:SupplierStability, yql:Indicator ;
    rdfs:label "供应商关系稳定性"@zh ;
    skos:notation "SCF-D4-01" ;
    skos:definition """年度供应商保留率,反映供应链稳定性""" ;
    yql:hasFormula """Suppliers_Both_Years / Suppliers_Prior_Year (年度保留率)""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:greenThreshold ">=90%" ;
    yql:amberThreshold "75-90%" ;
    yql:redThreshold "<75%" ;
    yql:usesTable ncc:BD_SUPPLIER, ncc:PO_ORDER ;
    yql:mapsToField ncc:BD_SUPPLIER__BEGINDATE, ncc:BD_SUPPLIER__PK_SUPPLIER ;
    yql:hasSQL """
-- SCF-D4-01 供应商关系稳定性
-- 公式: 合作≥2年的供应商数 / 活跃供应商数
-- 活跃:近 12 个月有订单;稳定:BD_SUPPLIER.BEGINDATE 早于 :asof_date - 24 月
WITH active_sup AS (
  SELECT DISTINCT PK_SUPPLIER FROM PO_ORDER
  WHERE PK_ORG = :org_id AND DBILLDATE >= ADD_MONTHS(:asof_date, -12)
),
stable_sup AS (
  SELECT s.PK_SUPPLIER
  FROM BD_SUPPLIER s
  WHERE s.PK_SUPPLIER IN (SELECT PK_SUPPLIER FROM active_sup)
    AND s.BEGINDATE <= TO_CHAR(ADD_MONTHS(:asof_date, -24), 'YYYY-MM-DD')
)
SELECT ROUND(
  (SELECT COUNT(*) FROM stable_sup) * 1.0 /
  NULLIF((SELECT COUNT(*) FROM active_sup), 0),
  4
) AS supplier_stability_ratio FROM dual;
-- TODO #SS-1: BD_SUPPLIER.BEGINDATE 类型为 CHAR(19),比较需类型处理
""" .

yql:Indicator_SCF_D4_04 a yql:DaysInventoryOutstanding, yql:Indicator ;
    rdfs:label "供应链库存周转天数"@zh ;
    skos:notation "SCF-D4-04" ;
    skos:definition """供应链场景的库存周转天数(与 PRE-D3-05 同公式,观察主体扩到链路)""" ;
    yql:hasFormula """AvgInventory / COGS * 365 (供应链全链路视角)""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<45" ;
    yql:amberThreshold "45-60" ;
    yql:redThreshold ">60" ;
    yql:usesTable ncc:GL_BALANCE, ncc:IA_MONTHNAB ;
    yql:hasSQL """
-- SCF-D4-04 供应链库存周转天数(同 PRE-D3-05 口径)
WITH inv_end AS (
  SELECT NVL(SUM(NABMNY), 0) AS amount
  FROM IA_MONTHNAB WHERE PK_ORG = :org_id
    AND CACCOUNTPERIOD = :year || :period
),
inv_begin AS (
  SELECT NVL(SUM(NABMNY), 0) AS amount
  FROM IA_MONTHNAB WHERE PK_ORG = :org_id
    AND CACCOUNTPERIOD = TO_CHAR(ADD_MONTHS(TO_DATE(:year || :period, 'YYYYMM'), -1), 'YYYYMM')
),
cogs AS (
  SELECT NVL(SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT), 0) AS amount
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
    AND (ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%')
)
SELECT ROUND(((inv_end.amount + inv_begin.amount) / 2) / NULLIF(cogs.amount, 0) * 365, 2)
  AS supply_chain_inventory_days
FROM inv_end, inv_begin, cogs;
""" .

yql:Indicator_SCF_D4_06 a yql:DPO, yql:Indicator ;
    rdfs:label "供应链DPO"@zh ;
    skos:notation "SCF-D4-06" ;
    skos:definition """应付账款周转天数 DPO""" ;
    yql:hasFormula """AvgAP / COGS * 365""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:greenThreshold "<60" ;
    yql:amberThreshold "60-90" ;
    yql:redThreshold ">90 (压款)" ;
    yql:usesTable ncc:AP_PAYABLEITEM, ncc:GL_BALANCE ;
    yql:mapsToField ncc:AP_PAYABLEITEM__BILLDATE, ncc:AP_PAYABLEITEM__PK_ORG ;
    yql:hasSQL """
-- SCF-D4-06 供应链 DPO(应付账款周转天数)
-- 公式: 平均应付 / 营业成本 × 365
WITH ap_end AS (
  SELECT NVL(SUM(LOCAL_MONEY_BAL), 0) AS amount
  FROM AP_PAYABLEITEM api
  WHERE api.PK_ORG = :org_id
    AND api.BILLDATE <= LAST_DAY(TO_DATE(:year||'-'||:period||'-01','YYYY-MM-DD'))
),
ap_begin AS (
  SELECT NVL(SUM(LOCAL_MONEY_BAL), 0) AS amount
  FROM AP_PAYABLEITEM api
  WHERE api.PK_ORG = :org_id
    AND api.BILLDATE <= LAST_DAY(ADD_MONTHS(TO_DATE(:year||'-'||:period||'-01','YYYY-MM-DD'), -1))
),
cogs AS (
  SELECT NVL(SUM(LOCALDEBITAMOUNT - LOCALCREDITAMOUNT), 0) AS amount
  FROM GL_BALANCE WHERE PK_ORG = :org_id AND PK_ACCOUNTINGBOOK = :book_id
    AND YEAR = :year AND PERIOD = :period
    AND (ACCOUNTCODE LIKE '6401%' OR ACCOUNTCODE LIKE '6402%')
)
SELECT ROUND(((ap_end.amount + ap_begin.amount) / 2) / NULLIF(cogs.amount, 0) * 365, 2)
  AS days_payable_outstanding
FROM ap_end, ap_begin, cogs;
-- TODO #DPO-1: LOCAL_MONEY_BAL 是应付余额字段名(已核对)
""" .

yql:Indicator_SCF_D4_07 a yql:SCFLoanHistory, yql:Indicator ;
    rdfs:label "供应链融资历史"@zh ;
    skos:notation "SCF-D4-07" ;
    skos:definition """历史供应链融资交易记录的结构化档案""" ;
    yql:hasFormula """复合记录:{TxnCount, CumulativeAmount, DefaultCount, OverdueCount, MaxYearsOfCooperation}""" ;
    yql:appliedInScenario scn:SupplyChainFinance ;
    yql:complexityTier "B" ;
    yql:usesTable ncc:CDMC_CONTRACT, ncc:CDMC_REPAYPRCPL ;
    yql:hasSQL """
-- SCF-D4-07 供应链融资历史(供应链融资笔数 + 按时还款率)
WITH loan_count AS (
  SELECT COUNT(DISTINCT PK_CONTRACT) AS cnt
  FROM CDMC_CONTRACT
  WHERE PK_ORG = :org_id
    AND DAPPROVEDATE BETWEEN TO_CHAR(ADD_MONTHS(:asof_date, -36), 'YYYY-MM-DD')
                         AND TO_CHAR(:asof_date, 'YYYY-MM-DD')
  /* TODO #SCF-1: 如何识别"供应链融资"?需 CDMC_CONTRACT.BILLTYPE 或 TRANSACTTYPE 枚举 */
),
repay_stats AS (
  SELECT
    COUNT(*) AS total_plans,
    SUM(CASE WHEN OVERDUEFLAG = 'N' OR OVERDUEFLAG IS NULL THEN 1 ELSE 0 END) AS on_time
  FROM CDMC_REPAYPRCPL
  WHERE PK_ORG = :org_id
    AND CALCUDATE BETWEEN TO_CHAR(ADD_MONTHS(:asof_date, -36), 'YYYY-MM-DD')
                      AND TO_CHAR(:asof_date, 'YYYY-MM-DD')
)
SELECT
  loan_count.cnt AS scf_loan_count,
  ROUND(repay_stats.on_time * 1.0 / NULLIF(repay_stats.total_plans, 0), 4) AS on_time_repay_ratio
FROM loan_count, repay_stats;
-- TODO #SCF-2: OVERDUEFLAG 值域:'Y'/'N' 还是 '0'/'1'?需确认
""" .


