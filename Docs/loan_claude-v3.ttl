# =============================================================================
# 信贷指标本体 v1.2 - A+B 档精简版(34 个可执行指标)
# 用友 YonBIP V3.0 NCC / FIBO 本体对齐 + yql 本地扩展
#
# 特性:
# 1. 包含 A+B 档 33 个 + 追加三表一致性(POST-D2-03),合计 34 个
# 2. NCC 表、字段含中文 rdfs:label
# 3. 每个指标内嵌 yql:hasSQL,代理服务 SPARQL 后直接 JDBC 执行
# 4. FIBO 白名单引用(v1.1 核验 0 幻觉)
# 5. SQL 字段 100% 对齐真实 NCC DDL
# =============================================================================

@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

@prefix fibo-fbc-dae-dbt:  <https://spec.edmcouncil.org/fibo/ontology/FBC/DebtAndEquities/Debt/> .
@prefix fibo-fbc-pas-fpas: <https://spec.edmcouncil.org/fibo/ontology/FBC/ProductsAndServices/FinancialProductsAndServices/> .
@prefix fibo-fnd-acc-cur:  <https://spec.edmcouncil.org/fibo/ontology/FND/Accounting/CurrencyAmount/> .
@prefix fibo-fnd-agr-ctr:  <https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Contracts/> .
@prefix fibo-fnd-arr-rt:   <https://spec.edmcouncil.org/fibo/ontology/FND/Arrangements/Ratios/> .
@prefix fibo-fnd-pas-psch: <https://spec.edmcouncil.org/fibo/ontology/FND/ProductsAndServices/PaymentsAndSchedules/> .

@prefix yql:     <http://yql.example.com/ontology/credit-risk/> .
@prefix ncc:     <http://yql.example.com/ontology/ncc-mapping/> .
@prefix scn:     <http://yql.example.com/ontology/scenario/> .
@prefix acc:     <http://yql.example.com/ontology/account-code/> .

# -------------------- Ontology 元数据 --------------------
<http://yql.example.com/ontology/credit-risk/v1.2> a owl:Ontology ;
    dcterms:title "信贷指标本体 v1.2 - A+B 档精简版(34 指标)"@zh ;
    owl:versionInfo "1.2.0" ;
    dcterms:created "2026-04-21"^^xsd:date .

# -------------------- 顶层类 --------------------
yql:Indicator a owl:Class ; rdfs:label "信贷指标"@zh .
yql:Ratio a owl:Class ; rdfs:subClassOf yql:Indicator, fibo-fnd-arr-rt:Ratio ; rdfs:label "比率指标"@zh .
yql:Days a owl:Class ; rdfs:subClassOf yql:Indicator ; rdfs:label "天数指标"@zh .
yql:ChangeRate a owl:Class ; rdfs:subClassOf yql:Indicator ; rdfs:label "变化率指标"@zh .
yql:Concentration a owl:Class ; rdfs:subClassOf yql:Indicator ; rdfs:label "集中度指标"@zh .
yql:Amount a owl:Class ; rdfs:subClassOf yql:Indicator, fibo-fnd-acc-cur:MonetaryAmount ; rdfs:label "金额指标"@zh .

yql:NCCTable a owl:Class ; rdfs:label "NCC 物理表"@zh .
yql:NCCField a owl:Class ; rdfs:label "NCC 物理字段"@zh .
yql:AccountCode a owl:Class ; rdfs:label "会计科目编码"@zh .
yql:Scenario a owl:Class ; rdfs:label "应用场景"@zh .

# -------------------- 对象属性 --------------------
yql:belongsToTable a owl:ObjectProperty ; rdfs:label "所属表"@zh ;
    rdfs:domain yql:NCCField ; rdfs:range yql:NCCTable .
yql:mapsToField a owl:ObjectProperty ; rdfs:label "映射到字段"@zh ;
    rdfs:domain yql:Indicator ; rdfs:range yql:NCCField .
yql:usesTable a owl:ObjectProperty ; rdfs:label "引用表"@zh ;
    rdfs:domain yql:Indicator ; rdfs:range yql:NCCTable .
yql:appliedInScenario a owl:ObjectProperty ; rdfs:label "应用场景"@zh ;
    rdfs:range yql:Scenario .
yql:usesAccountCode a owl:ObjectProperty ; rdfs:label "使用科目"@zh ;
    rdfs:range yql:AccountCode .

# -------------------- 数据属性 --------------------
yql:hasFormula a owl:DatatypeProperty ; rdfs:label "计算公式"@zh ; rdfs:range xsd:string .
yql:hasSQL a owl:DatatypeProperty ; rdfs:label "可执行 SQL"@zh ;
    rdfs:comment "代理服务 SPARQL 查出后直接 JDBC 执行"@zh ; rdfs:range xsd:string .
yql:tableCode a owl:DatatypeProperty ; rdfs:label "表英文代码"@zh ; rdfs:range xsd:string .
yql:fieldCode a owl:DatatypeProperty ; rdfs:label "字段英文代码"@zh ; rdfs:range xsd:string .
yql:fieldType a owl:DatatypeProperty ; rdfs:label "字段类型"@zh ; rdfs:range xsd:string .
yql:complexityTier a owl:DatatypeProperty ; rdfs:label "复杂度档位"@zh ; rdfs:range xsd:string .
yql:greenThreshold a owl:DatatypeProperty ; rdfs:label "绿灯阈值"@zh ; rdfs:range xsd:string .
yql:amberThreshold a owl:DatatypeProperty ; rdfs:label "黄灯阈值"@zh ; rdfs:range xsd:string .
yql:redThreshold a owl:DatatypeProperty ; rdfs:label "红灯阈值"@zh ; rdfs:range xsd:string .
yql:unit a owl:DatatypeProperty ; rdfs:label "单位"@zh ; rdfs:range xsd:string .
yql:accountCodeValue a owl:DatatypeProperty ; rdfs:label "科目编码值"@zh ; rdfs:range xsd:string .

# -------------------- 应用场景 --------------------
scn:PreLoanDD a yql:Scenario ; rdfs:label "贷前尽调"@zh .
scn:PostLoanMonitoring a yql:Scenario ; rdfs:label "贷后监控"@zh .
scn:SupplyChainFinance a yql:Scenario ; rdfs:label "供应链金融"@zh .


# -------------------- 会计科目编码 --------------------
