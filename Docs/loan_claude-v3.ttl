# -------------------- NCC 字段 --------------------
ncc:AP_PAYABLEITEM__BILLDATE a yql:NCCField ;
    rdfs:label "应付单明细表.日期"@zh ;
    skos:prefLabel "日期"@zh ;
    yql:fieldCode "BILLDATE" ;
    yql:fieldType "CHAR(19)" ;
    yql:belongsToTable ncc:AP_PAYABLEITEM .
ncc:AP_PAYABLEITEM__PK_ORG a yql:NCCField ;
    rdfs:label "应付单明细表.组织"@zh ;
    skos:prefLabel "组织"@zh ;
