# -------------------- 指标子类 --------------------
yql:QuickRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "速动比率"@zh .
yql:CurrentRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "流动比率"@zh .
yql:CashRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "现金比率"@zh .
yql:InterestCoverageRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "利息覆盖倍数"@zh .
yql:CashCoverageDays a owl:Class ;
    rdfs:subClassOf yql:Days ;
    rdfs:label "现金覆盖天数"@zh .
yql:EBITDAMargin a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "EBITDA利润率"@zh .
yql:GrossMargin a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "毛利率"@zh .
yql:NetProfitMargin a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "净利润率"@zh .
yql:CFOtoNIRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "经营现金流净利润比"@zh .
yql:DebtToAssetRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "资产负债率"@zh .
yql:EffectiveNetAssets a owl:Class ;
    rdfs:subClassOf yql:Amount ;
    rdfs:label "有效净资产"@zh .
yql:DaysInventoryOutstanding a owl:Class ;
    rdfs:subClassOf yql:Days ;
    rdfs:label "存货周转天数"@zh .
yql:FreeCashFlow a owl:Class ;
    rdfs:subClassOf yql:Amount ;
    rdfs:label "自由现金流"@zh .
yql:CapExToRevenueRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "资本支出营收比"@zh .
yql:TotalAssetTurnover a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "总资产周转率"@zh .
yql:ROE a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "净资产收益率"@zh .
yql:CustomerConcentration a owl:Class ;
    rdfs:subClassOf yql:Concentration ;
    rdfs:label "客户集中度"@zh .
yql:SupplierConcentration a owl:Class ;
    rdfs:subClassOf yql:Concentration ;
    rdfs:label "供应商集中度"@zh .
yql:RelatedPartyARRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "关联方应收占比"@zh .
yql:RelatedPartyTxRatio a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "关联方交易占比"@zh .
yql:ARConcentration a owl:Class ;
    rdfs:subClassOf yql:Concentration ;
    rdfs:label "应收集中度"@zh .
yql:ARDisputeRate a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "应收争议率"@zh .
yql:SupplierStability a owl:Class ;
    rdfs:subClassOf yql:Ratio ;
    rdfs:label "供应商稳定性"@zh .
yql:DPO a owl:Class ;
    rdfs:subClassOf yql:Days ;
    rdfs:label "应付账款周转天数"@zh .
yql:SCFLoanHistory a owl:Class ;
    rdfs:subClassOf yql:Indicator ;
    rdfs:label "供应链融资历史"@zh .
