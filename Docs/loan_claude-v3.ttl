# SELECT ?sql WHERE { ?ind skos:notation "PRE-D1-01" ; yql:hasSQL ?sql . }
#
# 示例 2: 某场景下所有指标 + SQL
# PREFIX yql: <http://yql.example.com/ontology/credit-risk/>
# PREFIX scn: <http://yql.example.com/ontology/scenario/>
# SELECT ?id ?name ?sql WHERE {
#   ?ind a yql:Indicator ; yql:appliedInScenario scn:PreLoanDD ;
#        skos:notation ?id ; rdfs:label ?name ; yql:hasSQL ?sql . }
#
# 示例 3: 列出指标引用的字段(中文标签)
# SELECT ?field_label WHERE {
#   yql:Indicator_PRE_D1_01 yql:mapsToField ?f .
#   ?f rdfs:label ?field_label . }
