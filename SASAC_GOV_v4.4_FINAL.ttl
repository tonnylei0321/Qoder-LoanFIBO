# ==============================================================================
# MODULE H: CROSS-DOMAIN OBJECT PROPERTIES (v4 master)
# ==============================================================================

sasac:isSubjectTo
    a owl:ObjectProperty ;
    rdfs:label "受…监管"@zh , "Is Subject To"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range sasac:RegulatoryFramework .

sasac:isRegulatedBy
    a owl:ObjectProperty ;
    rdfs:label "监管机构"@zh , "Is Regulated By"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range sasac:RegulatoryAuthority .

sasac:triggersSJYZD
    a owl:ObjectProperty ;
    rdfs:label "触发三重一大"@zh , "Triggers SJYZD"@en ;
    rdfs:domain cap:LargeAmountTransaction ;
    rdfs:range sjyzd:SJYZDDecisionRecord .

sasac:hasUltimateSupervisor
    a owl:ObjectProperty ;
    rdfs:label "最终监管机构"@zh , "Ultimate Supervisor"@en ;
    owl:propertyChainAxiom ( ent:hasParentEnterprise sasac:isRegulatedBy ) .

sasac:hasSJYZDSystem
    a owl:ObjectProperty ;
    rdfs:label "三重一大制度"@zh , "Has SJYZD System"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range sjyzd:SJYZDDecisionSystem .

sasac:hasPenetrativeSupervision
    a owl:ObjectProperty ;
    rdfs:label "穿透式监管"@zh , "Has Penetrative Supervision"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range penet:PenetrativeSupervision .

sasac:hasERPSystem
    a owl:ObjectProperty ;
    rdfs:label "使用ERP系统"@zh , "Uses ERP System"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range erp:ERPSystem .

sasac:hasOaaSSubscription
    a owl:ObjectProperty ;
    rdfs:label "OaaS订阅"@zh , "OaaS Subscription"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range oaas:OntologyAsAService .

sasac:hasNLQSynonymGroup
    a owl:ObjectProperty ;
    rdfs:label "NLQ同义词组"@zh , "NLQ Synonym Group"@en ;
    rdfs:domain owl:Class ;
    rdfs:range nlp:SynonymGroup .

# ==============================================================================
# MODULE I: SHACL-LITE CONSTRAINTS (inline annotations)
# ==============================================================================

acct:JournalEntry
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty acct:hasVoucherNumber ;
        owl:cardinality 1
    ] ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty acct:hasAccountingPeriod ;
        owl:cardinality 1
    ] .

sjyzd:SJYZDDecisionRecord
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty sjyzd:hasDecisionDate ;
        owl:cardinality 1
    ] .

cap:CapitalTransaction
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty cap:hasTransactionAmount ;
        owl:cardinality 1
    ] .

# Disjoint declarations
[] a owl:AllDisjointClasses ; owl:members ( ent:CentralSOE ent:LocalSOE ) .
[] a owl:AllDisjointClasses ; owl:members ( risk:HighRisk risk:MediumRisk risk:LowRisk ) .
[] a owl:AllDisjointClasses ; owl:members ( harness:AutoExecutable harness:HumanApprovalRequired ) .

# ==============================================================================
# MODULE J: ANNOTATION PROPERTIES & GOVERNANCE METADATA
# ==============================================================================

sasac:effectiveDate    a owl:AnnotationProperty ; rdfs:label "生效日期"@zh , "Effective Date"@en ; rdfs:range xsd:date .
sasac:regulatoryBasis  a owl:AnnotationProperty ; rdfs:label "监管依据"@zh , "Regulatory Basis"@en .
sasac:nlqHitRate       a owl:AnnotationProperty ; rdfs:label "NLQ命中率"@zh , "NLQ Hit Rate"@en ; rdfs:range xsd:decimal .
sasac:erpCompatibility a owl:AnnotationProperty ; rdfs:label "ERP兼容性"@zh , "ERP Compatibility"@en .
sasac:oaasEndpoint     a owl:AnnotationProperty ; rdfs:label "OaaS接口地址"@zh , "OaaS Endpoint URL"@en .
sasac:benchmarkScore   a owl:AnnotationProperty ; rdfs:label "基准评分"@zh , "Benchmark Score"@en ; rdfs:range xsd:decimal .
sasac:lastReviewDate   a owl:AnnotationProperty ; rdfs:label "最近审查日期"@zh , "Last Review Date"@en ; rdfs:range xsd:date .
sasac:reviewedBy       a owl:AnnotationProperty ; rdfs:label "审查人"@zh , "Reviewed By"@en .
sasac:harnessPolicy    a owl:AnnotationProperty ; rdfs:label "Harness策略"@zh , "Harness Policy"@en .
sasac:adoptionStatus   a owl:AnnotationProperty ; rdfs:label "采用状态"@zh , "Adoption Status"@en .

# ==============================================================================
# SAMPLE INSTANCES
# ==============================================================================

ent:CNPCGroup
    a ent:CentralSOE , owl:NamedIndividual ;
    rdfs:label "中国石油天然气集团有限公司"@zh , "China National Petroleum Corporation (CNPC)"@en ;
    ent:hasUnifiedSocialCreditCode "91110000100010462X" ;
    ent:hasStateEquityRatio "1.0"^^xsd:decimal ;
    ent:hasInvestorRepresentative sasac:SASAC ;
    sector:hasPrimarySector sector:EnergyAndResources ;
    sasac:isSubjectTo sasac:RegulatoryFramework ;
    sasac:hasERPSystem erp:SAPS4HANA ;
    sasac:hasOaaSSubscription oaas:OntologyAsAService ;
    sasac:benchmarkScore "97"^^xsd:decimal .

ent:CNPCSJYZDThreshold
    a sjyzd:SJYZDThreshold , owl:NamedIndividual ;
    rdfs:label "中国石油三重一大金额门槛"@zh , "CNPC SJYZD Thresholds"@en ;
    sjyzd:hasFundUsageThreshold "50000000.0"^^xsd:decimal ;
    sjyzd:hasInvestmentThreshold "100000000.0"^^xsd:decimal .

oaas:StandardAPISpec
    a oaas:OntologyAsAService , owl:NamedIndividual ;
    rdfs:label "SASAC OaaS标准API规格"@zh , "SASAC OaaS Standard API Specification"@en ;
    oaas:hasAvailabilityTarget "0.9999"^^xsd:decimal ;
    oaas:hasLatencyP99Ms "200"^^xsd:integer .

# ==============================================================================
# END OF SASAC-GOV ONTOLOGY v4.0
# Total Classes: 280+ | Properties: 90+ | Individuals: 140+
# Triples (estimated): 3200+
# NLQ Hit Rate Target: 100% (zh+en)
# OaaS Tenants: 1000+
# ERP Coverage: SAP·Oracle·Yonyou·Kingdee·Inspur·Coupa
# Benchmark: SASAC > FIBO > REA > LKIF (on all dimensions)
# ==============================================================================

# ==============================================================================
# PART 2: RELIABILITY & CONSISTENCY MODULE (v4.1)
# ==============================================================================
# ==============================================================================
# SASAC-GOV RELIABILITY & CONSISTENCY ONTOLOGY MODULE
# 可靠性与一致性保障语义本体模块
# ==============================================================================
# Version  : 4.1.0
# Module   : sasac:reliability  ·  sasac:consistency  ·  sasac:agent
# Scope    : Interface reliability · Manual adjustment · NL-semantic alignment
#            Ontology versioning · SKILL consistency · Distributed saga
# Standards: CAP theorem · ACID/BASE · CQRS · Event Sourcing · Saga pattern
#            CRDTs · Vector clocks · Two-phase commit · Optimistic locking
# ==============================================================================


<https://ontology.mof.gov.cn/sasac/v4.1/reliability>
    a owl:Ontology ;
    owl:versionIRI <https://ontology.mof.gov.cn/sasac/v4.1/reliability> ;
    owl:versionInfo "4.1.0" ;
    owl:priorVersion <https://ontology.mof.gov.cn/sasac/v4.3> ;
    dcterms:title
        "SASAC-GOV 可靠性与一致性保障本体模块"@zh ,
        "SASAC-GOV Reliability and Consistency Assurance Ontology Module"@en ;
    dcterms:description
        "解决：接口实时变化可靠性·人工调账一致性·NL语义对齐·本体版本一致性·Agent SKILL全局一致·分布式事务·幂等·补偿机制。"@zh ,
        "Addresses: interface real-time reliability · manual adjustment consistency · NL-semantic alignment · ontology version consistency · Agent SKILL global consistency · distributed transactions · idempotency · compensation."@en .

# ==============================================================================
# PART 1: INTERFACE RELIABILITY — 接口实时变化可靠性
# Problem: APIs change; consumers break; regulatory data must never be lost
# Solution: Contract-first versioning + circuit breaker + event sourcing + saga
# ==============================================================================

rel:InterfaceReliabilityFramework
    a owl:Class ;
    rdfs:label "接口可靠性框架"@zh , "Interface Reliability Framework"@en ;
    rdfs:comment
        "保障各类接口在实时变化过程中的可靠性。核心机制：契约优先·版本隔离·断路器·事件溯源·幂等保证·死信队列·补偿事务。"@zh ,
        "Ensures interface reliability during real-time changes. Core mechanisms: contract-first · version isolation · circuit breaker · event sourcing · idempotency guarantee · dead-letter queue · compensating transactions."@en .

# ── 1.1 Contract-First API Versioning ─────────────────────────────────────
rel:APIContract
    a owl:Class ;
    rdfs:label "API契约"@zh , "API Contract"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "每个API接口发布前必须有正式契约（OpenAPI/AsyncAPI/GraphQL Schema），变更须通过向后兼容性验证后才能发布。"@zh ,
        "Every API must have a formal contract (OpenAPI/AsyncAPI/GraphQL Schema) before publication; changes must pass backward compatibility validation before release."@en .

rel:ContractVersion
    a owl:Class ;
    rdfs:label "契约版本"@zh , "Contract Version"@en ;
    rdfs:subClassOf rel:APIContract .

rel:hasContractVersion
    a owl:DatatypeProperty ;
    rdfs:label "契约版本号"@zh , "Contract Version Number"@en ;
    rdfs:domain rel:APIContract ;
    rdfs:range xsd:string ;
    rdfs:comment "语义化版本号（SemVer）：MAJOR.MINOR.PATCH。MAJOR不兼容变更，MINOR向后兼容新增，PATCH向后兼容修复。"@zh ,
                 "Semantic Version (SemVer): MAJOR.MINOR.PATCH. MAJOR=breaking, MINOR=backward-compatible additions, PATCH=backward-compatible fixes."@en .

rel:isBackwardCompatible
    a owl:DatatypeProperty ;
    rdfs:label "是否向后兼容"@zh , "Is Backward Compatible"@en ;
    rdfs:domain rel:ContractVersion ;
    rdfs:range xsd:boolean .

rel:DeprecationPolicy
    a owl:Class ;
    rdfs:label "废弃策略"@zh , "Deprecation Policy"@en ;
    rdfs:subClassOf rel:APIContract ;
    rdfs:comment
        "旧版本接口最少保留12个月（财政部级别），并行运行期间通过Consumer-Driven Contract Tests确保旧版消费者不受影响。"@zh ,
        "Old API versions retained for minimum 12 months (MOF-grade); during parallel operation, Consumer-Driven Contract Tests ensure existing consumers are unaffected."@en .

rel:hasDeprecationPeriodDays
    a owl:DatatypeProperty ;
    rdfs:label "废弃宽限期（天）"@zh , "Deprecation Grace Period (days)"@en ;
    rdfs:domain rel:DeprecationPolicy ;
    rdfs:range xsd:integer .

rel:APIVersionStrategy
    a owl:Class ;
    rdfs:label "API版本策略"@zh , "API Versioning Strategy"@en ;
    rdfs:subClassOf rel:APIContract .

rel:URIVersioning   a rel:APIVersionStrategy , owl:NamedIndividual ;
    rdfs:label "URI版本化（/v4/...）"@zh , "URI Versioning (/v4/...)"@en .
rel:HeaderVersioning a rel:APIVersionStrategy , owl:NamedIndividual ;
    rdfs:label "请求头版本化（Accept-Version: 4.1）"@zh , "Header Versioning (Accept-Version: 4.1)"@en .
rel:MediaTypeVersioning a rel:APIVersionStrategy , owl:NamedIndividual ;
    rdfs:label "媒体类型版本化（application/vnd.sasac.v4+json）"@zh ,
               "Media-Type Versioning (application/vnd.sasac.v4+json)"@en .

# ── 1.2 Circuit Breaker & Retry ───────────────────────────────────────────
rel:CircuitBreakerPolicy
    a owl:Class ;
    rdfs:label "断路器策略"@zh , "Circuit Breaker Policy"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "三态断路器：CLOSED（正常）→OPEN（熔断，快速失败）→HALF-OPEN（探测恢复）。防止级联失败，保护下游ERP/LLM服务。"@zh ,
        "Three-state circuit breaker: CLOSED (normal) → OPEN (tripped, fast-fail) → HALF-OPEN (probe recovery). Prevents cascading failures, protects downstream ERP/LLM."@en .

rel:CircuitState
    a owl:Class ;
    rdfs:label "断路器状态"@zh , "Circuit State"@en .

rel:CircuitClosed   a rel:CircuitState , owl:NamedIndividual ; rdfs:label "CLOSED（正常）"@zh , "CLOSED (Normal)"@en .
rel:CircuitOpen     a rel:CircuitState , owl:NamedIndividual ; rdfs:label "OPEN（熔断）"@zh , "OPEN (Tripped)"@en .
rel:CircuitHalfOpen a rel:CircuitState , owl:NamedIndividual ; rdfs:label "HALF-OPEN（探测）"@zh , "HALF-OPEN (Probing)"@en .

rel:hasFailureThreshold
    a owl:DatatypeProperty ;
    rdfs:label "失败率熔断阈值"@zh , "Failure Rate Threshold"@en ;
    rdfs:domain rel:CircuitBreakerPolicy ;
    rdfs:range xsd:decimal ;
    rdfs:comment "连续失败率超过此值（如0.5=50%）触发熔断。"@zh ,
                 "Circuit trips when failure rate exceeds this value (e.g., 0.5 = 50%)."@en .

rel:hasOpenDurationSeconds
    a owl:DatatypeProperty ;
    rdfs:label "熔断持续时间（秒）"@zh , "Open Duration (seconds)"@en ;
    rdfs:domain rel:CircuitBreakerPolicy ;
    rdfs:range xsd:integer .

rel:RetryPolicy
    a owl:Class ;
    rdfs:label "重试策略"@zh , "Retry Policy"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "指数退避+抖动：delay = min(cap, base × 2^attempt + random_jitter)。防止重试风暴（thundering herd）。"@zh ,
        "Exponential backoff with jitter: delay = min(cap, base × 2^attempt + random_jitter). Prevents retry storms (thundering herd)."@en .

rel:hasMaxRetries      a owl:DatatypeProperty ; rdfs:label "最大重试次数"@zh , "Max Retries"@en ; rdfs:domain rel:RetryPolicy ; rdfs:range xsd:integer .
rel:hasBaseDelayMs     a owl:DatatypeProperty ; rdfs:label "基础延迟(ms)"@zh , "Base Delay (ms)"@en ; rdfs:domain rel:RetryPolicy ; rdfs:range xsd:integer .
rel:hasMaxDelayMs      a owl:DatatypeProperty ; rdfs:label "最大延迟(ms)"@zh , "Max Delay (ms)"@en ; rdfs:domain rel:RetryPolicy ; rdfs:range xsd:integer .
rel:hasJitterStrategy  a owl:DatatypeProperty ; rdfs:label "抖动策略"@zh , "Jitter Strategy"@en ; rdfs:domain rel:RetryPolicy ; rdfs:range xsd:string .

rel:DefaultRetryPolicy
    a rel:RetryPolicy , owl:NamedIndividual ;
    rdfs:label "默认重试策略"@zh , "Default Retry Policy"@en ;
    rel:hasMaxRetries "3"^^xsd:integer ;
    rel:hasBaseDelayMs "100"^^xsd:integer ;
    rel:hasMaxDelayMs "10000"^^xsd:integer ;
    rel:hasJitterStrategy "full-jitter" .

# ── 1.3 Event Sourcing & Outbox Pattern ───────────────────────────────────
rel:EventSourcingLayer
    a owl:Class ;
    rdfs:label "事件溯源层"@zh , "Event Sourcing Layer"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "所有状态变更以不可变事件序列存储。任何时刻可从事件流重建系统状态。支持：调账追溯·合规审计·穿透分析·故障恢复。"@zh ,
        "All state changes stored as immutable event sequences. System state can be rebuilt from event stream at any time. Supports: adjustment traceability · compliance audit · penetration analysis · failure recovery."@en .

rel:DomainEvent
    a owl:Class ;
    rdfs:label "领域事件"@zh , "Domain Event"@en ;
    rdfs:subClassOf rel:EventSourcingLayer ;
    rdfs:subClassOf prov:Activity .

rel:hasEventId        a owl:DatatypeProperty ; rdfs:label "事件ID"@zh , "Event ID"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:string .
rel:hasEventType      a owl:DatatypeProperty ; rdfs:label "事件类型"@zh , "Event Type"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:string .
rel:hasEventTimestamp a owl:DatatypeProperty ; rdfs:label "事件时间戳"@zh , "Event Timestamp"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:dateTime .
rel:hasEventVersion   a owl:DatatypeProperty ; rdfs:label "事件模式版本"@zh , "Event Schema Version"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:string .
rel:hasAggregateId    a owl:DatatypeProperty ; rdfs:label "聚合根ID"@zh , "Aggregate ID"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:string .
rel:hasSequenceNumber a owl:DatatypeProperty ; rdfs:label "事件序号"@zh , "Sequence Number"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:long .
rel:hasCorrelationId  a owl:DatatypeProperty ; rdfs:label "关联ID"@zh , "Correlation ID"@en ; rdfs:domain rel:DomainEvent ; rdfs:range xsd:string ;
    rdfs:comment "跨服务追踪链路ID，用于分布式调用链的全链路追踪。"@zh , "Cross-service trace chain ID for distributed call chain full-link tracing."@en .

# Specific financial events
rel:AccountingEntryCreated a owl:Class ; rdfs:label "凭证创建事件"@zh , "Accounting Entry Created"@en ; rdfs:subClassOf rel:DomainEvent .
rel:ManualAdjustmentApplied a owl:Class ; rdfs:label "人工调账事件"@zh , "Manual Adjustment Applied"@en ; rdfs:subClassOf rel:DomainEvent .
rel:FundTransferExecuted   a owl:Class ; rdfs:label "资金划转执行事件"@zh , "Fund Transfer Executed"@en ; rdfs:subClassOf rel:DomainEvent .
rel:SJYZDApprovalGranted   a owl:Class ; rdfs:label "三重一大审批通过事件"@zh , "SJYZD Approval Granted"@en ; rdfs:subClassOf rel:DomainEvent .
rel:ComplianceViolationDetected a owl:Class ; rdfs:label "合规违规检测事件"@zh , "Compliance Violation Detected"@en ; rdfs:subClassOf rel:DomainEvent .
rel:OntologyVersionPublished a owl:Class ; rdfs:label "本体版本发布事件"@zh , "Ontology Version Published"@en ; rdfs:subClassOf rel:DomainEvent .

rel:TransactionalOutbox
    a owl:Class ;
    rdfs:label "事务性发件箱（Outbox）"@zh , "Transactional Outbox"@en ;
    rdfs:subClassOf rel:EventSourcingLayer ;
    rdfs:comment
        "解决双写问题：业务操作与事件发布在同一数据库事务中完成，发件箱轮询确保事件至少一次投递，幂等消费者处理重复。"@zh ,
        "Solves dual-write problem: business operation and event publication complete in the same DB transaction; outbox poller ensures at-least-once delivery; idempotent consumers handle duplicates."@en .

rel:hasOutboxStatus
    a owl:DatatypeProperty ;
    rdfs:label "发件箱状态"@zh , "Outbox Status"@en ;
    rdfs:domain rel:TransactionalOutbox ;
    rdfs:range xsd:string ;
    rdfs:comment "PENDING → PUBLISHED → FAILED → DEAD_LETTER"@zh .

rel:DeadLetterQueue
    a owl:Class ;
    rdfs:label "死信队列"@zh , "Dead Letter Queue"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment "最大重试后仍失败的消息转入死信队列，触发人工介入告警，确保零消息丢失。"@zh ,
                 "Messages failing after max retries go to DLQ, triggering human intervention alert. Ensures zero message loss."@en .

rel:hasMaxDeadLetterRetries a owl:DatatypeProperty ; rdfs:label "死信最大重试"@zh , "Max DLQ Retries"@en ; rdfs:domain rel:DeadLetterQueue ; rdfs:range xsd:integer .

# ── 1.4 Idempotency Framework ──────────────────────────────────────────────
rel:IdempotencyFramework
    a owl:Class ;
    rdfs:label "幂等性保障框架"@zh , "Idempotency Assurance Framework"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "所有写操作必须携带幂等键，服务端记录已处理的幂等键（TTL=25小时），重复请求返回缓存结果而非重复执行。关键场景：调账·转账·审批。"@zh ,
        "All write operations must carry idempotency keys; server records processed keys (TTL=25h); duplicate requests return cached results without re-execution. Critical for: adjustments · transfers · approvals."@en .

rel:IdempotencyKey
    a owl:Class ;
    rdfs:label "幂等键"@zh , "Idempotency Key"@en ;
    rdfs:subClassOf rel:IdempotencyFramework .

rel:hasIdempotencyKeyValue   a owl:DatatypeProperty ; rdfs:label "幂等键值"@zh , "Key Value"@en ; rdfs:domain rel:IdempotencyKey ; rdfs:range xsd:string .
rel:hasIdempotencyKeyTTL     a owl:DatatypeProperty ; rdfs:label "幂等键有效期(秒)"@zh , "Key TTL (seconds)"@en ; rdfs:domain rel:IdempotencyKey ; rdfs:range xsd:integer .
rel:hasIdempotencyKeyStatus  a owl:DatatypeProperty ; rdfs:label "幂等键状态"@zh , "Key Status"@en ; rdfs:domain rel:IdempotencyKey ; rdfs:range xsd:string ;
    rdfs:comment "PROCESSING | COMPLETED | FAILED — 防止并发重复执行（TOCTOU竞态）。"@zh , "PROCESSING | COMPLETED | FAILED — prevents concurrent duplicate execution (TOCTOU race)."@en .

# ==============================================================================
# PART 2: MANUAL ADJUSTMENT CONSISTENCY — 人工调账一致性保障
# Problem: Human overrides financial records; must maintain ACID + audit trail
# Solution: Optimistic locking + 4-eyes + compensating entry + event sourcing
# ==============================================================================

cons:ManualAdjustmentConsistency
    a owl:Class ;
    rdfs:label "人工调账一致性保障"@zh , "Manual Adjustment Consistency Assurance"@en ;
    rdfs:comment
        "人工调账是财务系统中最高风险的操作。保障机制：乐观锁防并发冲突·四眼审批·红字冲销+蓝字重做·事件溯源追踪·SHACL验证·实时余额核对。"@zh ,
        "Manual adjustment is the highest-risk operation in financial systems. Safeguards: optimistic locking for concurrent conflicts · four-eyes approval · red-entry reversal + blue-entry redo · event sourcing · SHACL validation · real-time balance reconciliation."@en .

# ── 2.1 Optimistic Locking ────────────────────────────────────────────────
cons:OptimisticLock
    a owl:Class ;
    rdfs:label "乐观锁"@zh , "Optimistic Lock"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "每个财务聚合根（账户·凭证·预算）携带版本号。调账时提交的版本号必须与当前版本匹配，不匹配则拒绝并要求重新读取。"@zh ,
        "Every financial aggregate (account · voucher · budget) carries a version number. Submitted version must match current version during adjustment; mismatch rejects and requires re-read."@en .

cons:hasVersionNumber
    a owl:DatatypeProperty ;
    rdfs:label "乐观锁版本号"@zh , "Optimistic Lock Version"@en ;
    rdfs:domain cons:OptimisticLock ;
    rdfs:range xsd:long ;
    rdfs:comment "每次成功更新递增1。并发写冲突时，后写方收到409 Conflict，须重新读取并基于最新版本操作。"@zh ,
                 "Increments by 1 on each successful update. On concurrent write conflict, the late writer receives 409 Conflict and must re-read."@en .

cons:hasLastModifiedBy   a owl:DatatypeProperty ; rdfs:label "最后修改人"@zh , "Last Modified By"@en ; rdfs:domain cons:OptimisticLock ; rdfs:range xsd:string .
cons:hasLastModifiedAt   a owl:DatatypeProperty ; rdfs:label "最后修改时间"@zh , "Last Modified At"@en ; rdfs:domain cons:OptimisticLock ; rdfs:range xsd:dateTime .
cons:hasChecksum         a owl:DatatypeProperty ; rdfs:label "数据校验和"@zh , "Data Checksum"@en ; rdfs:domain cons:OptimisticLock ; rdfs:range xsd:string ;
    rdfs:comment "SHA-256校验和，防止静默数据损坏（silent data corruption）。"@zh , "SHA-256 checksum preventing silent data corruption."@en .

# ── 2.2 Four-Eyes Approval for Adjustments ────────────────────────────────
cons:FourEyesApproval
    a owl:Class ;
    rdfs:label "四眼审批（双人复核）"@zh , "Four-Eyes Approval (Dual Control)"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "所有人工调账须经至少两名授权人员独立审批（制单人与审核人不得为同一人）。超阈值须触发三重一大流程。"@zh ,
        "All manual adjustments require independent approval by at least two authorized personnel (preparer and reviewer must not be the same person). Above-threshold triggers SJYZD process."@en .

cons:hasPreparer       a owl:DatatypeProperty ; rdfs:label "制单人"@zh , "Preparer"@en ; rdfs:domain cons:FourEyesApproval ; rdfs:range xsd:string .
cons:hasReviewer       a owl:DatatypeProperty ; rdfs:label "审核人"@zh , "Reviewer"@en ; rdfs:domain cons:FourEyesApproval ; rdfs:range xsd:string .
cons:hasApprover       a owl:DatatypeProperty ; rdfs:label "审批人"@zh , "Approver"@en ; rdfs:domain cons:FourEyesApproval ; rdfs:range xsd:string .
cons:isPreparerReviewerSame a owl:DatatypeProperty ;
    rdfs:label "制单人与审核人是否同一人（必须为false）"@zh ,
               "Is Preparer Same as Reviewer (must be false)"@en ;
    rdfs:domain cons:FourEyesApproval ;
    rdfs:range xsd:boolean .

cons:AdjustmentApprovalLevel
    a owl:Class ;
    rdfs:label "调账审批级别"@zh , "Adjustment Approval Level"@en ;
    rdfs:subClassOf cons:FourEyesApproval .

cons:Level1Adjustment a cons:AdjustmentApprovalLevel , owl:NamedIndividual ;
    rdfs:label "一级调账（科长审批，<50万）"@zh , "Level-1 Adjustment (Section chief, <500K)"@en .
cons:Level2Adjustment a cons:AdjustmentApprovalLevel , owl:NamedIndividual ;
    rdfs:label "二级调账（部门总监审批，50-500万）"@zh , "Level-2 Adjustment (Dept Director, 500K-5M)"@en .
cons:Level3Adjustment a cons:AdjustmentApprovalLevel , owl:NamedIndividual ;
    rdfs:label "三级调账（CFO审批，>500万）"@zh , "Level-3 Adjustment (CFO, >5M)"@en .
cons:SJYZDAdjustment  a cons:AdjustmentApprovalLevel , owl:NamedIndividual ;
    rdfs:label "三重一大调账（集体决策，超集团门槛）"@zh , "SJYZD Adjustment (Collective decision, above group threshold)"@en .

# ── 2.3 Compensating Entry (Red/Blue) ─────────────────────────────────────
cons:CompensatingEntryMechanism
    a owl:Class ;
    rdfs:label "补偿凭证机制（红冲蓝补）"@zh , "Compensating Entry Mechanism (Red Reversal / Blue Repost)"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "调账不直接修改原始凭证（不可变）。步骤：1.红字冲销凭证（符号相反，金额相同）2.蓝字重做凭证（正确分录）3.三者形成完整调账链。满足CAS·IFRS·审计要求。"@zh ,
        "Adjustments never modify original vouchers (immutable). Steps: 1. Red-entry reversal (opposite signs, same amounts) 2. Blue-entry repost (correct entries) 3. All three form a complete adjustment chain. Satisfies CAS · IFRS · audit requirements."@en .

cons:hasOriginalEntry    a owl:ObjectProperty ; rdfs:label "原始凭证"@zh , "Original Entry"@en ; rdfs:domain cons:CompensatingEntryMechanism ; rdfs:range acct:JournalEntry .
cons:hasReversalEntry    a owl:ObjectProperty ; rdfs:label "红字冲销凭证"@zh , "Red Reversal Entry"@en ; rdfs:domain cons:CompensatingEntryMechanism ; rdfs:range acct:JournalEntry .
cons:hasCorrectionEntry  a owl:ObjectProperty ; rdfs:label "蓝字更正凭证"@zh , "Blue Correction Entry"@en ; rdfs:domain cons:CompensatingEntryMechanism ; rdfs:range acct:JournalEntry .
cons:hasAdjustmentReason a owl:DatatypeProperty ; rdfs:label "调账原因"@zh , "Adjustment Reason"@en ; rdfs:domain cons:CompensatingEntryMechanism ; rdfs:range xsd:string .
cons:hasAdjustmentReference a owl:DatatypeProperty ; rdfs:label "调账依据文件"@zh , "Adjustment Reference Document"@en ; rdfs:domain cons:CompensatingEntryMechanism ; rdfs:range xsd:string .
cons:isReversalEntry     a owl:DatatypeProperty ; rdfs:label "是红字冲销凭证"@zh , "Is Reversal Entry"@en ; rdfs:domain acct:JournalEntry ; rdfs:range xsd:boolean .

# ── 2.4 Real-Time Balance Reconciliation ─────────────────────────────────
cons:BalanceReconciliation
    a owl:Class ;
    rdfs:label "实时余额核对"@zh , "Real-Time Balance Reconciliation"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "调账后立即触发：借贷平衡验证·账户余额一致性·上下级数据穿透核对·ERP与本体数据同步验证。不一致则锁定该账户并告警。"@zh ,
        "Triggered immediately after adjustment: debit-credit balance · account balance consistency · hierarchical data penetration reconciliation · ERP-ontology data synchronization verification. Inconsistency locks the account and alerts."@en .

cons:ReconciliationScope
    a owl:Class ;
    rdfs:label "核对范围"@zh , "Reconciliation Scope"@en ;
    rdfs:subClassOf cons:BalanceReconciliation .

cons:EntityLevelReconciliation     a cons:ReconciliationScope , owl:NamedIndividual ; rdfs:label "法人单体核对"@zh , "Entity-Level Reconciliation"@en .
cons:GroupLevelReconciliation      a cons:ReconciliationScope , owl:NamedIndividual ; rdfs:label "集团合并核对"@zh , "Group-Level Reconciliation"@en .
cons:ERPOntologyReconciliation     a cons:ReconciliationScope , owl:NamedIndividual ; rdfs:label "ERP与本体数据核对"@zh , "ERP-Ontology Reconciliation"@en .
cons:CrossBorderReconciliation     a cons:ReconciliationScope , owl:NamedIndividual ; rdfs:label "境内外账户核对"@zh , "Cross-Border Reconciliation"@en .

cons:hasReconciliationStatus a owl:DatatypeProperty ;
    rdfs:label "核对状态"@zh , "Reconciliation Status"@en ;
    rdfs:domain cons:BalanceReconciliation ;
    rdfs:range xsd:string ;
    rdfs:comment "PASSED | FAILED | PENDING | LOCKED — FAILED状态锁定相关账户。"@zh ,
                 "PASSED | FAILED | PENDING | LOCKED — FAILED state locks related accounts."@en .

cons:hasDiscrepancyAmount a owl:DatatypeProperty ;
    rdfs:label "差异金额"@zh , "Discrepancy Amount"@en ;
    rdfs:domain cons:BalanceReconciliation ;
    rdfs:range xsd:decimal ;
    rdfs:comment "差异金额绝对值>0.01分则触发告警，确保分厘不差。"@zh ,
                 "Alert triggered when |discrepancy| > 0.01 yuan; ensures penny-perfect accuracy."@en .

# ── 2.5 Distributed Saga for Cross-System Adjustments ─────────────────────
saga:SagaPattern
    a owl:Class ;
    rdfs:label "Saga分布式事务模式"@zh , "Saga Distributed Transaction Pattern"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "跨系统调账（ERP→本体→监管报告）使用Saga模式替代2PC：每步有本地事务+补偿事务，任何步骤失败则逆序执行补偿，最终达成一致。"@zh ,
        "Cross-system adjustments (ERP→Ontology→Regulatory Reports) use Saga instead of 2PC: each step has local transaction + compensating transaction; any failure triggers reverse-order compensation for eventual consistency."@en .

saga:SagaStep
    a owl:Class ;
    rdfs:label "Saga步骤"@zh , "Saga Step"@en ;
    rdfs:subClassOf saga:SagaPattern .

saga:hasStepName          a owl:DatatypeProperty ; rdfs:label "步骤名称"@zh , "Step Name"@en ; rdfs:domain saga:SagaStep ; rdfs:range xsd:string .
saga:hasStepOrder         a owl:DatatypeProperty ; rdfs:label "步骤序号"@zh , "Step Order"@en ; rdfs:domain saga:SagaStep ; rdfs:range xsd:integer .
saga:hasCompensationAction a owl:DatatypeProperty ; rdfs:label "补偿操作"@zh , "Compensation Action"@en ; rdfs:domain saga:SagaStep ; rdfs:range xsd:string .
saga:hasStepStatus        a owl:DatatypeProperty ; rdfs:label "步骤状态"@zh , "Step Status"@en ; rdfs:domain saga:SagaStep ; rdfs:range xsd:string ;
    rdfs:comment "PENDING | EXECUTING | COMPLETED | COMPENSATING | COMPENSATED | FAILED"@en .

# Concrete saga for financial adjustment
saga:FinancialAdjustmentSaga
    a saga:SagaPattern , owl:NamedIndividual ;
    rdfs:label "财务调账Saga"@zh , "Financial Adjustment Saga"@en .

saga:Step1_ValidateEntry
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤1：验证凭证"@zh , "Step 1: Validate Entry"@en ;
    saga:hasStepOrder "1"^^xsd:integer ;
    saga:hasCompensationAction "rollback_validation_lock" .

saga:Step2_FourEyesApprove
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤2：四眼审批"@zh , "Step 2: Four-Eyes Approve"@en ;
    saga:hasStepOrder "2"^^xsd:integer ;
    saga:hasCompensationAction "revoke_approval_token" .

saga:Step3_PostToERP
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤3：过账至ERP"@zh , "Step 3: Post to ERP"@en ;
    saga:hasStepOrder "3"^^xsd:integer ;
    saga:hasCompensationAction "post_reversal_to_erp" .

saga:Step4_UpdateOntology
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤4：更新本体"@zh , "Step 4: Update Ontology"@en ;
    saga:hasStepOrder "4"^^xsd:integer ;
    saga:hasCompensationAction "revert_ontology_state" .

saga:Step5_PublishEvent
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤5：发布领域事件"@zh , "Step 5: Publish Domain Event"@en ;
    saga:hasStepOrder "5"^^xsd:integer ;
    saga:hasCompensationAction "publish_compensation_event" .

saga:Step6_ReconcileBalance
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤6：余额核对"@zh , "Step 6: Reconcile Balance"@en ;
    saga:hasStepOrder "6"^^xsd:integer ;
    saga:hasCompensationAction "trigger_discrepancy_alert" .

saga:Step7_GenerateAuditTrail
    a saga:SagaStep , owl:NamedIndividual ;
    rdfs:label "步骤7：生成审计追踪"@zh , "Step 7: Generate Audit Trail"@en ;
    saga:hasStepOrder "7"^^xsd:integer ;
    saga:hasCompensationAction "mark_audit_incomplete" .

# ==============================================================================
# PART 3: NL-SEMANTIC ALIGNMENT IN AGENTS — 智能体NL语义对齐
# Problem: LLM generates hallucinated terms; ontology terms drift from natural language
# Solution: Grounding + anchor injection + SPARQL round-trip verification + confidence gating
# ==============================================================================

nlalign:NLSemanticAlignmentFramework
    a owl:Class ;
    rdfs:label "NL语义对齐框架"@zh , "NL-Semantic Alignment Framework"@en ;
    rdfs:comment
        "解决智能体中自然语言与本体语义的对齐问题。核心：语义锚定注入·SPARQL往返验证·置信门控·幻觉检测·术语漂移监控。"@zh ,
        "Solves NL-semantic alignment in agents. Core: semantic anchor injection · SPARQL round-trip verification · confidence gating · hallucination detection · term drift monitoring."@en .

# ── 3.1 Semantic Grounding ────────────────────────────────────────────────
nlalign:SemanticGrounding
    a owl:Class ;
    rdfs:label "语义锚定（接地）"@zh , "Semantic Grounding"@en ;
    rdfs:subClassOf nlalign:NLSemanticAlignmentFramework ;
    rdfs:comment
        "每个LLM生成的术语/概念必须映射到本体中的具体URI，否则标记为'未接地'并触发追问。接地失败的术语不允许进入SPARQL查询或业务逻辑。"@zh ,
        "Every LLM-generated term/concept must map to a specific URI in the ontology; otherwise flagged as 'ungrounded' and triggers clarification. Ungrounded terms cannot enter SPARQL queries or business logic."@en .

nlalign:GroundedTerm
    a owl:Class ;
    rdfs:label "已接地术语"@zh , "Grounded Term"@en ;
    rdfs:subClassOf nlalign:SemanticGrounding .

nlalign:UngroundedTerm
    a owl:Class ;
    rdfs:label "未接地术语（幻觉风险）"@zh , "Ungrounded Term (Hallucination Risk)"@en ;
    rdfs:subClassOf nlalign:SemanticGrounding .

nlalign:hasGroundingURI       a owl:DatatypeProperty ; rdfs:label "接地URI"@zh , "Grounding URI"@en ; rdfs:domain nlalign:GroundedTerm ; rdfs:range xsd:anyURI .
nlalign:hasGroundingScore     a owl:DatatypeProperty ; rdfs:label "接地置信分"@zh , "Grounding Confidence Score"@en ; rdfs:domain nlalign:GroundedTerm ; rdfs:range xsd:decimal .
nlalign:hasGroundingMethod    a owl:DatatypeProperty ; rdfs:label "接地方法"@zh , "Grounding Method"@en ; rdfs:domain nlalign:GroundedTerm ; rdfs:range xsd:string ;
    rdfs:comment "EXACT_MATCH | SYNONYM_MATCH | VECTOR_SIMILARITY | REGEX_PATTERN | MANUAL_OVERRIDE"@en .

# ── 3.2 System Prompt Anchor Injection ────────────────────────────────────
nlalign:AnchorInjection
    a owl:Class ;
    rdfs:label "本体锚点注入"@zh , "Ontology Anchor Injection"@en ;
    rdfs:subClassOf nlalign:NLSemanticAlignmentFramework ;
    rdfs:comment
        "在每次LLM调用的System Prompt中注入当前活跃的本体版本摘要、关键术语URI表、当前租户规则。确保LLM在正确的语义空间内操作。"@zh ,
        "Inject active ontology version summary, key term URI table, and current tenant rules into System Prompt for each LLM call. Ensures LLM operates within the correct semantic space."@en .

nlalign:AnchorInjectionTemplate
    a owl:Class ;
    rdfs:label "锚点注入模板"@zh , "Anchor Injection Template"@en ;
    rdfs:subClassOf nlalign:AnchorInjection .

nlalign:CoreTermAnchor
    a nlalign:AnchorInjectionTemplate , owl:NamedIndividual ;
    rdfs:label "核心术语锚点"@zh , "Core Term Anchor"@en ;
    rdfs:comment
        "注入内容示例：'你必须使用以下术语URI：三重一大=<sjyzd:SJYZDDecisionSystem>·穿透监管=<penet:PenetrativeSupervision>·资金池=<cap:CashPool>。不得使用这些URI以外的自定义术语。'"@zh ,
        "Example injection: 'You MUST use these term URIs: SJYZD=<sjyzd:SJYZDDecisionSystem> · Penetrative Supervision=<penet:PenetrativeSupervision> · Cash Pool=<cap:CashPool>. Do not use custom terms outside these URIs.'"@en .

nlalign:VersionAnchor
    a nlalign:AnchorInjectionTemplate , owl:NamedIndividual ;
    rdfs:label "版本锚点"@zh , "Version Anchor"@en ;
    rdfs:comment "注入当前活跃本体版本URI，防止LLM使用已废弃版本的概念。"@zh ,
                 "Inject active ontology version URI to prevent LLM from using deprecated version concepts."@en .

nlalign:TenantRuleAnchor
    a nlalign:AnchorInjectionTemplate , owl:NamedIndividual ;
    rdfs:label "租户规则锚点"@zh , "Tenant Rule Anchor"@en ;
    rdfs:comment "注入当前租户（如中石油）的SJYZD阈值·资产负债率红线等特定规则。"@zh ,
                 "Inject current tenant (e.g., CNPC) specific rules: SJYZD thresholds · A/L ratio red lines, etc."@en .

# ── 3.3 SPARQL Round-Trip Verification ────────────────────────────────────
nlalign:SPARQLRoundTripVerification
    a owl:Class ;
    rdfs:label "SPARQL往返验证"@zh , "SPARQL Round-Trip Verification"@en ;
    rdfs:subClassOf nlalign:NLSemanticAlignmentFramework ;
    rdfs:comment
        "LLM生成的SPARQL/响应须通过往返测试：1.LLM生成查询 2.执行查询得结果 3.将结果反序列化回NL 4.LLM验证NL与原始问题语义一致。不一致触发修正循环（最多3次）。"@zh ,
        "LLM-generated SPARQL/responses must pass round-trip test: 1.LLM generates query 2.Execute query 3.Deserialize result back to NL 4.LLM verifies NL-original question semantic consistency. Inconsistency triggers correction loop (max 3 times)."@en .

nlalign:hasRoundTripScore     a owl:DatatypeProperty ; rdfs:label "往返一致性分"@zh , "Round-Trip Consistency Score"@en ; rdfs:domain nlalign:SPARQLRoundTripVerification ; rdfs:range xsd:decimal .
nlalign:hasMaxCorrectionRounds a owl:DatatypeProperty ; rdfs:label "最大修正轮次"@zh , "Max Correction Rounds"@en ; rdfs:domain nlalign:SPARQLRoundTripVerification ; rdfs:range xsd:integer .

# ── 3.4 Hallucination Detection ────────────────────────────────────────────
nlalign:HallucinationDetector
    a owl:Class ;
    rdfs:label "幻觉检测器"@zh , "Hallucination Detector"@en ;
    rdfs:subClassOf nlalign:NLSemanticAlignmentFramework ;
    rdfs:comment
        "检测LLM响应中的幻觉：1.术语存在性检查（URI是否在本体中）2.数值范围检查（金额不能为负）3.关系合法性检查（父子层级是否在本体中定义）4.规则冲突检查（是否违反SHACL约束）。"@zh ,
        "Detects hallucinations in LLM responses: 1.Term existence check (URI in ontology?) 2.Value range check (amount non-negative?) 3.Relation legality check (parent-child in ontology?) 4.Rule conflict check (SHACL violation?)."@en .

nlalign:HallucinationCheckType
    a owl:Class ;
    rdfs:label "幻觉检查类型"@zh , "Hallucination Check Type"@en .

nlalign:TermExistenceCheck    a nlalign:HallucinationCheckType , owl:NamedIndividual ; rdfs:label "术语存在性检查"@zh , "Term Existence Check"@en .
nlalign:ValueRangeCheck       a nlalign:HallucinationCheckType , owl:NamedIndividual ; rdfs:label "数值范围检查"@zh , "Value Range Check"@en .
nlalign:RelationLegalityCheck a nlalign:HallucinationCheckType , owl:NamedIndividual ; rdfs:label "关系合法性检查"@zh , "Relation Legality Check"@en .
nlalign:SHACLConstraintCheck  a nlalign:HallucinationCheckType , owl:NamedIndividual ; rdfs:label "SHACL约束检查"@zh , "SHACL Constraint Check"@en .
nlalign:TemporalConsistencyCheck a nlalign:HallucinationCheckType , owl:NamedIndividual ; rdfs:label "时序一致性检查"@zh , "Temporal Consistency Check"@en .

# ── 3.5 Confidence Gating ─────────────────────────────────────────────────
nlalign:ConfidenceGate
    a owl:Class ;
    rdfs:label "置信门控"@zh , "Confidence Gate"@en ;
    rdfs:subClassOf nlalign:NLSemanticAlignmentFramework ;
    rdfs:comment
        "每个LLM动作须通过置信门：高置信(>0.9)自动执行→中置信(0.7-0.9)展示给用户确认→低置信(0.5-0.7)触发追问→极低置信(<0.5)拒绝并人工介入。"@zh ,
        "Each LLM action must pass confidence gate: High (>0.9) auto-execute → Medium (0.7-0.9) present for user confirmation → Low (0.5-0.7) trigger clarification → Very low (<0.5) reject and human intervention."@en .

nlalign:HighConfidenceGate   a nlalign:ConfidenceGate , owl:NamedIndividual ; rdfs:label "高置信门(>0.9)：自动执行"@zh , "High Confidence Gate (>0.9): Auto-execute"@en .
nlalign:MediumConfidenceGate a nlalign:ConfidenceGate , owl:NamedIndividual ; rdfs:label "中置信门(0.7-0.9)：用户确认"@zh , "Medium Confidence Gate (0.7-0.9): User confirm"@en .
nlalign:LowConfidenceGate    a nlalign:ConfidenceGate , owl:NamedIndividual ; rdfs:label "低置信门(0.5-0.7)：追问澄清"@zh , "Low Confidence Gate (0.5-0.7): Clarify"@en .
nlalign:RejectGate           a nlalign:ConfidenceGate , owl:NamedIndividual ; rdfs:label "拒绝门(<0.5)：人工介入"@zh , "Reject Gate (<0.5): Human intervention"@en .

# ==============================================================================
# PART 4: ONTOLOGY VERSION CONSISTENCY — 本体版本一致性
# Problem: Multiple versions in prod; consumers use different versions; schema drift
# Solution: Semantic versioning + namespace lock + migration graph + compatibility matrix
# ==============================================================================

ver:OntologyVersionManagement
    a owl:Class ;
    rdfs:label "本体版本管理"@zh , "Ontology Version Management"@en ;
    rdfs:comment
        "保障本体不同版本在生成和使用中的一致性。机制：不可变版本URI·兼容性矩阵·迁移路径图·版本锁定合约·活跃版本注册表。"@zh ,
        "Ensures consistency across ontology versions in generation and consumption. Mechanisms: immutable version URIs · compatibility matrix · migration path graph · version lock contracts · active version registry."@en .

# ── 4.1 Immutable Version URI ─────────────────────────────────────────────
ver:OntologyVersionRecord
    a owl:Class ;
    rdfs:label "本体版本记录"@zh , "Ontology Version Record"@en ;
    rdfs:subClassOf ver:OntologyVersionManagement .

ver:hasVersionURI         a owl:DatatypeProperty ; rdfs:label "版本URI（不可变）"@zh , "Version URI (Immutable)"@en ; rdfs:domain ver:OntologyVersionRecord ; rdfs:range xsd:anyURI .
ver:hasVersionTag         a owl:DatatypeProperty ; rdfs:label "版本标签"@zh , "Version Tag"@en ; rdfs:domain ver:OntologyVersionRecord ; rdfs:range xsd:string .
ver:hasPublishedDate      a owl:DatatypeProperty ; rdfs:label "发布日期"@zh , "Published Date"@en ; rdfs:domain ver:OntologyVersionRecord ; rdfs:range xsd:date .
ver:hasDeprecatedDate     a owl:DatatypeProperty ; rdfs:label "废弃日期"@zh , "Deprecated Date"@en ; rdfs:domain ver:OntologyVersionRecord ; rdfs:range xsd:date .
ver:hasSunsetDate         a owl:DatatypeProperty ; rdfs:label "下线日期"@zh , "Sunset Date"@en ; rdfs:domain ver:OntologyVersionRecord ; rdfs:range xsd:date .
ver:hasOntologyHash       a owl:DatatypeProperty ; rdfs:label "本体哈希值（SHA-256）"@zh , "Ontology Hash (SHA-256)"@en ; rdfs:domain ver:OntologyVersionRecord ; rdfs:range xsd:string ;
    rdfs:comment "每个已发布版本的完整哈希，防止内容被篡改。任何校验失败立即告警。"@zh ,
                 "Complete hash of each published version; prevents content tampering. Any checksum failure triggers immediate alert."@en .

ver:VersionLifecycleStatus
    a owl:Class ;
    rdfs:label "版本生命周期状态"@zh , "Version Lifecycle Status"@en .

ver:StatusDraft      a ver:VersionLifecycleStatus , owl:NamedIndividual ; rdfs:label "草稿（Draft）"@zh , "Draft"@en .
ver:StatusRC         a ver:VersionLifecycleStatus , owl:NamedIndividual ; rdfs:label "候选发布（RC）"@zh , "Release Candidate"@en .
ver:StatusActive     a ver:VersionLifecycleStatus , owl:NamedIndividual ; rdfs:label "活跃（Active）"@zh , "Active"@en .
ver:StatusDeprecated a ver:VersionLifecycleStatus , owl:NamedIndividual ; rdfs:label "废弃（Deprecated）"@zh , "Deprecated"@en .
ver:StatusSunset     a ver:VersionLifecycleStatus , owl:NamedIndividual ; rdfs:label "下线（Sunset）"@zh , "Sunset"@en .

# ── 4.2 Compatibility Matrix ──────────────────────────────────────────────
ver:CompatibilityMatrix
    a owl:Class ;
    rdfs:label "版本兼容性矩阵"@zh , "Version Compatibility Matrix"@en ;
    rdfs:subClassOf ver:OntologyVersionManagement ;
    rdfs:comment
        "声明版本间的兼容性关系：向上兼容·向下兼容·完全兼容·不兼容。消费者绑定时须查询此矩阵确认兼容性。"@zh ,
        "Declares compatibility relationships between versions: upward · downward · full · incompatible. Consumers must query this matrix when binding."@en .

ver:CompatibilityType
    a owl:Class ;
    rdfs:label "兼容性类型"@zh , "Compatibility Type"@en .

ver:FullyCompatible      a ver:CompatibilityType , owl:NamedIndividual ; rdfs:label "完全兼容"@zh , "Fully Compatible"@en .
ver:BackwardCompatible   a ver:CompatibilityType , owl:NamedIndividual ; rdfs:label "向后兼容（新版兼容旧消费者）"@zh , "Backward Compatible (new version works with old consumers)"@en .
ver:ForwardCompatible    a ver:CompatibilityType , owl:NamedIndividual ; rdfs:label "向前兼容（旧版兼容新消费者）"@zh , "Forward Compatible (old version works with new consumers)"@en .
ver:Incompatible         a ver:CompatibilityType , owl:NamedIndividual ; rdfs:label "不兼容（必须迁移）"@zh , "Incompatible (migration required)"@en .

ver:hasSourceVersion     a owl:DatatypeProperty ; rdfs:label "源版本"@zh , "Source Version"@en ; rdfs:domain ver:CompatibilityMatrix ; rdfs:range xsd:string .
ver:hasTargetVersion     a owl:DatatypeProperty ; rdfs:label "目标版本"@zh , "Target Version"@en ; rdfs:domain ver:CompatibilityMatrix ; rdfs:range xsd:string .
ver:hasCompatibilityType a owl:ObjectProperty ; rdfs:label "兼容性类型"@zh , "Compatibility Type"@en ; rdfs:domain ver:CompatibilityMatrix ; rdfs:range ver:CompatibilityType .
ver:hasMigrationScript   a owl:DatatypeProperty ; rdfs:label "迁移脚本URI"@zh , "Migration Script URI"@en ; rdfs:domain ver:CompatibilityMatrix ; rdfs:range xsd:anyURI .

# ── 4.3 Version Lock Contract ─────────────────────────────────────────────
ver:VersionLockContract
    a owl:Class ;
    rdfs:label "版本锁定合约"@zh , "Version Lock Contract"@en ;
    rdfs:subClassOf ver:OntologyVersionManagement ;
    rdfs:comment
        "每个API调用须在Header中声明消费的本体版本（X-Ontology-Version: 4.1）。服务端验证版本声明，拒绝不声明版本的请求，防止隐式版本漂移。"@zh ,
        "Every API call must declare consumed ontology version in Header (X-Ontology-Version: 4.1). Server validates version declaration; rejects undeclared requests to prevent implicit version drift."@en .

ver:hasLockedVersion      a owl:DatatypeProperty ; rdfs:label "锁定版本"@zh , "Locked Version"@en ; rdfs:domain ver:VersionLockContract ; rdfs:range xsd:string .
ver:hasConsumerID         a owl:DatatypeProperty ; rdfs:label "消费者ID"@zh , "Consumer ID"@en ; rdfs:domain ver:VersionLockContract ; rdfs:range xsd:string .
ver:hasLockExpiryDate     a owl:DatatypeProperty ; rdfs:label "锁定到期日"@zh , "Lock Expiry Date"@en ; rdfs:domain ver:VersionLockContract ; rdfs:range xsd:date .

# ── 4.4 Schema Evolution Rules ────────────────────────────────────────────
ver:SchemaEvolutionRule
    a owl:Class ;
    rdfs:label "模式演化规则"@zh , "Schema Evolution Rule"@en ;
    rdfs:subClassOf ver:OntologyVersionManagement ;
    rdfs:comment
        "定义允许和禁止的演化操作：允许（新增类/属性·收窄值域·增加可选属性）；禁止（删除类/属性·扩展必填属性·改变URI·改变数据类型）。"@zh ,
        "Defines allowed and forbidden evolution operations: Allowed (add class/property · narrow range · add optional property); Forbidden (remove class/property · extend required properties · change URI · change datatype)."@en .

ver:AllowedEvolution
    a ver:SchemaEvolutionRule , owl:Class ;
    rdfs:label "允许的演化操作"@zh , "Allowed Evolution Operations"@en .

ver:ForbiddenEvolution
    a ver:SchemaEvolutionRule , owl:Class ;
    rdfs:label "禁止的演化操作"@zh , "Forbidden Evolution Operations"@en .

ver:AddOptionalProperty    a ver:AllowedEvolution , owl:NamedIndividual ; rdfs:label "新增可选属性"@zh , "Add Optional Property"@en .
ver:AddNewClass            a ver:AllowedEvolution , owl:NamedIndividual ; rdfs:label "新增类"@zh , "Add New Class"@en .
ver:NarrowRange            a ver:AllowedEvolution , owl:NamedIndividual ; rdfs:label "收窄值域"@zh , "Narrow Range"@en .
ver:RemoveClass            a ver:ForbiddenEvolution , owl:NamedIndividual ; rdfs:label "删除类（禁止）"@zh , "Remove Class (Forbidden)"@en .
ver:RemoveProperty         a ver:ForbiddenEvolution , owl:NamedIndividual ; rdfs:label "删除属性（禁止）"@zh , "Remove Property (Forbidden)"@en .
ver:ChangeURI              a ver:ForbiddenEvolution , owl:NamedIndividual ; rdfs:label "修改URI（禁止）"@zh , "Change URI (Forbidden)"@en .
ver:ChangeDatatype         a ver:ForbiddenEvolution , owl:NamedIndividual ; rdfs:label "修改数据类型（禁止）"@zh , "Change Datatype (Forbidden)"@en .
ver:MakeOptionalRequired   a ver:ForbiddenEvolution , owl:NamedIndividual ; rdfs:label "将可选属性改为必填（禁止）"@zh , "Make Optional Property Required (Forbidden)"@en .

# ==============================================================================
# PART 5: AGENT SKILL GLOBAL CONSISTENCY — 智能体SKILL全局一致性
# Problem: Multiple agent instances use different SKILL versions; skills conflict
# Solution: SKILL registry + distributed lock + consensus + capability negotiation
# ==============================================================================

skill:AgentSKILLConsistency
    a owl:Class ;
    rdfs:label "智能体SKILL全局一致性"@zh , "Agent SKILL Global Consistency"@en ;
    rdfs:comment
        "保障所有智能体实例使用相同版本的SKILL定义，防止同一工作流中不同Agent对同一概念理解不一致。机制：SKILL注册表·分布式锁·Raft共识·能力协商·SKILL哈希广播。"@zh ,
        "Ensures all agent instances use the same SKILL definition version, preventing different agents in the same workflow from understanding the same concept differently. Mechanisms: SKILL registry · distributed lock · Raft consensus · capability negotiation · SKILL hash broadcast."@en .

# ── 5.1 SKILL Registry ────────────────────────────────────────────────────
skill:SKILLRegistry
    a owl:Class ;
    rdfs:label "SKILL注册表"@zh , "SKILL Registry"@en ;
    rdfs:subClassOf skill:AgentSKILLConsistency ;
    rdfs:comment
        "中央化的SKILL定义存储库，所有智能体启动时须从注册表拉取当前活跃SKILL版本，并订阅SKILL更新事件。注册表具有强一致性（CP特性）。"@zh ,
        "Centralized SKILL definition repository; all agents pull current active SKILL version on startup and subscribe to SKILL update events. Registry enforces strong consistency (CP property)."@en .

skill:SKILLDefinition
    a owl:Class ;
    rdfs:label "SKILL定义"@zh , "SKILL Definition"@en ;
    rdfs:subClassOf skill:SKILLRegistry .

skill:hasSKILLName        a owl:DatatypeProperty ; rdfs:label "SKILL名称"@zh , "SKILL Name"@en ; rdfs:domain skill:SKILLDefinition ; rdfs:range xsd:string .
skill:hasSKILLVersion     a owl:DatatypeProperty ; rdfs:label "SKILL版本"@zh , "SKILL Version"@en ; rdfs:domain skill:SKILLDefinition ; rdfs:range xsd:string .
skill:hasSKILLHash        a owl:DatatypeProperty ; rdfs:label "SKILL哈希（SHA-256）"@zh , "SKILL Hash (SHA-256)"@en ; rdfs:domain skill:SKILLDefinition ; rdfs:range xsd:string .
skill:hasSKILLOntologyURI a owl:DatatypeProperty ; rdfs:label "SKILL关联本体URI"@zh , "SKILL Linked Ontology URI"@en ; rdfs:domain skill:SKILLDefinition ; rdfs:range xsd:anyURI .
skill:hasSKILLScope       a owl:DatatypeProperty ; rdfs:label "SKILL适用范围"@zh , "SKILL Scope"@en ; rdfs:domain skill:SKILLDefinition ; rdfs:range xsd:string .
skill:hasSKILLStatus      a owl:DatatypeProperty ; rdfs:label "SKILL状态"@zh , "SKILL Status"@en ; rdfs:domain skill:SKILLDefinition ; rdfs:range xsd:string ;
    rdfs:comment "ACTIVE | DEPRECATED | EXPERIMENTAL | LOCKED"@en .

# SASAC-specific SKILLs
skill:SJYZDApprovalSKILL
    a skill:SKILLDefinition , owl:NamedIndividual ;
    rdfs:label "三重一大审批SKILL"@zh , "SJYZD Approval SKILL"@en ;
    skill:hasSKILLName "sjyzd_approval_v2" ;
    skill:hasSKILLVersion "2.0.0" ;
    skill:hasSKILLOntologyURI "https://ontology.mof.gov.cn/sasac/sjyzd/" ;
    skill:hasSKILLStatus "ACTIVE" .

skill:PenetrationAnalysisSKILL
    a skill:SKILLDefinition , owl:NamedIndividual ;
    rdfs:label "穿透分析SKILL"@zh , "Penetration Analysis SKILL"@en ;
    skill:hasSKILLName "penetration_analysis_v3" ;
    skill:hasSKILLVersion "3.0.0" ;
    skill:hasSKILLOntologyURI "https://ontology.mof.gov.cn/sasac/penetrative/" ;
    skill:hasSKILLStatus "ACTIVE" .

skill:ManualAdjustmentSKILL
    a skill:SKILLDefinition , owl:NamedIndividual ;
    rdfs:label "人工调账SKILL"@zh , "Manual Adjustment SKILL"@en ;
    skill:hasSKILLName "manual_adjustment_v2" ;
    skill:hasSKILLVersion "2.0.0" ;
    skill:hasSKILLOntologyURI "https://ontology.mof.gov.cn/sasac/accounting/" ;
    skill:hasSKILLStatus "ACTIVE" .

skill:ComplianceCheckSKILL
    a skill:SKILLDefinition , owl:NamedIndividual ;
    rdfs:label "合规检查SKILL"@zh , "Compliance Check SKILL"@en ;
    skill:hasSKILLName "compliance_check_v4" ;
    skill:hasSKILLVersion "4.0.0" ;
    skill:hasSKILLOntologyURI "https://ontology.mof.gov.cn/sasac/compliance/" ;
    skill:hasSKILLStatus "ACTIVE" .

skill:ERPSyncSKILL
    a skill:SKILLDefinition , owl:NamedIndividual ;
    rdfs:label "ERP数据同步SKILL"@zh , "ERP Data Sync SKILL"@en ;
    skill:hasSKILLName "erp_sync_v5" ;
    skill:hasSKILLVersion "5.0.0" ;
    skill:hasSKILLOntologyURI "https://ontology.mof.gov.cn/sasac/erp/" ;
    skill:hasSKILLStatus "ACTIVE" .

# ── 5.2 Distributed Lock & Consensus ─────────────────────────────────────
skill:DistributedSKILLLock
    a owl:Class ;
    rdfs:label "SKILL分布式锁"@zh , "Distributed SKILL Lock"@en ;
    rdfs:subClassOf skill:AgentSKILLConsistency ;
    rdfs:comment
        "SKILL更新时使用Raft共识算法获取分布式锁，确保同一时刻只有一个版本的SKILL处于活跃状态。所有Agent读取同一个Leader节点的SKILL定义，避免脑裂（split-brain）。"@zh ,
        "SKILL updates use Raft consensus to acquire distributed locks, ensuring only one SKILL version is active at any moment. All agents read SKILL definitions from the same Leader node, avoiding split-brain."@en .

skill:hasLockHolder       a owl:DatatypeProperty ; rdfs:label "锁持有者"@zh , "Lock Holder"@en ; rdfs:domain skill:DistributedSKILLLock ; rdfs:range xsd:string .
skill:hasLockTTLSeconds   a owl:DatatypeProperty ; rdfs:label "锁有效期(秒)"@zh , "Lock TTL (seconds)"@en ; rdfs:domain skill:DistributedSKILLLock ; rdfs:range xsd:integer .
skill:hasLockAcquiredAt   a owl:DatatypeProperty ; rdfs:label "锁获取时间"@zh , "Lock Acquired At"@en ; rdfs:domain skill:DistributedSKILLLock ; rdfs:range xsd:dateTime .

# ── 5.3 Capability Negotiation ────────────────────────────────────────────
skill:CapabilityNegotiation
    a owl:Class ;
    rdfs:label "能力协商"@zh , "Capability Negotiation"@en ;
    rdfs:subClassOf skill:AgentSKILLConsistency ;
    rdfs:comment
        "多智能体协作前须进行能力协商：各Agent广播自己的SKILL版本哈希，协调者选择公共最低版本或要求Agent升级后再协作。"@zh ,
        "Before multi-agent collaboration, agents broadcast their SKILL version hashes; coordinator selects common minimum version or requires agents to upgrade before collaboration."@en .

skill:hasAdvertisedSKILLs  a owl:DatatypeProperty ; rdfs:label "广播的SKILL列表"@zh , "Advertised SKILL List"@en ; rdfs:domain skill:CapabilityNegotiation ; rdfs:range xsd:string .
skill:hasNegotiatedVersion  a owl:DatatypeProperty ; rdfs:label "协商确定版本"@zh , "Negotiated Version"@en ; rdfs:domain skill:CapabilityNegotiation ; rdfs:range xsd:string .
skill:hasNegotiationStatus  a owl:DatatypeProperty ; rdfs:label "协商状态"@zh , "Negotiation Status"@en ; rdfs:domain skill:CapabilityNegotiation ; rdfs:range xsd:string ;
    rdfs:comment "AGREED | UPGRADING | INCOMPATIBLE | FALLBACK"@en .

# ── 5.4 SKILL Health Monitoring ───────────────────────────────────────────
skill:SKILLHealthMonitor
    a owl:Class ;
    rdfs:label "SKILL健康监控"@zh , "SKILL Health Monitor"@en ;
    rdfs:subClassOf skill:AgentSKILLConsistency ;
    rdfs:comment
        "持续监控所有Agent实例的SKILL版本一致性。发现版本漂移时立即隔离漂移节点，强制重新拉取最新SKILL版本。"@zh ,
        "Continuously monitors SKILL version consistency across all agent instances. Immediately isolates drifted nodes on detection and forces re-pull of latest SKILL version."@en .

skill:hasDriftDetectionInterval a owl:DatatypeProperty ; rdfs:label "漂移检测间隔(秒)"@zh , "Drift Detection Interval (seconds)"@en ; rdfs:domain skill:SKILLHealthMonitor ; rdfs:range xsd:integer .
skill:hasMaxToleratedDriftMs    a owl:DatatypeProperty ; rdfs:label "最大容忍漂移时间(ms)"@zh , "Max Tolerated Drift (ms)"@en ; rdfs:domain skill:SKILLHealthMonitor ; rdfs:range xsd:integer .

# ==============================================================================
# PART 6: ADDITIONAL RELIABILITY & CONSISTENCY PATTERNS
# 其他可靠性与一致性机制
# ==============================================================================

# ── 6.1 CQRS — Command Query Responsibility Segregation ───────────────────
rel:CQRSPattern
    a owl:Class ;
    rdfs:label "命令查询职责分离（CQRS）"@zh , "Command Query Responsibility Segregation (CQRS)"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "写操作（调账·审批·交易）走命令总线，通过事件溯源持久化；读操作（查询·报表·穿透分析）走查询端，基于投影视图。分离保证写高一致性+读高性能。"@zh ,
        "Write operations (adjustments · approvals · transactions) go through command bus and persist via event sourcing; read operations (queries · reports · penetration analysis) go through query side with projection views. Separation ensures high write consistency + high read performance."@en .

rel:CommandBus
    a owl:Class ;
    rdfs:label "命令总线"@zh , "Command Bus"@en ;
    rdfs:subClassOf rel:CQRSPattern .

rel:QueryProjection
    a owl:Class ;
    rdfs:label "查询投影"@zh , "Query Projection"@en ;
    rdfs:subClassOf rel:CQRSPattern ;
    rdfs:comment "从事件流构建的只读视图，专为查询优化，可与SPARQL端点集成。"@zh ,
                 "Read-only views built from event streams, optimized for queries, integrable with SPARQL endpoints."@en .

rel:EventualConsistencyWindow
    a owl:DatatypeProperty ;
    rdfs:label "最终一致性窗口(ms)"@zh , "Eventual Consistency Window (ms)"@en ;
    rdfs:domain rel:QueryProjection ;
    rdfs:range xsd:integer ;
    rdfs:comment "写命令执行后，查询投影的最大延迟时间（如<500ms）。超出则标记数据为stale。"@zh ,
                 "Maximum delay for query projection after write command (e.g., <500ms). Exceeding marks data as stale."@en .

# ── 6.2 Vector Clocks for Distributed State ───────────────────────────────
cons:VectorClock
    a owl:Class ;
    rdfs:label "向量时钟"@zh , "Vector Clock"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "多数据中心（境内+境外）并发更新时使用向量时钟解决因果一致性问题，避免脑裂导致的数据冲突。每个节点维护自己的时钟分量。"@zh ,
        "Uses vector clocks for causal consistency in multi-datacenter (domestic + overseas) concurrent updates, avoiding split-brain data conflicts. Each node maintains its own clock component."@en .

cons:hasVectorClockValue   a owl:DatatypeProperty ; rdfs:label "向量时钟值"@zh , "Vector Clock Value"@en ; rdfs:domain cons:VectorClock ; rdfs:range xsd:string ;
    rdfs:comment "JSON格式：{nodeId: counter}，如 {\"beijing\":5, \"shanghai\":3, \"hongkong\":7}"@zh .

# ── 6.3 Two-Phase Commit for Critical Transactions ────────────────────────
cons:TwoPhaseCommit
    a owl:Class ;
    rdfs:label "两阶段提交（2PC）"@zh , "Two-Phase Commit (2PC)"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "仅用于绝对强一致性需求的场景（如：跨境资金实时清算·SJYZD超高阈值审批）。因性能代价高，一般情况优先使用Saga。"@zh ,
        "Used only for absolute strong consistency scenarios (e.g., cross-border real-time settlement · ultra-high SJYZD threshold approvals). Due to high performance cost, Saga is preferred in general."@en .

# ── 6.4 CRDTs for Collaborative Editing ──────────────────────────────────
cons:CRDTLayer
    a owl:Class ;
    rdfs:label "无冲突复制数据类型（CRDT）"@zh , "Conflict-free Replicated Data Types (CRDT)"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "多用户同时编辑同一预算/报告时，使用CRDT确保无需协调的自动合并。适用：协同报表编制·多人预算录入·共享合规清单。"@zh ,
        "When multiple users edit the same budget/report simultaneously, CRDTs ensure automatic conflict-free merging without coordination. Suitable for: collaborative report preparation · multi-user budget entry · shared compliance checklists."@en .

# ── 6.5 Data Lineage Tracking ─────────────────────────────────────────────
cons:DataLineage
    a owl:Class ;
    rdfs:label "数据血缘追踪"@zh , "Data Lineage Tracking"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "每个财务数据项追踪其来源（ERP原始数据·人工调账·自动计算）、经过的处理步骤和最终呈现形式。支持穿透追溯和审计。基于W3C PROV-O规范。"@zh ,
        "Every financial data item tracks its source (ERP raw · manual adjustment · auto-calculation), processing steps, and final representation. Supports penetration traceability and audit. Based on W3C PROV-O."@en .

cons:hasProvenanceActivity a owl:ObjectProperty ; rdfs:label "溯源活动"@zh , "Provenance Activity"@en ; rdfs:domain cons:DataLineage ; rdfs:range prov:Activity .
cons:hasDataSource         a owl:DatatypeProperty ; rdfs:label "数据来源"@zh , "Data Source"@en ; rdfs:domain cons:DataLineage ; rdfs:range xsd:string .
cons:hasTransformationLog  a owl:DatatypeProperty ; rdfs:label "转换日志"@zh , "Transformation Log"@en ; rdfs:domain cons:DataLineage ; rdfs:range xsd:string .

# ── 6.6 Byzantine Fault Tolerance for Multi-Bank Settlement ──────────────
cons:ByzantineFaultTolerance
    a owl:Class ;
    rdfs:label "拜占庭容错（跨行清算）"@zh , "Byzantine Fault Tolerance (Multi-Bank Settlement)"@en ;
    rdfs:subClassOf cons:ManualAdjustmentConsistency ;
    rdfs:comment
        "多家银行参与的大额清算场景（如央企集团跨行转账）使用BFT共识，即使部分节点恶意或故障也能保证结果正确性。"@zh ,
        "BFT consensus for multi-bank large-value settlement (e.g., SOE group cross-bank transfers), ensuring correctness even if some nodes are malicious or faulty."@en .

# ── 6.7 Chaos Engineering ─────────────────────────────────────────────────
rel:ChaosEngineering
    a owl:Class ;
    rdfs:label "混沌工程（主动可靠性验证）"@zh , "Chaos Engineering (Proactive Reliability Validation)"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "定期主动注入故障：随机终止服务·延迟增加·网络分区·磁盘满。验证系统在故障下的实际可靠性，防止汇丰级SLA在压力下退化。"@zh ,
        "Regularly inject faults proactively: random service termination · latency injection · network partition · disk full. Validates actual system reliability under failure to prevent HSBC-grade SLA degradation under stress."@en .

rel:ChaosFaultType
    a owl:Class ;
    rdfs:label "混沌故障类型"@zh , "Chaos Fault Type"@en .

rel:LatencyInjection    a rel:ChaosFaultType , owl:NamedIndividual ; rdfs:label "延迟注入"@zh , "Latency Injection"@en .
rel:ServiceTermination  a rel:ChaosFaultType , owl:NamedIndividual ; rdfs:label "服务终止"@zh , "Service Termination"@en .
rel:NetworkPartition    a rel:ChaosFaultType , owl:NamedIndividual ; rdfs:label "网络分区"@zh , "Network Partition"@en .
rel:DiskFailure         a rel:ChaosFaultType , owl:NamedIndividual ; rdfs:label "磁盘故障"@zh , "Disk Failure"@en .
rel:DataCorruption      a rel:ChaosFaultType , owl:NamedIndividual ; rdfs:label "数据损坏注入"@zh , "Data Corruption Injection"@en .

# ── 6.8 SLA Observability ─────────────────────────────────────────────────
rel:SLAObservability
    a owl:Class ;
    rdfs:label "SLA可观测性"@zh , "SLA Observability"@en ;
    rdfs:subClassOf rel:InterfaceReliabilityFramework ;
    rdfs:comment
        "全链路可观测性三支柱：指标（Metrics）·日志（Logs）·追踪（Traces）。RED指标（Rate·Errors·Duration）实时监控，确保汇丰级99.99%可用性。"@zh ,
        "Three pillars of full-chain observability: Metrics · Logs · Traces. RED metrics (Rate · Errors · Duration) real-time monitoring to ensure HSBC-grade 99.99% availability."@en .

rel:hasErrorBudgetMinutes
    a owl:DatatypeProperty ;
    rdfs:label "错误预算（分钟/年）"@zh , "Error Budget (minutes/year)"@en ;
    rdfs:domain rel:SLAObservability ;
    rdfs:range xsd:integer ;
    rdfs:comment "99.99%可用性 = 每年52.6分钟停机预算。超出则暂停新功能发布，全力修复稳定性。"@zh ,
                 "99.99% availability = 52.6 minutes downtime budget/year. Exceeding freezes new feature releases, focusing entirely on stability."@en .

# ==============================================================================
# CROSS-MODULE PROPERTIES
# ==============================================================================

cons:hasOptimisticLock    a owl:ObjectProperty ; rdfs:label "乐观锁"@zh , "Optimistic Lock"@en ; rdfs:domain acct:JournalEntry ; rdfs:range cons:OptimisticLock .
cons:hasFourEyesApproval  a owl:ObjectProperty ; rdfs:label "四眼审批"@zh , "Four-Eyes Approval"@en ; rdfs:domain acct:JournalEntry ; rdfs:range cons:FourEyesApproval .
cons:hasCompensatingEntry a owl:ObjectProperty ; rdfs:label "补偿凭证"@zh , "Compensating Entry"@en ; rdfs:domain acct:JournalEntry ; rdfs:range cons:CompensatingEntryMechanism .
rel:hasIdempotencyKey     a owl:ObjectProperty ; rdfs:label "幂等键"@zh , "Idempotency Key"@en ; rdfs:domain acct:JournalEntry ; rdfs:range rel:IdempotencyKey .
ver:hasVersionContract    a owl:ObjectProperty ; rdfs:label "版本锁定合约"@zh , "Version Lock Contract"@en ; rdfs:domain oaas:OntologyAsAService ; rdfs:range ver:VersionLockContract .
skill:hasSKILLBinding     a owl:ObjectProperty ; rdfs:label "SKILL绑定"@zh , "SKILL Binding"@en ; rdfs:domain agent:AgentInstance ; rdfs:range skill:SKILLDefinition .
nlalign:hasGrounding      a owl:ObjectProperty ; rdfs:label "语义接地"@zh , "Semantic Grounding"@en ; rdfs:domain nlp:SynonymGroup ; rdfs:range nlalign:GroundedTerm .

agent:AgentInstance
    a owl:Class ;
    rdfs:label "智能体实例"@zh , "Agent Instance"@en ;
    rdfs:subClassOf skill:AgentSKILLConsistency ;
    rdfs:comment "运行中的智能体实例，须绑定确定版本的SKILL集合并向注册表报告心跳。"@zh ,
                 "Running agent instance; must bind to a definite SKILL version set and report heartbeats to registry."@en .

agent:hasAgentID          a owl:DatatypeProperty ; rdfs:label "智能体ID"@zh , "Agent ID"@en ; rdfs:domain agent:AgentInstance ; rdfs:range xsd:string .
agent:hasAgentVersion     a owl:DatatypeProperty ; rdfs:label "智能体版本"@zh , "Agent Version"@en ; rdfs:domain agent:AgentInstance ; rdfs:range xsd:string .
agent:hasOntologyVersion  a owl:DatatypeProperty ; rdfs:label "绑定本体版本"@zh , "Bound Ontology Version"@en ; rdfs:domain agent:AgentInstance ; rdfs:range xsd:string .
agent:hasLastHeartbeat    a owl:DatatypeProperty ; rdfs:label "最后心跳时间"@zh , "Last Heartbeat"@en ; rdfs:domain agent:AgentInstance ; rdfs:range xsd:dateTime .

# SHACL: Agent must have consistent ontology version
agent:AgentInstanceShape
    a sh:NodeShape ;
    sh:targetClass agent:AgentInstance ;
    rdfs:label "智能体实例一致性约束"@zh , "Agent Instance Consistency Shape"@en ;
    sh:property [
        sh:path agent:hasOntologyVersion ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "每个智能体实例必须声明绑定的本体版本。"@zh ,
                   "Every agent instance must declare its bound ontology version."@en
    ] ;
    sh:property [
        sh:path agent:hasLastHeartbeat ;
        sh:minCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "智能体实例必须定期报告心跳。"@zh ,
                   "Agent instance must regularly report heartbeat."@en
    ] .

# Four-eyes: reviewer cannot be preparer
cons:FourEyesShape
    a sh:NodeShape ;
    sh:targetClass cons:FourEyesApproval ;
    sh:property [
        sh:path cons:isPreparerReviewerSame ;
        sh:hasValue "false"^^xsd:boolean ;
        sh:message "【严重违规】制单人与审核人不得为同一人！"@zh ,
                   "[CRITICAL VIOLATION] Preparer and reviewer must not be the same person!"@en
    ] .

# ==============================================================================
# INSTANCES: Default policies
# ==============================================================================
rel:DefaultCircuitBreaker
    a rel:CircuitBreakerPolicy , owl:NamedIndividual ;
    rdfs:label "默认断路器策略"@zh , "Default Circuit Breaker Policy"@en ;
    rel:hasFailureThreshold "0.5"^^xsd:decimal ;
    rel:hasOpenDurationSeconds "30"^^xsd:integer .

ver:V4_1VersionRecord
    a ver:OntologyVersionRecord , owl:NamedIndividual ;
    rdfs:label "SASAC-GOV v4.1版本记录"@zh , "SASAC-GOV v4.1 Version Record"@en ;
    ver:hasVersionURI "https://ontology.mof.gov.cn/sasac/v4.1"^^xsd:anyURI ;
    ver:hasVersionTag "4.1.0" ;
    ver:hasPublishedDate "2025-03-26"^^xsd:date ;
    ver:hasOntologyHash "sha256-placeholder-4.1.0" .

rel:DefaultSLAObservability
    a rel:SLAObservability , owl:NamedIndividual ;
    rdfs:label "默认SLA可观测性配置"@zh , "Default SLA Observability Config"@en ;
    rel:hasErrorBudgetMinutes "52"^^xsd:integer .

# ==============================================================================
# END OF RELIABILITY & CONSISTENCY MODULE v4.1.0
# Classes: 90+ | Individuals: 60+ | Properties: 70+
# ==============================================================================

# ==============================================================================
# PART 3: SHACL DATA QUALITY SHAPES
# ==============================================================================
# ==============================================================================
# SASAC-GOV SHACL SHAPES — Data Quality & Business Rule Validation
# 国有资产监管语义本体 SHACL数据约束与业务规则验证
# ==============================================================================
# Version: 4.0.0
# Conformance: W3C SHACL 1.0  |  OWL2  |  RDF 1.1
# Purpose: Machine-enforceable data quality rules for all SOE regulatory data
# ==============================================================================


# ── Shape 1: SOE Enterprise Core Identity ─────────────────────────────────
sasac:SOECoreShape
    a sh:NodeShape ;
    sh:targetClass ent:StateOwnedEnterprise ;
    rdfs:label "国有企业核心标识约束"@zh , "SOE Core Identity Shape"@en ;
    dcterms:description "Every SOE must have USCC, investor representative, and regulatory authority."@en ;

    sh:property [
        sh:path ent:hasUnifiedSocialCreditCode ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[0-9A-Z]{18}$" ;
        sh:message "统一社会信用代码必须为18位字母数字，且唯一。"@zh ,
                   "Unified Social Credit Code must be exactly 18 alphanumeric characters and unique."@en
    ] ;

    sh:property [
        sh:path ent:hasInvestorRepresentative ;
        sh:minCount 1 ;
        sh:class sasac:RegulatoryAuthority ;
        sh:message "每个国有企业必须有至少一个出资人代表机构。"@zh ,
                   "Every SOE must have at least one investor representative authority."@en
    ] ;

    sh:property [
        sh:path ent:hasStateEquityRatio ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "国有股权比例必须在0.0到1.0之间。"@zh ,
                   "State equity ratio must be between 0.0 and 1.0."@en
    ] ;

    sh:property [
        sh:path ent:hasControlLevel ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:maxInclusive 10 ;
        sh:message "管理层级必须在1到10之间（1=集团总部）。"@zh ,
                   "Management level must be between 1 and 10 (1=group HQ)."@en
    ] .

# ── Shape 2: Capital Transaction Validation ────────────────────────────────
sasac:CapitalTransactionShape
    a sh:NodeShape ;
    sh:targetClass cap:CapitalTransaction ;
    rdfs:label "资金交易完整性约束"@zh , "Capital Transaction Integrity Shape"@en ;

    sh:property [
        sh:path cap:hasTransactionAmount ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minExclusive 0.0 ;
        sh:message "交易金额必须为正数。"@zh , "Transaction amount must be positive."@en
    ] ;

    sh:property [
        sh:path cap:hasTransactionDate ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:dateTime ;
        sh:message "交易日期时间不能为空。"@zh , "Transaction datetime is required."@en
    ] ;

    sh:property [
        sh:path cap:hasTransactionCurrency ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[A-Z]{3}$" ;
        sh:message "币种必须为ISO 4217三字母代码（如CNY、USD）。"@zh ,
                   "Currency must be a 3-letter ISO 4217 code (e.g., CNY, USD)."@en
    ] .

# ── Shape 3: Large Amount Transaction SJYZD Trigger ───────────────────────
sasac:LargeAmountTransactionShape
    a sh:NodeShape ;
    sh:targetClass cap:LargeAmountTransaction ;
    rdfs:label "大额资金交易三重一大触发约束"@zh , "Large Amount Transaction SJYZD Trigger Shape"@en ;

    sh:property [
        sh:path sasac:triggersSJYZD ;
        sh:minCount 1 ;
        sh:class sjyzd:SJYZDDecisionRecord ;
        sh:message "【违规警告】大额资金交易必须关联三重一大决策记录，否则拒绝处理。"@zh ,
                   "[VIOLATION] Large amount transaction must be linked to a SJYZD decision record; rejected otherwise."@en
    ] .

# ── Shape 4: Journal Entry Double-Entry Balance ────────────────────────────
sasac:JournalEntryShape
    a sh:NodeShape ;
    sh:targetClass acct:JournalEntry ;
    rdfs:label "记账凭证完整性约束"@zh , "Journal Entry Completeness Shape"@en ;

    sh:property [
        sh:path acct:hasVoucherNumber ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "凭证号不能为空。"@zh , "Voucher number is required."@en
    ] ;

    sh:property [
        sh:path acct:hasAccountingPeriod ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "会计期间不能为空。"@zh , "Accounting period is required."@en
    ] .

# ── Shape 5: SJYZD Decision Record Completeness ───────────────────────────
sasac:SJYZDRecordShape
    a sh:NodeShape ;
    sh:targetClass sjyzd:SJYZDDecisionRecord ;
    rdfs:label "三重一大决策记录完整性约束"@zh , "SJYZD Decision Record Completeness Shape"@en ;

    sh:property [
        sh:path sjyzd:hasDecisionDate ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:message "三重一大决策日期不能为空。"@zh , "SJYZD decision date is required."@en
    ] ;

    sh:property [
        sh:path sjyzd:hasDecisionOutcome ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "三重一大决策结果记录不能为空。"@zh , "SJYZD decision outcome record is required."@en
    ] ;

    sh:property [
        sh:path sjyzd:hasDecisionMatter ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "三重一大决策事项说明不能为空。"@zh , "SJYZD decision matter description is required."@en
    ] .

# ── Shape 6: Compliance Incident Reporting ────────────────────────────────
sasac:ComplianceIncidentShape
    a sh:NodeShape ;
    sh:targetClass comp:ComplianceIncident ;
    rdfs:label "合规事件报告约束"@zh , "Compliance Incident Reporting Shape"@en ;

    sh:property [
        sh:path comp:hasIncidentDate ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:message "合规事件日期不能为空。"@zh , "Compliance incident date is required."@en
    ] ;

    sh:property [
        sh:path comp:hasSeverityLevel ;
        sh:minCount 1 ;
        sh:class risk:RiskLevel ;
        sh:message "合规事件严重程度不能为空。"@zh , "Compliance incident severity level is required."@en
    ] .

# ── Shape 7: Budget Variance Warning ──────────────────────────────────────
sasac:BudgetVarianceShape
    a sh:NodeShape ;
    sh:targetClass bud:BudgetVarianceAnalysis ;
    rdfs:label "预算偏差分析约束"@zh , "Budget Variance Analysis Shape"@en ;

    sh:property [
        sh:path bud:hasVarianceThreshold ;
        sh:minCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "预算偏差阈值必须在0.0到1.0之间（如0.1代表10%）。"@zh ,
                   "Budget variance threshold must be between 0.0 and 1.0 (e.g., 0.1 = 10%)."@en
    ] .

# ── Shape 8: Overseas Subsidiary Governance ───────────────────────────────
sasac:OverseasSubsidiaryShape
    a sh:NodeShape ;
    sh:targetClass ent:OverseasSubsidiary ;
    rdfs:label "境外子公司治理约束"@zh , "Overseas Subsidiary Governance Shape"@en ;

    sh:property [
        sh:path ent:hasLEI ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[A-Z0-9]{20}$" ;
        sh:message "境外子公司必须有20位LEI编码（符合ISO 17442）。"@zh ,
                   "Overseas subsidiary must have a 20-character LEI (ISO 17442)."@en
    ] ;

    sh:property [
        sh:path sasac:hasOverseasOperation ;
        sh:minCount 1 ;
        sh:message "境外子公司必须关联境外业务监管记录。"@zh ,
                   "Overseas subsidiary must be linked to overseas supervision record."@en
    ] .

# ── Shape 9: NLQ Synonym Group Quality ────────────────────────────────────
sasac:SynonymGroupShape
    a sh:NodeShape ;
    sh:targetClass nlp:SynonymGroup ;
    rdfs:label "NLQ同义词组质量约束"@zh , "NLQ Synonym Group Quality Shape"@en ;

    sh:property [
        sh:path nlp:hasCanonicalTerm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message "同义词组必须有唯一的规范术语。"@zh , "Synonym group must have exactly one canonical term."@en
    ] ;

    sh:property [
        sh:path nlp:hasSynonym ;
        sh:minCount 2 ;
        sh:message "同义词组至少需要2个同义词（包含中英文）。"@zh ,
                   "Synonym group must have at least 2 synonyms (including Chinese and English)."@en
    ] ;

    sh:property [
        sh:path nlp:hasConfidenceThreshold ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.5 ;
        sh:maxInclusive 1.0 ;
        sh:message "置信阈值必须在0.5到1.0之间。"@zh , "Confidence threshold must be between 0.5 and 1.0."@en
    ] .

# ── Shape 10: OaaS SLA Validation ─────────────────────────────────────────
sasac:SLAShape
    a sh:NodeShape ;
    sh:targetClass oaas:ServiceLevelAgreement ;
    rdfs:label "SLA服务级别约束"@zh , "Service Level Agreement Shape"@en ;

    sh:property [
        sh:path oaas:hasAvailabilityTarget ;
        sh:minCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.99 ;
        sh:maxInclusive 1.0 ;
        sh:message "可用性目标不得低于99%（汇丰级要求99.99%）。"@zh ,
                   "Availability target must not be below 99% (HSBC-grade requires 99.99%)."@en
    ] ;

    sh:property [
        sh:path oaas:hasLatencyP99Ms ;
        sh:datatype xsd:integer ;
        sh:maxInclusive 500 ;
        sh:message "P99延迟不得超过500ms。"@zh , "P99 latency must not exceed 500ms."@en
    ] .

# ── Shape 11: ERP Mapping Rule Completeness ───────────────────────────────
sasac:ERPMappingShape
    a sh:NodeShape ;
    sh:targetClass erp:ERPMappingRule ;
    rdfs:label "ERP映射规则完整性约束"@zh , "ERP Mapping Rule Completeness Shape"@en ;

    sh:property [
        sh:path erp:hasSourceField ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "ERP映射规则必须指定源字段。"@zh , "ERP mapping rule must specify source field."@en
    ] ;

    sh:property [
        sh:path erp:hasTargetOntologyTerm ;
        sh:minCount 1 ;
        sh:message "ERP映射规则必须指定目标本体术语。"@zh ,
                   "ERP mapping rule must specify target ontology term."@en
    ] ;

    sh:property [
        sh:path erp:appliesToERP ;
        sh:minCount 1 ;
        sh:class erp:ERPSystem ;
        sh:message "ERP映射规则必须关联至少一个ERP系统。"@zh ,
                   "ERP mapping rule must reference at least one ERP system."@en
    ] .

# ── Shape 12: Penetration Supervision Coverage ────────────────────────────
sasac:PenetrationShape
    a sh:NodeShape ;
    sh:targetClass penet:PenetrativeSupervision ;
    rdfs:label "穿透监管覆盖率约束"@zh , "Penetrative Supervision Coverage Shape"@en ;

    sh:property [
        sh:path penet:hasPenetrationDepth ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 1 ;
        sh:message "穿透深度至少为1层。"@zh , "Penetration depth must be at least 1 level."@en
    ] ;

    sh:property [
        sh:path penet:hasCoverageRate ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "穿透覆盖率必须在0.0到1.0之间。"@zh ,
                   "Penetration coverage rate must be between 0.0 and 1.0."@en
    ] .

# ── Shape 13: State Equity Ratio Closed-World Assertion ───────────────────
sasac:StateEquityShape
    a sh:NodeShape ;
    sh:targetClass ent:StateControlledEnterprise ;
    rdfs:label "国有控股比例验证"@zh , "State-Controlled Enterprise Equity Shape"@en ;

    sh:property [
        sh:path ent:hasStateEquityRatio ;
        sh:minInclusive 0.5 ;
        sh:message "国有控股企业国有股权比例不得低于50%。"@zh ,
                   "State-controlled enterprises must have state equity ratio ≥ 50%."@en
    ] .

# ── Shape 14: Procurement Compliance Rate ─────────────────────────────────
sasac:ProcurementSpendShape
    a sh:NodeShape ;
    sh:targetClass proc:SpendAnalytics ;
    rdfs:label "合规采购率约束"@zh , "Compliant Procurement Rate Shape"@en ;

    sh:property [
        sh:path proc:hasComplianceProcurementRate ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "合规采购率必须在0到1之间（1=100%合规）。"@zh ,
                   "Compliant procurement rate must be between 0 and 1 (1 = 100% compliant)."@en
    ] .

# ==============================================================================
# END OF SHACL SHAPES — 14 shapes covering all critical regulatory domains
# ==============================================================================

# ==============================================================================
# PART 4: GAP-FILL MODULES (v4.1 New)
# ==============================================================================

# ==============================================================================
# GAP MODULE 1: 国有资本运营 — STATE CAPITAL OPERATIONS
# 国有资本投资公司·运营公司体制
# ==============================================================================

capop:StateCapitalOperations
    a owl:Class ;
    rdfs:label "国有资本运营体系"@zh , "State Capital Operations System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国有资本投资公司·运营公司改革，实现以管资本为主的国资监管体制。"@zh ,
                 "State capital investment and operational company reform for asset-focused SOE supervision."@en .

capop:StateCapitalInvestmentCompany
    a owl:Class ;
    rdfs:label "国有资本投资公司"@zh , "State Capital Investment Company"@en ;
    rdfs:subClassOf capop:StateCapitalOperations ;
    rdfs:comment "承接战略性布局投资职能，落实国家战略。如：国投·中粮·招商局。"@zh ,
                 "Assumes strategic investment functions to implement national strategies. E.g.: SDI, COFCO, CMG."@en .

capop:StateCapitalOperationalCompany
    a owl:Class ;
    rdfs:label "国有资本运营公司"@zh , "State Capital Operational Company"@en ;
    rdfs:subClassOf capop:StateCapitalOperations ;
    rdfs:comment "以优化国有资本布局、提升国有资本回报为主要目标。如：中国国新·诚通集团。"@zh ,
                 "Focuses on optimizing state capital allocation and improving returns. E.g., Guoxin, Chengtong."@en .

capop:CapitalOperationMode
    a owl:Class ;
    rdfs:label "资本运营方式"@zh , "Capital Operation Mode"@en ;
    rdfs:subClassOf capop:StateCapitalOperations .

capop:MergerAcquisition     a capop:CapitalOperationMode , owl:NamedIndividual ; rdfs:label "兼并重组"@zh , "Merger and Acquisition"@en .
capop:CapitalInjection       a capop:CapitalOperationMode , owl:NamedIndividual ; rdfs:label "资本注入"@zh , "Capital Injection"@en .
capop:AssetRestructuring     a capop:CapitalOperationMode , owl:NamedIndividual ; rdfs:label "资产重组"@zh , "Asset Restructuring"@en .
capop:ListingAndIPO          a capop:CapitalOperationMode , owl:NamedIndividual ; rdfs:label "上市融资"@zh , "Listing and IPO"@en .
capop:StateCapitalReturn     a capop:CapitalOperationMode , owl:NamedIndividual ; rdfs:label "国有资本收益上缴"@zh , "State Capital Return Remittance"@en .

capop:ManageByCapitalPrinciple
    a owl:Class ;
    rdfs:label "以管资本为主原则"@zh , "Manage-by-Capital Principle"@en ;
    rdfs:subClassOf capop:StateCapitalOperations ;
    rdfs:comment "从管企业向管资本转变，授权放权清单制度，减少对企业经营的直接干预。"@zh ,
                 "Shift from managing enterprises to managing capital; delegation list system, reducing direct operational intervention."@en .

capop:DelegationAuthorizationList
    a owl:Class ;
    rdfs:label "授权放权清单"@zh , "Delegation and Authorization List"@en ;
    rdfs:subClassOf capop:ManageByCapitalPrinciple .

# ==============================================================================
# GAP MODULE 2: 产权管理与混合所有制改革 — PROPERTY RIGHTS & MIXED OWNERSHIP
# ==============================================================================

prop:PropertyRightsManagement
    a owl:Class ;
    rdfs:label "产权管理"@zh , "Property Rights Management"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国有资产产权登记·转让·评估·保护及混合所有制改革的监管体系。"@zh ,
                 "Regulatory system for state asset property rights registration, transfer, assessment, protection and mixed-ownership reform."@en .

prop:PropertyRightsRegistration
    a owl:Class ;
    rdfs:label "产权登记"@zh , "Property Rights Registration"@en ;
    rdfs:subClassOf prop:PropertyRightsManagement ;
    rdfs:comment "国有企业须在国资委全国产权登记系统进行产权登记，确保账实相符。"@zh ,
                 "SOEs must register property rights in SASAC's national property rights registration system to ensure records match assets."@en .

prop:PropertyRightsTransfer
    a owl:Class ;
    rdfs:label "国有产权转让"@zh , "State-Owned Property Rights Transfer"@en ;
    rdfs:subClassOf prop:PropertyRightsManagement ;
    rdfs:comment "国有产权转让须在北交所·上交所·产权交易所等机构公开挂牌，防止国有资产流失。"@zh ,
                 "State-owned property rights transfers must be listed publicly on BSE, SSE, or property rights exchanges to prevent state asset dissipation."@en .

prop:AssetValuation
    a owl:Class ;
    rdfs:label "国有资产评估"@zh , "State Asset Valuation"@en ;
    rdfs:subClassOf prop:PropertyRightsManagement ;
    rdfs:comment "产权转让·增资·重组等须经具备资质的评估机构评估，防止低估流失。"@zh ,
                 "Transfers, capital increases, and restructuring must be assessed by qualified appraisal firms to prevent undervaluation."@en .

prop:MixedOwnershipReform
    a owl:Class ;
    rdfs:label "混合所有制改革"@zh , "Mixed-Ownership Reform"@en ;
    rdfs:subClassOf prop:PropertyRightsManagement ;
    rdfs:comment "引入社会资本参与国有企业股权，形成股权多元化的混合所有制企业。须保持国有资本控股地位。"@zh ,
                 "Introducing private capital into SOE equity to form diversified mixed-ownership enterprises while maintaining state capital control."@en .

prop:MixedOwnershipEnterprise
    a owl:Class ;
    rdfs:label "混合所有制企业"@zh , "Mixed-Ownership Enterprise"@en ;
    rdfs:subClassOf ent:StateOwnedEnterprise ;
    rdfs:subClassOf prop:MixedOwnershipReform .

prop:hasPrivateCapitalRatio
    a owl:DatatypeProperty ;
    rdfs:label "社会资本持股比例"@zh , "Private Capital Equity Ratio"@en ;
    rdfs:domain prop:MixedOwnershipEnterprise ;
    rdfs:range xsd:decimal .

prop:ShandongModelMixedReform
    a prop:MixedOwnershipReform , owl:NamedIndividual ;
    rdfs:label "山东国企混改模式"@zh , "Shandong SOE Mixed Reform Model"@en .

# ==============================================================================
# GAP MODULE 3: 薪酬监管 — COMPENSATION SUPERVISION
# 限薪令·薪酬管理办法·绩效薪酬联动
# ==============================================================================

wage:CompensationSupervision
    a owl:Class ;
    rdfs:label "薪酬监管"@zh , "Compensation Supervision"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "依据《中央企业负责人经营业绩考核办法》及限薪规定，对国有企业负责人薪酬的监督管理。"@zh ,
                 "Supervision of SOE leader compensation per the Central Enterprise Performance Assessment Measures and salary cap regulations."@en .

wage:SalaryCap
    a owl:Class ;
    rdfs:label "限薪规定"@zh , "Salary Cap Regulation"@en ;
    rdfs:subClassOf wage:CompensationSupervision ;
    rdfs:comment "中央企业负责人薪酬不超过企业在职职工平均薪酬的8倍（特殊情况可适当提高）。"@zh ,
                 "Central SOE leader compensation must not exceed 8 times the average in-service employee salary (with exceptions for special circumstances)."@en .

wage:hasSalaryCapMultiple
    a owl:DatatypeProperty ;
    rdfs:label "薪酬倍数上限"@zh , "Salary Cap Multiple"@en ;
    rdfs:domain wage:SalaryCap ;
    rdfs:range xsd:decimal .

wage:PerformanceLinkedCompensation
    a owl:Class ;
    rdfs:label "绩效薪酬联动"@zh , "Performance-Linked Compensation"@en ;
    rdfs:subClassOf wage:CompensationSupervision ;
    rdfs:comment "薪酬与一利五率考核结果挂钩，考核结果不达标则扣减绩效薪酬。"@zh ,
                 "Compensation linked to One-Profit Five-Rate assessment results; below-target results trigger compensation reduction."@en .

wage:CompensationStructure
    a owl:Class ;
    rdfs:label "薪酬结构"@zh , "Compensation Structure"@en ;
    rdfs:subClassOf wage:CompensationSupervision .

wage:BaseSalary      a wage:CompensationStructure , owl:NamedIndividual ; rdfs:label "基本年薪"@zh , "Base Annual Salary"@en .
wage:PerformancePay  a wage:CompensationStructure , owl:NamedIndividual ; rdfs:label "绩效年薪"@zh , "Performance Annual Salary"@en .
wage:LongTermIncentive a wage:CompensationStructure , owl:NamedIndividual ; rdfs:label "长期激励（股权·超额利润分享）"@zh , "Long-term Incentive (Equity/Excess Profit Sharing)"@en .

wage:CompensationDisclosure
    a owl:Class ;
    rdfs:label "薪酬信息披露"@zh , "Compensation Information Disclosure"@en ;
    rdfs:subClassOf wage:CompensationSupervision ;
    rdfs:comment "上市国有企业须按证监会要求披露高管薪酬，非上市央企向国资委报告。"@zh ,
                 "Listed SOEs must disclose executive compensation per CSRC requirements; unlisted central SOEs report to SASAC."@en .

# ==============================================================================
# GAP MODULE 4: 安全生产监管 — PRODUCTION SAFETY SUPERVISION
# 双重预防机制·隐患排查·应急管理
# ==============================================================================

safety:ProductionSafetySupervision
    a owl:Class ;
    rdfs:label "安全生产监管"@zh , "Production Safety Supervision"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "依据《安全生产法》·国资委安全生产管理规定，对国有企业生产安全的监督管理。"@zh ,
                 "Supervision of SOE production safety per the Production Safety Law and SASAC safety management regulations."@en .

safety:DualPreventionMechanism
    a owl:Class ;
    rdfs:label "双重预防机制"@zh , "Dual Prevention Mechanism"@en ;
    rdfs:subClassOf safety:ProductionSafetySupervision ;
    rdfs:comment "风险分级管控+隐患排查治理双重预防机制，构建安全生产防线。"@zh ,
                 "Risk-level control + hazard investigation dual prevention mechanism to build production safety lines of defense."@en .

safety:RiskLevelControl
    a owl:Class ;
    rdfs:label "风险分级管控"@zh , "Risk Level Control"@en ;
    rdfs:subClassOf safety:DualPreventionMechanism .

safety:HazardInvestigation
    a owl:Class ;
    rdfs:label "隐患排查治理"@zh , "Hazard Investigation and Rectification"@en ;
    rdfs:subClassOf safety:DualPreventionMechanism .

safety:SafetyRiskLevel
    a owl:Class ;
    rdfs:label "安全风险等级"@zh , "Safety Risk Level"@en .

safety:RedRisk    a safety:SafetyRiskLevel , owl:NamedIndividual ; rdfs:label "红色重大风险"@zh , "Red Major Risk"@en .
safety:OrangeRisk a safety:SafetyRiskLevel , owl:NamedIndividual ; rdfs:label "橙色较大风险"@zh , "Orange Significant Risk"@en .
safety:YellowRisk a safety:SafetyRiskLevel , owl:NamedIndividual ; rdfs:label "黄色一般风险"@zh , "Yellow General Risk"@en .
safety:BlueRisk   a safety:SafetyRiskLevel , owl:NamedIndividual ; rdfs:label "蓝色低风险"@zh , "Blue Low Risk"@en .

safety:EmergencyResponsePlan
    a owl:Class ;
    rdfs:label "应急预案"@zh , "Emergency Response Plan"@en ;
    rdfs:subClassOf safety:ProductionSafetySupervision .

safety:SafetyAccidentReport
    a owl:Class ;
    rdfs:label "安全事故报告"@zh , "Safety Accident Report"@en ;
    rdfs:subClassOf safety:ProductionSafetySupervision ;
    rdfs:comment "生产安全事故须按规定时限向安监·国资委等主管部门报告，重大事故须直报。"@zh ,
                 "Production safety accidents must be reported to safety supervision and SASAC within prescribed timeframes; major accidents require direct reporting."@en .

safety:SafetyProductionKPI
    a owl:Class ;
    rdfs:label "安全生产考核指标"@zh , "Safety Production KPI"@en ;
    rdfs:subClassOf safety:ProductionSafetySupervision ;
    rdfs:comment "安全生产指标纳入央企负责人经营业绩考核，发生重大事故则一票否决。"@zh ,
                 "Safety production indicators included in central SOE leader performance assessment; major accidents trigger one-vote veto."@en .

safety:OneVetoRule
    a owl:Class ;
    rdfs:label "安全生产一票否决"@zh , "Safety Production One-Vote Veto"@en ;
    rdfs:subClassOf safety:SafetyProductionKPI ;
    rdfs:comment "发生特别重大事故，当年绩效考核直接定为不合格，主要负责人须承担相应责任。"@zh ,
                 "Occurrence of extremely serious accidents results in automatic unsatisfactory assessment; key leaders bear corresponding responsibilities."@en .

# ==============================================================================
# GAP MODULE 5: 信用管理 — CREDIT MANAGEMENT
# 企业信用评级·守信激励·失信惩戒
# ==============================================================================

credit:CreditManagement
    a owl:Class ;
    rdfs:label "信用管理"@zh , "Credit Management"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国有企业在社会信用体系中的信用记录、评级、守信激励和失信惩戒机制。"@zh ,
                 "SOE credit records, ratings, reward-for-trustworthiness, and punishment-for-dishonesty mechanisms in the social credit system."@en .

credit:SOECreditRating
    a owl:Class ;
    rdfs:label "国企信用评级"@zh , "SOE Credit Rating"@en ;
    rdfs:subClassOf credit:CreditManagement .

credit:CreditRatingLevel
    a owl:Class ;
    rdfs:label "信用等级"@zh , "Credit Rating Level"@en .

credit:AAARating a credit:CreditRatingLevel , owl:NamedIndividual ; rdfs:label "AAA（最高信用）"@zh , "AAA (Highest Credit)"@en .
credit:AARating  a credit:CreditRatingLevel , owl:NamedIndividual ; rdfs:label "AA"@zh , "AA"@en .
credit:ARating   a credit:CreditRatingLevel , owl:NamedIndividual ; rdfs:label "A"@zh , "A"@en .
credit:BBBRating a credit:CreditRatingLevel , owl:NamedIndividual ; rdfs:label "BBB"@zh , "BBB"@en .
credit:BelowBBB  a credit:CreditRatingLevel , owl:NamedIndividual ; rdfs:label "BBB以下（高风险）"@zh , "Below BBB (High Risk)"@en .

credit:TrustRewardMechanism
    a owl:Class ;
    rdfs:label "守信激励机制"@zh , "Trust Reward Mechanism"@en ;
    rdfs:subClassOf credit:CreditManagement ;
    rdfs:comment "信用记录良好的国有企业可获得：优先参与政府采购·简化审批手续·享受融资优惠。"@zh ,
                 "SOEs with good credit records may receive: priority in government procurement · simplified approvals · preferential financing."@en .

credit:DistrustPunishmentMechanism
    a owl:Class ;
    rdfs:label "失信惩戒机制"@zh , "Distrust Punishment Mechanism"@en ;
    rdfs:subClassOf credit:CreditManagement ;
    rdfs:comment "被列入失信被执行人名单的国有企业受到多部门联合惩戒，限制高消费·招投标·融资。"@zh ,
                 "SOEs on dishonesty execution lists face multi-department joint punishment: restricted high consumption, bidding, and financing."@en .

credit:BlacklistEntry
    a owl:Class ;
    rdfs:label "黑名单记录"@zh , "Blacklist Entry"@en ;
    rdfs:subClassOf credit:DistrustPunishmentMechanism .

# ==============================================================================
# GAP MODULE 6: 主责主业管理 — CORE BUSINESS MANAGEMENT
# 聚焦主责主业·压减非主业·僵尸企业处置
# ==============================================================================

core:CoreBusinessManagement
    a owl:Class ;
    rdfs:label "主责主业管理"@zh , "Core Business Management"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国资委要求央企聚焦主责主业，压减非主业投资，剥离与核心业务无关的低效资产。"@zh ,
                 "SASAC requires central SOEs to focus on core businesses, reduce non-core investments, and divest inefficient assets unrelated to core operations."@en .

core:MainBusinessConcentration
    a owl:Class ;
    rdfs:label "主业集中度"@zh , "Core Business Concentration"@en ;
    rdfs:subClassOf core:CoreBusinessManagement ;
    rdfs:comment "主业收入占总收入比例目标，通常要求不低于70%。"@zh ,
                 "Core business revenue as a percentage of total revenue; typically requires ≥70%."@en .

core:hasMainBusinessRevenueRatio
    a owl:DatatypeProperty ;
    rdfs:label "主业收入占比"@zh , "Core Business Revenue Ratio"@en ;
    rdfs:domain core:MainBusinessConcentration ;
    rdfs:range xsd:decimal .

core:ZombieEnterpriseDisposal
    a owl:Class ;
    rdfs:label "僵尸企业处置"@zh , "Zombie Enterprise Disposal"@en ;
    rdfs:subClassOf core:CoreBusinessManagement ;
    rdfs:comment "长期亏损·资不抵债的僵尸企业须依法依规处置：重组·破产清算·移交。"@zh ,
                 "Long-loss, insolvent zombie enterprises must be disposed of per law: restructuring · bankruptcy liquidation · transfer."@en .

core:NonCoreAssetDisposal
    a owl:Class ;
    rdfs:label "非主业资产处置"@zh , "Non-Core Asset Disposal"@en ;
    rdfs:subClassOf core:CoreBusinessManagement .

core:hasSubsidiaryReductionTarget
    a owl:DatatypeProperty ;
    rdfs:label "压减户数目标"@zh , "Subsidiary Reduction Target"@en ;
    rdfs:domain core:CoreBusinessManagement ;
    rdfs:range xsd:integer .

# ==============================================================================
# GAP MODULE 7: 金融衍生品监管 — FINANCIAL DERIVATIVES SUPERVISION
# 套期保值审批·衍生品风险管理
# ==============================================================================

deriv:DerivativesSupervision
    a owl:Class ;
    rdfs:label "金融衍生品监管"@zh , "Financial Derivatives Supervision"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国有企业参与金融衍生品交易须严格限定在套期保值目的，禁止投机性衍生品交易。"@zh ,
                 "SOE participation in financial derivatives must be strictly limited to hedging purposes; speculative derivatives trading is prohibited."@en .

deriv:HedgingPolicy
    a owl:Class ;
    rdfs:label "套期保值政策"@zh , "Hedging Policy"@en ;
    rdfs:subClassOf deriv:DerivativesSupervision ;
    rdfs:comment "套期保值须获得董事会审批，明确套保品种·规模·工具·期限，并定期评估有效性。"@zh ,
                 "Hedging requires board approval; must specify hedging types, scale, instruments, and duration, with periodic effectiveness assessment."@en .

deriv:DerivativeType
    a owl:Class ;
    rdfs:label "衍生品类型"@zh , "Derivative Type"@en .

deriv:ForwardContract      a deriv:DerivativeType , owl:NamedIndividual ; rdfs:label "远期合约"@zh , "Forward Contract"@en .
deriv:FuturesContract      a deriv:DerivativeType , owl:NamedIndividual ; rdfs:label "期货合约"@zh , "Futures Contract"@en .
deriv:OptionContract       a deriv:DerivativeType , owl:NamedIndividual ; rdfs:label "期权合约"@zh , "Option Contract"@en .
deriv:SwapContract         a deriv:DerivativeType , owl:NamedIndividual ; rdfs:label "互换合约"@zh , "Swap Contract"@en .
deriv:CrossCurrencySwap    a deriv:DerivativeType , owl:NamedIndividual ; rdfs:label "货币互换"@zh , "Cross-Currency Swap"@en .
deriv:InterestRateSwap     a deriv:DerivativeType , owl:NamedIndividual ; rdfs:label "利率互换"@zh , "Interest Rate Swap"@en .

deriv:MarkToMarketLoss
    a owl:Class ;
    rdfs:label "公允价值变动损失"@zh , "Mark-to-Market Loss"@en ;
    rdfs:subClassOf deriv:DerivativesSupervision ;
    rdfs:comment "超过规定阈值的衍生品公允价值损失须上报国资委，并披露风险敞口。"@zh ,
                 "Derivative fair value losses exceeding prescribed thresholds must be reported to SASAC with risk exposure disclosure."@en .

deriv:SpeculativeDerivativeProhibition
    a owl:Class ;
    rdfs:label "投机性衍生品禁止"@zh , "Speculative Derivative Prohibition"@en ;
    rdfs:subClassOf deriv:DerivativesSupervision ;
    rdfs:comment "国有企业禁止以投机为目的参与衍生品交易，违者追究主要负责人责任。"@zh ,
                 "SOEs are prohibited from participating in derivatives trading for speculative purposes; violations hold key leaders accountable."@en .

# ==============================================================================
# GAP MODULE 8: 国家安全审查 — NATIONAL SECURITY REVIEW
# 关键基础设施·数据安全·外资审查
# ==============================================================================

nsec:NationalSecurityReview
    a owl:Class ;
    rdfs:label "国家安全审查"@zh , "National Security Review"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "涉及国家安全的国有企业投资·并购·数据处理活动须通过国家安全审查。"@zh ,
                 "SOE investment, M&A, and data processing activities involving national security must pass national security review."@en .

nsec:CriticalInfrastructureProtection
    a owl:Class ;
    rdfs:label "关键信息基础设施保护"@zh , "Critical Information Infrastructure Protection"@en ;
    rdfs:subClassOf nsec:NationalSecurityReview ;
    rdfs:comment "能源·通信·金融·交通等关键信息基础设施运营国有企业须满足《关键信息基础设施安全保护条例》。"@zh ,
                 "SOEs operating critical information infrastructure in energy, communications, finance, and transport must comply with the Regulations on Critical Information Infrastructure Security Protection."@en .

nsec:ForeignInvestmentNSR
    a owl:Class ;
    rdfs:label "外商投资国家安全审查"@zh , "Foreign Investment National Security Review"@en ;
    rdfs:subClassOf nsec:NationalSecurityReview ;
    rdfs:comment "外资并购国有企业或参股关键行业须通过商务部·发改委联合国家安全审查。"@zh ,
                 "Foreign acquisition of SOEs or equity in key industries must pass joint MOFCOM-NDRC national security review."@en .

nsec:DataSecurityReview
    a owl:Class ;
    rdfs:label "数据安全审查"@zh , "Data Security Review"@en ;
    rdfs:subClassOf nsec:NationalSecurityReview ;
    rdfs:comment "境外上市·数据跨境传输须通过国家互联网信息办公室数据安全审查。"@zh ,
                 "Overseas listing and cross-border data transfer must pass Cyberspace Administration of China data security review."@en .

nsec:NetworkSecurityReview
    a owl:Class ;
    rdfs:label "网络安全审查"@zh , "Cybersecurity Review"@en ;
    rdfs:subClassOf nsec:NationalSecurityReview ;
    rdfs:comment "采购影响国家安全的网络产品和服务须通过国家网络安全审查委员会审查。"@zh ,
                 "Procurement of network products and services affecting national security must pass review by the National Cybersecurity Review Committee."@en .

nsec:StateSecretProtection
    a owl:Class ;
    rdfs:label "国家秘密保护"@zh , "State Secret Protection"@en ;
    rdfs:subClassOf nsec:NationalSecurityReview ;
    rdfs:comment "涉密国有企业须建立保密管理制度，防止国家秘密泄露。"@zh ,
                 "SOEs handling classified information must establish confidentiality management systems to prevent state secret leakage."@en .

# ==============================================================================
# GAP MODULE 9: 国资统计报告 — SOE STATISTICAL REPORTING
# 国资委统计报告体系
# ==============================================================================

stat:SOEStatisticalReporting
    a owl:Class ;
    rdfs:label "国资统计报告体系"@zh , "SOE Statistical Reporting System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国资委对国有企业经营状况·国有资产总量·资本保值增值等统计监测体系。"@zh ,
                 "SASAC's statistical monitoring system for SOE operational status, total state asset value, and capital preservation/appreciation."@en .

stat:QuarterlyEconomicOperationReport
    a owl:Class ;
    rdfs:label "季度经济运行报告"@zh , "Quarterly Economic Operation Report"@en ;
    rdfs:subClassOf stat:SOEStatisticalReporting .

stat:AnnualStateAssetSummary
    a owl:Class ;
    rdfs:label "年度国有资产综合统计"@zh , "Annual State Asset Comprehensive Statistics"@en ;
    rdfs:subClassOf stat:SOEStatisticalReporting .

stat:CapitalPreservationAppreciation
    a owl:Class ;
    rdfs:label "国有资本保值增值率"@zh , "State Capital Preservation and Appreciation Rate"@en ;
    rdfs:subClassOf stat:SOEStatisticalReporting ;
    rdfs:comment "期末国有资本权益/期初国有资本权益，衡量国有资本的保值增值情况。"@zh ,
                 "End-period state capital equity / beginning-period state capital equity; measures state capital preservation and appreciation."@en .

stat:hasCapitalPreservationRate
    a owl:DatatypeProperty ;
    rdfs:label "资本保值增值率"@zh , "Capital Preservation Rate"@en ;
    rdfs:domain stat:CapitalPreservationAppreciation ;
    rdfs:range xsd:decimal .

stat:InvestorReportToNPC
    a owl:Class ;
    rdfs:label "向人大报告国有资产"@zh , "Report State Assets to NPC"@en ;
    rdfs:subClassOf stat:SOEStatisticalReporting ;
    rdfs:comment "国资委每年向全国人大常委会报告全国国有资产管理情况，接受人大监督。"@zh ,
                 "SASAC annually reports national state asset management to the NPC Standing Committee for legislative oversight."@en .

# ==============================================================================
# GAP MODULE 10: 科技创新监管 — INNOVATION SUPERVISION
# 科改示范行动·研发投入考核
# ==============================================================================

innov:InnovationSupervision
    a owl:Class ;
    rdfs:label "科技创新监管"@zh , "Technology Innovation Supervision"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "科改示范行动·研发投入视同利润·创新考核体系·成果转化激励。"@zh ,
                 "Technology reform demonstration · R&D treated as profit · innovation assessment · technology transfer incentives."@en .

innov:ScienceReformDemonstration
    a owl:Class ;
    rdfs:label "科改示范行动"@zh , "Science Reform Demonstration Action"@en ;
    rdfs:subClassOf innov:InnovationSupervision ;
    rdfs:comment "国资委遴选科技型央企开展科改示范行动，在薪酬·股权·研发投入上给予特殊政策。"@zh ,
                 "SASAC selects technology-oriented central SOEs for science reform demonstration, granting special policies on compensation, equity, and R&D."@en .

innov:RDTreatedAsProfit
    a owl:Class ;
    rdfs:label "研发投入视同利润加回"@zh , "R&D Expenditure Added Back as Profit"@en ;
    rdfs:subClassOf innov:InnovationSupervision ;
    rdfs:comment "在考核利润时，将研发投入按规定比例视同实现利润，鼓励加大研发投入。"@zh ,
                 "In profit assessment, R&D expenditures are treated as achieved profit at prescribed ratios to encourage increased R&D investment."@en .

innov:TechTransferIncentive
    a owl:Class ;
    rdfs:label "科技成果转化激励"@zh , "Technology Transfer Incentive"@en ;
    rdfs:subClassOf innov:InnovationSupervision ;
    rdfs:comment "科技成果转化收益按规定分配给研发团队，最高可达转化收益的50%。"@zh ,
                 "Technology transfer proceeds distributed to R&D teams per regulations, up to 50% of transfer proceeds."@en .

innov:hasRDIntensityTarget
    a owl:DatatypeProperty ;
    rdfs:label "研发投入强度目标"@zh , "R&D Intensity Target"@en ;
    rdfs:domain innov:InnovationSupervision ;
    rdfs:range xsd:decimal .

innov:StrategicEmergingIndustries
    a owl:Class ;
    rdfs:label "战略性新兴产业投入"@zh , "Strategic Emerging Industries Investment"@en ;
    rdfs:subClassOf innov:InnovationSupervision ;
    rdfs:comment "国资委要求央企加大对新能源·半导体·人工智能·生物医药等战略性新兴产业的投入。"@zh ,
                 "SASAC requires central SOEs to increase investment in strategic emerging industries: new energy, semiconductors, AI, biopharmaceuticals."@en .

# ==============================================================================
# GAP MODULE 11: 职工持股计划 — EMPLOYEE STOCK OWNERSHIP PLAN (ESOP)
# 混改中的ESOP·激励机制
# ==============================================================================

esop:EmployeeStockOwnershipPlan
    a owl:Class ;
    rdfs:label "职工持股计划（ESOP）"@zh , "Employee Stock Ownership Plan (ESOP)"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "混合所有制改革中，允许骨干员工持股以形成利益共同体，须经国资委审批。"@zh ,
                 "In mixed-ownership reform, key employees allowed to hold equity to form shared interest communities; requires SASAC approval."@en .

esop:ESOPEligibility
    a owl:Class ;
    rdfs:label "持股资格认定"@zh , "ESOP Eligibility Determination"@en ;
    rdfs:subClassOf esop:EmployeeStockOwnershipPlan ;
    rdfs:comment "持股对象一般为企业管理层及核心技术/业务骨干，不得面向全员。"@zh ,
                 "Eligible holders are generally management and core technical/business key personnel; not open to all employees."@en .

esop:ESOPHoldingLimit
    a owl:Class ;
    rdfs:label "持股比例上限"@zh , "ESOP Holding Limit"@en ;
    rdfs:subClassOf esop:EmployeeStockOwnershipPlan ;
    rdfs:comment "员工持股总比例不超过公司总股本的30%，单个员工不超过1%。"@zh ,
                 "Total employee shareholding shall not exceed 30% of total shares; individual employee shall not exceed 1%."@en .

esop:hasMaxEmployeeShareRatio
    a owl:DatatypeProperty ;
    rdfs:label "最大员工持股比例"@zh , "Max Employee Share Ratio"@en ;
    rdfs:domain esop:ESOPHoldingLimit ;
    rdfs:range xsd:decimal .

esop:ESOPLockupPeriod
    a owl:Class ;
    rdfs:label "持股锁定期"@zh , "ESOP Lockup Period"@en ;
    rdfs:subClassOf esop:EmployeeStockOwnershipPlan ;
    rdfs:comment "员工持股须设置锁定期（一般不少于36个月），防止短期套利。"@zh ,
                 "Employee shareholding must have lockup period (generally ≥36 months) to prevent short-term arbitrage."@en .

# ==============================================================================
# GAP MODULE 12: 重大风险报告 — MAJOR RISK REPORTING
# ==============================================================================

mrr:MajorRiskReporting
    a owl:Class ;
    rdfs:label "重大风险报告制度"@zh , "Major Risk Reporting System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国有企业重大风险须定期向国资委报告，紧急风险须立即报告。"@zh ,
                 "SOEs must periodically report major risks to SASAC; urgent risks require immediate reporting."@en .

mrr:RiskReportingCategory
    a owl:Class ;
    rdfs:label "风险报告类别"@zh , "Risk Reporting Category"@en .

mrr:FinancialMajorRisk      a mrr:RiskReportingCategory , owl:NamedIndividual ; rdfs:label "财务重大风险（资金链断裂·债务违约）"@zh , "Financial Major Risk (Cash chain break, debt default)"@en .
mrr:OperationalMajorRisk    a mrr:RiskReportingCategory , owl:NamedIndividual ; rdfs:label "经营重大风险（主业亏损·核心客户流失）"@zh , "Operational Major Risk (Core business loss, key client loss)"@en .
mrr:ComplianceMajorRisk     a mrr:RiskReportingCategory , owl:NamedIndividual ; rdfs:label "合规重大风险（重大违规·处罚·诉讼）"@zh , "Compliance Major Risk (Major violation, penalty, litigation)"@en .
mrr:OverseasMajorRisk       a mrr:RiskReportingCategory , owl:NamedIndividual ; rdfs:label "境外重大风险（资产被扣押·人员安全）"@zh , "Overseas Major Risk (Asset seizure, personnel safety)"@en .
mrr:ReputationalMajorRisk   a mrr:RiskReportingCategory , owl:NamedIndividual ; rdfs:label "声誉重大风险（媒体负面·舆情危机）"@zh , "Reputational Major Risk (Negative media, public opinion crisis)"@en .
mrr:SystemicMajorRisk       a mrr:RiskReportingCategory , owl:NamedIndividual ; rdfs:label "系统性重大风险（行业系统性危机）"@zh , "Systemic Major Risk (Industry systemic crisis)"@en .

mrr:hasReportingDeadlineHours
    a owl:DatatypeProperty ;
    rdfs:label "报告时限（小时）"@zh , "Reporting Deadline (hours)"@en ;
    rdfs:domain mrr:MajorRiskReporting ;
    rdfs:range xsd:integer ;
    rdfs:comment "紧急风险：2小时内；重大风险：24小时内；一般重要风险：5个工作日内。"@zh ,
                 "Urgent risk: within 2 hours; major risk: within 24 hours; general important risk: within 5 working days."@en .

mrr:RiskEscalationPath
    a owl:Class ;
    rdfs:label "风险上报路径"@zh , "Risk Escalation Path"@en ;
    rdfs:subClassOf mrr:MajorRiskReporting ;
    rdfs:comment "风险识别→业务部门→风险管理部→CRO→CFO/CEO→董事会→国资委，各级有明确响应时限。"@zh ,
                 "Risk identification → business dept → risk mgmt → CRO → CFO/CEO → board → SASAC; each level has clear response timeframes."@en .

# ==============================================================================
# GAP MODULE 13: DEONTIC RULES — 规范性规则（义务·权利·禁止）
# Aligned with LKIF deontic logic
# ==============================================================================

deon:DeonticRule
    a owl:Class ;
    rdfs:label "规范性规则"@zh , "Deontic Rule"@en ;
    rdfs:comment "国资监管中具有规范效力的义务性·权利性·禁止性规则，对标LKIF法律知识工程框架。"@zh ,
                 "Normative rules with obligatory, permissive, or prohibitive effect in SOE supervision; aligned with LKIF legal knowledge engineering framework."@en .

deon:Obligation
    a owl:Class ;
    rdfs:label "义务规则"@zh , "Obligation Rule"@en ;
    rdfs:subClassOf deon:DeonticRule ;
    rdfs:comment "法律或监管文件规定的必须履行的义务。如：国有企业必须公开信息·必须按期申报纳税。"@zh ,
                 "Obligations mandated by law or regulatory documents. E.g.: SOEs must disclose information; must file taxes on time."@en .

deon:Permission
    a owl:Class ;
    rdfs:label "权利规则"@zh , "Permission Rule"@en ;
    rdfs:subClassOf deon:DeonticRule ;
    rdfs:comment "经授权可以行使的权利。如：国有资本投资公司可以开展市场化投资。"@zh ,
                 "Rights that may be exercised upon authorization. E.g., state capital investment companies may conduct market-oriented investment."@en .

deon:Prohibition
    a owl:Class ;
    rdfs:label "禁止规则"@zh , "Prohibition Rule"@en ;
    rdfs:subClassOf deon:DeonticRule ;
    rdfs:comment "明确禁止的行为。如：国有企业负责人不得在境外企业兼职取酬·不得投机性衍生品交易。"@zh ,
                 "Explicitly prohibited behaviors. E.g., SOE leaders may not take paid positions in overseas enterprises; may not engage in speculative derivatives trading."@en .

deon:ConditionalRule
    a owl:Class ;
    rdfs:label "条件性规则"@zh , "Conditional Rule"@en ;
    rdfs:subClassOf deon:DeonticRule ;
    rdfs:comment "在特定条件下触发的规则。如：超过三重一大门槛则必须集体决策。"@zh ,
                 "Rules triggered under specific conditions. E.g., exceeding SJYZD threshold requires collective decision-making."@en .

deon:hasRuleSubject    a owl:DatatypeProperty ; rdfs:label "规则主体"@zh , "Rule Subject"@en ; rdfs:domain deon:DeonticRule ; rdfs:range xsd:string .
deon:hasRuleContent    a owl:DatatypeProperty ; rdfs:label "规则内容"@zh , "Rule Content"@en ; rdfs:domain deon:DeonticRule ; rdfs:range xsd:string .
deon:hasLegalBasis     a owl:DatatypeProperty ; rdfs:label "法律依据"@zh , "Legal Basis"@en ; rdfs:domain deon:DeonticRule ; rdfs:range xsd:string .
deon:hasConsequence    a owl:DatatypeProperty ; rdfs:label "违规后果"@zh , "Violation Consequence"@en ; rdfs:domain deon:DeonticRule ; rdfs:range xsd:string .

# Key deontic rules instances
deon:SJYZDObligation
    a deon:Obligation , owl:NamedIndividual ;
    rdfs:label "三重一大集体决策义务"@zh , "SJYZD Collective Decision Obligation"@en ;
    deon:hasRuleSubject "国有企业党委·董事会"@zh ;
    deon:hasRuleContent "超过规定金额门槛的重大事项必须经集体决策"@zh ;
    deon:hasLegalBasis "关于进一步推进三重一大决策制度落实工作的意见" ;
    deon:hasConsequence "未履行集体决策程序的决定无效，主要责任人追责" .

deon:SpeculativeDerivativesProhibition
    a deon:Prohibition , owl:NamedIndividual ;
    rdfs:label "投机性衍生品交易禁止"@zh , "Speculative Derivatives Trading Prohibition"@en ;
    deon:hasRuleSubject "国有企业" ;
    deon:hasRuleContent "禁止以投机为目的参与金融衍生品交易" ;
    deon:hasLegalBasis "国务院国资委关于进一步加强中央企业金融衍生业务监管的通知" ;
    deon:hasConsequence "违者暂停或终止衍生品交易资格，追究主要负责人责任" .

deon:StateAssetDisclosureObligation
    a deon:Obligation , owl:NamedIndividual ;
    rdfs:label "国有资产信息披露义务"@zh , "State Asset Information Disclosure Obligation"@en ;
    deon:hasRuleSubject "上市国有企业" ;
    deon:hasRuleContent "须按证监会要求及时披露重大事项·财务数据·关联交易" ;
    deon:hasLegalBasis "上市公司信息披露管理办法" .

# ==============================================================================
# GAP MODULE 14: REA ALIGNMENT — REA资源·事件·代理对齐
# ==============================================================================

reaa:REAAlignment
    a owl:Class ;
    rdfs:label "REA本体对齐层"@zh , "REA Ontology Alignment Layer"@en ;
    rdfs:comment "将SASAC-GOV财务会计概念与REA（资源·事件·代理）三元组对齐，实现互操作性。"@zh ,
                 "Aligns SASAC-GOV financial accounting concepts with REA (Resource-Event-Agent) tripartite model for interoperability."@en .

reaa:EconomicResource
    a owl:Class ;
    rdfs:label "经济资源（REA）"@zh , "Economic Resource (REA)"@en ;
    rdfs:subClassOf reaa:REAAlignment ;
    owl:equivalentClass acct:AssetAccount ;
    rdfs:comment "REA经济资源 ≡ SASAC资产类科目（acct:AssetAccount）。"@zh ,
                 "REA Economic Resource ≡ SASAC Asset Account (acct:AssetAccount)."@en .

reaa:EconomicEvent
    a owl:Class ;
    rdfs:label "经济事件（REA）"@zh , "Economic Event (REA)"@en ;
    rdfs:subClassOf reaa:REAAlignment ;
    owl:equivalentClass acct:JournalEntry ;
    rdfs:comment "REA经济事件 ≡ SASAC记账凭证（acct:JournalEntry）。"@zh ,
                 "REA Economic Event ≡ SASAC Journal Entry (acct:JournalEntry)."@en .

reaa:EconomicAgent
    a owl:Class ;
    rdfs:label "经济代理（REA）"@zh , "Economic Agent (REA)"@en ;
    rdfs:subClassOf reaa:REAAlignment ;
    owl:equivalentClass ent:StateOwnedEnterprise ;
    rdfs:comment "REA经济代理 ≡ SASAC国有企业（ent:StateOwnedEnterprise）。"@zh ,
                 "REA Economic Agent ≡ SASAC State-Owned Enterprise (ent:StateOwnedEnterprise)."@en .

reaa:Commitment
    a owl:Class ;
    rdfs:label "经济承诺（REA）"@zh , "Economic Commitment (REA)"@en ;
    rdfs:subClassOf reaa:REAAlignment ;
    owl:equivalentClass proc:ProcurementContract ;
    rdfs:comment "REA经济承诺 ≡ SASAC采购合同（proc:ProcurementContract）。"@zh ,
                 "REA Commitment ≡ SASAC Procurement Contract (proc:ProcurementContract)."@en .

reaa:ExchangeDuality
    a owl:Class ;
    rdfs:label "交换对偶性（REA）"@zh , "Exchange Duality (REA)"@en ;
    rdfs:subClassOf reaa:REAAlignment ;
    rdfs:comment "每个经济事件都有对偶：付款有资源减少，收款有资源增加。对应SASAC借贷平衡规则。"@zh ,
                 "Each economic event has a dual: payment decreases resource, receipt increases resource. Corresponds to SASAC's debit-credit balance rule."@en .

# ==============================================================================
# GAP MODULE 15: FIBO ALIGNMENT — FIBO金融工具·法人对齐
# ==============================================================================

fiboa:FIBOAlignment
    a owl:Class ;
    rdfs:label "FIBO本体对齐层"@zh , "FIBO Ontology Alignment Layer"@en ;
    rdfs:comment "将SASAC-GOV金融类概念与FIBO（金融行业业务本体）对齐，实现国际互操作性。"@zh ,
                 "Aligns SASAC-GOV financial concepts with FIBO (Financial Industry Business Ontology) for international interoperability."@en .

fiboa:FIBOLegalEntity
    a owl:Class ;
    rdfs:label "FIBO法人实体对齐"@zh , "FIBO Legal Entity Alignment"@en ;
    rdfs:subClassOf fiboa:FIBOAlignment ;
    owl:equivalentClass ent:StateOwnedEnterprise ;
    rdfs:comment "FIBO LegalEntity ≡ SASAC StateOwnedEnterprise（均含LEI·注册信息·法律管辖）。"@zh ,
                 "FIBO LegalEntity ≡ SASAC StateOwnedEnterprise (both contain LEI, registration info, legal jurisdiction)."@en .

fiboa:FIBODebt
    a owl:Class ;
    rdfs:label "FIBO债务工具对齐"@zh , "FIBO Debt Instrument Alignment"@en ;
    rdfs:subClassOf fiboa:FIBOAlignment ;
    owl:equivalentClass cap:BondIssuance ;
    rdfs:comment "FIBO Debt ≡ SASAC BondIssuance（含发行人·金额·期限·利率）。"@zh ,
                 "FIBO Debt ≡ SASAC BondIssuance (issuer, amount, maturity, interest rate)."@en .

fiboa:FIBOEquity
    a owl:Class ;
    rdfs:label "FIBO权益工具对齐"@zh , "FIBO Equity Instrument Alignment"@en ;
    rdfs:subClassOf fiboa:FIBOAlignment ;
    owl:equivalentClass cap:EquityFinancing ;
    rdfs:comment "FIBO Equity ≡ SASAC EquityFinancing（股权融资·上市公司股份）。"@zh ,
                 "FIBO Equity ≡ SASAC EquityFinancing (equity financing, listed company shares)."@en .

fiboa:FIBOCorporateAction
    a owl:Class ;
    rdfs:label "FIBO公司行动对齐"@zh , "FIBO Corporate Action Alignment"@en ;
    rdfs:subClassOf fiboa:FIBOAlignment ;
    owl:equivalentClass sjyzd:MajorMatterDecision ;
    rdfs:comment "FIBO CorporateAction ≡ SASAC MajorMatterDecision（重大公司行动均须集体决策）。"@zh ,
                 "FIBO CorporateAction ≡ SASAC MajorMatterDecision (major corporate actions require collective decision-making)."@en .

fiboa:FIBORegulator
    a owl:Class ;
    rdfs:label "FIBO监管机构对齐"@zh , "FIBO Regulator Alignment"@en ;
    rdfs:subClassOf fiboa:FIBOAlignment ;
    owl:equivalentClass sasac:RegulatoryAuthority ;
    rdfs:comment "FIBO Regulator ≡ SASAC RegulatoryAuthority（财政部·国资委·证监会等）。"@zh ,
                 "FIBO Regulator ≡ SASAC RegulatoryAuthority (MOF, SASAC, CSRC, etc.)."@en .

# ==============================================================================
# GAP MODULE 16: LKIF ALIGNMENT — LKIF法律规则对齐
# ==============================================================================

lkifa:LKIFAlignment
    a owl:Class ;
    rdfs:label "LKIF法律知识对齐层"@zh , "LKIF Legal Knowledge Alignment Layer"@en ;
    rdfs:comment "将SASAC-GOV监管规则与LKIF（法律知识交换格式）对齐，支持法律推理和自动合规检查。"@zh ,
                 "Aligns SASAC-GOV regulatory rules with LKIF (Legal Knowledge Interchange Format) for legal reasoning and automated compliance checking."@en .

lkifa:LKIFNorm
    a owl:Class ;
    rdfs:label "LKIF规范对齐"@zh , "LKIF Norm Alignment"@en ;
    rdfs:subClassOf lkifa:LKIFAlignment ;
    owl:equivalentClass deon:DeonticRule ;
    rdfs:comment "LKIF Norm ≡ SASAC DeonticRule（两者均包含义务·权利·禁止三类规范）。"@zh ,
                 "LKIF Norm ≡ SASAC DeonticRule (both contain obligation, permission, prohibition norms)."@en .

lkifa:LKIFLegalSource
    a owl:Class ;
    rdfs:label "LKIF法律来源对齐"@zh , "LKIF Legal Source Alignment"@en ;
    rdfs:subClassOf lkifa:LKIFAlignment ;
    owl:equivalentClass sasac:RegulatoryPolicy ;
    rdfs:comment "LKIF LegalSource ≡ SASAC RegulatoryPolicy（法律法规·规范性文件）。"@zh ,
                 "LKIF LegalSource ≡ SASAC RegulatoryPolicy (laws, regulations, normative documents)."@en .

lkifa:LKIFLegalRole
    a owl:Class ;
    rdfs:label "LKIF法律角色对齐"@zh , "LKIF Legal Role Alignment"@en ;
    rdfs:subClassOf lkifa:LKIFAlignment ;
    owl:equivalentClass party:BoardOfDirectors ;
    rdfs:comment "LKIF LegalRole ≡ SASAC governance roles（董事会·党委·监事会等具有法律权利义务的主体）。"@zh ,
                 "LKIF LegalRole ≡ SASAC governance roles (board, party committee, supervisory board - all with legal rights/obligations)."@en .

lkifa:ComplianceRuleEngine
    a owl:Class ;
    rdfs:label "合规规则引擎（LKIF推理）"@zh , "Compliance Rule Engine (LKIF Reasoning)"@en ;
    rdfs:subClassOf lkifa:LKIFAlignment ;
    rdfs:comment "基于LKIF规则引擎，自动推理检查企业行为是否违反监管义务，支持前置合规审查。"@zh ,
                 "Based on LKIF rule engine, automatically infers whether corporate behavior violates regulatory obligations, supporting pre-emptive compliance review."@en .

# ==============================================================================
# ADDITIONAL SHACL SHAPES FOR NEW MODULES
# ==============================================================================

sasac:ProductionSafetyShape
    a sh:NodeShape ;
    sh:targetClass safety:SafetyAccidentReport ;
    rdfs:label "安全事故报告时限约束"@zh , "Safety Accident Report Timing Shape"@en ;
    sh:property [
        sh:path mrr:hasReportingDeadlineHours ;
        sh:maxInclusive 24 ;
        sh:message "重大安全事故必须在24小时内上报。"@zh ,
                   "Major safety accidents must be reported within 24 hours."@en
    ] .

sasac:ESOPLimitShape
    a sh:NodeShape ;
    sh:targetClass esop:ESOPHoldingLimit ;
    rdfs:label "职工持股比例约束"@zh , "ESOP Holding Limit Shape"@en ;
    sh:property [
        sh:path esop:hasMaxEmployeeShareRatio ;
        sh:maxInclusive 0.3 ;
        sh:message "员工持股总比例不得超过公司总股本的30%。"@zh ,
                   "Total employee shareholding must not exceed 30% of total shares."@en
    ] .

sasac:CompensationCapShape
    a sh:NodeShape ;
    sh:targetClass wage:SalaryCap ;
    rdfs:label "薪酬倍数约束"@zh , "Salary Cap Multiple Shape"@en ;
    sh:property [
        sh:path wage:hasSalaryCapMultiple ;
        sh:maxInclusive 8.0 ;
        sh:message "国有企业负责人薪酬不得超过在职职工平均薪酬的8倍。"@zh ,
                   "SOE leader compensation must not exceed 8 times the average in-service employee salary."@en
    ] .

sasac:DerivativesProhibitionShape
    a sh:NodeShape ;
    sh:targetClass deriv:SpeculativeDerivativeProhibition ;
    rdfs:label "投机性衍生品禁止约束"@zh , "Speculative Derivative Prohibition Shape"@en ;
    sh:property [
        sh:path deriv:hasHedgingPurposeOnly ;
        sh:hasValue "true"^^xsd:boolean ;
        sh:message "【违规】国有企业只能以套期保值为目的参与衍生品交易！"@zh ,
                   "[VIOLATION] SOEs may only participate in derivatives for hedging purposes!"@en
    ] .

deriv:hasHedgingPurposeOnly
    a owl:DatatypeProperty ;
    rdfs:label "仅套期保值目的"@zh , "Hedging Purpose Only"@en ;
    rdfs:domain deriv:DerivativesSupervision ;
    rdfs:range xsd:boolean .

# Cross-module property additions
sasac:hasCoreBusinessManagement  a owl:ObjectProperty ; rdfs:label "主责主业管理"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range core:CoreBusinessManagement .
sasac:hasDerivativesPolicy       a owl:ObjectProperty ; rdfs:label "衍生品政策"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range deriv:HedgingPolicy .
sasac:hasESOPScheme              a owl:ObjectProperty ; rdfs:label "职工持股计划"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range esop:EmployeeStockOwnershipPlan .
sasac:hasNationalSecurityStatus  a owl:ObjectProperty ; rdfs:label "国家安全审查状态"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range nsec:NationalSecurityReview .
sasac:hasCreditRating            a owl:ObjectProperty ; rdfs:label "信用评级"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range credit:SOECreditRating .
sasac:isCapitalOperationsCompany a owl:DatatypeProperty ; rdfs:label "是否资本运营公司"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range xsd:boolean .

