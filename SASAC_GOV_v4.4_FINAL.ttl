report:RegulatoryReporting
    a owl:Class ;
    rdfs:label "监管报告体系"@zh , "Regulatory Reporting System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国有企业向财政部·国资委·证监会等监管机构定期提交的各类报告，包括月报·季报·年报·专项报告·内控评价报告。"@zh ,
                 "Various reports SOEs periodically submit to MOF, SASAC, CSRC, etc., including monthly, quarterly, annual, special-purpose, and internal control evaluation reports."@en .

report:MonthlyFinancialFlash  a owl:NamedIndividual ; rdfs:label "月度财务快报"@zh , "Monthly Financial Flash"@en ; rdfs:type report:RegulatoryReporting .
report:QuarterlyReport        a owl:NamedIndividual ; rdfs:label "季度报告"@zh , "Quarterly Report"@en ; rdfs:type report:RegulatoryReporting .
report:AnnualReport           a owl:NamedIndividual ; rdfs:label "年度报告"@zh , "Annual Report"@en ; rdfs:type report:RegulatoryReporting .
report:InternalControlReport  a owl:NamedIndividual ; rdfs:label "内控评价报告"@zh , "Internal Control Evaluation Report"@en ; rdfs:type report:RegulatoryReporting .
report:ESGReport              a owl:NamedIndividual ; rdfs:label "ESG/社会责任报告"@zh , "ESG/CSR Report"@en ; rdfs:type report:RegulatoryReporting .
report:ComplianceReport       a owl:NamedIndividual ; rdfs:label "合规管理报告"@zh , "Compliance Management Report"@en ; rdfs:type report:RegulatoryReporting .
report:hasSubmissionDeadline  a owl:DatatypeProperty ; rdfs:label "报告提交截止日"@zh , "Submission Deadline"@en ; rdfs:domain report:RegulatoryReporting ; rdfs:range xsd:string .
report:hasReportingFrequency  a owl:ObjectProperty ; rdfs:label "报告频率"@zh , "Reporting Frequency"@en ; rdfs:domain report:RegulatoryReporting ; rdfs:range xsd:string .

fin:FinancialSupervision
    a owl:Class ;
    rdfs:label "财务监督"@zh , "Financial Supervision"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "依据《企业财务通则》和企业会计准则对国有企业财务活动的全面监督，含资产管理·利润分配·关联交易·财务信息质量。"@zh ,
                 "Comprehensive supervision of SOE financial activities per Enterprise Financial General Rules and accounting standards, covering asset management, profit distribution, related-party transactions, financial information quality."@en .

fin:RelatedPartyTransaction   a owl:Class ; rdfs:label "关联方交易"@zh , "Related Party Transaction"@en ; rdfs:subClassOf fin:FinancialSupervision .
fin:ProfitDistribution        a owl:Class ; rdfs:label "利润分配"@zh , "Profit Distribution"@en ; rdfs:subClassOf fin:FinancialSupervision .
fin:FinancialInformationQuality a owl:Class ; rdfs:label "财务信息质量"@zh , "Financial Information Quality"@en ; rdfs:subClassOf fin:FinancialSupervision .


# ==============================================================================
# PART 5: v4.2 EXPERT-REVIEW PATCH (SASAC Chairman + SASAC 8 Bureaus +
#         Top-50 CFOs + CNPC·Sinopec·CMG·CR·Poly Overseas Finance Directors)
# P0 Fixes: 三类企业·境外产权登记·国有资本经营预算·油气PSC·多法域合并·EPC·32号令
# P1 Fixes: OFAC细化·大宗商品结算·SPV/VIE·港股HKFRS·EU CSRD·航运·战略规划
# ==============================================================================

# ==============================================================================
# SASAC-GOV v4.2 EXPERT-REVIEW PATCH
# 专家联合评审补丁模块
# ==============================================================================
# P0: 三类企业·境外产权登记·国有资本经营预算·油气PSC·多法域合并·EPC·32号令
# P1: 合并抵消·OFAC细化·大宗商品结算·SPV/VIE·港股·CSRD·航运·二类分类
# Source: SASAC Chairman + SASAC 8 Bureaus + Top-50 CFOs + Overseas Finance Directors
# ==============================================================================

# v4.2 new prefixes

# ==============================================================================
# P0-FIX 1: 三类企业分类 — STAT-01
# 商业一类·商业二类·公益类 — 考核差异化的基础
# ==============================================================================

cat3:EnterpriseCategory3System
    a owl:Class ;
    rdfs:label "央企三类功能分类体系"@zh ,
               "Central SOE Three-Category Functional Classification"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "国资委将央企按主业功能分为三类：商业一类（充分竞争领域）·商业二类（关系国民经济命脉的重要行业）·公益类（以保障民生·服务社会为主），各类考核指标和监管强度不同。"@zh ,
        "SASAC classifies central SOEs into three functional categories: Commercial Type-I (fully competitive markets), Commercial Type-II (key industries vital to national economy), and Public-Welfare (primarily serving public interests), each with differentiated KPIs and regulatory intensity."@en .

cat3:CommercialTypeI
    a owl:Class ;
    rdfs:label "商业一类（充分竞争领域）"@zh ,
               "Commercial Type-I (Fully Competitive)"@en ;
    rdfs:subClassOf ent:CentralSOE ;
    rdfs:comment
        "处于充分竞争领域的央企，主要追求经济效益，参照一般竞争性企业监管。考核重点：ROE·利润总额·EVA。典型：中石油·中石化·中国移动·中远海运。"@zh ,
        "Central SOEs in fully competitive markets, primarily pursuing economic returns, regulated similarly to general competitive enterprises. Key KPIs: ROE · total profit · EVA. Examples: CNPC, Sinopec, China Mobile, COSCO."@en .

cat3:CommercialTypeII
    a owl:Class ;
    rdfs:label "商业二类（功能保障·国民经济命脉）"@zh ,
               "Commercial Type-II (Functional Security, Key Industries)"@en ;
    rdfs:subClassOf ent:CentralSOE ;
    rdfs:comment
        "涉及关系国家安全、国民经济命脉的重要行业，兼顾经济效益与战略功能。考核适当降低财务目标，增加功能性指标。典型：国家电网·中核·中航工业·中国铁路。"@zh ,
        "SOEs in industries vital to national security and key economic sectors; balance economic returns with strategic functions. KPIs reduce financial targets and add functional indicators. Examples: State Grid, CNNC, AVIC, China Railway."@en .

cat3:PublicWelfareType
    a owl:Class ;
    rdfs:label "公益类（保障民生·服务社会）"@zh ,
               "Public-Welfare Type (People's Livelihood, Social Service)"@en ;
    rdfs:subClassOf ent:CentralSOE ;
    rdfs:comment
        "以保障民生、服务社会公众为主要目标，允许微利或不盈利，政府给予必要补贴。考核重点：服务质量·成本管控·安全运营。典型：中国邮政（部分业务）·中国储备粮·水利设施。"@zh ,
        "Primary goal is public welfare; allowed to be marginally profitable or unprofitable; government provides necessary subsidies. Key KPIs: service quality · cost control · safe operations. Examples: China Post (certain services), Sinograin, water infrastructure."@en .

cat3:hasEnterpriseCategory
    a owl:ObjectProperty ;
    rdfs:label "央企功能分类"@zh , "Enterprise Functional Category"@en ;
    rdfs:domain ent:CentralSOE ;
    rdfs:range cat3:EnterpriseCategory3System .

cat3:CategorySpecificKPI
    a owl:Class ;
    rdfs:label "分类差异化考核指标"@zh , "Category-Differentiated KPI"@en ;
    rdfs:subClassOf cat3:EnterpriseCategory3System ;
    rdfs:comment "不同类别央企适用不同考核指标权重：商业一类财务指标权重70%+；商业二类财务60%+功能40%；公益类功能指标权重60%+。"@zh ,
                 "Different KPI weights by category: Commercial I: financial ≥70%; Commercial II: financial 60% + functional 40%; Public-Welfare: functional ≥60%."@en .

cat3:TypeIKPIWeight    a cat3:CategorySpecificKPI , owl:NamedIndividual ;
    rdfs:label "商业一类KPI：财务≥70%"@zh , "Type-I KPI: Financial ≥70%"@en .
cat3:TypeIIKPIWeight   a cat3:CategorySpecificKPI , owl:NamedIndividual ;
    rdfs:label "商业二类KPI：财务60%+功能40%"@zh , "Type-II KPI: Financial 60%+Functional 40%"@en .
cat3:PublicKPIWeight   a cat3:CategorySpecificKPI , owl:NamedIndividual ;
    rdfs:label "公益类KPI：功能≥60%"@zh , "Public KPI: Functional ≥60%"@en .

cat3:SubsidyMechanism
    a owl:Class ;
    rdfs:label "公益类政府补贴机制"@zh , "Public-Welfare Government Subsidy Mechanism"@en ;
    rdfs:subClassOf cat3:PublicWelfareType ;
    rdfs:comment "公益类央企履行政策性亏损业务时，政府按规定给予财政补贴，须单独核算补贴收入与政策性业务成本。"@zh ,
                 "When public-welfare SOEs incur policy-driven losses, government provides fiscal subsidies; subsidy income and policy-business costs must be separately accounted."@en .

# ==============================================================================
# P0-FIX 2: 国有资本经营预算 — FIN-02
# 财政部核心监管工具：资本收益上缴·预算编制·资金用途
# ==============================================================================

capbud:StateCapitalOperatingBudget
    a owl:Class ;
    rdfs:label "国有资本经营预算"@zh , "State Capital Operating Budget"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "依据《国有资本经营预算管理办法》，财政部统筹安排国有资本经营预算收支，包括：国有企业上缴收益（利润）·国有资本经营预算支出（注资·改革补贴）。"@zh ,
        "Per State Capital Operating Budget Management Measures, MOF coordinates state capital operating budget revenue and expenditure, including: SOE profit remittances · state capital operating expenditure (capital injection, reform subsidies)."@en .

capbud:ProfitRemittanceRate
    a owl:Class ;
    rdfs:label "国有资本收益上缴比例"@zh , "State Capital Profit Remittance Rate"@en ;
    rdfs:subClassOf capbud:StateCapitalOperatingBudget ;
    rdfs:comment "按企业类型差异化收取：充分竞争类15%·自然垄断类10%·公共服务类5%·政策性类免收。"@zh ,
                 "Differentiated by enterprise type: fully competitive 15% · natural monopoly 10% · public service 5% · policy-type exempt."@en .

capbud:FullyCompetitiveRate
    a capbud:ProfitRemittanceRate , owl:NamedIndividual ;
    rdfs:label "充分竞争类：上缴15%"@zh , "Fully Competitive: 15% Remittance"@en ;
    capbud:hasRemittanceRateValue "0.15"^^xsd:decimal .

capbud:NaturalMonopolyRate
    a capbud:ProfitRemittanceRate , owl:NamedIndividual ;
    rdfs:label "自然垄断类：上缴10%"@zh , "Natural Monopoly: 10% Remittance"@en ;
    capbud:hasRemittanceRateValue "0.10"^^xsd:decimal .

capbud:PublicServiceRate
    a capbud:ProfitRemittanceRate , owl:NamedIndividual ;
    rdfs:label "公共服务类：上缴5%"@zh , "Public Service: 5% Remittance"@en ;
    capbud:hasRemittanceRateValue "0.05"^^xsd:decimal .

capbud:hasRemittanceRateValue a owl:DatatypeProperty ;
    rdfs:label "上缴比例值"@zh , "Remittance Rate Value"@en ;
    rdfs:domain capbud:ProfitRemittanceRate ;
    rdfs:range xsd:decimal .

capbud:CapitalOperatingBudgetExpenditure
    a owl:Class ;
    rdfs:label "国有资本经营预算支出"@zh , "State Capital Operating Budget Expenditure"@en ;
    rdfs:subClassOf capbud:StateCapitalOperatingBudget .

capbud:CapitalInjectionExpenditure
    a capbud:CapitalOperatingBudgetExpenditure , owl:Class ;
    rdfs:label "资本金注入支出"@zh , "Capital Injection Expenditure"@en .
capbud:ReformSubsidyExpenditure
    a capbud:CapitalOperatingBudgetExpenditure , owl:Class ;
    rdfs:label "改革补贴支出"@zh , "Reform Subsidy Expenditure"@en .
capbud:PolicyLossSubsidy
    a capbud:CapitalOperatingBudgetExpenditure , owl:Class ;
    rdfs:label "政策性亏损补贴"@zh , "Policy-Driven Loss Subsidy"@en .

capbud:BudgetLinkToEnterpriseFullBudget
    a owl:Class ;
    rdfs:label "资本经营预算与全面预算衔接"@zh , "Capital Budget — Full Budget Linkage"@en ;
    rdfs:subClassOf capbud:StateCapitalOperatingBudget ;
    rdfs:comment "企业全面预算中须专项反映国有资本经营预算上缴义务，资金调度须预留充足头寸。"@zh ,
                 "Enterprise comprehensive budget must specifically reflect state capital operating budget remittance obligations; cash scheduling must reserve sufficient liquidity."@en .

# ==============================================================================
# P0-FIX 3: 境外国有资产产权登记 — INTL-01
# ==============================================================================

oareg:OverseasAssetRegistry
    a owl:Class ;
    rdfs:label "境外国有资产产权登记"@zh , "Overseas State-Owned Asset Registry"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment
        "依据国资委《中央企业境外国有资产监督管理暂行办法》，央企须将境外持有的股权、不动产、知识产权等纳入境外资产信息系统登记，实现境外资产全口径监管。"@zh ,
        "Per SASAC Interim Measures for Supervision of Overseas State-Owned Assets of Central SOEs, central SOEs must register overseas equity, real property, IP, etc. in the overseas asset information system for comprehensive coverage."@en .

oareg:OverseasAssetCategory
    a owl:Class ;
    rdfs:label "境外资产类别"@zh , "Overseas Asset Category"@en .

oareg:OverseasEquity         a oareg:OverseasAssetCategory , owl:NamedIndividual ; rdfs:label "境外股权资产"@zh , "Overseas Equity Assets"@en .
oareg:OverseasRealProperty   a oareg:OverseasAssetCategory , owl:NamedIndividual ; rdfs:label "境外不动产"@zh , "Overseas Real Property"@en .
oareg:OverseasIPAssets       a oareg:OverseasAssetCategory , owl:NamedIndividual ; rdfs:label "境外知识产权"@zh , "Overseas IP Assets"@en .
oareg:OverseasFinancialAssets a oareg:OverseasAssetCategory , owl:NamedIndividual ; rdfs:label "境外金融资产"@zh , "Overseas Financial Assets"@en .
oareg:OverseasConcessionRights a oareg:OverseasAssetCategory , owl:NamedIndividual ; rdfs:label "境外特许经营权"@zh , "Overseas Concession Rights"@en .

oareg:hasRegistryNumber       a owl:DatatypeProperty ; rdfs:label "境外资产登记编号"@zh , "Overseas Asset Registry Number"@en ; rdfs:domain oareg:OverseasAssetRegistry ; rdfs:range xsd:string .
oareg:hasHostCountry          a owl:DatatypeProperty ; rdfs:label "所在国"@zh , "Host Country"@en ; rdfs:domain oareg:OverseasAssetRegistry ; rdfs:range xsd:string .
oareg:hasBookValue            a owl:DatatypeProperty ; rdfs:label "账面价值（人民币）"@zh , "Book Value (RMB)"@en ; rdfs:domain oareg:OverseasAssetRegistry ; rdfs:range xsd:decimal .
oareg:hasRegistrationStatus   a owl:DatatypeProperty ; rdfs:label "登记状态"@zh , "Registration Status"@en ; rdfs:domain oareg:OverseasAssetRegistry ; rdfs:range xsd:string ;
    rdfs:comment "ACTIVE | DISPOSED | FROZEN | SEIZED | UNDER_INVESTIGATION"@en .
oareg:hasLastVerifiedDate     a owl:DatatypeProperty ; rdfs:label "最近核实日期"@zh , "Last Verified Date"@en ; rdfs:domain oareg:OverseasAssetRegistry ; rdfs:range xsd:date .
oareg:hasAnnualReportObligation a owl:DatatypeProperty ; rdfs:label "须年度报告"@zh , "Annual Report Required"@en ; rdfs:domain oareg:OverseasAssetRegistry ; rdfs:range xsd:boolean .

oareg:OverseasAssetProtectionMeasure
    a owl:Class ;
    rdfs:label "境外资产保护措施"@zh , "Overseas Asset Protection Measure"@en ;
    rdfs:subClassOf oareg:OverseasAssetRegistry .

oareg:PoliticalRiskInsurance   a oareg:OverseasAssetProtectionMeasure , owl:NamedIndividual ;
    rdfs:label "政治风险保险（中国出口信保·SINOSURE）"@zh ,
               "Political Risk Insurance (SINOSURE)"@en .
oareg:AssetFreezeMonitoring    a oareg:OverseasAssetProtectionMeasure , owl:NamedIndividual ;
    rdfs:label "资产冻结监控预警"@zh , "Asset Freeze Monitoring Alert"@en .
oareg:HostCountryLegalProtection a oareg:OverseasAssetProtectionMeasure , owl:NamedIndividual ;
    rdfs:label "东道国双边投资协定保护（BIT）"@zh ,
               "Host Country Bilateral Investment Treaty Protection (BIT)"@en .

# ==============================================================================
# P0-FIX 4: 油气PSC/JOA合同专项 — CNPC-01
# 产品分成合同·风险服务合同·联合作业协议
# ==============================================================================

psc:OilGasContractAccounting
    a owl:Class ;
    rdfs:label "境外油气合同会计"@zh , "Overseas Oil and Gas Contract Accounting"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment
        "中石油·中石化等能源央企在境外采用多种合同模式开采油气资源，各合同模式的会计确认·计量·储量核算方法不同。"@zh ,
        "Energy central SOEs (CNPC, Sinopec) use multiple contract models for overseas oil/gas extraction; each model has different accounting recognition, measurement, and reserve accounting methods."@en .

psc:ContractType
    a owl:Class ;
    rdfs:label "境外油气合同类型"@zh , "Overseas Oil/Gas Contract Type"@en .

psc:ProductionSharingContract
    a psc:ContractType , owl:NamedIndividual ;
    rdfs:label "产品分成合同（PSC）"@zh , "Production Sharing Contract (PSC)"@en ;
    rdfs:comment "东道国政府（NOC）保留资源所有权，外国投资者（IOC/CNPC）承担勘探风险，成功则按约定比例分配产量。分为成本油（Cost Oil）和利润油（Profit Oil）。"@zh ,
                 "Host government (NOC) retains resource ownership; foreign investor (IOC/CNPC) bears exploration risk and receives proportional share of production if successful. Split into Cost Oil and Profit Oil."@en .

psc:RiskServiceContract
    a psc:ContractType , owl:NamedIndividual ;
    rdfs:label "风险服务合同（RSC）"@zh , "Risk Service Contract (RSC)"@en ;
    rdfs:comment "外国投资者提供服务并承担风险，以服务费或部分产量作为回报，不直接拥有资源份额。"@zh ,
                 "Foreign investor provides services and bears risk; receives service fee or portion of production as return without directly owning resource shares."@en .

psc:ConcessionAgreement
    a psc:ContractType , owl:NamedIndividual ;
    rdfs:label "特许权协议"@zh , "Concession Agreement"@en ;
    rdfs:comment "外国投资者获得特定区块的勘探开采特许权，缴纳矿区使用费（Royalty）和企业所得税。"@zh ,
                 "Foreign investor obtains concession for exploration/production in specific blocks, paying royalties and corporate income tax."@en .

psc:JointOperationAgreement
    a psc:ContractType , owl:NamedIndividual ;
    rdfs:label "联合作业协议（JOA）"@zh , "Joint Operation Agreement (JOA)"@en ;
    rdfs:comment "多个公司共同开发同一油气区块，设立联合作业委员会（JMC），由作业者（Operator）代表各方作业。"@zh ,
                 "Multiple companies jointly develop same oil/gas block; joint management committee (JMC) established; operator acts on behalf of all parties."@en .

psc:CostOil
    a owl:Class ;
    rdfs:label "成本油（成本回收）"@zh , "Cost Oil (Cost Recovery)"@en ;
    rdfs:subClassOf psc:ProductionSharingContract ;
    rdfs:comment "PSC下外国投资者用于回收已发生勘探开发成本的产量份额，通常设上限（如60%）。"@zh ,
                 "Under PSC, the production share foreign investor uses to recover incurred exploration/development costs; typically capped (e.g., 60%)."@en .

psc:hasCostRecoveryCap         a owl:DatatypeProperty ; rdfs:label "成本回收上限"@zh , "Cost Recovery Cap"@en ; rdfs:domain psc:CostOil ; rdfs:range xsd:decimal .

psc:ProfitOil
    a owl:Class ;
    rdfs:label "利润油（利润分成）"@zh , "Profit Oil (Profit Split)"@en ;
    rdfs:subClassOf psc:ProductionSharingContract ;
    rdfs:comment "扣除成本油后剩余产量在东道国政府和外国投资者之间按约定比例分配。"@zh ,
                 "Remaining production after cost oil deduction, split between host government and foreign investor per agreed ratios."@en .

psc:hasGovtProfitOilShare      a owl:DatatypeProperty ; rdfs:label "政府利润油分成比例"@zh , "Government Profit Oil Share"@en ; rdfs:domain psc:ProfitOil ; rdfs:range xsd:decimal .
psc:hasInvestorProfitOilShare  a owl:DatatypeProperty ; rdfs:label "投资者利润油分成比例"@zh , "Investor Profit Oil Share"@en ; rdfs:domain psc:ProfitOil ; rdfs:range xsd:decimal .

psc:Royalty
    a owl:Class ;
    rdfs:label "矿区使用费（Royalty）"@zh , "Royalty"@en ;
    rdfs:subClassOf psc:OilGasContractAccounting ;
    rdfs:comment "按产量或收入一定比例支付给东道国政府或矿产权人的费用，在税前扣除。"@zh ,
                 "Fee paid to host government or mineral rights owner as percentage of production or revenue; deductible before tax."@en .

psc:hasRoyaltyRate             a owl:DatatypeProperty ; rdfs:label "矿区使用费率"@zh , "Royalty Rate"@en ; rdfs:domain psc:Royalty ; rdfs:range xsd:decimal .

psc:OilGasReserveAccounting
    a owl:Class ;
    rdfs:label "油气储量核算（PRMS标准）"@zh , "Oil and Gas Reserve Accounting (PRMS)"@en ;
    rdfs:subClassOf psc:OilGasContractAccounting ;
    rdfs:comment "依据石油资源管理体系（PRMS），储量分为证实储量（1P）·证实+概算（2P）·证实+概算+可能（3P），须按年进行独立评估。"@zh ,
                 "Per Petroleum Resources Management System (PRMS), reserves classified as Proved (1P) · Proved+Probable (2P) · 3P; require annual independent assessment."@en .

psc:ReserveCategory
    a owl:Class ; rdfs:label "储量类别"@zh , "Reserve Category"@en .
psc:ProvedReserves    a psc:ReserveCategory , owl:NamedIndividual ; rdfs:label "证实储量（1P）"@zh , "Proved Reserves (1P)"@en .
psc:ProbableReserves  a psc:ReserveCategory , owl:NamedIndividual ; rdfs:label "概算储量（2P）"@zh , "Probable Reserves (2P)"@en .
psc:PossibleReserves  a psc:ReserveCategory , owl:NamedIndividual ; rdfs:label "可能储量（3P）"@zh , "Possible Reserves (3P)"@en .

psc:DecommissioningLiability
    a owl:Class ;
    rdfs:label "弃置义务（ARO）"@zh , "Asset Retirement Obligation (ARO)"@en ;
    rdfs:subClassOf psc:OilGasContractAccounting ;
    rdfs:comment "油气设施退役时的拆除·恢复环境义务，须按IAS 37/CAS 13计提弃置准备。"@zh ,
                 "Obligation to dismantle and restore environment when oil/gas facilities are retired; must provide for ARO per IAS 37/CAS 13."@en .

# ==============================================================================
# P0-FIX 5: 多法域合并报表 — CMG-01
# 不同GAAP准则间的调整与合并
# ==============================================================================

multgaap:MultiJurisdictionConsolidation
    a owl:Class ;
    rdfs:label "多法域合并报表体系"@zh , "Multi-Jurisdiction Consolidated Reporting System"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment
        "集团在50+国家有业务时，需将不同会计准则（IFRS·US GAAP·HKFRS·各国GAAP）编制的报表统一转换为集团报告准则（CAS）后再合并。"@zh ,
        "When a group operates in 50+ countries, financial statements prepared under different standards (IFRS, US GAAP, HKFRS, local GAAPs) must be converted to the group reporting standard (CAS) before consolidation."@en .

multgaap:GAAPlabel
    a owl:Class ;
    rdfs:label "适用会计准则标签"@zh , "Applicable Accounting Standard Label"@en .

multgaap:IFRS_Label    a multgaap:GAAPlabel , owl:NamedIndividual ; rdfs:label "IFRS（国际财报准则）"@zh , "IFRS"@en .
multgaap:HKFRS_Label   a multgaap:GAAPlabel , owl:NamedIndividual ; rdfs:label "HKFRS（香港财报准则）"@zh , "HKFRS"@en .
multgaap:USGAAP_Label  a multgaap:GAAPlabel , owl:NamedIndividual ; rdfs:label "US GAAP"@zh , "US GAAP"@en .
multgaap:CAS_Label     a multgaap:GAAPlabel , owl:NamedIndividual ; rdfs:label "CAS（企业会计准则）"@zh , "CAS (China Accounting Standards)"@en .
multgaap:LocalGAAP     a multgaap:GAAPlabel , owl:NamedIndividual ; rdfs:label "当地GAAP（本地会计准则）"@zh , "Local GAAP"@en .

multgaap:GAAPConversionAdjustment
    a owl:Class ;
    rdfs:label "GAAP差异调整"@zh , "GAAP Conversion Adjustment"@en ;
    rdfs:subClassOf multgaap:MultiJurisdictionConsolidation ;
    rdfs:comment "将境外子公司从所在地GAAP转换为集团报告准则的调整分录，须单独记录和审计。"@zh ,
                 "Adjustment entries converting overseas subsidiaries from local GAAP to group reporting standard; must be separately recorded and audited."@en .

multgaap:hasFromGAAP    a owl:ObjectProperty ; rdfs:label "源准则"@zh , "From GAAP"@en ; rdfs:domain multgaap:GAAPConversionAdjustment ; rdfs:range multgaap:GAAPlabel .
multgaap:hasToGAAP      a owl:ObjectProperty ; rdfs:label "目标准则"@zh , "To GAAP"@en ; rdfs:domain multgaap:GAAPConversionAdjustment ; rdfs:range multgaap:GAAPlabel .
multgaap:hasAdjustmentAmount a owl:DatatypeProperty ; rdfs:label "调整金额"@zh , "Adjustment Amount"@en ; rdfs:domain multgaap:GAAPConversionAdjustment ; rdfs:range xsd:decimal .

multgaap:FunctionalCurrencyDetermination
    a owl:Class ;
    rdfs:label "功能货币认定"@zh , "Functional Currency Determination"@en ;
    rdfs:subClassOf multgaap:MultiJurisdictionConsolidation ;
    rdfs:comment "按IAS 21/CAS 19确定境外实体的功能货币，影响汇兑损益处理（计入损益还是OCI）。"@zh ,
                 "Determines overseas entity's functional currency per IAS 21/CAS 19; impacts forex gain/loss treatment (P&L vs. OCI)."@en .

multgaap:CurrencyTranslationMethod
    a owl:Class ;
    rdfs:label "货币折算方法"@zh , "Currency Translation Method"@en .
multgaap:CurrentRateMethod   a multgaap:CurrencyTranslationMethod , owl:NamedIndividual ; rdfs:label "现时法（期末汇率）"@zh , "Current Rate Method"@en .
multgaap:TemporalMethod      a multgaap:CurrencyTranslationMethod , owl:NamedIndividual ; rdfs:label "时序法（历史汇率）"@zh , "Temporal Method"@en .

multgaap:IntraGroupEliminationDetail
    a owl:Class ;
    rdfs:label "集团内部交易抵消明细"@zh , "Intra-Group Elimination Detail"@en ;
    rdfs:subClassOf multgaap:MultiJurisdictionConsolidation ;
    rdfs:comment "解决CFO-01痛点：内部应收/应付·内部销售·内部股息·未实现内部损益的逐笔抵消标识和自动生成。"@zh ,
                 "Addresses CFO-01 pain point: line-item identification and auto-generation of eliminations for intra-group receivables/payables, sales, dividends, unrealized intra-group profits."@en .

multgaap:EliminationType
    a owl:Class ; rdfs:label "抵消类型"@zh , "Elimination Type"@en .
multgaap:IntraGroupReceivablePayable a multgaap:EliminationType , owl:NamedIndividual ; rdfs:label "内部应收/应付抵消"@zh , "Intra-Group Receivable/Payable Elimination"@en .
multgaap:IntraGroupSalesProfit       a multgaap:EliminationType , owl:NamedIndividual ; rdfs:label "内部销售未实现损益"@zh , "Unrealized Intra-Group Sales Profit"@en .
multgaap:IntraGroupDividend          a multgaap:EliminationType , owl:NamedIndividual ; rdfs:label "内部股息抵消"@zh , "Intra-Group Dividend Elimination"@en .
multgaap:IntraGroupLoanInterest      a multgaap:EliminationType , owl:NamedIndividual ; rdfs:label "内部贷款利息抵消"@zh , "Intra-Group Loan Interest Elimination"@en .

# ==============================================================================
# P0-FIX 6: EPC工程总包专项会计 — POLY-02
# IFRS 15完工百分比·变更令·索赔·保证金
# ==============================================================================

epc:EPCContractAccounting
    a owl:Class ;
    rdfs:label "EPC工程总包合同会计"@zh , "EPC Engineering Contract Accounting"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment
        "中建·中交·中铁·保利等工程承包央企的EPC/BOT/PPP项目专项会计。依据IFRS 15/CAS 14（完工百分比）·IFRIC 12（服务特许权安排）处理。"@zh ,
        "Specialized accounting for EPC/BOT/PPP projects of engineering SOEs (CSCEC, CCCC, CRRC, Poly). Per IFRS 15/CAS 14 (percentage of completion) and IFRIC 12 (service concession arrangements)."@en .

epc:PercentageOfCompletion
    a owl:Class ;
    rdfs:label "完工百分比法"@zh , "Percentage of Completion Method"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "按实际完工进度确认收入，进度度量方式：已完工程投入成本/合同总预算成本。"@zh ,
                 "Revenue recognized per actual completion progress; progress measured as: costs incurred to date / total estimated contract costs."@en .

epc:hasCompletionPercentage    a owl:DatatypeProperty ; rdfs:label "完工百分比"@zh , "Completion Percentage"@en ; rdfs:domain epc:PercentageOfCompletion ; rdfs:range xsd:decimal .
epc:hasTotalContractRevenue    a owl:DatatypeProperty ; rdfs:label "合同总收入"@zh , "Total Contract Revenue"@en ; rdfs:domain epc:EPCContractAccounting ; rdfs:range xsd:decimal .
epc:hasTotalContractCost       a owl:DatatypeProperty ; rdfs:label "合同总成本预算"@zh , "Total Estimated Contract Cost"@en ; rdfs:domain epc:EPCContractAccounting ; rdfs:range xsd:decimal .
epc:hasContractStatus          a owl:DatatypeProperty ; rdfs:label "合同执行状态"@zh , "Contract Execution Status"@en ; rdfs:domain epc:EPCContractAccounting ; rdfs:range xsd:string ;
    rdfs:comment "BIDDING | AWARDED | IN_EXECUTION | DEFECT_LIABILITY | COMPLETED | DISPUTE"@en .

epc:VariationOrder
    a owl:Class ;
    rdfs:label "合同变更令（VO/CO）"@zh , "Variation Order (VO)"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "业主指示的工程变更，引起合同金额和工期变化。已批准变更令纳入合同金额，待批变更令作为或有资产。"@zh ,
                 "Owner-directed engineering changes causing contract amount/duration changes. Approved VOs included in contract value; pending VOs treated as contingent assets."@en .

epc:Claim
    a owl:Class ;
    rdfs:label "索赔（Claim）"@zh , "Contract Claim"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "承包商因业主原因（延期付款·设计变更·恶劣地质）产生的额外费用索赔。须有合理证据且可能收回才能确认。"@zh ,
                 "Contractor's additional cost claims due to owner-caused events (delayed payment, design changes, unforeseen ground conditions). Recognized only with reasonable evidence of recovery."@en .

epc:RetentionMoney
    a owl:Class ;
    rdfs:label "预留金（Retention Money）"@zh , "Retention Money"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "业主按合同金额一定比例预留，待质保期结束后退还。分为施工期预留（通常5%）和质保期预留。"@zh ,
                 "Retained by owner at percentage of contract value, released after defect liability period. Split: construction retention (typically 5%) and defect liability retention."@en .

epc:PerformanceBond
    a owl:Class ;
    rdfs:label "履约保证金"@zh , "Performance Bond"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "承包商提供给业主的履约担保，通常为合同价10%的银行保函，完工后退还。"@zh ,
                 "Performance guarantee provided by contractor to owner; typically 10% of contract value bank guarantee, returned upon completion."@en .

epc:ConstructionPeriodInterestCapitalization
    a owl:Class ;
    rdfs:label "建设期利息资本化"@zh , "Construction Period Interest Capitalization"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "BOT/PPP项目建设期内的借款利息，满足条件时资本化为在建工程成本。依据IAS 23/CAS 17。"@zh ,
                 "Borrowing costs during BOT/PPP construction period, capitalized as construction-in-progress costs when criteria met. Per IAS 23/CAS 17."@en .

epc:ServiceConcessionArrangement
    a owl:Class ;
    rdfs:label "服务特许权安排（IFRIC 12）"@zh , "Service Concession Arrangement (IFRIC 12)"@en ;
    rdfs:subClassOf epc:EPCContractAccounting ;
    rdfs:comment "BOT/TOT等特许经营模式下，基础设施不归承包商所有，但承包商在特许期内运营并获取费用。按金融资产模式或无形资产模式确认。"@zh ,
                 "Under BOT/TOT concessions, infrastructure not owned by operator; operator earns fees during concession period. Recognized under financial asset model or intangible asset model."@en .

epc:hasFinancialAssetModel   a owl:DatatypeProperty ; rdfs:label "采用金融资产模式"@zh , "Financial Asset Model Applied"@en ; rdfs:domain epc:ServiceConcessionArrangement ; rdfs:range xsd:boolean .

# ==============================================================================
# P0-FIX 7: 32号令产权交易程序 — PROP-01
# 企业国有资产交易监督管理办法（国资委·财政部令第32号）
# ==============================================================================

tx32:SOEAssetTransactionRegulation
    a owl:Class ;
    rdfs:label "企业国有资产交易监管（32号令）"@zh ,
               "SOE Asset Transaction Supervision (Order No.32)"@en ;
    rdfs:subClassOf prop:PropertyRightsManagement ;
    rdfs:comment
        "依据《企业国有资产交易监督管理办法》（国资委·财政部令第32号），规范国有产权·国有资产·上市公司国有股权的公开交易，防止国有资产流失。"@zh ,
        "Per the Measures for Supervision and Administration of Transactions of Enterprise State-Owned Assets (Order No.32), regulating open trading of state-owned property rights, assets, and listed company state equity to prevent asset dissipation."@en .

tx32:TransactionScope
    a owl:Class ;
    rdfs:label "适用交易范围"@zh , "Applicable Transaction Scope"@en .

tx32:PropertyRightTransfer  a tx32:TransactionScope , owl:NamedIndividual ; rdfs:label "国有产权转让"@zh , "State-Owned Property Rights Transfer"@en .
tx32:AssetTransfer          a tx32:TransactionScope , owl:NamedIndividual ; rdfs:label "国有资产转让（重大资产）"@zh , "State-Owned Major Asset Transfer"@en .
tx32:ListedEquityTransfer   a tx32:TransactionScope , owl:NamedIndividual ; rdfs:label "上市公司国有股权转让"@zh , "Listed Company State Equity Transfer"@en .
tx32:CapitalIncrease        a tx32:TransactionScope , owl:NamedIndividual ; rdfs:label "增资（引入战略投资者）"@zh , "Capital Increase (Strategic Investor Introduction)"@en .

tx32:PublicListingRequirement
    a owl:Class ;
    rdfs:label "公开挂牌要求"@zh , "Public Listing Requirement"@en ;
    rdfs:subClassOf tx32:SOEAssetTransactionRegulation ;
    rdfs:comment "产权转让须在依法设立的产权交易所（上交所·深交所·北交所·各地产交所）公开挂牌，不少于20个工作日。"@zh ,
                 "Property right transfers must be publicly listed on legally established property rights exchanges (SSE, SZSE, BSE, local exchanges) for no less than 20 working days."@en .

tx32:hasListingDurationWorkdays a owl:DatatypeProperty ;
    rdfs:label "挂牌期限（工作日）"@zh , "Listing Duration (Workdays)"@en ;
    rdfs:domain tx32:PublicListingRequirement ;
    rdfs:range xsd:integer .

tx32:PriceFloor
    a owl:Class ;
    rdfs:label "底价确定规则"@zh , "Reserve Price Determination Rules"@en ;
    rdfs:subClassOf tx32:SOEAssetTransactionRegulation ;
    rdfs:comment "转让价格不得低于经核准的评估值，且不得低于评估值的90%（特殊情况须经审批）。"@zh ,
                 "Transfer price must not be less than the approved appraised value and not less than 90% of appraised value (special cases require approval)."@en .

tx32:hasMinimumPriceRatio a owl:DatatypeProperty ;
    rdfs:label "底价占评估值最低比例"@zh , "Minimum Price as % of Appraised Value"@en ;
    rdfs:domain tx32:PriceFloor ;
    rdfs:range xsd:decimal .

tx32:TransactionApprovalHierarchy
    a owl:Class ;
    rdfs:label "交易审批层级"@zh , "Transaction Approval Hierarchy"@en ;
    rdfs:subClassOf tx32:SOEAssetTransactionRegulation .

tx32:BuyerQualification
    a owl:Class ;
    rdfs:label "受让方资格审查"@zh , "Acquirer Qualification Review"@en ;
    rdfs:subClassOf tx32:SOEAssetTransactionRegulation ;
    rdfs:comment "受让方须符合：商业信誉·财务实力·无重大违规记录·具备经营资质（特许行业）。境外受让方须额外进行国家安全审查。"@zh ,
                 "Acquirer must meet: commercial reputation, financial strength, no major violations, operational qualifications (licensed industries). Overseas acquirers require additional national security review."@en .

tx32:PostTransactionDisclosure
    a owl:Class ;
    rdfs:label "交易结果公示"@zh , "Post-Transaction Disclosure"@en ;
    rdfs:subClassOf tx32:SOEAssetTransactionRegulation ;
    rdfs:comment "交易完成后须在交易所或国资委网站公示结果，接受社会监督。"@zh ,
                 "Transaction results must be publicly disclosed on exchange or SASAC website after completion for public supervision."@en .

# ==============================================================================
# P1-FIX 1: OFAC制裁实操细节 — CNPC-02
# ==============================================================================

sanction:OFACComplianceDetail
    a owl:Class ;
    rdfs:label "OFAC制裁合规实操"@zh , "OFAC Sanctions Compliance Operations"@en ;
    rdfs:subClassOf comp:SanctionsCompliance ;
    rdfs:comment "美国财政部海外资产控制办公室（OFAC）制裁的实操合规机制，中石油·中石化等在美有业务的央企必须遵守。"@zh ,
                 "Operational compliance mechanisms for OFAC (Office of Foreign Assets Control) sanctions; mandatory for central SOEs with US business operations."@en .

sanction:SDNList
    a owl:Class ;
    rdfs:label "SDN名单（特别指定国民）"@zh , "Specially Designated Nationals List (SDN)"@en ;
    rdfs:subClassOf sanction:OFACComplianceDetail ;
    rdfs:comment "OFAC维护的SDN名单每日更新，与SDN名单上的实体及其50%以上控股实体（50%规则）的任何交易被禁止。"@zh ,
                 "OFAC maintains SDN list updated daily; any transaction with SDN-listed entities or their 50%+ controlled subsidiaries (50% Rule) is prohibited."@en .

sanction:FiftyPercentRule
    a owl:Class ;
    rdfs:label "50%规则（关联实体禁止）"@zh , "50% Rule (Affiliated Entity Prohibition)"@en ;
    rdfs:subClassOf sanction:SDNList ;
    rdfs:comment "即使实体未直接列入SDN名单，若SDN实体持有其50%以上股权，该实体同样受禁令约束。"@zh ,
                 "Even if an entity is not directly on the SDN list, if an SDN entity holds 50%+ equity, that entity is also subject to the prohibition."@en .

sanction:SecondaryTertiaryRisk
    a owl:Class ;
    rdfs:label "二次/三次制裁风险"@zh , "Secondary/Tertiary Sanctions Risk"@en ;
    rdfs:subClassOf sanction:OFACComplianceDetail ;
    rdfs:comment "二次制裁针对非美国实体与被制裁国（俄·伊·委·朝·叙）的重大交易，可能导致美国市场准入和美元结算中断。"@zh ,
                 "Secondary sanctions target non-US entities conducting significant transactions with sanctioned countries (Russia, Iran, Venezuela, DPRK, Syria), potentially causing loss of US market access and USD settlement."@en .

sanction:VSDProcedure
    a owl:Class ;
    rdfs:label "OFAC主动披露程序（VSD）"@zh , "OFAC Voluntary Self-Disclosure (VSD)"@en ;
    rdfs:subClassOf sanction:OFACComplianceDetail ;
    rdfs:comment "发现潜在制裁违规时，主动向OFAC自愿披露可显著降低处罚（通常减半）。须在合理时间内（通常30天内初报）。"@zh ,
                 "When potential sanction violations are discovered, voluntary disclosure to OFAC can significantly reduce penalties (typically halved). Initial report generally within 30 days."@en .

sanction:SanctionsScreeningFrequency
    a owl:DatatypeProperty ;
    rdfs:label "制裁筛查频率"@zh , "Sanctions Screening Frequency"@en ;
    rdfs:domain sanction:OFACComplianceDetail ;
    rdfs:range xsd:string ;
    rdfs:comment "推荐：每日更新SDN名单·每笔交易前筛查交易对手·季度批量筛查供应商。"@zh ,
                 "Recommended: daily SDN list updates · screen counterparties before each transaction · quarterly batch screening of vendors."@en .

# ==============================================================================
# P1-FIX 2: 大宗商品贸易结算 — SINOPEC-01
# ==============================================================================

comtrade:CommodityTradeSettlement
    a owl:Class ;
    rdfs:label "大宗商品贸易结算"@zh , "Commodity Trade Settlement"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment "中石化·五矿·中储粮等贸易类央企在境外从事大宗商品贸易时涉及的信用证·结构融资·衍生品结算机制。"@zh ,
                 "Credit instruments, structured finance, and derivatives settlement for commodity trade by trading-oriented central SOEs (Sinopec, Minmetals, Sinograin)."@en .

comtrade:LetterOfCredit
    a owl:Class ;
    rdfs:label "信用证（L/C）"@zh , "Letter of Credit (L/C)"@en ;
    rdfs:subClassOf comtrade:CommodityTradeSettlement .

comtrade:DocumentaryLC      a comtrade:LetterOfCredit , owl:NamedIndividual ; rdfs:label "跟单信用证"@zh , "Documentary Letter of Credit"@en .
comtrade:StandbyLC          a comtrade:LetterOfCredit , owl:NamedIndividual ; rdfs:label "备用信用证"@zh , "Standby Letter of Credit"@en .

comtrade:Forfaiting
    a owl:Class ;
    rdfs:label "福费廷（票据贴现）"@zh , "Forfaiting"@en ;
    rdfs:subClassOf comtrade:CommodityTradeSettlement ;
    rdfs:comment "出口商将未到期的远期汇票或本票以贴现方式卖断给银行，提前回收资金。"@zh ,
                 "Exporter sells unmatured bills of exchange or promissory notes to bank at discount for early cash recovery."@en .

comtrade:CIPSSettlement
    a owl:Class ;
    rdfs:label "CIPS人民币跨境支付"@zh , "CIPS (Cross-Border Interbank Payment System) Settlement"@en ;
    rdfs:subClassOf comtrade:CommodityTradeSettlement ;
    rdfs:comment "通过中国跨境银行间支付清算（CIPS）系统结算人民币跨境交易，是SWIFT的补充通道，对制裁风险有一定隔离。"@zh ,
                 "Settles cross-border RMB transactions through CIPS, supplementing SWIFT and providing some insulation from sanctions risks."@en .

comtrade:PriceRiskHedging
    a owl:Class ;
    rdfs:label "大宗商品价格套保"@zh , "Commodity Price Risk Hedging"@en ;
    rdfs:subClassOf comtrade:CommodityTradeSettlement ;
    rdfs:comment "原油·铜·铁矿石·农产品等大宗商品价格风险，通过期货·期权·互换进行套期保值，须严格执行国资委套保政策。"@zh ,
                 "Crude oil, copper, iron ore, agricultural commodities price risks hedged via futures, options, swaps; must strictly follow SASAC hedging policies."@en .

# ==============================================================================
# P1-FIX 3: SPV/VIE架构合规 — CMG-02
# ==============================================================================

spvvie:SPVVIEComplianceFramework
    a owl:Class ;
    rdfs:label "SPV/VIE架构合规框架"@zh , "SPV/VIE Structure Compliance Framework"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment "评估国有企业在海外设立特殊目的载体（SPV）和可变利益实体（VIE）架构的合规性，防止通过复杂架构规避监管。"@zh ,
                 "Assesses compliance of SOE-established overseas SPVs and Variable Interest Entity (VIE) structures to prevent supervisory circumvention through complex architectures."@en .

spvvie:SPVLegitimacyCriteria
    a owl:Class ;
    rdfs:label "SPV设立合法性标准"@zh , "SPV Establishment Legitimacy Criteria"@en ;
    rdfs:subClassOf spvvie:SPVVIEComplianceFramework ;
    rdfs:comment "合法SPV须有：真实商业目的·实质性经营活动（非空壳）·合理税务安排（非避税地滥用）·国资委备案。"@zh ,
                 "Legitimate SPV must have: genuine business purpose, substantive operations (non-shell), reasonable tax arrangements (no tax haven abuse), SASAC filing."@en .

spvvie:VIEConsolidationJudgment
    a owl:Class ;
    rdfs:label "VIE合并判断标准"@zh , "VIE Consolidation Judgment Criteria"@en ;
    rdfs:subClassOf spvvie:SPVVIEComplianceFramework ;
    rdfs:comment "可变利益实体是否纳入合并范围：须判断是否为主要受益人（Primary Beneficiary），即谁承担最大风险/获得最大收益。"@zh ,
                 "Whether VIEs are consolidated: must determine if entity is primary beneficiary (bears most risk/receives most benefits)."@en .

spvvie:OffshoreHoldingStructureRisk
    a owl:Class ;
    rdfs:label "离岸控股架构风险"@zh , "Offshore Holding Structure Risk"@en ;
    rdfs:subClassOf spvvie:SPVVIEComplianceFramework ;
    rdfs:comment "境外多层控股架构可能引发：股息汇回税务成本·国安审查升级·穿透监管复杂度·境外产权流失风险。"@zh ,
                 "Overseas multi-layer holding structures may trigger: dividend repatriation tax costs, escalated national security reviews, penetration supervision complexity, overseas property rights loss risks."@en .

# ==============================================================================
# P1-FIX 4: 香港/HKFRS合规 — CR-01
# ==============================================================================

hkfrs:HKFRSComplianceFramework
    a owl:Class ;
    rdfs:label "香港会计准则与港股合规"@zh , "HKFRS and Hong Kong Listing Compliance"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment "在香港联交所上市的国有企业须遵守香港财务报告准则（HKFRS）及联交所上市规则，同时满足中国境内CAS报告要求。"@zh ,
                 "State-owned enterprises listed on the Hong Kong Stock Exchange must comply with HKFRS and HKEX Listing Rules while meeting domestic CAS reporting requirements."@en .

hkfrs:HKEXListingRules
    a owl:Class ;
    rdfs:label "联交所上市规则"@zh , "HKEX Listing Rules"@en ;
    rdfs:subClassOf hkfrs:HKFRSComplianceFramework .

hkfrs:ConnectedTransactionRule
    a owl:Class ;
    rdfs:label "关连交易规则（联交所）"@zh , "Connected Transaction Rules (HKEX)"@en ;
    rdfs:subClassOf hkfrs:HKEXListingRules ;
    rdfs:comment "联交所关连交易规则比CAS关联方更严格，要求独立股东批准的门槛更低，独立财务顾问意见。"@zh ,
                 "HKEX connected transaction rules are stricter than CAS related-party rules; lower thresholds for independent shareholder approval and IFA opinion."@en .

hkfrs:AHShareDualListing
    a owl:Class ;
    rdfs:label "A+H股双重上市合规"@zh , "A+H Share Dual Listing Compliance"@en ;
    rdfs:subClassOf hkfrs:HKFRSComplianceFramework ;
    rdfs:comment "同时在A股和H股上市的央企须遵守两套规则：信息披露同步·重大事项双所申报·内幕消息管理。"@zh ,
                 "Central SOEs dual-listed on A and H shares must comply with both rulesets: synchronized disclosure, dual-exchange major event filing, insider information management."@en .

hkfrs:CAStoHKFRSDifference
    a owl:Class ;
    rdfs:label "CAS与HKFRS主要差异"@zh , "Key CAS-HKFRS Differences"@en ;
    rdfs:subClassOf hkfrs:HKFRSComplianceFramework ;
    rdfs:comment "主要差异：政府补助处理（IAS 20 vs CAS 16）·金融工具分类·商誉摊销（CAS保留摊销）·关联方范围（国有实体豁免差异）。"@zh ,
                 "Key differences: government grants (IAS 20 vs CAS 16), financial instrument classification, goodwill amortization (CAS retains), related-party scope (state entity exemption differences)."@en .

# ==============================================================================
# P1-FIX 5: EU CSRD企业可持续报告 — CHEM-02
# ==============================================================================

csrd:EUCSRDCompliance
    a owl:Class ;
    rdfs:label "欧盟企业可持续发展报告指令（CSRD）"@zh ,
               "EU Corporate Sustainability Reporting Directive (CSRD)"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment
        "2024年起欧盟CSRD对在欧运营的大型企业生效，覆盖部分在欧有重大业务的中国央企子公司（中国化工·中远·华为等）。要求双重重要性评估·ESRS标准·第三方鉴证。"@zh ,
        "EU CSRD effective from 2024 for large companies operating in EU; covers certain Chinese central SOE subsidiaries with significant EU operations. Requires double materiality assessment, ESRS standards, third-party assurance."@en .

csrd:DoubleMaterialityAssessment
    a owl:Class ;
    rdfs:label "双重重要性评估"@zh , "Double Materiality Assessment"@en ;
    rdfs:subClassOf csrd:EUCSRDCompliance ;
    rdfs:comment "财务重要性（对企业财务影响）+影响重要性（对环境/社会影响）双维度评估。"@zh ,
                 "Dual-dimension assessment: financial materiality (impact on enterprise finances) + impact materiality (impact on environment/society)."@en .

csrd:ESRSStandard
    a owl:Class ;
    rdfs:label "ESRS可持续发展报告标准"@zh , "ESRS (European Sustainability Reporting Standards)"@en ;
    rdfs:subClassOf csrd:EUCSRDCompliance .

csrd:ESRS_E1  a csrd:ESRSStandard , owl:NamedIndividual ; rdfs:label "ESRS E1气候变化"@zh , "ESRS E1 Climate Change"@en .
csrd:ESRS_E2  a csrd:ESRSStandard , owl:NamedIndividual ; rdfs:label "ESRS E2污染"@zh , "ESRS E2 Pollution"@en .
csrd:ESRS_S1  a csrd:ESRSStandard , owl:NamedIndividual ; rdfs:label "ESRS S1自有员工"@zh , "ESRS S1 Own Workforce"@en .
csrd:ESRS_G1  a csrd:ESRSStandard , owl:NamedIndividual ; rdfs:label "ESRS G1商业行为"@zh , "ESRS G1 Business Conduct"@en .

csrd:ValueChainDueDiligence
    a owl:Class ;
    rdfs:label "价值链尽职调查"@zh , "Value Chain Due Diligence"@en ;
    rdfs:subClassOf csrd:EUCSRDCompliance ;
    rdfs:comment "CSRD要求披露供应链ESG风险，需对一级供应商进行人权·劳工·环境尽职调查（与EU CSDDD协同）。"@zh ,
                 "CSRD requires supply chain ESG risk disclosure; due diligence on Tier-1 suppliers for human rights, labor, environmental issues (aligned with EU CSDDD)."@en .

# ==============================================================================
# P1-FIX 6: 航运专项会计 — COSCO-01
# ==============================================================================

shipping:ShippingIndustryAccounting
    a owl:Class ;
    rdfs:label "航运行业专项会计"@zh , "Shipping Industry Specialized Accounting"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment "中远海运等航运央企的特殊会计处理：IFRS 16租赁·IMO环保合规·碳排放·运费收入确认。"@zh ,
                 "Specialized accounting for shipping central SOEs (COSCO): IFRS 16 leases, IMO environmental compliance, carbon emissions, freight revenue recognition."@en .

shipping:VesselLeaseAccounting
    a owl:Class ;
    rdfs:label "船舶租赁会计（IFRS 16）"@zh , "Vessel Lease Accounting (IFRS 16)"@en ;
    rdfs:subClassOf shipping:ShippingIndustryAccounting .

shipping:BareboatCharter a shipping:VesselLeaseAccounting , owl:NamedIndividual ;
    rdfs:label "光租（Bareboat Charter）"@zh , "Bareboat Charter (Demise Charter)"@en ;
    rdfs:comment "光租通常为融资租赁，承租方确认使用权资产和租赁负债。"@zh , "Bareboat charter typically a finance lease; lessee recognizes ROU asset and lease liability."@en .
shipping:TimeCharter a shipping:VesselLeaseAccounting , owl:NamedIndividual ;
    rdfs:label "期租（Time Charter）"@zh , "Time Charter"@en ;
    rdfs:comment "期租可能为经营租赁或融资租赁，取决于合同条款和租期。"@zh , "Time charter may be operating or finance lease depending on contract terms and duration."@en .
shipping:VoyageCharter a shipping:VesselLeaseAccounting , owl:NamedIndividual ;
    rdfs:label "程租（Voyage Charter）"@zh , "Voyage Charter"@en ;
    rdfs:comment "程租通常为服务合同，非租赁，按航次确认收入。"@zh , "Voyage charter typically a service contract (not a lease); revenue recognized per voyage."@en .

shipping:DemurrageDespatch
    a owl:Class ;
    rdfs:label "滞期费与速遣费"@zh , "Demurrage and Despatch"@en ;
    rdfs:subClassOf shipping:ShippingIndustryAccounting ;
    rdfs:comment "货物装卸超时产生滞期费（船东向租船人收取）；提前完成产生速遣费（通常为滞期费50%）。"@zh ,
                 "Excess loading/discharging time generates demurrage (shipowner charges charterer); early completion generates despatch (typically 50% of demurrage rate)."@en .

shipping:IMOCarbonCompliance
    a owl:Class ;
    rdfs:label "IMO碳排放合规（CII评级）"@zh , "IMO Carbon Emission Compliance (CII Rating)"@en ;
    rdfs:subClassOf shipping:ShippingIndustryAccounting ;
    rdfs:comment "IMO 2023强制要求船舶报告碳强度指标（CII），评级A-E影响船舶运营许可和二手船价值。"@zh ,
                 "IMO 2023 mandates vessel carbon intensity indicator (CII) reporting; A-E rating affects vessel operating licenses and second-hand vessel values."@en .

shipping:EUETSForShipping
    a owl:Class ;
    rdfs:label "欧盟碳市场（航运ETS）"@zh , "EU Emissions Trading System for Shipping (EU ETS)"@en ;
    rdfs:subClassOf shipping:ShippingIndustryAccounting ;
    rdfs:comment "2024年起欧盟将航运纳入EU ETS，抵港或离港欧盟港口的船舶须购买碳配额。"@zh ,
                 "From 2024, EU includes shipping in EU ETS; vessels calling at EU ports must purchase carbon allowances."@en .

# ==============================================================================
# STRATEGY MODULE: 战略规划管理 — PLAN-01
# ==============================================================================

strat:StrategicPlanningManagement
    a owl:Class ;
    rdfs:label "战略规划监管管理"@zh , "Strategic Planning Supervision Management"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "国资委对央企中长期战略规划的审批·备案·执行监督·动态调整的监管体系。"@zh ,
                 "SASAC's regulatory system for reviewing, filing, execution monitoring, and dynamic adjustment of central SOE medium/long-term strategic plans."@en .

strat:FiveYearPlan
    a owl:Class ;
    rdfs:label "企业五年发展规划"@zh , "Enterprise Five-Year Development Plan"@en ;
    rdfs:subClassOf strat:StrategicPlanningManagement ;
    rdfs:comment "与国家五年规划周期衔接的企业中期发展规划，须经国资委审批。"@zh ,
                 "Enterprise medium-term development plan aligned with national five-year plan cycle; requires SASAC approval."@en .

strat:AnnualPlanExecution
    a owl:Class ;
    rdfs:label "年度计划执行情况"@zh , "Annual Plan Execution Status"@en ;
    rdfs:subClassOf strat:StrategicPlanningManagement .

strat:StrategicInvestmentPriority
    a owl:Class ;
    rdfs:label "战略性投资方向"@zh , "Strategic Investment Priority"@en ;
    rdfs:subClassOf strat:StrategicPlanningManagement ;
    rdfs:comment "新能源·半导体·人工智能·生物医药·量子信息等战略性新兴产业投资须在五年规划中明确比例要求。"@zh ,
                 "Investment in strategic emerging industries (new energy, semiconductors, AI, biopharmaceuticals, quantum) must specify ratio requirements in five-year plans."@en .

# ==============================================================================
# TAX DEFERRED DIFFERENCES — CFO-06
# 会计与税务差异·递延税款
# ==============================================================================

taxdiff:AccountingTaxDifference
    a owl:Class ;
    rdfs:label "会计与税务差异（递延税款）"@zh , "Accounting-Tax Differences (Deferred Tax)"@en ;
    rdfs:subClassOf acct:AccountingSystem ;
    rdfs:comment "按IAS 12/CAS 18，会计利润与应税所得的差异分为暂时性差异（产生递延税资产/负债）和永久性差异。"@zh ,
                 "Per IAS 12/CAS 18, differences between accounting profit and taxable income split into temporary differences (generating deferred tax assets/liabilities) and permanent differences."@en .

taxdiff:TemporaryDifference
    a owl:Class ;
    rdfs:label "暂时性差异"@zh , "Temporary Difference"@en ;
    rdfs:subClassOf taxdiff:AccountingTaxDifference .

taxdiff:TaxableTemporary     a taxdiff:TemporaryDifference , owl:NamedIndividual ; rdfs:label "应纳税暂时性差异（→递延税负债）"@zh , "Taxable Temporary Difference (→DTL)"@en .
taxdiff:DeductibleTemporary  a taxdiff:TemporaryDifference , owl:NamedIndividual ; rdfs:label "可抵扣暂时性差异（→递延税资产）"@zh , "Deductible Temporary Difference (→DTA)"@en .

taxdiff:AcceleratedDepreciation
    a taxdiff:TemporaryDifference , owl:Class ;
    rdfs:label "加速折旧税务差异"@zh , "Accelerated Depreciation Tax Difference"@en ;
    rdfs:comment "高新技术企业固定资产一次性扣除，税务折旧>会计折旧，产生应纳税暂时性差异。"@zh ,
                 "High-tech enterprise one-time deduction of fixed assets; tax depreciation > accounting depreciation, generating taxable temporary differences."@en .

# ==============================================================================
# RELATED PARTY SPECIAL RULES FOR SOE — CFO-05
# 国有企业关联方认定特殊规则
# ==============================================================================

relppty:SOERelatedPartySpecialRules
    a owl:Class ;
    rdfs:label "国有企业关联方认定特殊规则"@zh , "SOE-Specific Related Party Identification Rules"@en ;
    rdfs:subClassOf fin:RelatedPartyTransaction ;
    rdfs:comment "国有企业关联方认定适用CAS 36及证监会关于国有实体豁免的特殊规定。同一国资委下的兄弟企业通常享有国有实体豁免，但仍须披露重大交易。"@zh ,
                 "SOE related-party identification applies CAS 36 and CSRC special rules on state entity exemptions. Sister SOEs under the same SASAC typically qualify for state entity exemption but must still disclose significant transactions."@en .

relppty:StateEntityExemption
    a owl:Class ;
    rdfs:label "国有实体豁免"@zh , "State Entity Exemption"@en ;
    rdfs:subClassOf relppty:SOERelatedPartySpecialRules ;
    rdfs:comment "同一国家/地方国资委控制下的兄弟国有企业，在CAS 36下豁免关联方披露（但HKFRS不豁免）。豁免不免除重大交易的信息披露义务。"@zh ,
                 "Sister SOEs under same national/local SASAC control are exempt from related-party disclosure under CAS 36 (but NOT under HKFRS). Exemption does not eliminate disclosure obligation for significant transactions."@en .

relppty:KeyManagementPersonnel
    a owl:Class ;
    rdfs:label "关键管理人员关联方"@zh , "Key Management Personnel Related Party"@en ;
    rdfs:subClassOf relppty:SOERelatedPartySpecialRules ;
    rdfs:comment "国有企业关键管理人员（党委书记·董事长·总经理·CFO）及其近亲属持有权益的实体构成关联方，须披露。"@zh ,
                 "Entities where key management personnel (party secretary, chairman, president, CFO) and their close family members hold interests constitute related parties requiring disclosure."@en .

# ==============================================================================
# SHACL SHAPES FOR NEW MODULES
# ==============================================================================

tx32:PublicListingShape
    a sh:NodeShape ;
    sh:targetClass tx32:PublicListingRequirement ;
    rdfs:label "32号令挂牌期限约束"@zh , "Order 32 Listing Duration Shape"@en ;
    sh:property [
        sh:path tx32:hasListingDurationWorkdays ;
        sh:minInclusive 20 ;
        sh:message "【32号令】国有产权转让挂牌期限不得少于20个工作日。"@zh ,
                   "[Order 32] State-owned property rights listing duration must not be less than 20 working days."@en
    ] .

tx32:PriceFloorShape
    a sh:NodeShape ;
    sh:targetClass tx32:PriceFloor ;
    rdfs:label "底价比例约束"@zh , "Reserve Price Ratio Shape"@en ;
    sh:property [
        sh:path tx32:hasMinimumPriceRatio ;
        sh:minInclusive 0.9 ;
        sh:message "【32号令】转让价格不得低于评估值的90%。"@zh ,
                   "[Order 32] Transfer price must not be less than 90% of appraised value."@en
    ] .

capbud:RemittanceRateShape
    a sh:NodeShape ;
    sh:targetClass capbud:ProfitRemittanceRate ;
    rdfs:label "国有资本收益上缴比例约束"@zh , "State Capital Remittance Rate Shape"@en ;
    sh:property [
        sh:path capbud:hasRemittanceRateValue ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 0.20 ;
        sh:message "国有资本收益上缴比例须在0%到20%之间（充分竞争类最高15%）。"@zh ,
                   "State capital profit remittance rate must be between 0% and 20% (max 15% for fully competitive)."@en
    ] .

psc:PSCCostRecoveryShape
    a sh:NodeShape ;
    sh:targetClass psc:CostOil ;
    rdfs:label "PSC成本回收上限约束"@zh , "PSC Cost Recovery Cap Shape"@en ;
    sh:property [
        sh:path psc:hasCostRecoveryCap ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "PSC成本回收上限须在0%到100%之间。"@zh ,
                   "PSC cost recovery cap must be between 0% and 100%."@en
    ] .

# Cross-module property additions for new modules
sasac:hasEnterpriseCategory3    a owl:ObjectProperty ; rdfs:label "功能分类"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range cat3:EnterpriseCategory3System .
sasac:hasCapitalBudgetObligation a owl:ObjectProperty ; rdfs:label "资本经营预算义务"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range capbud:StateCapitalOperatingBudget .
sasac:hasOverseasAssetRegistry  a owl:ObjectProperty ; rdfs:label "境外资产产权登记"@zh ; rdfs:domain ent:OverseasSubsidiary ; rdfs:range oareg:OverseasAssetRegistry .
sasac:hasOilGasContract         a owl:ObjectProperty ; rdfs:label "境外油气合同"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range psc:OilGasContractAccounting .
sasac:hasEPCContract            a owl:ObjectProperty ; rdfs:label "EPC工程总包合同"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range epc:EPCContractAccounting .
sasac:hasStrategicPlan          a owl:ObjectProperty ; rdfs:label "战略规划"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range strat:StrategicPlanningManagement .


# ==============================================================================
# PART 6: v4.3 — 五维穿透深化 · 管资本转型 · 四大监管目标
# Five-Dimension Penetration · Capital Management · Four Regulatory Objectives
# ==============================================================================
# ==============================================================================
# SASAC-GOV v4.3 — 穿透式监管深化 · 管资本转型 · 四大监管目标
# SASAC-GOV v4.3 — Deep Penetration · Capital Management Transformation
#                  Four Regulatory Objectives
# ==============================================================================
# Upgrade drivers:
#   A. 五维穿透：穿透股权·穿透业务·穿透资金·穿透责任·穿透风险
#   B. 转型框架：管资本(vs管企业)·实时防控(vs事后问责)
#   C. 四目标：防流失·提效率·强治理·服务战略
# ==============================================================================

# existing
# v4.3 new

# ==============================================================================
# ██████╗  █████╗ ██████╗ ████████╗    ██╗
# ██╔══██╗██╔══██╗██╔══██╗╚══██╔══╝    ██║
# ██████╔╝███████║██████╔╝   ██║       ██║
# ██╔═══╝ ██╔══██║██╔══██╗   ██║       ╚═╝
# ██║     ██║  ██║██║  ██║   ██║       ██╗
# ╚═╝     ╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝       ╚═╝
# PART A: 五维穿透式监管 (FIVE-DIMENSION PENETRATION)
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# A1. 穿透股权（EQUITY PENETRATION）
#     任意持股层级→识别真实控制权·国有股权比例·VIE/SPV穿透·交叉持股图谱
# ──────────────────────────────────────────────────────────────────────────────

peq:EquityPenetrationSystem
    a owl:Class ;
    rdfs:label "穿透股权体系"@zh , "Equity Penetration System"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "以图论方法对任意深度股权结构进行穿透，识别：最终控制人·国有股权实际比例·一致行动人·表决权配置·交叉持股·循环持股。依据《公司法》及国资委穿透监管规定。"@zh ,
        "Graph-theoretic penetration of equity structures at any depth to identify: ultimate controller · actual state equity ratio · concert parties · voting power allocation · cross-shareholding · circular shareholding. Per Company Law and SASAC penetration supervision regulations."@en .

peq:EquityLayerMap
    a owl:Class ;
    rdfs:label "股权层级图谱"@zh , "Equity Layer Map"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "可视化表达从监管机构到末端被监管主体的完整股权层级树，支持∞层级递归遍历。"@zh ,
                 "Visual representation of the complete equity layer tree from regulator to terminal monitored entity; supports infinite-depth recursive traversal."@en .

peq:hasDirectShareholding
    a owl:DatatypeProperty ;
    rdfs:label "直接持股比例"@zh , "Direct Shareholding Ratio"@en ;
    rdfs:domain peq:EquityLayerMap ; rdfs:range xsd:decimal .

peq:hasEffectiveShareholding
    a owl:DatatypeProperty ;
    rdfs:label "穿透后实际持股比例"@zh , "Effective (Penetrated) Shareholding Ratio"@en ;
    rdfs:domain peq:EquityLayerMap ; rdfs:range xsd:decimal ;
    rdfs:comment "考虑间接持股链路后的最终实际持股比例。计算：∏(各层持股比例)。"@zh ,
                 "Final actual shareholding after indirect chain calculation: ∏(shareholding ratio at each layer)."@en .

peq:StateEquityEffectiveRatio
    a owl:Class ;
    rdfs:label "穿透后国有股权实际占比"@zh , "Effective State Equity Ratio (Post-Penetration)"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "穿透多层持股后，国有资本的最终实际控制比例，用于判断是否满足国有控股认定标准（>50%）。"@zh ,
                 "Final actual state capital control ratio after multi-layer penetration; used to determine whether state-controlled enterprise threshold (>50%) is met."@en .

peq:ConcertParty
    a owl:Class ;
    rdfs:label "一致行动人"@zh , "Concert Party"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "通过协议或默契共同行使表决权的多个股东，穿透后须合并计算其持股比例。"@zh ,
                 "Multiple shareholders who exercise voting rights jointly through agreement or tacit understanding; shareholdings must be aggregated after penetration."@en .

peq:VotingRightSeparation
    a owl:Class ;
    rdfs:label "表决权与所有权分离识别"@zh , "Voting Right-Ownership Separation Detection"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "识别双重股权结构（AB股·超级投票权·一致行动协议）导致的控制权与所有权不一致。"@zh ,
                 "Detects dual-class share structures (A/B shares, supervoting, concert action agreements) causing inconsistency between control rights and ownership."@en .

peq:CrossShareholdingDetection
    a owl:Class ;
    rdfs:label "交叉持股识别"@zh , "Cross-Shareholding Detection"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "两个或多个企业相互持股形成的交叉持股环路，可人为放大表面持股比例，须穿透消除。"@zh ,
                 "Cross-shareholding loops where two or more enterprises mutually hold shares, which can artificially inflate apparent shareholding ratios; must be unwound through penetration."@en .

peq:CircularShareholdingRisk
    a owl:Class ;
    rdfs:label "循环持股风险"@zh , "Circular Shareholding Risk"@en ;
    rdfs:subClassOf peq:CrossShareholdingDetection ;
    rdfs:comment "A→B→C→A形成的循环持股闭环，可能用于规避监管、人为控制表决权，须标记为高风险并上报。"@zh ,
                 "A→B→C→A circular shareholding loop, potentially used to evade supervision and artificially control voting rights; must be flagged as high-risk and reported."@en .

peq:EquityPenetrationDepth
    a owl:DatatypeProperty ;
    rdfs:label "股权穿透深度（层数）"@zh , "Equity Penetration Depth (Layers)"@en ;
    rdfs:domain peq:EquityPenetrationSystem ; rdfs:range xsd:integer ;
    rdfs:comment "已实现穿透的股权层级数量，国资委要求穿透至最终自然人或国家。"@zh ,
                 "Number of equity layers penetrated; SASAC requires penetration to ultimate natural person or the state."@en .

peq:BeneficialOwnershipThreshold
    a owl:DatatypeProperty ;
    rdfs:label "实际控制人认定阈值"@zh , "Beneficial Ownership Identification Threshold"@en ;
    rdfs:domain peq:EquityPenetrationSystem ; rdfs:range xsd:decimal ;
    rdfs:comment "持股超过此阈值（通常25%或50%）须向国资委登记为实际控制人。"@zh ,
                 "Shareholding exceeding this threshold (typically 25% or 50%) must be registered as actual controller with SASAC."@en .

peq:HiddenShareholderDetection
    a owl:Class ;
    rdfs:label "隐名股东识别"@zh , "Hidden Shareholder Detection"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "借名持股·代持协议·信托持股等隐藏真实股东的行为，穿透后须还原真实出资人。"@zh ,
                 "Nominee shareholding, holding-on-behalf agreements, trust shareholding, and other behaviors concealing true shareholders; true investors must be restored after penetration."@en .

peq:StateEquityDilutionAlert
    a owl:Class ;
    rdfs:label "国有股权稀释预警"@zh , "State Equity Dilution Alert"@en ;
    rdfs:subClassOf peq:EquityPenetrationSystem ;
    rdfs:comment "增资·股权转让·股权激励等操作导致国有股权比例下降时自动预警，若低于控股红线须立即报告。"@zh ,
                 "Automatic alert when capital increase, equity transfer, or equity incentives cause state equity ratio decline; mandatory immediate reporting if control threshold is breached."@en .

peq:hasDilutionThreshold
    a owl:DatatypeProperty ;
    rdfs:label "稀释预警阈值"@zh , "Dilution Alert Threshold"@en ;
    rdfs:domain peq:StateEquityDilutionAlert ; rdfs:range xsd:decimal .

# ──────────────────────────────────────────────────────────────────────────────
# A2. 穿透业务（BUSINESS PENETRATION）
#     多业态集团→识别真实经营实质·关联业务·影子业务·主业偏离
# ──────────────────────────────────────────────────────────────────────────────

pbiz:BusinessPenetrationSystem
    a owl:Class ;
    rdfs:label "穿透业务体系"@zh , "Business Penetration System"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "穿透多业态集团的业务实质，识别：主业偏离·影子业务·通道业务·名义业务与实质业务不符·跨板块利益输送。"@zh ,
        "Penetrates business substance of multi-sector conglomerates to identify: core business deviation, shadow operations, channel businesses, mismatch between nominal and actual business, cross-sector benefit channeling."@en .

pbiz:SubstanceOverFormTest
    a owl:Class ;
    rdfs:label "实质重于形式穿透"@zh , "Substance-Over-Form Business Test"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "识别业务的经济实质是否与法律形式一致。如：名义上的'咨询费'实为利润转移；名义'投资'实为融资绕道。"@zh ,
                 "Identifies whether a business's economic substance is consistent with its legal form. E.g., nominal 'consulting fees' that are actually profit transfers; nominal 'investments' that are actually disguised financing."@en .

pbiz:ShadowBusinessDetection
    a owl:Class ;
    rdfs:label "影子业务识别"@zh , "Shadow Business Detection"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "国有企业名义从事主业，实际通过关联方或子公司从事非主业高风险业务，规避主责主业监管。"@zh ,
                 "SOE nominally engaged in core business; actually conducting non-core high-risk activities through related parties or subsidiaries to evade core business supervision."@en .

pbiz:ChannelBusinessRisk
    a owl:Class ;
    rdfs:label "通道业务风险"@zh , "Channel Business Risk"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "国有企业作为通道方，为第三方规避监管提供便利，承担名义风险却无实质收益，实为隐性担保。"@zh ,
                 "SOE acts as channel entity to facilitate third-party supervisory evasion; bears nominal risk without substantive returns, essentially providing implicit guarantees."@en .

pbiz:RelatedPartyBusinessPenetration
    a owl:Class ;
    rdfs:label "关联方业务穿透"@zh , "Related Party Business Penetration"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "穿透识别通过关联方开展的隐性业务：关联采购是否市价·关联销售是否公允·关联资金占用是否合规。"@zh ,
                 "Penetrates hidden businesses conducted through related parties: whether related-party procurement is at market price, related-party sales are fair, related-party fund occupancy is compliant."@en .

pbiz:CoreBusinessDeviationScore
    a owl:Class ;
    rdfs:label "主业偏离度评分"@zh , "Core Business Deviation Score"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "量化评估企业实际业务与申报主业的偏离程度。主业收入占比<70%触发预警，<50%须强制整改。"@zh ,
                 "Quantitatively assesses deviation between actual business and declared core business. Core revenue <70% triggers alert; <50% requires mandatory rectification."@en .

pbiz:hasDeviationScore
    a owl:DatatypeProperty ;
    rdfs:label "偏离度评分（0-100）"@zh , "Deviation Score (0-100)"@en ;
    rdfs:domain pbiz:CoreBusinessDeviationScore ; rdfs:range xsd:decimal .

pbiz:AbnormalRelatedPartyTransaction
    a owl:Class ;
    rdfs:label "异常关联交易识别"@zh , "Abnormal Related Party Transaction Detection"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "识别偏离公允价值的关联交易：定价偏差>20%·频繁循环交易·无商业实质的交易·单向资金占用。"@zh ,
                 "Identifies related-party transactions deviating from fair value: pricing deviation >20%, frequent circular transactions, transactions without commercial substance, unilateral fund occupation."@en .

pbiz:CrossSectorBenefitChanneling
    a owl:Class ;
    rdfs:label "跨板块利益输送穿透"@zh , "Cross-Sector Benefit Channeling Penetration"@en ;
    rdfs:subClassOf pbiz:BusinessPenetrationSystem ;
    rdfs:comment "多业态集团通过跨板块定价操纵，将利润从监管严格板块转移至监管宽松板块，规避绩效考核。"@zh ,
                 "Multi-sector conglomerates manipulate cross-sector pricing to transfer profits from tightly regulated sectors to loosely regulated ones, evading performance assessment."@en .

pbiz:OperatingSubstanceScore
    a owl:DatatypeProperty ;
    rdfs:label "经营实质性评分"@zh , "Operating Substance Score"@en ;
    rdfs:domain pbiz:BusinessPenetrationSystem ; rdfs:range xsd:decimal ;
    rdfs:comment "评估子公司是否具有真实经营实质（人员·资产·收入·合同），识别空壳公司。评分<30分标记为空壳风险。"@zh ,
                 "Assesses whether subsidiaries have genuine operating substance (staff, assets, revenue, contracts) to identify shell companies. Score <30 flagged as shell company risk."@en .

# ──────────────────────────────────────────────────────────────────────────────
# A3. 穿透资金（FUND PENETRATION）
#     多层资金流动→全链路追踪·违规占用·体外循环·洗钱·非法流出
# ──────────────────────────────────────────────────────────────────────────────

pfund:FundPenetrationSystem
    a owl:Class ;
    rdfs:label "穿透资金体系"@zh , "Fund Penetration System"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "对国有企业资金从来源→归集→运用→收益的全链路穿透追踪，识别：体外循环·违规占用·虚假交易·洗钱·非法流出境外。"@zh ,
        "Full-chain penetration tracking of SOE funds from source→pooling→deployment→returns, identifying: off-balance-sheet circulation, illegal occupation, fictitious transactions, money laundering, illegal overseas outflows."@en .

pfund:FundFlowGraph
    a owl:Class ;
    rdfs:label "资金流向图谱"@zh , "Fund Flow Graph"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "以有向图建模资金在各账户·实体·法域间的流动路径，支持路径查询和异常识别。节点=账户/实体，边=转账事件。"@zh ,
                 "Models fund flow paths between accounts, entities, and jurisdictions using directed graphs; supports path queries and anomaly detection. Nodes=accounts/entities; edges=transfer events."@en .

pfund:hasFlowSourceAccount
    a owl:DatatypeProperty ;
    rdfs:label "资金来源账户"@zh , "Fund Source Account"@en ;
    rdfs:domain pfund:FundFlowGraph ; rdfs:range xsd:string .

pfund:hasFlowDestinationAccount
    a owl:DatatypeProperty ;
    rdfs:label "资金目的账户"@zh , "Fund Destination Account"@en ;
    rdfs:domain pfund:FundFlowGraph ; rdfs:range xsd:string .

pfund:hasFundFlowHops
    a owl:DatatypeProperty ;
    rdfs:label "资金流转跳数"@zh , "Fund Flow Hop Count"@en ;
    rdfs:domain pfund:FundFlowGraph ; rdfs:range xsd:integer ;
    rdfs:comment "资金从起点到终点经过的中间账户数量，跳数越多规避监管可能性越高。≥5跳触发深度调查。"@zh ,
                 "Number of intermediate accounts from source to destination; more hops indicate higher probability of supervisory evasion. ≥5 hops triggers deep investigation."@en .

pfund:OffBalanceSheetFundCirculation
    a owl:Class ;
    rdfs:label "资金体外循环识别"@zh , "Off-Balance-Sheet Fund Circulation Detection"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "识别通过表外账户·个人账户·第三方归集等方式绕过账务系统的资金流动，是贪腐高发路径。"@zh ,
                 "Detects fund flows bypassing accounting systems via off-balance-sheet accounts, personal accounts, or third-party pooling — a high-frequency corruption pathway."@en .

pfund:IllegalFundOccupation
    a owl:Class ;
    rdfs:label "违规资金占用"@zh , "Illegal Fund Occupation"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "大股东·关联方未经授权占用国有企业资金，包括：拆借·担保代偿·应收款挂账·预付款沉淀。"@zh ,
                 "Unauthorized occupation of SOE funds by major shareholders or related parties, including: unsecured borrowing, guarantee compensation, hanging receivables, prepayment deposits."@en .

pfund:FictitiousTransaction
    a owl:Class ;
    rdfs:label "虚假交易资金穿透"@zh , "Fictitious Transaction Fund Penetration"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "通过虚开发票·虚构合同·循环交易将资金转移的行为。特征：无真实货物流·合同金额异常·对手方无实质经营。"@zh ,
                 "Fund diversion through fake invoices, fictitious contracts, circular transactions. Characteristics: no actual goods flow, abnormal contract amounts, counterparties with no substantive operations."@en .

pfund:IllegalOverseasOutflow
    a owl:Class ;
    rdfs:label "非法境外资金流出"@zh , "Illegal Overseas Fund Outflow"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "国有资金通过地下钱庄·虚假贸易·未申报现金·数字货币等渠道非法流出境外，触犯外汇管理法规。"@zh ,
                 "Illegal outflow of state funds overseas through underground banks, fictitious trade, undeclared cash, digital currencies, violating foreign exchange management regulations."@en .

pfund:CashFlowAnomalyScore
    a owl:Class ;
    rdfs:label "现金流异常评分"@zh , "Cash Flow Anomaly Score"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "基于交易金额·频率·对手方·时间模式的多维评分，≥80分触发自动可疑交易上报。"@zh ,
                 "Multi-dimensional scoring based on transaction amount, frequency, counterparty, time patterns; ≥80 triggers automatic suspicious transaction reporting."@en .

pfund:hasAnomalyScore
    a owl:DatatypeProperty ;
    rdfs:label "异常评分（0-100）"@zh , "Anomaly Score (0-100)"@en ;
    rdfs:domain pfund:CashFlowAnomalyScore ; rdfs:range xsd:decimal .

pfund:FundPenetrationRealTimeEngine
    a owl:Class ;
    rdfs:label "资金穿透实时引擎"@zh , "Fund Penetration Real-Time Engine"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "每笔资金交易发生后<100ms完成多维规则匹配，对异常交易实时拦截或标记，实现事前预防而非事后审计。"@zh ,
                 "Completes multi-dimensional rule matching <100ms after each fund transaction; real-time interception or flagging of abnormal transactions achieves pre-event prevention vs. post-event auditing."@en .

pfund:hasRealTimeLatencyMs
    a owl:DatatypeProperty ;
    rdfs:label "实时检测延迟(ms)"@zh , "Real-Time Detection Latency (ms)"@en ;
    rdfs:domain pfund:FundPenetrationRealTimeEngine ; rdfs:range xsd:integer .

pfund:FundDestinationVerification
    a owl:Class ;
    rdfs:label "资金最终用途核验"@zh , "Fund Final Destination Verification"@en ;
    rdfs:subClassOf pfund:FundPenetrationSystem ;
    rdfs:comment "验证专项资金（国家拨款·债券募资·专项贷款）是否实际用于批准用途，防止专款挪用。"@zh ,
                 "Verifies whether earmarked funds (state grants, bond proceeds, special loans) are actually used for approved purposes, preventing misappropriation."@en .

# ──────────────────────────────────────────────────────────────────────────────
# A4. 穿透责任（ACCOUNTABILITY PENETRATION）
#     突破法人边界→识别真实责任主体·决策链条·个人责任·连带责任
# ──────────────────────────────────────────────────────────────────────────────

presp:AccountabilityPenetrationSystem
    a owl:Class ;
    rdfs:label "穿透责任体系"@zh , "Accountability Penetration System"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "突破法人独立人格边界，追踪决策链条，将责任穿透至真实决策人·实际控制人·连带责任人。实现：谁决策·谁担责；谁受益·谁担责。"@zh ,
        "Penetrates corporate veil to trace decision chains; attributes responsibility to actual decision-makers, actual controllers, and jointly liable parties. Implements: who decides, who is accountable; who benefits, who is liable."@en .

presp:DecisionChainTracing
    a owl:Class ;
    rdfs:label "决策链条追踪"@zh , "Decision Chain Tracing"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "对重大损失·违规行为追溯完整决策链：方案提出→可行性论证→集体审议→批准→执行→监督，识别各环节责任人。"@zh ,
                 "Traces the complete decision chain for major losses and violations: proposal→feasibility→collective deliberation→approval→execution→oversight; identifies responsible persons at each node."@en .

presp:DecisionNode
    a owl:Class ;
    rdfs:label "决策节点"@zh , "Decision Node"@en ;
    rdfs:subClassOf presp:DecisionChainTracing .

presp:hasNodeRole
    a owl:DatatypeProperty ;
    rdfs:label "节点角色"@zh , "Node Role"@en ;
    rdfs:domain presp:DecisionNode ; rdfs:range xsd:string ;
    rdfs:comment "PROPOSER | ADVISOR | REVIEWER | APPROVER | EXECUTOR | SUPERVISOR"@en .

presp:hasNodePerson
    a owl:DatatypeProperty ;
    rdfs:label "责任人"@zh , "Responsible Person"@en ;
    rdfs:domain presp:DecisionNode ; rdfs:range xsd:string .

presp:CorporateVeilPenetration
    a owl:Class ;
    rdfs:label "法人人格穿透（揭开公司面纱）"@zh , "Corporate Veil Penetration (Piercing the Corporate Veil)"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "当控股股东·实际控制人滥用法人独立人格损害债权人权益时，依《公司法》第23条对其追究连带责任。国有控股股东不得以法人独立性为由逃避赔偿责任。"@zh ,
                 "When controlling shareholders or actual controllers abuse corporate separate personality to harm creditors, joint and several liability is imposed per Company Law Article 23. State controlling shareholders cannot use corporate independence to escape compensation liability."@en .

presp:PersonalLiabilityForDirectors
    a owl:Class ;
    rdfs:label "董事个人责任"@zh , "Personal Director Liability"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "董事·监事·高级管理人员违反忠实义务·勤勉义务，对公司造成损失须依《公司法》第188条承担赔偿责任。"@zh ,
                 "Directors, supervisors, and senior managers who violate duties of loyalty and diligence, causing losses to the company, must bear compensation liability per Company Law Article 188."@en .

presp:BenefitVsLiabilityAlignment
    a owl:Class ;
    rdfs:label "受益与担责对齐原则"@zh , "Benefit-Liability Alignment Principle"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "穿透识别从违规行为中获益的真实受益人，无论其是否在形式决策链上，均须承担相应法律责任。"@zh ,
                 "Penetrates to identify the true beneficiaries of misconduct; regardless of whether they appear in the formal decision chain, corresponding legal liability must be borne."@en .

presp:GovernmentOfficialAccountability
    a owl:Class ;
    rdfs:label "党纪政务追责"@zh , "Party Discipline and Administrative Accountability"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "国有企业领导人员兼具党员和管理者双重身份，违规同时触发：民事赔偿责任·行政处罚·党纪处分·刑事追诉，责任穿透无死角。"@zh ,
                 "SOE leaders have dual identities as party members and managers; violations simultaneously trigger: civil compensation, administrative penalties, party discipline, criminal prosecution — comprehensive accountability with no blind spots."@en .

presp:FourAccountabilityMechanism
    a owl:Class ;
    rdfs:label "四责合一追责机制"@zh , "Four-In-One Accountability Mechanism"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "整合：党纪责任·行政责任·民事责任·刑事责任四条追责路径，实现责任穿透全覆盖。"@zh ,
                 "Integrates four accountability pathways: party discipline · administrative · civil · criminal, achieving comprehensive accountability coverage."@en .

presp:PartyDiscipline      a presp:FourAccountabilityMechanism , owl:NamedIndividual ; rdfs:label "党纪责任"@zh , "Party Discipline Liability"@en .
presp:AdministrativePenalty a presp:FourAccountabilityMechanism , owl:NamedIndividual ; rdfs:label "行政处罚责任"@zh , "Administrative Penalty Liability"@en .
presp:CivilLiability        a presp:FourAccountabilityMechanism , owl:NamedIndividual ; rdfs:label "民事赔偿责任"@zh , "Civil Compensation Liability"@en .
presp:CriminalLiability     a presp:FourAccountabilityMechanism , owl:NamedIndividual ; rdfs:label "刑事追诉责任"@zh , "Criminal Prosecution Liability"@en .

presp:AccountabilityPenetrationRecord
    a owl:Class ;
    rdfs:label "追责穿透记录"@zh , "Accountability Penetration Record"@en ;
    rdfs:subClassOf presp:AccountabilityPenetrationSystem ;
    rdfs:comment "将追责结果写入责任人档案，纳入企业诚信体系，影响其未来任职资格·薪酬激励·市场准入。"@zh ,
                 "Records accountability results in responsible persons' files; included in enterprise integrity system affecting future appointment qualifications, compensation incentives, and market access."@en .

presp:hasAccountabilitySubject
    a owl:DatatypeProperty ;
    rdfs:label "追责主体"@zh , "Accountability Subject"@en ;
    rdfs:domain presp:AccountabilityPenetrationRecord ; rdfs:range xsd:string .

presp:hasViolationType
    a owl:DatatypeProperty ;
    rdfs:label "违规类型"@zh , "Violation Type"@en ;
    rdfs:domain presp:AccountabilityPenetrationRecord ; rdfs:range xsd:string .

presp:hasLossAmount
    a owl:DatatypeProperty ;
    rdfs:label "造成国有资产损失金额"@zh , "State Asset Loss Amount Caused"@en ;
    rdfs:domain presp:AccountabilityPenetrationRecord ; rdfs:range xsd:decimal .

# ──────────────────────────────────────────────────────────────────────────────
# A5. 穿透风险（RISK PENETRATION）
#     多层风险传导→识别风险根源·传导路径·系统性放大·实时预警
# ──────────────────────────────────────────────────────────────────────────────

prisk:RiskPenetrationSystem
    a owl:Class ;
    rdfs:label "穿透风险体系"@zh , "Risk Penetration System"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "识别风险在集团层级间的传导路径和放大机制，实现从末端风险信号到根源风险的反向穿透，以及从监管层到末端的正向风险传导预警。"@zh ,
        "Identifies risk transmission paths and amplification mechanisms across group tiers; enables reverse penetration from terminal risk signals to root causes, and forward risk transmission warnings from regulatory layer to terminals."@en .

prisk:RiskContagionMap
    a owl:Class ;
    rdfs:label "风险传染图谱"@zh , "Risk Contagion Map"@en ;
    rdfs:subClassOf prisk:RiskPenetrationSystem ;
    rdfs:comment "建模风险在集团内部传播的网络结构：哪些实体是风险传导的关键节点·哪些路径可能引发系统性危机。"@zh ,
                 "Models the network structure of risk propagation within the group: which entities are key transmission nodes, which paths may trigger systemic crises."@en .

prisk:hasRiskCentralityScore
    a owl:DatatypeProperty ;
    rdfs:label "风险中心度评分"@zh , "Risk Centrality Score"@en ;
    rdfs:domain prisk:RiskContagionMap ; rdfs:range xsd:decimal ;
    rdfs:comment "基于网络中心度算法（PageRank/Betweenness），评分越高代表该实体是风险传导枢纽，须重点监控。"@zh ,
                 "Based on network centrality algorithms (PageRank/Betweenness); higher score indicates the entity is a risk transmission hub requiring priority monitoring."@en .

prisk:SystemicRiskAmplification
    a owl:Class ;
    rdfs:label "系统性风险放大识别"@zh , "Systemic Risk Amplification Detection"@en ;
    rdfs:subClassOf prisk:RiskPenetrationSystem ;
    rdfs:comment "识别可能将局部风险放大为系统性危机的机制：流动性危机→信用危机→清偿危机的传导链条。"@zh ,
                 "Identifies mechanisms that amplify local risks into systemic crises: liquidity crisis → credit crisis → solvency crisis transmission chain."@en .

prisk:RootCauseAnalysis
    a owl:Class ;
    rdfs:label "风险根源穿透分析"@zh , "Root Cause Risk Penetration Analysis"@en ;
    rdfs:subClassOf prisk:RiskPenetrationSystem ;
    rdfs:comment "从风险事件（如贷款违约）向上穿透：经营恶化→战略错误→治理失灵→腐败→监管缺失，识别根本成因。"@zh ,
                 "Penetrates upward from risk events (e.g., loan default): operational deterioration → strategic error → governance failure → corruption → regulatory gap, identifying root causes."@en .

prisk:RiskTransmissionPath
    a owl:Class ;
    rdfs:label "风险传导路径"@zh , "Risk Transmission Path"@en ;
    rdfs:subClassOf prisk:RiskPenetrationSystem .

prisk:hasTransmissionSource
    a owl:DatatypeProperty ;
    rdfs:label "风险来源节点"@zh , "Risk Source Node"@en ;
    rdfs:domain prisk:RiskTransmissionPath ; rdfs:range xsd:string .

prisk:hasTransmissionTarget
    a owl:DatatypeProperty ;
    rdfs:label "风险目标节点"@zh , "Risk Target Node"@en ;
    rdfs:domain prisk:RiskTransmissionPath ; rdfs:range xsd:string .

prisk:hasTransmissionMechanism
    a owl:DatatypeProperty ;
    rdfs:label "传导机制"@zh , "Transmission Mechanism"@en ;
    rdfs:domain prisk:RiskTransmissionPath ; rdfs:range xsd:string ;
    rdfs:comment "CREDIT_EXPOSURE | OPERATIONAL_DEPENDENCY | EQUITY_GUARANTEE | REPUTATIONAL_CONTAGION | REGULATORY_SPILLOVER"@en .

prisk:EarlyWarningSignal
    a owl:Class ;
    rdfs:label "风险预警信号"@zh , "Risk Early Warning Signal"@en ;
    rdfs:subClassOf prisk:RiskPenetrationSystem ;
    rdfs:comment "在风险实质化前识别的先行指标：账期延长·资金周转率下降·关联交易异常·高管频繁离职·审计师意见变化。"@zh ,
                 "Leading indicators identifying risk before materialization: extending payment terms, declining capital turnover, abnormal related-party transactions, frequent executive departures, auditor opinion changes."@en .

prisk:WarningSignalType
    a owl:Class ; rdfs:label "预警信号类型"@zh , "Warning Signal Type"@en .
prisk:LiquidityWarning       a prisk:WarningSignalType , owl:NamedIndividual ; rdfs:label "流动性预警（逾期应付·银行抽贷）"@zh , "Liquidity Warning (Overdue payables, bank loan recall)"@en .
prisk:OperationalWarning     a prisk:WarningSignalType , owl:NamedIndividual ; rdfs:label "经营预警（收入连续下滑·订单萎缩）"@zh , "Operational Warning (Continuous revenue decline, order shrinkage)"@en .
prisk:GovernanceWarning      a prisk:WarningSignalType , owl:NamedIndividual ; rdfs:label "治理预警（董事频繁变更·审计师辞职）"@zh , "Governance Warning (Frequent director changes, auditor resignation)"@en .
prisk:ComplianceWarning      a prisk:WarningSignalType , owl:NamedIndividual ; rdfs:label "合规预警（监管处罚·诉讼激增）"@zh , "Compliance Warning (Regulatory penalties, litigation surge)"@en .
prisk:FraudWarning           a prisk:WarningSignalType , owl:NamedIndividual ; rdfs:label "欺诈预警（账目异常·审计缺口）"@zh , "Fraud Warning (Account anomalies, audit gaps)"@en .

prisk:RiskPenetrationIndex
    a owl:Class ;
    rdfs:label "风险穿透指数"@zh , "Risk Penetration Index"@en ;
    rdfs:subClassOf prisk:RiskPenetrationSystem ;
    rdfs:comment "综合股权·业务·资金·责任四维穿透数据，计算集团整体风险穿透指数（0-100），用于国资委监管优先级排序。"@zh ,
                 "Synthesizes equity, business, capital, and accountability penetration data to compute a group-level risk penetration index (0-100) for SASAC supervisory priority ranking."@en .

prisk:hasRPIScore
    a owl:DatatypeProperty ;
    rdfs:label "风险穿透指数得分"@zh , "Risk Penetration Index Score"@en ;
    rdfs:domain prisk:RiskPenetrationIndex ; rdfs:range xsd:decimal .

# ==============================================================================
# ██████╗  █████╗ ██████╗ ████████╗    ██████╗
# ██╔══██╗██╔══██╗██╔══██╗╚══██╔══╝    ██╔══██╗
# ██████╔╝███████║██████╔╝   ██║       ██████╔╝
# ██╔═══╝ ██╔══██║██╔══██╗   ██║       ██╔══██╗
# ██║     ██║  ██║██║  ██║   ██║       ██████╔╝
# ╚═╝     ╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝       ╚═════╝
# PART B: 从"管企业"到"管资本"·从"事后问责"到"实时防控"
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# B1. 管资本转型框架（MANAGE-CAPITAL TRANSFORMATION）
# ──────────────────────────────────────────────────────────────────────────────

mcap:ManageCapitalTransformation
    a owl:Class ;
    rdfs:label "管资本转型框架"@zh , "Manage-Capital Transformation Framework"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "从直接管企业（管人·管事·管资产）向管资本（管回报·管风险·管结构·管约束）的根本性转型，以出资人视角而非行政主管视角监管国有企业。"@zh ,
        "Fundamental transformation from directly managing enterprises (managing people, affairs, assets) to managing capital (managing returns, risks, structure, constraints); supervised from investor perspective rather than administrative superior perspective."@en .

mcap:DirectEnterpriseManagement
    a owl:Class ;
    rdfs:label "管企业模式（旧）"@zh , "Direct Enterprise Management Mode (Legacy)"@en ;
    rdfs:subClassOf mcap:ManageCapitalTransformation ;
    rdfs:comment "传统模式：国资委直接干预人事·投资·采购·重大合同等经营决策，角色混同：所有者+监管者+经营者。"@zh ,
                 "Traditional mode: SASAC directly intervenes in personnel, investment, procurement, major contracts; roles conflated: owner + regulator + operator."@en .

mcap:ManageCapitalMode
    a owl:Class ;
    rdfs:label "管资本模式（新）"@zh , "Capital Management Mode (New)"@en ;
    rdfs:subClassOf mcap:ManageCapitalTransformation ;
    rdfs:comment "新模式：国资委通过出资人权利行使资本约束，专注于：资本回报要求·风险容忍度设定·重大决策授权·规范运作监督，企业日常经营自主。"@zh ,
                 "New mode: SASAC exercises capital constraints through investor rights, focusing on: capital return requirements, risk tolerance setting, major decision authorization, standardized operations oversight; enterprises have operational autonomy."@en .

mcap:CapitalReturnRequirement
    a owl:Class ;
    rdfs:label "资本回报要求（出资人底线）"@zh , "Capital Return Requirement (Investor Baseline)"@en ;
    rdfs:subClassOf mcap:ManageCapitalMode ;
    rdfs:comment "国资委设定最低ROE·EVA目标，企业自主决定如何实现。超越要求→奖励；持续未达→追责。"@zh ,
                 "SASAC sets minimum ROE/EVA targets; enterprises autonomously decide how to achieve them. Exceeding targets → rewards; persistent failure → accountability."@en .

mcap:hasMinimumROETarget
    a owl:DatatypeProperty ;
    rdfs:label "最低ROE要求"@zh , "Minimum ROE Requirement"@en ;
    rdfs:domain mcap:CapitalReturnRequirement ; rdfs:range xsd:decimal .

mcap:hasMinimumEVATarget
    a owl:DatatypeProperty ;
    rdfs:label "最低EVA要求（亿元）"@zh , "Minimum EVA Requirement (CNY 100M)"@en ;
    rdfs:domain mcap:CapitalReturnRequirement ; rdfs:range xsd:decimal .

mcap:DelegationAuthorizationSystem
    a owl:Class ;
    rdfs:label "授权放权体系"@zh , "Delegation and Authorization System"@en ;
    rdfs:subClassOf mcap:ManageCapitalMode ;
    rdfs:comment "通过授权放权清单，明确哪些事项须国资委审批，哪些完全授权企业自主，实现所有权和经营权分离。"@zh ,
                 "Through delegation lists, clearly defines which matters require SASAC approval and which are fully delegated to enterprises; achieves separation of ownership and operational rights."@en .

mcap:SASACApprovalList
    a owl:Class ;
    rdfs:label "国资委审批事项清单"@zh , "SASAC Approval Item List"@en ;
    rdfs:subClassOf mcap:DelegationAuthorizationSystem ;
    rdfs:comment "须经国资委审批的核心事项：股权结构变更·章程修改·主业确定·重大境外投资·高管任命。"@zh ,
                 "Core matters requiring SASAC approval: equity structure change, charter amendment, core business determination, major overseas investment, senior executive appointment."@en .

mcap:EnterpriseAutonomyList
    a owl:Class ;
    rdfs:label "企业自主经营事项清单"@zh , "Enterprise Operational Autonomy Item List"@en ;
    rdfs:subClassOf mcap:DelegationAuthorizationSystem ;
    rdfs:comment "企业在授权范围内自主决定：日常采购·内部组织架构·绩效激励·常规投资·合作伙伴选择。"@zh ,
                 "Enterprises autonomously decide within authorized scope: routine procurement, internal organizational structure, performance incentives, routine investments, partner selection."@en .

mcap:CapitalAllocationReview
    a owl:Class ;
    rdfs:label "资本配置优化评审"@zh , "Capital Allocation Optimization Review"@en ;
    rdfs:subClassOf mcap:ManageCapitalMode ;
    rdfs:comment "定期评估国有资本在各板块·各企业间的配置效率，推动资本从低效板块向高效战略领域流动。"@zh ,
                 "Periodically assesses the allocation efficiency of state capital across sectors and enterprises; promotes capital flow from low-efficiency sectors to high-efficiency strategic areas."@en .

mcap:CapitalExitMechanism
    a owl:Class ;
    rdfs:label "国有资本退出机制"@zh , "State Capital Exit Mechanism"@en ;
    rdfs:subClassOf mcap:ManageCapitalMode ;
    rdfs:comment "对持续低效·不符合国家战略的国有资本实施有序退出：转让·兼并·破产·股权减持。退出资金重新配置至战略领域。"@zh ,
                 "Implements orderly exit for persistently inefficient state capital not aligned with national strategy: transfer, merger, bankruptcy, equity reduction. Exit proceeds reallocated to strategic areas."@en .

mcap:ExitTriggerCondition
    a owl:Class ; rdfs:label "退出触发条件"@zh , "Exit Trigger Condition"@en .
mcap:ROEBelowCapitalCost  a mcap:ExitTriggerCondition , owl:NamedIndividual ;
    rdfs:label "ROE持续低于资本成本（连续3年）"@zh , "ROE Persistently Below Capital Cost (3 Consecutive Years)"@en .
mcap:NonStrategicBusiness a mcap:ExitTriggerCondition , owl:NamedIndividual ;
    rdfs:label "非战略性主业（国资委明确退出领域）"@zh , "Non-Strategic Core Business (SASAC Exit Directive)"@en .
mcap:ZombieEnterprise     a mcap:ExitTriggerCondition , owl:NamedIndividual ;
    rdfs:label "僵尸企业认定（连续亏损·资不抵债）"@zh , "Zombie Enterprise Determination"@en .

# ──────────────────────────────────────────────────────────────────────────────
# B2. 实时防控体系（REAL-TIME CONTROL SYSTEM）
# ──────────────────────────────────────────────────────────────────────────────

rtctrl:RealTimeControlSystem
    a owl:Class ;
    rdfs:label "实时防控体系"@zh , "Real-Time Prevention and Control System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "从事后审计→实时监控→事前预警的监管时序转型。核心能力：数据实时采集·规则实时匹配·异常实时拦截·预警实时推送·决策实时支持。"@zh ,
        "Regulatory timing transformation from post-event auditing → real-time monitoring → pre-event warning. Core capabilities: real-time data collection, real-time rule matching, real-time anomaly interception, real-time alert push, real-time decision support."@en .

rtctrl:MonitoringTimelineEvolution
    a owl:Class ;
    rdfs:label "监管时序演进"@zh , "Monitoring Timeline Evolution"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem .

rtctrl:PostEventAudit
    a rtctrl:MonitoringTimelineEvolution , owl:NamedIndividual ;
    rdfs:label "事后审计（传统·滞后6-12月）"@zh , "Post-Event Audit (Traditional, 6-12 month lag)"@en .
rtctrl:PeriodReport
    a rtctrl:MonitoringTimelineEvolution , owl:NamedIndividual ;
    rdfs:label "定期报告（月/季·滞后1-3月）"@zh , "Periodic Reporting (Monthly/Quarterly, 1-3 month lag)"@en .
rtctrl:NearRealTime
    a rtctrl:MonitoringTimelineEvolution , owl:NamedIndividual ;
    rdfs:label "准实时（T+1日·日间监控）"@zh , "Near Real-Time (T+1, Intraday Monitoring)"@en .
rtctrl:TrueRealTime
    a rtctrl:MonitoringTimelineEvolution , owl:NamedIndividual ;
    rdfs:label "真实时（秒级·毫秒级拦截）"@zh , "True Real-Time (Second/millisecond interception)"@en .

rtctrl:RealTimeDataIngestion
    a owl:Class ;
    rdfs:label "实时数据采集"@zh , "Real-Time Data Ingestion"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem ;
    rdfs:comment "通过ERP API·银企直连·资金监管系统·电子发票平台实时采集资金交易·凭证·合同·发票数据，延迟<5秒。"@zh ,
                 "Real-time collection of fund transactions, vouchers, contracts, and invoice data via ERP API, bank-enterprise direct connection, fund supervision systems, e-invoice platforms; delay <5 seconds."@en .

rtctrl:hasDataIngestionDelay
    a owl:DatatypeProperty ;
    rdfs:label "数据采集延迟(秒)"@zh , "Data Ingestion Delay (seconds)"@en ;
    rdfs:domain rtctrl:RealTimeDataIngestion ; rdfs:range xsd:integer .

rtctrl:RuleEngineRealTime
    a owl:Class ;
    rdfs:label "实时规则引擎"@zh , "Real-Time Rule Engine"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem ;
    rdfs:comment "基于CEP（复杂事件处理）·流式计算（Flink/Spark Streaming）的实时规则匹配引擎，支持：阈值规则·序列规则·关联规则·机器学习模型。"@zh ,
                 "Real-time rule matching engine based on CEP (Complex Event Processing) and stream computing (Flink/Spark Streaming); supports threshold rules, sequence rules, association rules, ML models."@en .

rtctrl:CEPPattern
    a owl:Class ;
    rdfs:label "复杂事件模式（CEP）"@zh , "Complex Event Pattern (CEP)"@en ;
    rdfs:subClassOf rtctrl:RuleEngineRealTime .

rtctrl:LargeAmountSplitPattern
    a rtctrl:CEPPattern , owl:NamedIndividual ;
    rdfs:label "大额拆分模式（化整为零规避阈值）"@zh , "Large Amount Splitting Pattern (Breaking up to Evade Threshold)"@en ;
    rdfs:comment "检测：同一受益人·1小时内·多笔小额支付之和超过三重一大门槛→标记为刻意规避。"@zh ,
                 "Detects: same beneficiary, within 1 hour, sum of multiple small payments exceeding SJYZD threshold → flagged as deliberate evasion."@en .

rtctrl:CircularFundPattern
    a rtctrl:CEPPattern , owl:NamedIndividual ;
    rdfs:label "循环资金模式（洗钱路径识别）"@zh , "Circular Fund Pattern (Money Laundering Path Detection)"@en ;
    rdfs:comment "检测：资金A→B→C→A在24小时内循环，金额相近→标记为循环洗钱路径。"@zh ,
                 "Detects: funds A→B→C→A circulating within 24 hours with similar amounts → flagged as circular money laundering path."@en .

rtctrl:UnusualTimePattern
    a rtctrl:CEPPattern , owl:NamedIndividual ;
    rdfs:label "异常时间模式（非工作时间大额）"@zh , "Unusual Time Pattern (Large Amount Outside Business Hours)"@en .

rtctrl:NewCounterpartyHighAmount
    a rtctrl:CEPPattern , owl:NamedIndividual ;
    rdfs:label "首次交易对手高金额模式"@zh , "First-Time Counterparty High Amount Pattern"@en .

rtctrl:PreventionControlMatrix
    a owl:Class ;
    rdfs:label "防控动作矩阵"@zh , "Prevention and Control Action Matrix"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem ;
    rdfs:comment "依据风险评分自动触发差异化防控动作，从无动作到全面冻结的分级响应。"@zh ,
                 "Automatically triggers differentiated prevention and control actions based on risk scores; graded responses from no action to full freeze."@en .

rtctrl:ControlAction
    a owl:Class ; rdfs:label "防控动作"@zh , "Control Action"@en .
rtctrl:AutomaticFlag       a rtctrl:ControlAction , owl:NamedIndividual ; rdfs:label "自动标记（记录·不拦截）"@zh , "Automatic Flag (Record, No Intercept)"@en .
rtctrl:PendingApproval     a rtctrl:ControlAction , owl:NamedIndividual ; rdfs:label "转人工审批（暂停·等待审批）"@zh , "Pending Approval (Suspend, Await Approval)"@en .
rtctrl:RealTimeIntercept   a rtctrl:ControlAction , owl:NamedIndividual ; rdfs:label "实时拦截（拒绝执行）"@zh , "Real-Time Intercept (Reject Execution)"@en .
rtctrl:AccountFreeze       a rtctrl:ControlAction , owl:NamedIndividual ; rdfs:label "账户冻结（临时·须解冻流程）"@zh , "Account Freeze (Temporary, Requires Unfreezing Process)"@en .
rtctrl:EmergencyReport     a rtctrl:ControlAction , owl:NamedIndividual ; rdfs:label "紧急上报（国资委·纪委·公安）"@zh , "Emergency Report (SASAC, Discipline Commission, Public Security)"@en .

rtctrl:hasActionThreshold
    a owl:DatatypeProperty ;
    rdfs:label "触发动作的风险分阈值"@zh , "Risk Score Threshold Triggering Action"@en ;
    rdfs:domain rtctrl:ControlAction ; rdfs:range xsd:decimal .

rtctrl:PostEventAccountabilityTransition
    a owl:Class ;
    rdfs:label "从事后问责到实时防控的转型路径"@zh , "Post-Event-to-Real-Time Transition Path"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem ;
    rdfs:comment "分三阶段实施：1.数字化基础（ERP联通·数据标准化）→2.准实时监控（T+1报告·日度预警）→3.真实时防控（秒级规则·自动拦截）。"@zh ,
                 "Three-phase implementation: 1. Digital foundation (ERP connectivity, data standardization) → 2. Near-real-time monitoring (T+1 reports, daily alerts) → 3. True real-time control (second-level rules, automatic interception)."@en .

rtctrl:RegulatoryDashboard
    a owl:Class ;
    rdfs:label "国资监管实时仪表盘"@zh , "SASAC Real-Time Regulatory Dashboard"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem ;
    rdfs:comment "国资委监管人员可实时查看：全集团资金流动·活跃异常预警·穿透分析结果·KPI实时达成情况·高风险企业排名。"@zh ,
                 "SASAC supervisory personnel can view in real time: group-wide fund flows, active anomaly alerts, penetration analysis results, real-time KPI achievement, high-risk enterprise ranking."@en .

rtctrl:DashboardWidget
    a owl:Class ; rdfs:label "仪表盘组件"@zh , "Dashboard Widget"@en .
rtctrl:FundFlowHeatmap        a rtctrl:DashboardWidget , owl:NamedIndividual ; rdfs:label "资金流动热力图"@zh , "Fund Flow Heatmap"@en .
rtctrl:ActiveAlertsPanel      a rtctrl:DashboardWidget , owl:NamedIndividual ; rdfs:label "活跃预警列表"@zh , "Active Alerts Panel"@en .
rtctrl:RiskRankingLeaderboard a rtctrl:DashboardWidget , owl:NamedIndividual ; rdfs:label "风险排名榜"@zh , "Risk Ranking Leaderboard"@en .
rtctrl:KPIProgressTracker     a rtctrl:DashboardWidget , owl:NamedIndividual ; rdfs:label "KPI实时进度"@zh , "KPI Real-Time Progress"@en .
rtctrl:EquityMapViewer        a rtctrl:DashboardWidget , owl:NamedIndividual ; rdfs:label "股权穿透图谱"@zh , "Equity Penetration Map Viewer"@en .
rtctrl:PenetrationDepthMeter  a rtctrl:DashboardWidget , owl:NamedIndividual ; rdfs:label "穿透深度计量器"@zh , "Penetration Depth Meter"@en .

# ==============================================================================
# ██████╗  █████╗ ██████╗ ████████╗     ██████╗
# ██╔══██╗██╔══██╗██╔══██╗╚══██╔══╝    ██╔════╝
# ██████╔╝███████║██████╔╝   ██║       ██║
# ██╔═══╝ ██╔══██║██╔══██╗   ██║       ██║
# ██║     ██║  ██║██║  ██║   ██║       ╚██████╗
# ╚═╝     ╚═╝  ╚═╝╚═╝  ╚═╝   ╚═╝        ╚═════╝
# PART C: 四大监管目标（FOUR REGULATORY OBJECTIVES）
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# C1. 防流失（PREVENT ASSET DISSIPATION）
#     守住国有资产安全底线
# ──────────────────────────────────────────────────────────────────────────────

noflow:PreventDissipationSystem
    a owl:Class ;
    rdfs:label "防流失监管体系"@zh , "State Asset Dissipation Prevention System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "国资监管第一目标：守住国有资产安全底线，防止国有资产以任何形式流失。涵盖：低价转让·腐败侵吞·决策失误损失·关联方占用·境外流失·合规违规损失。"@zh ,
        "First regulatory objective: securing the state asset safety baseline to prevent state asset dissipation in any form. Covers: undervalued transfers, corruption embezzlement, decision error losses, related party occupation, overseas dissipation, compliance violation losses."@en .

noflow:DissipationPathway
    a owl:Class ;
    rdfs:label "国有资产流失路径"@zh , "State Asset Dissipation Pathway"@en ;
    rdfs:subClassOf noflow:PreventDissipationSystem .

noflow:UndervaluedTransferPath
    a noflow:DissipationPathway , owl:NamedIndividual ;
    rdfs:label "低价转让（关联交易·MBO）"@zh , "Undervalued Transfer (Related-Party, MBO)"@en ;
    rdfs:comment "通过低于评估价转让国有资产，包括：关联方交易·管理层收购（MBO）·虚假招标。核心防控：32号令底价规则·评估程序强制。"@zh ,
                 "Transferring state assets below appraisal value through: related-party transactions, MBOs, fake bidding. Key controls: Order 32 reserve price rules, mandatory assessment procedures."@en .

noflow:CorruptionEmbezzlementPath
    a noflow:DissipationPathway , owl:NamedIndividual ;
    rdfs:label "腐败侵吞（行贿·回扣·挪用）"@zh , "Corruption Embezzlement (Bribery, Kickbacks, Misappropriation)"@en .

noflow:DecisionMistakeLoss
    a noflow:DissipationPathway , owl:NamedIndividual ;
    rdfs:label "决策失误损失（违规投资·盲目扩张）"@zh , "Decision Mistake Loss (Illegal Investment, Blind Expansion)"@en .

noflow:RelatedPartyOccupation
    a noflow:DissipationPathway , owl:NamedIndividual ;
    rdfs:label "关联方占用（挪作他用·长期占用）"@zh , "Related Party Occupation (Diversion, Long-term Occupation)"@en .

noflow:OverseasDissipation
    a noflow:DissipationPathway , owl:NamedIndividual ;
    rdfs:label "境外资产流失（转移·隐匿·抵押）"@zh , "Overseas Asset Dissipation (Transfer, Concealment, Pledge)"@en .

noflow:DissipationDetectionRule
    a owl:Class ;
    rdfs:label "流失识别规则"@zh , "Dissipation Detection Rule"@en ;
    rdfs:subClassOf noflow:PreventDissipationSystem .

noflow:PriceDeviationRule
    a noflow:DissipationDetectionRule , owl:NamedIndividual ;
    rdfs:label "价格偏差规则（交易价<评估价90%→预警）"@zh , "Price Deviation Rule (Price <90% of Appraisal → Alert)"@en .

noflow:UnapprovedTransferRule
    a noflow:DissipationDetectionRule , owl:NamedIndividual ;
    rdfs:label "未审批转让规则（产权转让未挂牌→违规）"@zh , "Unapproved Transfer Rule (Rights Transfer Without Listing → Violation)"@en .

noflow:FundOccupationRule
    a noflow:DissipationDetectionRule , owl:NamedIndividual ;
    rdfs:label "资金占用规则（关联方占用>30天未归还→预警）"@zh , "Fund Occupation Rule (Related Party Occupation >30 Days Without Return → Alert)"@en .

noflow:AssetSafetyIndex
    a owl:Class ;
    rdfs:label "国有资产安全指数"@zh , "State Asset Safety Index"@en ;
    rdfs:subClassOf noflow:PreventDissipationSystem ;
    rdfs:comment "综合评估国有资产面临的流失风险，0（极高流失风险）→100（完全安全）。低于60分须上报国资委启动专项检查。"@zh ,
                 "Comprehensive assessment of state asset dissipation risk: 0 (extremely high risk) → 100 (fully secure). Below 60 triggers reporting to SASAC for special investigation."@en .

noflow:hasSafetyIndexScore
    a owl:DatatypeProperty ;
    rdfs:label "安全指数得分"@zh , "Safety Index Score"@en ;
    rdfs:domain noflow:AssetSafetyIndex ; rdfs:range xsd:decimal .

noflow:StateAssetPreservationAssurance
    a owl:Class ;
    rdfs:label "国有资产保值保障机制"@zh , "State Asset Preservation Assurance Mechanism"@en ;
    rdfs:subClassOf noflow:PreventDissipationSystem ;
    rdfs:comment "三道防线：1.内控（职责分离·授权管理）2.合规（合规检查·内部审计）3.监督（外部审计·国资委检查·纪检监察）。"@zh ,
                 "Three lines of defense: 1. Internal control (segregation, authorization) 2. Compliance (compliance check, internal audit) 3. Supervision (external audit, SASAC inspection, discipline supervision)."@en .

# ──────────────────────────────────────────────────────────────────────────────
# C2. 提效率（IMPROVE EFFICIENCY）
#     国有资本配置与运营效率
# ──────────────────────────────────────────────────────────────────────────────

effcap:CapitalEfficiencySystem
    a owl:Class ;
    rdfs:label "国有资本效率提升体系"@zh , "State Capital Efficiency Enhancement System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "从资本配置效率·运营效率·结构优化三个维度提升国有资本整体效益，实现国有资本保值增值。"@zh ,
        "Enhances overall state capital returns through three dimensions: capital allocation efficiency, operational efficiency, and structural optimization to achieve state capital preservation and appreciation."@en .

effcap:CapitalAllocationEfficiency
    a owl:Class ;
    rdfs:label "资本配置效率"@zh , "Capital Allocation Efficiency"@en ;
    rdfs:subClassOf effcap:CapitalEfficiencySystem ;
    rdfs:comment "评估国有资本在不同板块·行业·企业间的配置是否最优化，向高效率领域集中。"@zh ,
                 "Assesses whether state capital allocation across sectors, industries, and enterprises is optimized; concentrates toward high-efficiency areas."@en .

effcap:PortfolioOptimization
    a owl:Class ;
    rdfs:label "国有资本组合优化"@zh , "State Capital Portfolio Optimization"@en ;
    rdfs:subClassOf effcap:CapitalAllocationEfficiency ;
    rdfs:comment "运用现代资产组合理论，在给定风险约束下最大化国有资本整体回报，识别过度分散·低效配置。"@zh ,
                 "Applies modern portfolio theory to maximize overall state capital returns within given risk constraints; identifies over-diversification and inefficient allocations."@en .

effcap:EVAAddedValue
    a owl:Class ;
    rdfs:label "EVA经济增加值驱动分析"@zh , "EVA Economic Value Added Driver Analysis"@en ;
    rdfs:subClassOf effcap:CapitalEfficiencySystem ;
    rdfs:comment "分解EVA驱动因素：税后营业利润提升（提收入·降成本）vs 资本成本降低（优化资本结构·降融资成本）。"@zh ,
                 "Decomposes EVA drivers: NOPAT improvement (increase revenue, reduce costs) vs. capital cost reduction (optimize capital structure, lower financing costs)."@en .

effcap:hasEVADriverScore
    a owl:DatatypeProperty ;
    rdfs:label "EVA驱动因素评分"@zh , "EVA Driver Score"@en ;
    rdfs:domain effcap:EVAAddedValue ; rdfs:range xsd:decimal .

effcap:OperationalEfficiencyKPI
    a owl:Class ;
    rdfs:label "运营效率KPI体系"@zh , "Operational Efficiency KPI System"@en ;
    rdfs:subClassOf effcap:CapitalEfficiencySystem .

effcap:AssetTurnoverRate     a effcap:OperationalEfficiencyKPI , owl:NamedIndividual ; rdfs:label "资产周转率"@zh , "Asset Turnover Rate"@en .
effcap:InventoryDays         a effcap:OperationalEfficiencyKPI , owl:NamedIndividual ; rdfs:label "存货周转天数"@zh , "Inventory Days"@en .
effcap:ReceivablesTurnover   a effcap:OperationalEfficiencyKPI , owl:NamedIndividual ; rdfs:label "应收账款周转率"@zh , "Receivables Turnover"@en .
effcap:CashConversionCycle   a effcap:OperationalEfficiencyKPI , owl:NamedIndividual ; rdfs:label "现金转换周期（CCC）"@zh , "Cash Conversion Cycle (CCC)"@en .
effcap:CapexEfficiencyRatio  a effcap:OperationalEfficiencyKPI , owl:NamedIndividual ; rdfs:label "资本支出效率比（收入/CAPEX）"@zh , "Capex Efficiency Ratio (Revenue/CAPEX)"@en .

effcap:CrossGroupResourceSharing
    a owl:Class ;
    rdfs:label "集团内协同效率"@zh , "Intra-Group Synergy Efficiency"@en ;
    rdfs:subClassOf effcap:CapitalEfficiencySystem ;
    rdfs:comment "量化集团内部协同价值：共享采购节省·统一融资降本·技术共享价值·品牌溢价贡献。"@zh ,
                 "Quantifies intra-group synergy value: shared procurement savings, unified financing cost reduction, technology sharing value, brand premium contribution."@en .

effcap:hasGroupSynergyValue
    a owl:DatatypeProperty ;
    rdfs:label "集团协同效益（亿元）"@zh , "Group Synergy Value (CNY 100M)"@en ;
    rdfs:domain effcap:CrossGroupResourceSharing ; rdfs:range xsd:decimal .

effcap:DigitalizationEfficiencyGain
    a owl:Class ;
    rdfs:label "数字化效率提升"@zh , "Digitalization Efficiency Gain"@en ;
    rdfs:subClassOf effcap:CapitalEfficiencySystem ;
    rdfs:comment "量化数字化转型对运营效率的贡献：流程自动化节省人工·数据驱动决策提升准确性·预测性维护降低故障率。"@zh ,
                 "Quantifies digital transformation contributions to operational efficiency: process automation labor savings, data-driven decision accuracy improvement, predictive maintenance failure rate reduction."@en .

# ──────────────────────────────────────────────────────────────────────────────
# C3. 强治理（STRENGTHEN GOVERNANCE）
#     完善公司治理，压实主体责任
# ──────────────────────────────────────────────────────────────────────────────

govstr:GovernanceStrengtheningSystem
    a owl:Class ;
    rdfs:label "强治理监管体系"@zh , "Governance Strengthening Supervision System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "完善国有企业公司治理结构，压实党委·董事会·经理层·监事会的主体责任，建立有效的权力制衡机制。"@zh ,
        "Improves SOE corporate governance structures; solidifies primary responsibilities of party committee, board, management, and supervisory board; establishes effective power checks and balances."@en .

govstr:GovernanceStructureQuality
    a owl:Class ;
    rdfs:label "公司治理结构质量评估"@zh , "Corporate Governance Structure Quality Assessment"@en ;
    rdfs:subClassOf govstr:GovernanceStrengtheningSystem ;
    rdfs:comment "评估治理结构的完善程度：党委前置机制·董事会独立性·监事会有效性·信息披露质量·股东权利保护。"@zh ,
                 "Assesses governance structure soundness: party committee prior mechanism, board independence, supervisory board effectiveness, disclosure quality, shareholder rights protection."@en .

govstr:BoardEffectivenessScore
    a owl:Class ;
    rdfs:label "董事会有效性评分"@zh , "Board Effectiveness Score"@en ;
    rdfs:subClassOf govstr:GovernanceStructureQuality ;
    rdfs:comment "评估维度：外部董事比例（>50%？）·会议频率·决策质量·专业委员会覆盖·独立性保障。"@zh ,
                 "Assessment dimensions: external director ratio (>50%?), meeting frequency, decision quality, committee coverage, independence assurance."@en .

govstr:hasBoardIndependenceRatio
    a owl:DatatypeProperty ;
    rdfs:label "外部/独立董事比例"@zh , "External/Independent Director Ratio"@en ;
    rdfs:domain govstr:BoardEffectivenessScore ; rdfs:range xsd:decimal .

govstr:PartyCommitteeGovernanceIntegration
    a owl:Class ;
    rdfs:label "党委与公司治理融合质量"@zh , "Party Committee-Corporate Governance Integration Quality"@en ;
    rdfs:subClassOf govstr:GovernanceStrengtheningSystem ;
    rdfs:comment "评估党委前置审议的实质有效性：是否流于形式·党委意见是否真实影响董事会决策·党委书记与董事长分设还是一人兼任。"@zh ,
                 "Assesses substantive effectiveness of party committee prior review: whether it's formalistic, whether party committee opinions truly influence board decisions, whether party secretary and chairman are separate roles."@en .

govstr:PrimaryResponsibilityPressure
    a owl:Class ;
    rdfs:label "主体责任压实机制"@zh , "Primary Responsibility Solidification Mechanism"@en ;
    rdfs:subClassOf govstr:GovernanceStrengtheningSystem ;
    rdfs:comment "通过：责任清单·问责制度·绩效挂钩·公开承诺，将治理主体责任落实到具体人员，防止'集体无责'现象。"@zh ,
                 "Through responsibility lists, accountability systems, performance linkage, and public commitments, assigns governance primary responsibilities to specific individuals to prevent 'collective non-accountability'."@en .

govstr:ResponsibilityMatrix
    a owl:Class ;
    rdfs:label "责任矩阵"@zh , "Responsibility Matrix"@en ;
    rdfs:subClassOf govstr:PrimaryResponsibilityPressure ;
    rdfs:comment "RACI（负责/批准/咨询/知情）矩阵，将每项监管要求对应到具体责任人，实现责任追溯。"@zh ,
                 "RACI (Responsible/Accountable/Consulted/Informed) matrix mapping each regulatory requirement to specific responsible persons for accountability traceability."@en .

govstr:hasRACIRole
    a owl:DatatypeProperty ;
    rdfs:label "RACI角色"@zh , "RACI Role"@en ;
    rdfs:domain govstr:ResponsibilityMatrix ; rdfs:range xsd:string ;
    rdfs:comment "R=负责执行 A=批准决策 C=被咨询 I=被知会"@zh , "R=Responsible A=Accountable C=Consulted I=Informed"@en .

govstr:TransparencyAndDisclosureQuality
    a owl:Class ;
    rdfs:label "透明度与信息披露质量"@zh , "Transparency and Disclosure Quality"@en ;
    rdfs:subClassOf govstr:GovernanceStrengtheningSystem ;
    rdfs:comment "评估信息披露的完整性·及时性·准确性·易读性，特别关注：关联交易披露·高管薪酬·风险因素·ESG信息。"@zh ,
                 "Assesses completeness, timeliness, accuracy, and readability of disclosures; particular focus on: related-party transaction disclosure, executive compensation, risk factors, ESG information."@en .

govstr:GovernanceScorecard
    a owl:Class ;
    rdfs:label "治理综合评分卡"@zh , "Governance Comprehensive Scorecard"@en ;
    rdfs:subClassOf govstr:GovernanceStrengtheningSystem ;
    rdfs:comment "国资委对标国际治理准则（OECD·G20原则）制定的央企治理综合评分，纳入绩效考核并与薪酬挂钩。"@zh ,
                 "SASAC's comprehensive SOE governance scorecard benchmarked against international governance principles (OECD, G20); incorporated into performance assessment and linked to compensation."@en .

govstr:GovernanceScorecardDimension
    a owl:Class ; rdfs:label "评分维度"@zh , "Scorecard Dimension"@en .
govstr:BoardStructureScore    a govstr:GovernanceScorecardDimension , owl:NamedIndividual ; rdfs:label "董事会结构（25分）"@zh , "Board Structure (25pts)"@en .
govstr:PartyBuildingScore     a govstr:GovernanceScorecardDimension , owl:NamedIndividual ; rdfs:label "党建融合（20分）"@zh , "Party Building Integration (20pts)"@en .
govstr:TransparencyScore      a govstr:GovernanceScorecardDimension , owl:NamedIndividual ; rdfs:label "信息透明度（20分）"@zh , "Information Transparency (20pts)"@en .
govstr:RiskComplianceScore    a govstr:GovernanceScorecardDimension , owl:NamedIndividual ; rdfs:label "风险合规管理（20分）"@zh , "Risk and Compliance (20pts)"@en .
govstr:StakeholderScore       a govstr:GovernanceScorecardDimension , owl:NamedIndividual ; rdfs:label "利益相关方保护（15分）"@zh , "Stakeholder Protection (15pts)"@en .

govstr:hasTotalGovernanceScore
    a owl:DatatypeProperty ;
    rdfs:label "治理综合评分（满分100）"@zh , "Total Governance Score (Max 100)"@en ;
    rdfs:domain govstr:GovernanceScorecard ; rdfs:range xsd:decimal .

# ──────────────────────────────────────────────────────────────────────────────
# C4. 服务战略（SERVE NATIONAL STRATEGY）
#     推动国有资本服务国家战略与高质量发展
# ──────────────────────────────────────────────────────────────────────────────

svcstrat:NationalStrategyServiceSystem
    a owl:Class ;
    rdfs:label "服务国家战略监管体系"@zh , "National Strategy Service Supervision System"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "国资监管第四目标：推动国有资本主动布局国家战略领域，服务高质量发展。含：战略性布局评估·科技自立自强·共同富裕贡献·碳达峰碳中和·国家安全保障。"@zh ,
        "Fourth regulatory objective: drives state capital to proactively position in national strategic areas to serve high-quality development. Includes: strategic layout assessment, sci-tech self-reliance, common prosperity contribution, carbon peak/neutrality, national security assurance."@en .

svcstrat:StrategicLayoutScore
    a owl:Class ;
    rdfs:label "国家战略布局贡献度"@zh , "National Strategic Layout Contribution Score"@en ;
    rdfs:subClassOf svcstrat:NationalStrategyServiceSystem ;
    rdfs:comment "评估央企资本布局与国家'十四五'战略重点领域的匹配度：新基建·新能源·数字经济·高端制造·生物医药·量子信息。"@zh ,
                 "Assesses alignment between central SOE capital layout and national 14th Five-Year Plan strategic priorities: new infrastructure, new energy, digital economy, high-end manufacturing, biopharmaceuticals, quantum information."@en .

svcstrat:StrategicArea
    a owl:Class ; rdfs:label "战略布局领域"@zh , "Strategic Layout Area"@en .
svcstrat:NewInfrastructure   a svcstrat:StrategicArea , owl:NamedIndividual ; rdfs:label "新基建（5G·数据中心·工业互联网）"@zh , "New Infrastructure (5G, Data Centers, Industrial Internet)"@en .
svcstrat:NewEnergy           a svcstrat:StrategicArea , owl:NamedIndividual ; rdfs:label "新能源（风光储氢）"@zh , "New Energy (Wind/Solar/Storage/Hydrogen)"@en .
svcstrat:DigitalEconomy      a svcstrat:StrategicArea , owl:NamedIndividual ; rdfs:label "数字经济（AI·大数据·云计算）"@zh , "Digital Economy (AI, Big Data, Cloud)"@en .
svcstrat:HighEndManufacturing a svcstrat:StrategicArea , owl:NamedIndividual ; rdfs:label "高端制造（半导体·航空·精密仪器）"@zh , "High-End Manufacturing (Semiconductor, Aviation, Precision Instruments)"@en .
svcstrat:BioPharma           a svcstrat:StrategicArea , owl:NamedIndividual ; rdfs:label "生物医药"@zh , "Biopharmaceuticals"@en .
svcstrat:QuantumInfotech      a svcstrat:StrategicArea , owl:NamedIndividual ; rdfs:label "量子信息"@zh , "Quantum Information Technology"@en .

svcstrat:SciTechSelfRelianceContribution
    a owl:Class ;
    rdfs:label "科技自立自强贡献"@zh , "Sci-Tech Self-Reliance Contribution"@en ;
    rdfs:subClassOf svcstrat:NationalStrategyServiceSystem ;
    rdfs:comment "量化央企在关键核心技术攻关·技术创新体系建设·国家实验室参与·知识产权创造方面的贡献。"@zh ,
                 "Quantifies central SOE contributions to: key core technology breakthroughs, technology innovation system building, national laboratory participation, intellectual property creation."@en .

svcstrat:hasPatentCount
    a owl:DatatypeProperty ;
    rdfs:label "有效发明专利数量"@zh , "Valid Invention Patent Count"@en ;
    rdfs:domain svcstrat:SciTechSelfRelianceContribution ; rdfs:range xsd:integer .

svcstrat:hasRDInvestmentAmount
    a owl:DatatypeProperty ;
    rdfs:label "研发投入绝对金额（亿元）"@zh , "R&D Investment Amount (CNY 100M)"@en ;
    rdfs:domain svcstrat:SciTechSelfRelianceContribution ; rdfs:range xsd:decimal .

svcstrat:CommonProsperityContribution
    a owl:Class ;
    rdfs:label "共同富裕贡献"@zh , "Common Prosperity Contribution"@en ;
    rdfs:subClassOf svcstrat:NationalStrategyServiceSystem ;
    rdfs:comment "量化央企在共同富裕方面的贡献：收入分配公平性·员工薪酬增长·乡村振兴投入·社会责任支出·税收贡献。"@zh ,
                 "Quantifies central SOE contributions to common prosperity: income distribution equity, employee compensation growth, rural revitalization investment, social responsibility spending, tax contributions."@en .

svcstrat:CarbonPeakNeutralityPath
    a owl:Class ;
    rdfs:label "碳达峰碳中和路径"@zh , "Carbon Peak and Neutrality Pathway"@en ;
    rdfs:subClassOf svcstrat:NationalStrategyServiceSystem ;
    rdfs:comment "国有企业在碳达峰（2030）·碳中和（2060）国家目标中的分路径贡献：降碳·固碳·替代·技术突破。"@zh ,
                 "SOE pathway contributions to national carbon peak (2030) and neutrality (2060) targets: emission reduction, carbon sequestration, substitution, technology breakthroughs."@en .

svcstrat:hasCarbonEmissionReductionRate
    a owl:DatatypeProperty ;
    rdfs:label "年碳排放降低率"@zh , "Annual Carbon Emission Reduction Rate"@en ;
    rdfs:domain svcstrat:CarbonPeakNeutralityPath ; rdfs:range xsd:decimal .

svcstrat:NationalSecurityAssurance
    a owl:Class ;
    rdfs:label "国家安全保障功能"@zh , "National Security Assurance Function"@en ;
    rdfs:subClassOf svcstrat:NationalStrategyServiceSystem ;
    rdfs:comment "央企作为国家经济安全的压舱石：能源安全保障·粮食安全保障·金融安全维护·通信安全保障·国防工业支撑。"@zh ,
                 "Central SOEs as ballast for national economic security: energy security assurance, food security assurance, financial security maintenance, communications security assurance, defense industry support."@en .

svcstrat:SecurityAssuranceDomain
    a owl:Class ; rdfs:label "安全保障领域"@zh , "Security Assurance Domain"@en .
svcstrat:EnergySecurity    a svcstrat:SecurityAssuranceDomain , owl:NamedIndividual ; rdfs:label "能源安全"@zh , "Energy Security"@en .
svcstrat:FoodSecurity      a svcstrat:SecurityAssuranceDomain , owl:NamedIndividual ; rdfs:label "粮食安全"@zh , "Food Security"@en .
svcstrat:FinancialSecurity a svcstrat:SecurityAssuranceDomain , owl:NamedIndividual ; rdfs:label "金融安全"@zh , "Financial Security"@en .
svcstrat:IndustrialChainSecurity a svcstrat:SecurityAssuranceDomain , owl:NamedIndividual ; rdfs:label "产业链供应链安全"@zh , "Industrial Chain and Supply Chain Security"@en .

svcstrat:HighQualityDevelopmentIndex
    a owl:Class ;
    rdfs:label "高质量发展综合指数"@zh , "High-Quality Development Composite Index"@en ;
    rdfs:subClassOf svcstrat:NationalStrategyServiceSystem ;
    rdfs:comment "综合评估国有企业在创新·协调·绿色·开放·共享新发展理念下的发展质量，作为国资委对央企的综合评价指标。"@zh ,
                 "Comprehensive assessment of SOE development quality under the Five Development Concepts (Innovation, Coordination, Green, Openness, Sharing) as SASAC's comprehensive enterprise evaluation metric."@en .

svcstrat:HQDIDimension
    a owl:Class ; rdfs:label "高质量发展指标维度"@zh , "HQD Index Dimension"@en .
svcstrat:InnovationDimension   a svcstrat:HQDIDimension , owl:NamedIndividual ; rdfs:label "创新（研发·专利·科技转化）"@zh , "Innovation (R&D, Patents, Tech Transfer)"@en .
svcstrat:CoordinationDimension a svcstrat:HQDIDimension , owl:NamedIndividual ; rdfs:label "协调（主业聚焦·产业链整合）"@zh , "Coordination (Core Focus, Supply Chain Integration)"@en .
svcstrat:GreenDimension        a svcstrat:HQDIDimension , owl:NamedIndividual ; rdfs:label "绿色（碳减排·绿色能源比例）"@zh , "Green (Carbon Reduction, Green Energy Ratio)"@en .
svcstrat:OpennessDimension     a svcstrat:HQDIDimension , owl:NamedIndividual ; rdfs:label "开放（国际化·\"一带一路\"贡献）"@zh , "Openness (Internationalization, BRI Contribution)"@en .
svcstrat:SharingDimension      a svcstrat:HQDIDimension , owl:NamedIndividual ; rdfs:label "共享（就业·纳税·社会贡献）"@zh , "Sharing (Employment, Tax, Social Contribution)"@en .

# ==============================================================================
# PART D: 数字化监管平台（DIGITAL REGULATORY PLATFORM）
# 支撑四大目标·五维穿透·双转型的技术架构
# ==============================================================================

digital:DigitalRegulatoryPlatform
    a owl:Class ;
    rdfs:label "国资数字化监管平台"@zh , "State Assets Digital Regulatory Platform"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment
        "集成五维穿透·双转型·四目标的统一数字平台。核心架构：数据层（采集·存储·治理）·分析层（规则·模型·AI）·应用层（监管仪表盘·预警·OaaS）·治理层（权限·审计·合规）。"@zh ,
        "Unified digital platform integrating five-dimension penetration, dual transformation, and four objectives. Core architecture: data layer (collection, storage, governance) · analysis layer (rules, models, AI) · application layer (regulatory dashboard, alerts, OaaS) · governance layer (permissions, audit, compliance)."@en .

digital:PenetrationAnalyticsEngine
    a owl:Class ;
    rdfs:label "穿透分析引擎"@zh , "Penetration Analytics Engine"@en ;
    rdfs:subClassOf digital:DigitalRegulatoryPlatform ;
    rdfs:comment "支持图计算的穿透分析引擎，运行在分布式图数据库（Neo4j·TuGraph）上，支持亿级节点的实时路径查询。"@zh ,
                 "Graph-computing penetration analytics engine running on distributed graph databases (Neo4j, TuGraph); supports real-time path queries on billion-scale nodes."@en .

digital:GraphDatabaseType
    a owl:Class ; rdfs:label "图数据库类型"@zh , "Graph Database Type"@en .
digital:Neo4j    a digital:GraphDatabaseType , owl:NamedIndividual ; rdfs:label "Neo4j（国际主流）"@zh , "Neo4j (International Mainstream)"@en .
digital:TuGraph  a digital:GraphDatabaseType , owl:NamedIndividual ; rdfs:label "TuGraph（蚂蚁集团·国产）"@zh , "TuGraph (Ant Group, Domestic)"@en .
digital:HugeGraph a digital:GraphDatabaseType , owl:NamedIndividual ; rdfs:label "HugeGraph（百度·国产）"@zh , "HugeGraph (Baidu, Domestic)"@en .

digital:AIRegulatoryModel
    a owl:Class ;
    rdfs:label "AI监管模型"@zh , "AI Regulatory Model"@en ;
    rdfs:subClassOf digital:DigitalRegulatoryPlatform ;
    rdfs:comment "应用于监管场景的AI模型：异常检测（孤立森林·自编码器）·风险预测（GBM·LSTM）·关系提取（GNN）·NLQ（RAG·Fine-tuned LLM）。"@zh ,
                 "AI models for regulatory scenarios: anomaly detection (Isolation Forest, Autoencoder), risk prediction (GBM, LSTM), relationship extraction (GNN), NLQ (RAG, fine-tuned LLM)."@en .

digital:AIModelType
    a owl:Class ; rdfs:label "AI模型类型"@zh , "AI Model Type"@en .
digital:AnomalyDetectionModel a digital:AIModelType , owl:NamedIndividual ; rdfs:label "异常检测模型（孤立森林·OCSVM）"@zh , "Anomaly Detection Model"@en .
digital:RiskPredictionModel   a digital:AIModelType , owl:NamedIndividual ; rdfs:label "风险预测模型（GBM·XGBoost）"@zh , "Risk Prediction Model"@en .
digital:GraphNeuralNetwork    a digital:AIModelType , owl:NamedIndividual ; rdfs:label "图神经网络（GNN·关系识别）"@zh , "Graph Neural Network (GNN, Relation Extraction)"@en .
digital:LLMRegulatoryAgent    a digital:AIModelType , owl:NamedIndividual ; rdfs:label "监管大模型智能体（RAG+工具调用）"@zh , "Regulatory LLM Agent (RAG + Tool Calling)"@en .

digital:DataSovereigntyCompliance
    a owl:Class ;
    rdfs:label "数据主权与合规"@zh , "Data Sovereignty and Compliance"@en ;
    rdfs:subClassOf digital:DigitalRegulatoryPlatform ;
    rdfs:comment "国资监管数据须存储在境内，敏感数据须加密，境外子公司数据跨境须合规审查。核心数据不得出境。"@zh ,
                 "SOE regulatory data must be stored domestically; sensitive data must be encrypted; overseas subsidiary data cross-border transfer requires compliance review. Core data must not leave China."@en .

# ==============================================================================
# CROSS-MODULE INTEGRATION PROPERTIES (v4.3)
# ==============================================================================

sasac:hasFiveIPenetration
    a owl:ObjectProperty ;
    rdfs:label "五维穿透配置"@zh , "Five-Dimension Penetration Configuration"@en ;
    rdfs:domain ent:StateOwnedEnterprise ;
    rdfs:range penet:PenetrativeSupervision .

sasac:hasEquityPenetration    a owl:ObjectProperty ; rdfs:label "股权穿透"@zh , "Equity Penetration"@en ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range peq:EquityPenetrationSystem .
sasac:hasBusinessPenetration  a owl:ObjectProperty ; rdfs:label "业务穿透"@zh , "Business Penetration"@en ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range pbiz:BusinessPenetrationSystem .
sasac:hasFundPenetration      a owl:ObjectProperty ; rdfs:label "资金穿透"@zh , "Fund Penetration"@en ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range pfund:FundPenetrationSystem .
sasac:hasAccountabilityPenetration a owl:ObjectProperty ; rdfs:label "责任穿透"@zh , "Accountability Penetration"@en ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range presp:AccountabilityPenetrationSystem .
sasac:hasRiskPenetration      a owl:ObjectProperty ; rdfs:label "风险穿透"@zh , "Risk Penetration"@en ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range prisk:RiskPenetrationSystem .

sasac:hasCapitalTransformation a owl:ObjectProperty ; rdfs:label "管资本转型"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range mcap:ManageCapitalTransformation .
sasac:hasRealTimeControl       a owl:ObjectProperty ; rdfs:label "实时防控"@zh ; rdfs:domain ent:StateOwnedEnterprise ; rdfs:range rtctrl:RealTimeControlSystem .

# Link four objectives to regulatory framework
sasac:hasDissipationPrevention  a owl:ObjectProperty ; rdfs:label "防流失目标"@zh ; rdfs:domain sasac:RegulatoryFramework ; rdfs:range noflow:PreventDissipationSystem .
sasac:hasEfficiencyObjective    a owl:ObjectProperty ; rdfs:label "提效率目标"@zh ; rdfs:domain sasac:RegulatoryFramework ; rdfs:range effcap:CapitalEfficiencySystem .
sasac:hasGovernanceObjective    a owl:ObjectProperty ; rdfs:label "强治理目标"@zh ; rdfs:domain sasac:RegulatoryFramework ; rdfs:range govstr:GovernanceStrengtheningSystem .
sasac:hasStrategyServiceObjective a owl:ObjectProperty ; rdfs:label "服务战略目标"@zh ; rdfs:domain sasac:RegulatoryFramework ; rdfs:range svcstrat:NationalStrategyServiceSystem .

# SHACL: Effective state equity ratio must be >0
peq:StateEquityEffectiveShape
    a sh:NodeShape ;
    sh:targetClass peq:StateEquityEffectiveRatio ;
    sh:property [
        sh:path peq:hasEffectiveShareholding ;
        sh:minExclusive 0.0 ;
        sh:message "穿透后国有实际持股必须大于0。"@zh ,
                   "Effective state equity ratio after penetration must be greater than 0."@en
    ] .

# SHACL: Risk Penetration Index completeness
prisk:RPIShape
    a sh:NodeShape ;
    sh:targetClass prisk:RiskPenetrationIndex ;
    sh:property [
        sh:path prisk:hasRPIScore ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
        sh:message "风险穿透指数必须在0到100之间。"@zh ,
                   "Risk Penetration Index must be between 0 and 100."@en
    ] .

# SHACL: Fund flow hop count warning
pfund:FundHopShape
    a sh:NodeShape ;
    sh:targetClass pfund:FundFlowGraph ;
    sh:property [
        sh:path pfund:hasFundFlowHops ;
        sh:maxInclusive 10 ;
        sh:message "资金流转超过10跳须立即触发深度调查预警。"@zh ,
                   "Fund flow exceeding 10 hops must immediately trigger deep investigation alert."@en
    ] .

# Key named instances
noflow:StandardSafetyThreshold
    a noflow:AssetSafetyIndex , owl:NamedIndividual ;
    rdfs:label "标准安全指数阈值"@zh , "Standard Safety Index Threshold"@en ;
    noflow:hasSafetyIndexScore "60.0"^^xsd:decimal .

rtctrl:StandardRealTimeConfig
    a rtctrl:RealTimeDataIngestion , owl:NamedIndividual ;
    rdfs:label "标准实时采集配置"@zh , "Standard Real-Time Ingestion Config"@en ;
    rtctrl:hasDataIngestionDelay "5"^^xsd:integer .

pfund:StandardFundEngine
    a pfund:FundPenetrationRealTimeEngine , owl:NamedIndividual ;
    rdfs:label "标准资金穿透实时引擎"@zh , "Standard Fund Penetration Real-Time Engine"@en ;
    pfund:hasRealTimeLatencyMs "100"^^xsd:integer .

