    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty sjyzd:hasDecisionDate ;
        owl:cardinality 1
    ] .

sjyzd:hasDecisionDate
    a owl:DatatypeProperty ;
    rdfs:label "决策日期"@zh , "Decision Date"@en ;
    rdfs:domain sjyzd:SJYZDDecisionRecord ;
