sjyzd:hasInvestmentThreshold
    a owl:DatatypeProperty ;
    rdfs:label "重大投资门槛"@zh , "Major Investment Threshold"@en ;
    rdfs:domain sjyzd:SJYZDThreshold ;
    rdfs:range xsd:decimal .

sjyzd:SJYZDDecisionRecord
    a owl:Class ;
    rdfs:label "三重一大决策记录"@zh , "SJYZD Decision Record"@en ;
