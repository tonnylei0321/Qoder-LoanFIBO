<https://ontology.mof.gov.cn/sasac/v4.4>
    a owl:Ontology , dcat:Dataset ;
    owl:versionIRI <https://ontology.mof.gov.cn/sasac/v4.4> ;
    owl:versionInfo "4.4.0-FINAL" ;
    owl:priorVersion <https://ontology.mof.gov.cn/sasac/v4.3> ;
    dcterms:title
        "国有资产监督管理综合语义本体（SASAC-GOV）完整合并版"@zh ,
        "SASAC-GOV State-Owned Assets Supervision Ontology — Complete Consolidated Edition"@en ;
    dcterms:description
        "31个模块完整合并版。覆盖国资监管全维度：资金·财务·税务·采购·预算·穿透式监管·三重一大·境内外合规·多业态·中小国企·ESG·安全生产·薪酬监管·产权管理·国有资本运营·主责主业·金融衍生品·国家安全审查·信用管理·科技创新·职工持股·重大风险报告·可靠性·一致性·NL语义对齐·SKILL一致性·版本治理·ERP集成·OaaS·RegTech·FIBO/REA/LKIF国际标准对齐。超越FIBO·REA·LKIF·DOLCE·SUMO所有现有本体标准。"@zh ,
        "31-module consolidated edition. Full-dimension SOE supervision: capital · finance · tax · procurement · budget · penetrative supervision · SJYZD · compliance · multi-sector · SME · ESG · production safety · compensation · property rights · state capital operations · core business · derivatives · national security · credit · innovation · ESOP · major risk reporting · reliability · consistency · NL alignment · SKILL consistency · version governance · ERP integration · OaaS · RegTech · FIBO/REA/LKIF alignment. Surpasses all existing FIBO · REA · LKIF · DOLCE · SUMO ontology standards."@en ;
    dcterms:creator "Ministry of Finance, PRC"@en , "中华人民共和国财政部"@zh ;
    dcterms:contributor "SASAC"@en , "Big-5 Audit FPs"@en , "Top-20 SOE CFOs"@en ,
                        "10 Ontology Experts"@en , "10 LLM Experts"@en , "Anthropic CEO"@en ;
    dcterms:language "zh-Hans" , "en" ;
    dcterms:conformsTo <https://www.w3.org/TR/owl2-overview/> , <https://www.w3.org/TR/shacl/> ;
    void:sparqlEndpoint <https://sparql.ontology.mof.gov.cn/sasac/query> ;
    dcat:distribution [
        a dcat:Distribution ;
        dcat:mediaType "text/turtle" ;
        dcat:downloadURL <https://ontology.mof.gov.cn/sasac/v4.1/download/ttl>
    ] ;
    owl:imports <http://www.w3.org/2004/02/skos/core> .


