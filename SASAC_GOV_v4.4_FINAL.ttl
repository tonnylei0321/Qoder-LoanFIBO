# existing
# v4.4 new namespaces

# ==============================================================================
# ██████████████████████████████████████████████████████████████████████████████
# PART I — 1号文：财务数智化转型升级
# 国资发监督规〔2026〕1号
# ██████████████████████████████████████████████████████████████████████████████
# ==============================================================================

# ── 1.1 DRP全域数字化资源管理平台 ─────────────────────────────────────────────
drp:DigitalizedResourceManagementPlatform
    a owl:Class ;
    rdfs:label "全域数字化资源管理平台（DRP）"@zh ,
               "Digitalized Resource-management Platform (DRP)"@en ;
    rdfs:subClassOf tech:TechnologyPlatform ;
    rdfs:comment
        "1号文核心概念：DRP是财务数智化转型的核心依托，覆盖招标·生产·销售·设计·工程等经营管理全域，实现全级次·全流程·全要素穿透管理。"@zh ,
        "Key concept from No.1 Circular: DRP is the core platform for financial digitalization, covering procurement, production, sales, design, engineering—achieving full-tier, full-process, full-element penetration management."@en .

drp:DRPCoverageScope
    a owl:Class ;
    rdfs:label "DRP覆盖范围"@zh , "DRP Coverage Scope"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform .

drp:FinancialSystemScope    a drp:DRPCoverageScope , owl:NamedIndividual ;
    rdfs:label "财务系统域（司库·共享·战略·预算·核算·资产·税务·费用）"@zh ,
               "Financial Domain (Treasury, Shared, Strategy, Budget, Accounting, Asset, Tax, Expense)"@en .
drp:BusinessSystemScope     a drp:DRPCoverageScope , owl:NamedIndividual ;
    rdfs:label "业务系统域（招标·生产·销售·物资·设计·工程）"@zh ,
               "Business Domain (Bidding, Production, Sales, Materials, Design, Engineering)"@en .
drp:ManagementSystemScope   a drp:DRPCoverageScope , owl:NamedIndividual ;
    rdfs:label "管理系统域（投资·法务·合同·人力·内控·审计）"@zh ,
               "Management Domain (Investment, Legal, Contract, HR, Internal Control, Audit)"@en .

drp:DRPThreePenetrationPrinciple
    a owl:Class ;
    rdfs:label "全级次全流程全要素穿透原则"@zh ,
               "Full-Tier Full-Process Full-Element Penetration Principle"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment "1号文明确要求：到2028年实现'全级次、全流程、全要素'穿透管理。"@zh ,
                 "No.1 Circular mandates: by 2028, achieve 'full-tier, full-process, full-element' penetration management."@en .

drp:hasDRPReadinessLevel
    a owl:DatatypeProperty ;
    rdfs:label "DRP建设成熟度"@zh , "DRP Readiness Level"@en ;
    rdfs:domain drp:DigitalizedResourceManagementPlatform ;
    rdfs:range xsd:integer ;
    rdfs:comment "1=启动 2=财务系统上线 3=全面集成 4=全域DRP建成。对应1号文四个时间节点。"@zh ,
                 "1=Initiated 2=Financial systems online 3=Fully integrated 4=Full DRP built. Maps to No.1 Circular's four milestones."@en .

# ── 1.2 四阶段时间里程碑目标 ───────────────────────────────────────────────────
mstn:FinancialDigitalizationMilestone
    a owl:Class ;
    rdfs:label "财务数智化转型里程碑"@zh ,
               "Financial Digitalization Milestone"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment "1号文明确四个时间节点目标，具有法律约束力的监管要求。"@zh ,
                 "No.1 Circular specifies four binding regulatory milestones."@en .

mstn:Milestone2026
    a mstn:FinancialDigitalizationMilestone , owl:NamedIndividual ;
    rdfs:label "里程碑一：2026年底"@zh , "Milestone 1: End of 2026"@en ;
    rdfs:comment "所有央企全面上线司库·共享·战略等财务管理系统并互联互通；财务级数据中台和常态化数据治理机制全面建成；基本实现信息真实可靠·资产清晰可管·资金规范可溯·风险基本可控。"@zh ,
                 "All central SOEs fully online with treasury, shared, and strategic financial systems interconnected; financial data platform and data governance fully established; information reliable, assets manageable, funds traceable, risks basically controlled."@en .

mstn:Milestone2027
    a mstn:FinancialDigitalizationMilestone , owl:NamedIndividual ;
    rdfs:label "里程碑二：2027年底"@zh , "Milestone 2: End of 2027"@en ;
    rdfs:comment "财务·投资·法务·合同·人力等管理系统全面集成；企业级数据中台基本建成；业财融合智慧管理模型深度应用；基本实现经营安全合规·决策科学高效·管控精准有力·监督穿透智能。"@zh ,
                 "Finance, investment, legal, contract, HR management systems fully integrated; enterprise data platform basically built; business-finance smart models deeply applied."@en .

mstn:Milestone2028
    a mstn:FinancialDigitalizationMilestone , owl:NamedIndividual ;
    rdfs:label "里程碑三：2028年底"@zh , "Milestone 3: End of 2028"@en ;
    rdfs:comment "具备条件的企业建成覆盖招标·生产·销售·设计·工程等经营管理全域的DRP系统；实现'全级次·全流程·全要素'穿透管理。"@zh ,
                 "Qualifying enterprises build full-domain DRP covering bidding, production, sales, design, engineering; achieve full-tier, full-process, full-element penetration management."@en .

mstn:MilestoneFifteenth5Year
    a mstn:FinancialDigitalizationMilestone , owl:NamedIndividual ;
    rdfs:label "里程碑四：十五五末（2030年）"@zh , "Milestone 4: End of 15th Five-Year Plan (2030)"@en ;
    rdfs:comment "所有中央企业基本建成DRP系统，为建设世界一流企业提供坚实支撑。"@zh ,
                 "All central SOEs basically complete DRP system construction, providing solid support for building world-class enterprises."@en .

mstn:hasMilestoneDeadline
    a owl:DatatypeProperty ;
    rdfs:label "里程碑截止日期"@zh , "Milestone Deadline"@en ;
    rdfs:domain mstn:FinancialDigitalizationMilestone ;
    rdfs:range xsd:gYear .

mstn:hasMilestoneAchievementRate
    a owl:DatatypeProperty ;
    rdfs:label "里程碑完成率"@zh , "Milestone Achievement Rate"@en ;
    rdfs:domain mstn:FinancialDigitalizationMilestone ;
    rdfs:range xsd:decimal .

# ── 1.3 业财审一体化 ───────────────────────────────────────────────────────────
bfas:BusinessFinanceAuditIntegration
    a owl:Class ;
    rdfs:label "业财审一体化"@zh ,
               "Business-Finance-Audit Integration (BFAS)"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment
        "1号文·2号文共同要求：实现业务系统·财务系统·审计监督的深度融合，形成数据自动流转·规则刚性执行·问题自动识别的一体化管理模式。"@zh ,
        "Both circulars require: deep integration of business, finance, and audit systems, forming automated data flow, rigid rule execution, and automatic problem identification."@en .

bfas:BusinessDrivenFinance
    a owl:Class ;
    rdfs:label "业务驱动财务核算"@zh , "Business-Driven Financial Accounting"@en ;
    rdfs:subClassOf bfas:BusinessFinanceAuditIntegration ;
    rdfs:comment "2号文第十三条：逐步实现业务流程驱动资金支付、资金支付驱动会计核算。"@zh ,
                 "Art.13 of No.2 Circular: gradually realize business process driving payment, payment driving accounting entries."@en .

bfas:OneKeyReportGeneration
    a owl:Class ;
    rdfs:label "财务报表一键生成"@zh , "One-Key Financial Report Generation"@en ;
    rdfs:subClassOf bfas:BusinessFinanceAuditIntegration ;
    rdfs:comment "通过嵌入合并报表抵销规则，实现财务报表一键生成、会计信息一穿到底。"@zh ,
                 "Through embedded consolidation elimination rules, achieve one-key report generation and penetrative accounting information."@en .

bfas:AuditIntegrationLayer
    a owl:Class ;
    rdfs:label "审计监督嵌入层"@zh , "Audit Supervision Embedded Layer"@en ;
    rdfs:subClassOf bfas:BusinessFinanceAuditIntegration ;
    rdfs:comment "将内部审计监督规则嵌入业务流程，实现事中实时监督，而非事后抽查。"@zh ,
                 "Embeds internal audit rules into business processes for real-time in-process supervision rather than post-hoc sampling."@en .

bfas:hasBFASIntegrationLevel
    a owl:DatatypeProperty ;
    rdfs:label "业财审集成度"@zh , "BFAS Integration Level"@en ;
    rdfs:domain bfas:BusinessFinanceAuditIntegration ;
    rdfs:range xsd:integer ;
    rdfs:comment "1=初步集成 2=数据互通 3=流程驱动 4=全自动一体"@zh ,
                 "1=Basic 2=Data sharing 3=Process-driven 4=Full automation"@en .

# ── 1.4 四流合一 ───────────────────────────────────────────────────────────────
foflow:FourFlowIntegration
    a owl:Class ;
    rdfs:label "四流合一（物流·资金流·信息流·价值流）"@zh ,
               "Four-Flow Integration (Logistics, Capital, Information, Value Flows)"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment
        "1号文要求：依托DRP系统实时共享业财数据，打造企业内部协同的'数字纽带'，实现物流、资金流、信息流、价值流'四流合一'。"@zh ,
        "No.1 Circular requires: leverage DRP for real-time business-finance data sharing to create a 'digital bond' enabling 'four-flow integration'."@en .

foflow:LogisticsFlow
    a owl:Class ;
    rdfs:label "物流"@zh , "Logistics Flow"@en ;
    rdfs:subClassOf foflow:FourFlowIntegration ;
    rdfs:comment "采购·仓储·生产·配送等物质实体流动的数字化跟踪。"@zh ,
                 "Digital tracking of physical material flows: procurement, storage, production, distribution."@en .

foflow:CapitalFlow
    a owl:Class ;
    rdfs:label "资金流"@zh , "Capital Flow"@en ;
    rdfs:subClassOf foflow:FourFlowIntegration ;
    rdfs:comment "与物流对应的资金支付·结算·归集流动，须与物流单据匹配验证。"@zh ,
                 "Corresponding fund payments, settlements, and pooling that must be verified against logistics documents."@en .

foflow:InformationFlow
    a owl:Class ;
    rdfs:label "信息流"@zh , "Information Flow"@en ;
    rdfs:subClassOf foflow:FourFlowIntegration ;
    rdfs:comment "跨部门·跨层级·跨系统的业务指令·合同·审批信息流动。"@zh ,
                 "Business instructions, contracts, and approval information flowing across departments, tiers, and systems."@en .

foflow:ValueFlow
    a owl:Class ;
    rdfs:label "价值流"@zh , "Value Flow"@en ;
    rdfs:subClassOf foflow:FourFlowIntegration ;
    rdfs:comment "经济价值在企业内外部的创造·转移·实现过程，映射到财务凭证·绩效·EVA。"@zh ,
                 "Creation, transfer, and realization of economic value inside and outside the enterprise, mapped to financial entries, KPIs, and EVA."@en .

foflow:FourFlowConsistencyCheck
    a owl:Class ;
    rdfs:label "四流一致性核验"@zh , "Four-Flow Consistency Verification"@en ;
    rdfs:subClassOf foflow:FourFlowIntegration ;
    rdfs:comment "自动核验：同一交易的物流单据·资金支付·信息审批·价值记账是否一致，不一致触发预警。"@zh ,
                 "Automatic verification: whether logistics documents, fund payments, information approvals, and value entries are consistent for the same transaction; inconsistency triggers alert."@en .

# ── 1.5 神经网络+图计算穿透监督模型 ───────────────────────────────────────────
aipen:AIEnhancedPenetrationModel
    a owl:Class ;
    rdfs:label "AI增强穿透监督模型"@zh , "AI-Enhanced Penetration Supervision Model"@en ;
    rdfs:subClassOf tech:TechnologyPlatform ;
    rdfs:comment
        "1号文第十条：运用神经网络、图计算等先进算法深度挖掘数据内在关联，提升对复杂隐蔽问题的洞察力。赋予模型自学习能力，自动更新问题识别规则与预警阈值。"@zh ,
        "Art.10 of No.1 Circular: apply neural networks and graph computing algorithms to mine data correlations; give models self-learning capability to auto-update detection rules and alert thresholds."@en .

aipen:NeuralNetworkDetectionModel
    a owl:Class ;
    rdfs:label "神经网络问题检测模型"@zh , "Neural Network Problem Detection Model"@en ;
    rdfs:subClassOf aipen:AIEnhancedPenetrationModel ;
    rdfs:comment "深度学习模型识别财务异常模式：LSTM时序异常、Autoencoder异常重建、GAN生成对抗检测。"@zh ,
                 "Deep learning models for financial anomaly detection: LSTM temporal anomaly, Autoencoder reconstruction, GAN adversarial detection."@en .

aipen:GraphComputingPenetrationModel
    a owl:Class ;
    rdfs:label "图计算穿透分析模型"@zh , "Graph Computing Penetration Analysis Model"@en ;
    rdfs:subClassOf aipen:AIEnhancedPenetrationModel ;
    rdfs:comment "图神经网络（GNN）对股权·资金·关联方网络进行深度穿透：节点=企业/账户，边=持股/转账关系，识别隐蔽关联。"@zh ,
                 "Graph Neural Networks (GNN) for deep penetration of equity, fund, and related-party networks: nodes=enterprises/accounts, edges=shareholding/transfer relations."@en .

aipen:SelfLearningRuleEngine
    a owl:Class ;
    rdfs:label "自学习规则引擎"@zh , "Self-Learning Rule Engine"@en ;
    rdfs:subClassOf aipen:AIEnhancedPenetrationModel ;
    rdfs:comment "基于强化学习自动更新穿透监督规则：发现新型违规模式后自动添加规则，废弃低效规则，保持规则库时效性。"@zh ,
                 "Reinforcement learning-based automatic rule updates: new violation patterns trigger rule addition, ineffective rules pruned, rule base remains current."@en .

aipen:PeopleEventTableAccountModel
    a owl:Class ;
    rdfs:label "人事表账AI大模型框架"@zh , "People-Event-Table-Account AI Model Framework"@en ;
    rdfs:subClassOf aipen:AIEnhancedPenetrationModel ;
    rdfs:comment "2号文第八条：围绕'人（管理者）·事（交易事件）·表（财务报表）·账（会计凭证）'构建国资央企人工智能大模型，深度挖掘数据价值。"@zh ,
                 "Art.8 of No.2 Circular: AI model framework centered on 'People (managers), Events (transactions), Tables (reports), Accounts (vouchers)' for deep SOE data value mining."@en .

aipen:hasModelType
    a owl:DatatypeProperty ;
    rdfs:label "模型类型"@zh , "Model Type"@en ;
    rdfs:domain aipen:AIEnhancedPenetrationModel ;
    rdfs:range xsd:string ;
    rdfs:comment "NEURAL_NETWORK | GRAPH_COMPUTING | SELF_LEARNING | LLM | HYBRID"@en .

aipen:hasDetectionAccuracy
    a owl:DatatypeProperty ;
    rdfs:label "问题检测准确率"@zh , "Problem Detection Accuracy"@en ;
    rdfs:domain aipen:AIEnhancedPenetrationModel ;
    rdfs:range xsd:decimal .

# ── 1.6 问题识别机制 ───────────────────────────────────────────────────────────
issue:ProblemIdentificationMechanism
    a owl:Class ;
    rdfs:label "问题识别机制"@zh , "Problem Identification Mechanism"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "1号文第十条：紧密围绕业务场景和商业实质，构建穿透监督模型，精准识别突出问题。强调针对性（靶向）·精准性·智能性三维要求。"@zh ,
                 "Art.10 of No.1 Circular: build penetration supervision models around business scenarios and commercial substance to precisely identify prominent problems. Requires targeted, precise, and intelligent approaches."@en .

issue:TargetedPenetrationModel
    a owl:Class ;
    rdfs:label "靶向穿透监督模型"@zh , "Targeted Penetration Supervision Model"@en ;
    rdfs:subClassOf issue:ProblemIdentificationMechanism ;
    rdfs:comment "针对审计·巡视·纪检监察指出的突出问题，专项研发穿透监督模型，解决长期存在的顽瘴痼疾。"@zh ,
                 "Develops targeted penetration models specifically for problems identified by audit, inspection, and discipline commissions to address chronic issues."@en .

issue:ChronicProblemDatabase
    a owl:Class ;
    rdfs:label "顽瘴痼疾问题库"@zh , "Chronic Problem Database"@en ;
    rdfs:subClassOf issue:ProblemIdentificationMechanism ;
    rdfs:comment "建立典型问题案例库，将制度漏洞·管理短板及时反馈，形成'发现问题→完善制度→补足短板'良性循环。"@zh ,
                 "Establishes typical problem case library; feeds back systemic gaps and management weaknesses to create virtuous cycle: problem discovery → system improvement → gap closure."@en .

issue:ProblemCategoryTag
    a owl:Class ;
    rdfs:label "问题分类标签"@zh , "Problem Category Tag"@en .

issue:FinancialFraudProblem    a issue:ProblemCategoryTag , owl:NamedIndividual ;
    rdfs:label "财务数据造假"@zh , "Financial Data Fraud"@en .
issue:ExcessiveLeverageProblem a issue:ProblemCategoryTag , owl:NamedIndividual ;
    rdfs:label "过度负债杠杆"@zh , "Excessive Leverage"@en .
issue:CorruptionProblem        a issue:ProblemCategoryTag , owl:NamedIndividual ;
    rdfs:label "腐败违规问题"@zh , "Corruption and Misconduct"@en .
issue:ViolationInvestmentProblem a issue:ProblemCategoryTag , owl:NamedIndividual ;
    rdfs:label "违规投资决策"@zh , "Violation Investment Decision"@en .
issue:IllegalFundOccupation    a issue:ProblemCategoryTag , owl:NamedIndividual ;
    rdfs:label "违规资金占用"@zh , "Illegal Fund Occupation"@en .

# ── 1.7 协同核查机制 ───────────────────────────────────────────────────────────
collab:CollaborativeVerificationMechanism
    a owl:Class ;
    rdfs:label "协同核查机制"@zh , "Collaborative Verification Mechanism"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "1号文第十一条：构建跨部门·跨层级·跨业务的协同核查体系，确保核查高效推进·过程清晰可溯·结果客观准确。"@zh ,
                 "Art.11 of No.1 Circular: build cross-department, cross-tier, cross-business collaborative verification system ensuring efficient progress, traceable process, and objective results."@en .

collab:AutomaticTaskDispatch
    a owl:Class ;
    rdfs:label "自动派单机制"@zh , "Automatic Task Dispatch Mechanism"@en ;
    rdfs:subClassOf collab:CollaborativeVerificationMechanism ;
    rdfs:comment "根据问题线索的业务属性与部门职责分工，通过系统实现核查任务精准·及时推送和进度实时跟踪。"@zh ,
                 "Based on problem clue business attributes and departmental responsibilities, the system precisely dispatches verification tasks with real-time progress tracking."@en .

collab:JointResearchJudgment
    a owl:Class ;
    rdfs:label "会商研判机制"@zh , "Joint Research and Judgment Mechanism"@en ;
    rdfs:subClassOf collab:CollaborativeVerificationMechanism ;
    rdfs:comment "对涉及多部门·多业务领域的复杂问题，定期组织相关业务·审计监督等部门会商研判，提升精准识别能力。"@zh ,
                 "For complex multi-department, multi-business problems, regularly organizes cross-department deliberation to improve precise identification capability."@en .

collab:hasVerificationStatus
    a owl:DatatypeProperty ;
    rdfs:label "核查状态"@zh , "Verification Status"@en ;
    rdfs:domain collab:CollaborativeVerificationMechanism ;
    rdfs:range xsd:string ;
    rdfs:comment "PENDING_DISPATCH | IN_VERIFICATION | JOINT_REVIEW | COMPLETED | ESCALATED"@en .

# ── 1.8 整改追责机制 ───────────────────────────────────────────────────────────
rect:RectificationAccountabilityMechanism
    a owl:Class ;
    rdfs:label "整改追责机制"@zh , "Rectification and Accountability Mechanism"@en ;
    rdfs:subClassOf sasac:RegulatoryFramework ;
    rdfs:comment "1号文第十二条：实行'登记建账—限时整改—验收销号'全流程线上管理，加强责任追究与业务管理·内部监督·专项治理等的协同。"@zh ,
                 "Art.12 of No.1 Circular: implements 'register-account → time-limited rectification → acceptance-closure' full online process management, coordinating accountability with business management and supervision."@en .

rect:RegistrationAndRecording
    a owl:Class ;
    rdfs:label "登记建账"@zh , "Registration and Recording"@en ;
    rdfs:subClassOf rect:RectificationAccountabilityMechanism ;
    rdfs:comment "发现问题后立即录入问题登记台账，建立问题卡片，明确整改责任人·期限·要求。"@zh ,
                 "Upon problem discovery, immediately enter problem registry, create problem card, clarify responsible person, deadline, and requirements."@en .

rect:TimeLimitedRectification
    a owl:Class ;
    rdfs:label "限时整改"@zh , "Time-Limited Rectification"@en ;
    rdfs:subClassOf rect:RectificationAccountabilityMechanism ;
    rdfs:comment "按问题严重程度设定整改期限：一般问题30天，重要问题15天，重大问题7天。期满自动升级处理。"@zh ,
                 "Sets rectification deadlines by severity: general 30 days, important 15 days, major 7 days. Auto-escalates upon expiry."@en .

rect:AcceptanceAndClosure
    a owl:Class ;
    rdfs:label "验收销号"@zh , "Acceptance and Closure"@en ;
    rdfs:subClassOf rect:RectificationAccountabilityMechanism ;
    rdfs:comment "整改完成后须经验收方确认销号，线上留存整改证据，纳入责任人绩效档案。"@zh ,
                 "After rectification, verifier confirms closure; online evidence preserved; included in responsible person's performance record."@en .

rect:EscalatedAccountability
    a owl:Class ;
    rdfs:label "挂牌督办与提级查办"@zh , "Supervised and Escalated Investigation"@en ;
    rdfs:subClassOf rect:RectificationAccountabilityMechanism ;
    rdfs:comment "对金额较大·影响严重·性质恶劣的问题实施挂牌督办与提级查办，严肃追责问责。"@zh ,
                 "Problems of large amounts, serious impact, or egregious nature are subject to supervised rectification and escalated investigation with strict accountability."@en .

rect:hasRectificationDeadlineDays
    a owl:DatatypeProperty ;
    rdfs:label "整改期限（天）"@zh , "Rectification Deadline (Days)"@en ;
    rdfs:domain rect:TimeLimitedRectification ;
    rdfs:range xsd:integer .

rect:hasRectificationStatus
    a owl:DatatypeProperty ;
    rdfs:label "整改状态"@zh , "Rectification Status"@en ;
    rdfs:domain rect:RectificationAccountabilityMechanism ;
    rdfs:range xsd:string ;
    rdfs:comment "REGISTERED | IN_RECTIFICATION | OVERDUE | ACCEPTED | CLOSED | ESCALATED"@en .

# ── 1.9 共享财务系统三大子系统 ─────────────────────────────────────────────────
shrfin:SharedFinanceSystem
    a owl:Class ;
    rdfs:label "共享财务系统"@zh , "Shared Financial System"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment "1号文第五条：按照'规范·完整·自动'标准建设完善共享财务系统，含无纸化报账·智慧核算·合规纳税三大子系统。"@zh ,
                 "Art.5 of No.1 Circular: build shared financial systems to 'standardized, complete, automatic' standards, with paperless reimbursement, smart accounting, and compliance tax sub-systems."@en .

shrfin:PaperlessReimbursementSystem
    a owl:Class ;
    rdfs:label "无纸化自动报账系统"@zh , "Paperless Auto-Reimbursement System"@en ;
    rdfs:subClassOf shrfin:SharedFinanceSystem ;
    rdfs:comment "健全智能填单·影像扫描·发票查验·智能审核功能，确保财务数据从业务前端自动采集，实现一点录入·多点应用。"@zh ,
                 "Includes smart form filling, image scanning, invoice verification, and smart review; ensures auto-collection from business front-end, enabling single-entry multi-use."@en .

shrfin:SmartAccountingEngine
    a owl:Class ;
    rdfs:label "智慧核算引擎"@zh , "Smart Accounting Engine"@en ;
    rdfs:subClassOf shrfin:SharedFinanceSystem ;
    rdfs:comment "健全会计引擎核算功能，确保凭证·账簿自动生成并形成电子档案，实现合并报表自动抵消·一键出表。"@zh ,
                 "Accounting engine auto-generates vouchers and ledgers into electronic archives, enabling automatic consolidation elimination and one-click report generation."@en .

shrfin:IntegratedTaxComplianceSystem
    a owl:Class ;
    rdfs:label "一体化合规纳税系统"@zh , "Integrated Tax Compliance System"@en ;
    rdfs:subClassOf shrfin:SharedFinanceSystem ;
    rdfs:comment "健全发票池·进销项管理·税金缴纳功能，确保发票集中管理·税费自动计提，实现纳税报表自动生成·一体申报。"@zh ,
                 "Invoice pool, input/output VAT management, tax payment functions; centralized invoice management, auto tax accrual, auto tax return generation and unified filing."@en .

# ── 1.10 司库系统三级升级 ──────────────────────────────────────────────────────
trs3:TreasurySystemUpgrade
    a owl:Class ;
    rdfs:label "司库系统三级升级"@zh , "Three-Level Treasury System Upgrade"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment "1号文第四条：迭代升级司库财务系统，按三个维度升级：资金→资源·境内→境外·企业→产业。"@zh ,
                 "Art.4 of No.1 Circular: iteratively upgrade treasury financial systems along three dimensions: capital→resources, domestic→overseas, enterprise→industry."@en .

trs3:CapitalToResourceUpgrade
    a trs3:TreasurySystemUpgrade , owl:NamedIndividual ;
    rdfs:label "升级维度一：资金→资源（金融产品·授信·产融协同）"@zh ,
               "Upgrade 1: Capital→Resources (Financial Products, Credit, Industrial-Finance Synergy)"@en ;
    rdfs:comment "全面整合集团金融产品·授信额度·产业链信用等金融资源，打造信贷管理·资本运作·产融协同统一运作平台。"@zh ,
                 "Integrates group financial products, credit limits, and supply chain credit into unified credit management, capital operation, and industrial-finance synergy platform."@en .

trs3:DomesticToOverseasUpgrade
    a trs3:TreasurySystemUpgrade , owl:NamedIndividual ;
    rdfs:label "升级维度二：境内→境外（一体化资金监测）"@zh ,
               "Upgrade 2: Domestic→Overseas (Integrated Fund Monitoring)"@en ;
    rdfs:comment "加强境外资金集中管理，构建覆盖境内外·本外币的一体化资金监测体系，助力人民币国际化。"@zh ,
                 "Strengthens overseas fund centralization, builds integrated monitoring covering domestic/overseas and RMB/foreign currencies, supporting RMB internationalization."@en .

trs3:EnterpriseToIndustryUpgrade
    a trs3:TreasurySystemUpgrade , owl:NamedIndividual ;
    rdfs:label "升级维度三：企业→产业（产业链服务平台）"@zh ,
               "Upgrade 3: Enterprise→Industry (Industrial Chain Service Platform)"@en ;
    rdfs:comment "通过整合资金流·合同流·物流等信息搭建产业链服务平台，推动产业链资金循环畅通，赋能产业高质量发展。"@zh ,
                 "Integrates fund flows, contract flows, and logistics to build an industrial chain service platform enabling supply chain financing and high-quality development."@en .

# ── 1.11 全面预算刚性约束系统 ─────────────────────────────────────────────────
rigbud:RigidBudgetConstraintSystem
    a owl:Class ;
    rdfs:label "全面预算刚性约束系统"@zh , "Comprehensive Budget Rigid Constraint System"@en ;
    rdfs:subClassOf drp:DigitalizedResourceManagementPlatform ;
    rdfs:comment "1号文第六条：推动预算系统与业务系统交互集成，开展多周期·多维度·多情景预算编制·执行监控·纠偏调整和考核评价，实现'多维精益·科学统筹·刚性约束'。"@zh ,
                 "Art.6: integrate budget with business systems; multi-cycle, multi-dimension, multi-scenario budgeting, execution monitoring, correction, and assessment achieving 'multi-dimensional precision, scientific planning, rigid constraint'."@en .

rigbud:BudgetRigidEnforcement
    a owl:Class ;
    rdfs:label "预算刚性执行控制"@zh , "Budget Rigid Enforcement Control"@en ;
    rdfs:subClassOf rigbud:RigidBudgetConstraintSystem ;
    rdfs:comment "超预算支付申请系统自动拦截，须经授权审批方可放行；预算执行偏差实时推送责任人。"@zh ,
                 "System auto-intercepts over-budget payment requests; authorized approval required to proceed; real-time deviation push to responsible persons."@en .

rigbud:MultiScenarioForecast
    a owl:Class ;
    rdfs:label "多情景预测分析"@zh , "Multi-Scenario Forecast Analysis"@en ;
    rdfs:subClassOf rigbud:RigidBudgetConstraintSystem ;
    rdfs:comment "围绕战略目标构建可追溯·可对标·可量化的预测分析工具，支持乐观·基准·悲观三情景滚动预测。"@zh ,
                 "Strategy-aligned tools for traceable, benchmarkable, quantifiable forecasts supporting optimistic, baseline, and pessimistic rolling scenarios."@en .

rigbud:EventBeforeProfit
    a owl:Class ;
    rdfs:label "事前算赢辅助决策"@zh , "Pre-Event Win Decision Support"@en ;
    rdfs:subClassOf rigbud:RigidBudgetConstraintSystem ;
    rdfs:comment "实现'事前算赢·事中算准·事后算明'的科学智能决策支撑体系。"@zh ,
                 "Pre-event profit calculation, in-process accuracy, post-event clarity decision support system."@en .

# ==============================================================================
# ██████████████████████████████████████████████████████████████████████████████
# PART II — 2号文：穿透式监管指导意见
# 国资发监督规〔2026〕2号  (10个重点领域穿透)
# ██████████████████████████████████████████████████████████████████████████████
# ==============================================================================

# ── 2.1 五个自动监管闭环（第2条核心机制）──────────────────────────────────────
fvauto:FiveAutoSupervisionLoop
    a owl:Class ;
    rdfs:label "五个自动智能化监管闭环"@zh ,
               "Five-Automatic Intelligent Supervision Loop"@en ;
    rdfs:subClassOf rtctrl:RealTimeControlSystem ;
    rdfs:comment
        "2号文第（二）条核心机制：形成数据自动采集·模型自动分析·风险自动预警·核查自动派单·整改自动跟踪的智能化监管闭环。"@zh ,
        "Art.(2) of No.2 Circular core mechanism: forms an intelligent supervision loop of auto-collection, auto-analysis, auto-warning, auto-dispatch, and auto-tracking."@en .

fvauto:AutomaticDataCollection
    a fvauto:FiveAutoSupervisionLoop , owl:Class ;
    rdfs:label "①数据自动采集"@zh , "① Automatic Data Collection"@en ;
    rdfs:comment "财务·业务·外部多源异构数据全量实时采集，无需人工干预，延迟<5秒。"@zh ,
                 "Full-volume real-time collection of financial, business, and external heterogeneous data without manual intervention; delay <5 seconds."@en .

fvauto:AutomaticModelAnalysis
    a fvauto:FiveAutoSupervisionLoop , owl:Class ;
    rdfs:label "②模型自动分析"@zh , "② Automatic Model Analysis"@en ;
    rdfs:comment "AI穿透监督模型对采集数据实时分析，识别异常波动·偏离趋势·不合逻辑问题线索。"@zh ,
                 "AI penetration models analyze collected data in real time, identifying anomalous fluctuations, trend deviations, and illogical problem clues."@en .

fvauto:AutomaticRiskWarning
    a fvauto:FiveAutoSupervisionLoop , owl:Class ;
    rdfs:label "③风险自动预警"@zh , "③ Automatic Risk Warning"@en ;
    rdfs:comment "风险评分超阈值自动推送预警至国资委监管平台·企业管理层·主管部门，分级预警。"@zh ,
                 "Risk scores exceeding thresholds auto-push alerts to SASAC platform, enterprise management, and regulatory departments with tiered warnings."@en .

fvauto:AutomaticTaskDispatch
    a fvauto:FiveAutoSupervisionLoop , owl:Class ;
    rdfs:label "④核查自动派单"@zh , "④ Automatic Verification Task Dispatch"@en ;
    rdfs:comment "根据问题线索业务属性自动匹配责任部门，系统自动生成核查任务并推送，实时跟踪核查进度。"@zh ,
                 "Automatically matches responsible departments based on problem business attributes; system auto-generates and pushes verification tasks with real-time progress tracking."@en .

fvauto:AutomaticRectificationTracking
    a fvauto:FiveAutoSupervisionLoop , owl:Class ;
    rdfs:label "⑤整改自动跟踪"@zh , "⑤ Automatic Rectification Tracking"@en ;
    rdfs:comment "整改任务进度·截止日期·验收情况全程系统追踪，超期自动升级，结果自动入库反馈。"@zh ,
                 "System fully tracks rectification task progress, deadlines, and acceptance; auto-escalates overdue tasks; results auto-entered into database."@en .

fvauto:hasFiveAutoCompletionRate
    a owl:DatatypeProperty ;
    rdfs:label "五个自动完成率"@zh , "Five-Auto Completion Rate"@en ;
    rdfs:domain fvauto:FiveAutoSupervisionLoop ;
    rdfs:range xsd:decimal .

# ── 2.2 一张网·一个库·一朵云 ──────────────────────────────────────────────────
infra:NetworkLibraryCloudInfrastructure
    a owl:Class ;
    rdfs:label "一张网一个库一朵云"@zh ,
               "Single Network, Single Database, Single Cloud Infrastructure"@en ;
    rdfs:subClassOf tech:TechnologyPlatform ;
    rdfs:comment
        "2号文第（五）条：加强'一张网·一个库·一朵云'基础设施建设，打通网络传输通道，实现跨业务·跨层级·跨区域·跨部门·跨国别数据实时高效传输。"@zh ,
        "Art.(5) of No.2 Circular: strengthen 'single network, single database, single cloud' infrastructure, enabling cross-business, cross-tier, cross-region, cross-department, cross-country real-time data transmission."@en .

infra:UnifiedNetworkLayer
    a owl:Class ;
    rdfs:label "一张网（统一数据传输网络）"@zh , "Single Network (Unified Data Transmission)"@en ;
    rdfs:subClassOf infra:NetworkLibraryCloudInfrastructure ;
    rdfs:comment "覆盖境内外的统一数据传输网络，支持国资委-央企-子企业多级穿透数据实时传输。"@zh ,
                 "Unified data transmission network covering domestic and overseas, supporting SASAC-central SOE-subsidiary multi-tier penetration real-time transmission."@en .

infra:UnifiedDataRepository
    a owl:Class ;
    rdfs:label "一个库（国资央企数据仓库）"@zh , "Single Database (SOE Data Warehouse)"@en ;
    rdfs:subClassOf infra:NetworkLibraryCloudInfrastructure ;
    rdfs:comment "统一的国资央企数据仓库，建立统一适用的数据标准和规范，支持全量实时采集、数据质量治理。"@zh ,
                 "Unified SOE data warehouse with consistent standards; supports full-volume real-time collection and data quality governance."@en .

infra:UnifiedCloudPlatform
    a owl:Class ;
    rdfs:label "一朵云（国资监管云平台）"@zh , "Single Cloud (State Assets Supervision Cloud)"@en ;
    rdfs:subClassOf infra:NetworkLibraryCloudInfrastructure ;
    rdfs:comment "国资委统一云平台，提供计算·存储·AI推理资源，满足监管模型运行的弹性资源需求，自主可控。"@zh ,
                 "SASAC unified cloud platform providing computing, storage, and AI inference resources for regulatory model operation; self-controlled."@en .

infra:hasCrossRegionDataCoverage
    a owl:DatatypeProperty ;
    rdfs:label "跨区域数据覆盖率"@zh , "Cross-Region Data Coverage Rate"@en ;
    rdfs:domain infra:NetworkLibraryCloudInfrastructure ;
    rdfs:range xsd:decimal .

# ── 2.3 隐私计算·敏感数据可用不可见 ───────────────────────────────────────────
priv:PrivacyComputingFramework
    a owl:Class ;
    rdfs:label "隐私计算框架"@zh , "Privacy Computing Framework"@en ;
    rdfs:subClassOf tech:TechnologyPlatform ;
    rdfs:comment
        "2号文第（九）条：运用隐私计算等技术实现敏感数据'可用不可见'。通过数据分类分级·隐私数据脱敏·数据鉴权等方式加强数据安全保护。"@zh ,
        "Art.(9) of No.2 Circular: implement 'usable but invisible' sensitive data through privacy computing; data classification/grading, de-identification, and data authentication."@en .

priv:AvailableButInvisible
    a owl:Class ;
    rdfs:label "可用不可见技术实现"@zh , "Available-but-Invisible Technical Implementation"@en ;
    rdfs:subClassOf priv:PrivacyComputingFramework ;
    rdfs:comment "联邦学习·安全多方计算·可信执行环境(TEE)等技术使监管数据可参与计算但不暴露原始值。"@zh ,
                 "Federated learning, secure multi-party computation, trusted execution environment (TEE) enable regulatory data to participate in computation without exposing raw values."@en .

priv:SensitiveDataClassification
    a owl:Class ;
    rdfs:label "数据分类分级管理"@zh , "Data Classification and Grading Management"@en ;
    rdfs:subClassOf priv:PrivacyComputingFramework ;
    rdfs:comment "按敏感程度分级：核心数据（军品·国安·特许经营）→重要数据（央企战略·重大合同）→一般数据。"@zh ,
                 "Graded by sensitivity: core data (military, national security, licensed operations) → important data (SOE strategy, major contracts) → general data."@en .

priv:DataSensitivityLevel
    a owl:Class ; rdfs:label "数据敏感级别"@zh , "Data Sensitivity Level"@en .
priv:CoreDataLevel      a priv:DataSensitivityLevel , owl:NamedIndividual ; rdfs:label "核心数据（最严格保护）"@zh , "Core Data (Strictest Protection)"@en .
priv:ImportantDataLevel a priv:DataSensitivityLevel , owl:NamedIndividual ; rdfs:label "重要数据"@zh , "Important Data"@en .
priv:GeneralDataLevel   a priv:DataSensitivityLevel , owl:NamedIndividual ; rdfs:label "一般数据"@zh , "General Data"@en .

# ── 2.4 区块链防数据篡改 ───────────────────────────────────────────────────────
chain:BlockchainAntiTamperSystem
    a owl:Class ;
    rdfs:label "区块链数据防篡改系统"@zh , "Blockchain Anti-Tamper Data System"@en ;
    rdfs:subClassOf tech:TechnologyPlatform ;
    rdfs:comment
        "2号文第（六）条：探索应用区块链等技术防止数据篡改，确保监管数据的真实性·完整性·不可抵赖性。"@zh ,
        "Art.(6) of No.2 Circular: explore blockchain to prevent data tampering, ensuring regulatory data authenticity, integrity, and non-repudiation."@en .

chain:ImmutableAuditChain
    a owl:Class ;
    rdfs:label "不可篡改审计链"@zh , "Immutable Audit Chain"@en ;
    rdfs:subClassOf chain:BlockchainAntiTamperSystem ;
    rdfs:comment "关键监管数据（三重一大决策·资金交易·整改记录）上链存证，任何修改均留痕且全网可验证。"@zh ,
                 "Key regulatory data (SJYZD decisions, fund transactions, rectification records) recorded on chain; any modification is traceable and network-verifiable."@en .

chain:SmartContractEnforcement
    a owl:Class ;
    rdfs:label "智能合约自动执行"@zh , "Smart Contract Auto-Execution"@en ;
    rdfs:subClassOf chain:BlockchainAntiTamperSystem ;
    rdfs:comment "将监管规则编码为智能合约，满足条件时自动触发预警·拦截·上报等动作，消除人为干预风险。"@zh ,
                 "Encodes regulatory rules as smart contracts; automatically triggers alerts, interceptions, and reports when conditions are met, eliminating human interference risk."@en .

# ── 2.5 投资穿透监管（第十条）─────────────────────────────────────────────────
invpen:InvestmentPenetrationSupervision
    a owl:Class ;
    rdfs:label "投资穿透式监管"@zh , "Investment Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十条：建立产业发展监测平台，全级次监测分析产业布局和发展情况；加强投资全过程在线监管，及时发现违规决策投资·高风险业务·无关多元经营等问题。"@zh ,
        "Art.10 of No.2 Circular: establish industrial development monitoring platform; full-tier monitoring of industrial layout; full-process online supervision of investments; detect illegal investment decisions, high-risk businesses, and unrelated diversification."@en .

invpen:IndustrialDevelopmentMonitoringPlatform
    a owl:Class ;
    rdfs:label "产业发展监测平台"@zh , "Industrial Development Monitoring Platform"@en ;
    rdfs:subClassOf invpen:InvestmentPenetrationSupervision ;
    rdfs:comment "全级次监测分析产业布局：主业/非主业投资计划·资金来源·项目进度·收益状况·投向行业等。"@zh ,
                 "Full-tier monitoring of industrial layout: core/non-core investment plans, fund sources, project progress, returns, and target industries."@en .

invpen:FullProcessInvestmentOnlineSupervision
    a owl:Class ;
    rdfs:label "投资全过程在线监管"@zh , "Full-Process Investment Online Supervision"@en ;
    rdfs:subClassOf invpen:InvestmentPenetrationSupervision ;
    rdfs:comment "覆盖：投资授权权限·决策审批·可研尽调·评估论证·合同签订·资金支付·投后管理全环节。"@zh ,
                 "Covers: investment authorization, decision approval, feasibility study, assessment, contract signing, fund payment, and post-investment management."@en .

invpen:MajorProjectFullMonitoring
    a owl:Class ;
    rdfs:label "重大工程项目全流程监管"@zh , "Major Project Full-Process Supervision"@en ;
    rdfs:subClassOf invpen:InvestmentPenetrationSupervision ;
    rdfs:comment "投资立项·承揽建设·质量安全·验收结算全流程监管；及时处置违规转分包·质量安全隐患·高估冒算工程款等问题。"@zh ,
                 "Full supervision of project initiation, construction, quality, and settlement; timely handling of illegal subcontracting, safety hazards, and inflated engineering costs."@en .

invpen:ControlWithoutControlRisk
    a owl:Class ;
    rdfs:label "控股不控权风险识别"@zh , "Shareholding-Without-Control Risk Detection"@en ;
    rdfs:subClassOf invpen:InvestmentPenetrationSupervision ;
    rdfs:comment "识别央企持股但实际控制权旁落的风险情形，通过穿透表决权·董事会席位·管理权分析。"@zh ,
                 "Identifies situations where central SOEs hold shares but lack actual control; analyzes voting rights, board seats, and management authority through penetration."@en .

# ── 2.6 产权穿透监管（第十一条）──────────────────────────────────────────────
propqc:PropertyRightsPenetrationControl
    a owl:Class ;
    rdfs:label "产权穿透式监管"@zh , "Property Rights Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十一条：完善产权信息化管理，强化各级次企业产权形成·变动·注销全生命周期把关，及时预警违规新设法人·违规挂靠·假冒国企等问题风险。"@zh ,
        "Art.11: improve property rights informatization; full lifecycle oversight of SOE property right formation, change, and deregistration; alert on illegal entity establishment, illegal affiliation, and fake SOE issues."@en .

propqc:PropertyRightsLifecycleTracking
    a owl:Class ;
    rdfs:label "产权全生命周期跟踪"@zh , "Property Rights Full-Lifecycle Tracking"@en ;
    rdfs:subClassOf propqc:PropertyRightsPenetrationControl ;
    rdfs:comment "产权形成（设立·增资·并购）→变动（转让·质押·减资）→注销（清算·注销·吊销）全程监管。"@zh ,
                 "Full supervision of property rights: formation (establishment, capital increase, M&A) → change (transfer, pledge, reduction) → deregistration (liquidation, cancellation, revocation)."@en .

propqc:FakeSOEDetection
    a owl:Class ;
    rdfs:label "假冒国企识别"@zh , "Fake SOE Detection"@en ;
    rdfs:subClassOf propqc:PropertyRightsPenetrationControl ;
    rdfs:comment "通过产权登记穿透验证：企业名称含'国'字号但无合法国有股权背景的假冒国企，及时预警并移交监管部门。"@zh ,
                 "Property rights penetration verification: enterprises with '国' in name but lacking legitimate state equity background; timely alert and handover to regulatory authorities."@en .

propqc:SpecialEquityStructureMonitoring
    a owl:Class ;
    rdfs:label "特殊股权结构监测"@zh , "Special Equity Structure Monitoring"@en ;
    rdfs:subClassOf propqc:PropertyRightsPenetrationControl ;
    rdfs:comment "及时监测分析特殊股权结构：法人户数和层级变动·交叉持股·循环持股·超复杂多层架构。"@zh ,
                 "Timely monitoring of special structures: legal entity count/tier changes, cross-shareholding, circular shareholding, overly complex multi-tier architectures."@en .

propqc:PropertyRegistryFoundation
    a owl:Class ;
    rdfs:label "产权登记作为国资监管底座"@zh ,
               "Property Registry as State Asset Supervision Foundation"@en ;
    rdfs:subClassOf propqc:PropertyRightsPenetrationControl ;
    rdfs:comment "2号文明确：发挥产权登记作为国资监管底座作用，消除产权登记企业与财务决算并表企业相关信息的不合理差异。"@zh ,
                 "No.2 Circular explicitly: leverage property registration as the foundation of state asset supervision; eliminate unreasonable differences between registered and consolidated enterprises."@en .

# ── 2.7 会计穿透监管·五假问题（第十三条）──────────────────────────────────────
acpen:AccountingPenetrationSupervision
    a owl:Class ;
    rdfs:label "会计穿透式监管"@zh , "Accounting Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十三条：依托业财审一体化，统一财务核算和报告体系，实现会计信息一穿到底；重点打击五类虚假问题。"@zh ,
        "Art.13: leverage BFAS integration, unify accounting and reporting systems, achieve end-to-end accounting penetration; priority combat against five types of fraud."@en .

acpen:FiveFraudProblemCombat
    a owl:Class ;
    rdfs:label "五假问题专项打击"@zh , "Five Fraud Problem Targeted Combat"@en ;
    rdfs:subClassOf acpen:AccountingPenetrationSupervision ;
    rdfs:comment "2号文明确重点打击五类虚假：经营业绩假·财务杠杆假·出清出表假·研发统计假·'两金'压降假。"@zh ,
                 "No.2 Circular targets five fraud types: fake operating performance, fake financial leverage, fake off-balance-sheet disposal, fake R&D statistics, fake 'two funds' reduction."@en .

acpen:FakeOperatingPerformance
    a acpen:FiveFraudProblemCombat , owl:NamedIndividual ;
    rdfs:label "经营业绩假（虚增收入利润）"@zh , "Fake Operating Performance (Inflated Revenue/Profit)"@en ;
    rdfs:comment "通过虚构收入·关联交易操纵·提前确认收入等手段虚增经营业绩，侵害国有权益。"@zh ,
                 "Inflating performance through fictitious revenue, related-party transaction manipulation, and early revenue recognition."@en .

acpen:FakeFinancialLeverage
    a acpen:FiveFraudProblemCombat , owl:NamedIndividual ;
    rdfs:label "财务杠杆假（隐藏债务）"@zh , "Fake Financial Leverage (Hidden Liabilities)"@en ;
    rdfs:comment "通过表外负债·明股实债·特殊目的载体等隐藏真实债务水平，规避资产负债率红线监管。"@zh ,
                 "Hiding true debt levels through off-balance-sheet liabilities, nominal equity/actual debt, and SPVs to evade A/L ratio red line supervision."@en .

acpen:FakeOffBalanceSheetDisposal
    a acpen:FiveFraudProblemCombat , owl:NamedIndividual ;
    rdfs:label "出清出表假（虚假资产处置）"@zh , "Fake Off-Balance-Sheet Disposal (Fictitious Asset Disposal)"@en ;
    rdfs:comment "以假交易将不良资产移出报表，实际风险和损失仍由央企承担。"@zh ,
                 "Fictitious transactions move non-performing assets off the balance sheet while central SOEs still bear actual risks and losses."@en .

acpen:FakeRDStatistics
    a acpen:FiveFraudProblemCombat , owl:NamedIndividual ;
    rdfs:label "研发统计假（虚构研发投入）"@zh , "Fake R&D Statistics (Fictitious R&D Investment)"@en ;
    rdfs:comment "将非研发费用计入研发投入，或重复计算，以享受国资委研发视同利润加回的考核优惠。"@zh ,
                 "Includes non-R&D costs as R&D, or double-counts, to benefit from SASAC's R&D-treated-as-profit assessment advantage."@en .

acpen:FakeTwoFundsReduction
    a acpen:FiveFraudProblemCombat , owl:NamedIndividual ;
    rdfs:label "'两金'压降假（虚假库存·应收款压降）"@zh , "Fake 'Two Funds' Reduction (Fictitious Inventory/Receivables Reduction)"@en ;
    rdfs:comment "'两金'=存货+应收账款。通过虚假出售·循环交易压降账面数据，实际资产占用未减少。"@zh ,
                 "'Two Funds' = inventory + receivables. Fictitious sales and circular transactions reduce book values without reducing actual asset occupation."@en .

acpen:AccountingPenetrationIndicator
    a owl:Class ;
    rdfs:label "会计穿透监管指标"@zh , "Accounting Penetration Supervision Indicator"@en ;
    rdfs:subClassOf acpen:AccountingPenetrationSupervision .

acpen:TwoFundsRatio             a acpen:AccountingPenetrationIndicator , owl:NamedIndividual ;
    rdfs:label "两金占比（存货+应收/营收）"@zh , "'Two Funds' Ratio (Inventory+Receivables/Revenue)"@en .
acpen:RDInvestmentRatio         a acpen:AccountingPenetrationIndicator , owl:NamedIndividual ;
    rdfs:label "研发投入强度"@zh , "R&D Investment Intensity"@en .
acpen:OffBalanceSheetRiskRatio  a acpen:AccountingPenetrationIndicator , owl:NamedIndividual ;
    rdfs:label "表外风险敞口比率"@zh , "Off-Balance-Sheet Risk Exposure Ratio"@en .

# ── 2.8 薪酬分配穿透监管（第十四条）──────────────────────────────────────────
salpen:CompensationPenetrationSupervision
    a owl:Class ;
    rdfs:label "薪酬分配穿透式监管"@zh , "Compensation Distribution Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十四条：按'全员·全级次·全口径'要求，将中央企业职工薪酬数据全面纳入信息系统监测，及时处置收入畸高·违规津贴补贴·薪酬倒挂等问题。"@zh ,
        "Art.14: per 'all staff, all tiers, full scope' requirements, bring all central SOE employee compensation data into system monitoring; timely handle abnormally high income, illegal allowances, and wage inversion."@en .

salpen:ThreeFullSalaryScope
    a owl:Class ;
    rdfs:label "全员全级次全口径薪酬覆盖"@zh , "All-Staff All-Tier Full-Scope Salary Coverage"@en ;
    rdfs:subClassOf salpen:CompensationPenetrationSupervision ;
    rdfs:comment "全员：包括在职·离退休·劳务派遣·外包；全级次：集团本部到末级子公司；全口径：工资+奖金+福利+津贴+股权激励全部纳入。"@zh ,
                 "All staff: active, retired, dispatched, outsourced; all tiers: group HQ to lowest subsidiaries; full scope: salary + bonus + benefits + allowances + equity incentives all included."@en .

salpen:AbnormalCompensationDetection
    a owl:Class ;
    rdfs:label "薪酬异常检测"@zh , "Abnormal Compensation Detection"@en ;
    rdfs:subClassOf salpen:CompensationPenetrationSupervision .

salpen:AbnormallyHighIncome     a salpen:AbnormalCompensationDetection , owl:NamedIndividual ;
    rdfs:label "收入畸高预警（超同岗位均值N倍）"@zh , "Abnormally High Income Alert (>N times peer average)"@en .
salpen:IllegalAllowances        a salpen:AbnormalCompensationDetection , owl:NamedIndividual ;
    rdfs:label "违规津贴补贴识别"@zh , "Illegal Allowance and Subsidy Detection"@en .
salpen:SalaryInversion          a salpen:AbnormalCompensationDetection , owl:NamedIndividual ;
    rdfs:label "薪酬不合理倒挂"@zh , "Unreasonable Salary Inversion"@en .
salpen:InventedHighPayNames     a salpen:AbnormalCompensationDetection , owl:NamedIndividual ;
    rdfs:label "巧立名目滥发高薪"@zh , "Invented Excuses for Excessive Pay"@en .

salpen:WageArrearComplaintPlatform
    a owl:Class ;
    rdfs:label "中央企业欠薪投诉平台"@zh , "Central SOE Wage Arrear Complaint Platform"@en ;
    rdfs:subClassOf salpen:CompensationPenetrationSupervision ;
    rdfs:comment "2号文明确：发挥中央企业欠薪投诉平台作用，及时核查处置欠薪线索，保障职工合法权益。"@zh ,
                 "No.2 Circular explicitly: leverage wage arrear complaint platform to timely investigate and handle wage arrear clues, protecting workers' legitimate rights."@en .

# ── 2.9 金融风险穿透监管（第十五条）──────────────────────────────────────────
finpen:FinancialRiskPenetrationSupervision
    a owl:Class ;
    rdfs:label "金融风险穿透式监管"@zh , "Financial Risk Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十五条：建立金融和基金业务监管平台，将所有控股参股金融机构·私募基金纳入风险监测，穿透分析底层资产，防止脱实向虚。"@zh ,
        "Art.15: establish financial and fund business monitoring platform; bring all controlled/participating financial institutions and private funds into risk monitoring; penetrate underlying assets; prevent financialization."@en .

finpen:FinancialInstitutionRiskMonitoring
    a owl:Class ;
    rdfs:label "金融机构风险监测（含私募基金）"@zh ,
               "Financial Institution Risk Monitoring (incl. Private Funds)"@en ;
    rdfs:subClassOf finpen:FinancialRiskPenetrationSupervision ;
    rdfs:comment "原则上将所有控股参股金融机构·私募基金管理公司及其主要产品类型·业务项目纳入风险监测范围。"@zh ,
                 "In principle, all controlled/participating financial institutions, private fund management companies, and their main products and businesses are included in risk monitoring."@en .

finpen:UnderlyingAssetPenetration
    a owl:Class ;
    rdfs:label "底层资产穿透分析"@zh , "Underlying Asset Penetration Analysis"@en ;
    rdfs:subClassOf finpen:FinancialRiskPenetrationSupervision ;
    rdfs:comment "穿透分析金融业务决策过程·资金流向·底层资产·投资收益等关键环节，识别多层嵌套的实际投资标的。"@zh ,
                 "Penetrates decision processes, fund flows, underlying assets, and investment returns; identifies actual investment targets through multi-layer nesting."@en .

finpen:FinancializationPrevention
    a owl:Class ;
    rdfs:label "防止脱实向虚"@zh , "Preventing Financialization (De-Industrialization)"@en ;
    rdfs:subClassOf finpen:FinancialRiskPenetrationSupervision ;
    rdfs:comment "合理控制各类金融产品风险敞口，防止央企过度参与金融投机活动，确保实体经济主业地位。"@zh ,
                 "Reasonably controls risk exposure of various financial products, preventing central SOEs from excessive financial speculation, ensuring industrial core business primacy."@en .

finpen:InternalPersonControlRisk
    a owl:Class ;
    rdfs:label "'内部人控制'风险防控"@zh , "'Insider Control' Risk Prevention"@en ;
    rdfs:subClassOf finpen:FinancialRiskPenetrationSupervision ;
    rdfs:comment "穿透分析控股参股金融机构股权结构·实际控制人·三重一大集体决策，加强内部人控制·派出人员履职不力等问题预警。"@zh ,
                 "Penetrates equity structures, actual controllers, and SJYZD decisions of controlled financial institutions; alerts on insider control and派出人员履职不力 issues."@en .

# ── 2.10 军品业务穿透监管（第十六条）────────────────────────────────────────
milpen:MilitaryBusinessPenetrationSupervision
    a owl:Class ;
    rdfs:label "军品业务穿透式监管"@zh , "Military Business Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十六条：承担军品业务的央企按能上线尽上线原则，将军品业务单位·合同·固定资产·研发活动纳入线上监管，确保军费和政府投资资金使用合规。"@zh ,
        "Art.16: defense-related central SOEs maximize online coverage; bring military business units, contracts, fixed assets, and R&D online; ensure compliant use of defense funds and government investment."@en .

milpen:MilitaryContractMonitoring
    a owl:Class ;
    rdfs:label "军品合同全程监管"@zh , "Military Contract Full-Process Monitoring"@en ;
    rdfs:subClassOf milpen:MilitaryBusinessPenetrationSupervision ;
    rdfs:comment "监管关键环节：军品业务交付·质量控制·军费和政府投资资金使用·成本核算·外协外购·非标件采购。"@zh ,
                 "Monitors key elements: military delivery, quality control, defense fund/government investment usage, cost accounting, outsourcing/procurement, and non-standard parts procurement."@en .

milpen:DefenseFundComplianceCheck
    a owl:Class ;
    rdfs:label "军费合规使用核查"@zh , "Defense Fund Compliance Verification"@en ;
    rdfs:subClassOf milpen:MilitaryBusinessPenetrationSupervision ;
    rdfs:comment "及时预警和处置：虚增军品成本·截留滞拨挪用军费·违规外协外购等问题。"@zh ,
                 "Timely alert and handle: inflated military costs, retained/delayed/diverted defense funds, and illegal outsourcing/procurement."@en .

milpen:hasClassificationLevel
    a owl:DatatypeProperty ;
    rdfs:label "涉密等级"@zh , "Classification Level"@en ;
    rdfs:domain milpen:MilitaryBusinessPenetrationSupervision ;
    rdfs:range xsd:string ;
    rdfs:comment "UNCLASSIFIED | SENSITIVE | CONFIDENTIAL | SECRET | TOP_SECRET — 决定数据处理与访问权限。"@zh ,
                 "UNCLASSIFIED | SENSITIVE | CONFIDENTIAL | SECRET | TOP_SECRET — determines data handling and access rights."@en .

# ── 2.11 采购供应链穿透监管（第十七条）──────────────────────────────────────
supch:SupplyChainPenetrationSupervision
    a owl:Class ;
    rdfs:label "采购与供应链穿透式监管"@zh , "Procurement and Supply Chain Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十七条：构建采购与供应链数字化监管平台，全面接入中央企业采购交易在线监管系统，定期监测全量采购交易合规性，穿透监督贸易业务背景。"@zh ,
        "Art.17: build digital procurement and supply chain supervision platform; integrate central SOE procurement online monitoring system; regular full-volume compliance monitoring; penetrate trade business background supervision."@en .

supch:ProcurementComplianceMonitoring
    a owl:Class ;
    rdfs:label "全量采购合规性监测"@zh , "Full-Volume Procurement Compliance Monitoring"@en ;
    rdfs:subClassOf supch:SupplyChainPenetrationSupervision ;
    rdfs:comment "加强采购方式选择·投标报价校验·供应商资质审查·合同评审·资金支付·采购价格确认等关键环节信息采集，定期监测合规性。"@zh ,
                 "Monitors procurement method selection, bid document verification, supplier qualification review, contract review, fund payment, and price confirmation; regular compliance monitoring."@en .

supch:FakeTradeDetection
    a owl:Class ;
    rdfs:label "虚假贸易穿透识别"@zh , "Fake Trade Penetration Detection"@en ;
    rdfs:subClassOf supch:SupplyChainPenetrationSupervision ;
    rdfs:comment "穿透监督贸易业务背景·交易对手·货权控制·贸易核算；对虚假贸易问题发现一起坚决惩治一起。"@zh ,
                 "Penetrates trade business background, counterparties, cargo right control, and trade accounting; detected fake trades are resolutely penalized."@en .

supch:FakeTradeIndicator
    a owl:Class ;
    rdfs:label "虚假贸易识别指标"@zh , "Fake Trade Detection Indicator"@en ;
    rdfs:subClassOf supch:FakeTradeDetection .

supch:NoActualCargoFlow      a supch:FakeTradeIndicator , owl:NamedIndividual ;
    rdfs:label "无实际货物流（无物流单据）"@zh , "No Actual Cargo Flow (No Logistics Documents)"@en .
supch:CircularTrade          a supch:FakeTradeIndicator , owl:NamedIndividual ;
    rdfs:label "循环贸易（A→B→C→A）"@zh , "Circular Trade (A→B→C→A)"@en .
supch:PriceSignificantlyAbnormal a supch:FakeTradeIndicator , owl:NamedIndividual ;
    rdfs:label "价格明显偏离市场（>30%）"@zh , "Price Significantly Abnormal (>30% deviation)"@en .
supch:RelatedPartyTrade      a supch:FakeTradeIndicator , owl:NamedIndividual ;
    rdfs:label "关联方循环贸易"@zh , "Related Party Circular Trade"@en .
supch:NoPurposeTrade         a supch:FakeTradeIndicator , owl:NamedIndividual ;
    rdfs:label "无实质商业目的交易"@zh , "No Substantive Business Purpose Trade"@en .

# ── 2.12 合同穿透监管（第十九条）─────────────────────────────────────────────
conpen:ContractPenetrationSupervision
    a owl:Class ;
    rdfs:label "合同穿透式监管"@zh , "Contract Penetration Supervision"@en ;
    rdfs:subClassOf penet:PenetrativeSupervision ;
    rdfs:comment
        "2号文第十九条：建立覆盖各级企业的合同管理信息系统，强化关键条款信息监测，实现合同流·资金流·资产流数据贯通。"@zh ,
        "Art.19: build contract management information system covering all enterprise tiers; monitor key clause information; achieve contract flow, capital flow, and asset flow data integration."@en .

conpen:ContractManagementInfoSystem
    a owl:Class ;
    rdfs:label "合同管理信息系统"@zh , "Contract Management Information System"@en ;
    rdfs:subClassOf conpen:ContractPenetrationSupervision ;
    rdfs:comment "覆盖各级企业的合同全生命周期系统：起草·审查·谈判·签订·履约·纠纷·归档。"@zh ,
                 "Full lifecycle contract system covering all enterprise tiers: drafting, review, negotiation, signing, performance, dispute, and archiving."@en .

conpen:KeyClauseMonitoring
    a owl:Class ;
    rdfs:label "合同关键条款监测"@zh , "Key Contract Clause Monitoring"@en ;
    rdfs:subClassOf conpen:ContractPenetrationSupervision ;
    rdfs:comment "监测关键条款：签约对象·合同标的·对赌约定·资金结算·纠纷处置·违约责任·权益保障，防范合同重大瑕疵风险。"@zh ,
                 "Monitors key clauses: contracting party, subject matter, bet-on arrangements, fund settlement, dispute handling, liability for breach, and rights protection."@en .

conpen:ThreeFlowContractIntegration
    a owl:Class ;
    rdfs:label "合同流资金流资产流三流贯通"@zh ,
               "Three-Flow Contract Integration (Contract, Capital, Asset)"@en ;
    rdfs:subClassOf conpen:ContractPenetrationSupervision ;
    rdfs:comment "推动合同履约全过程监控，实现合同流·资金流·资产流等数据贯通，及时发现合同成果虚假·违规对赌·违规支付等问题。"@zh ,
                 "Full-process contract performance monitoring; integrates contract, capital, and asset flows to timely detect fictitious contract results, illegal bet-on clauses, and unauthorized payments."@en .

conpen:ContractProblemType
    a owl:Class ;
    rdfs:label "合同违规类型"@zh , "Contract Violation Type"@en .

conpen:ReviewSigningInversion   a conpen:ContractProblemType , owl:NamedIndividual ;
    rdfs:label "合同审签倒置（先签后审）"@zh , "Signing Before Review (Inverted Process)"@en .
conpen:FictitiousBusinessContract a conpen:ContractProblemType , owl:NamedIndividual ;
    rdfs:label "虚构业务合同"@zh , "Fictitious Business Contract"@en .
conpen:FakeContractResults      a conpen:ContractProblemType , owl:NamedIndividual ;
    rdfs:label "合同成果虚假"@zh , "Fake Contract Results"@en .
conpen:IllegalBetOnClause       a conpen:ContractProblemType , owl:NamedIndividual ;
    rdfs:label "违规对赌约定"@zh , "Illegal Bet-On Clause"@en .
conpen:UnauthorizedPayment      a conpen:ContractProblemType , owl:NamedIndividual ;
    rdfs:label "违规支付"@zh , "Unauthorized Payment"@en .

conpen:LegalDisputeManagement
    a owl:Class ;
    rdfs:label "法律纠纷案件穿透管理"@zh , "Legal Dispute Case Penetration Management"@en ;
    rdfs:subClassOf conpen:ContractPenetrationSupervision ;
    rdfs:comment "及时掌握全量案件数据，突出重大案件管理，以案促管避免同类纠纷反复发生。"@zh ,
                 "Timely access to all case data, emphasis on major cases, uses cases to promote management improvement and prevent recurrence."@en .

# ── 2.13 境外单位穿透监管强化（第十八条）────────────────────────────────────
fakedet:OverseasPenetrationEnhancement
    a owl:Class ;
    rdfs:label "境外单位穿透监管（强化）"@zh , "Overseas Unit Penetration Supervision (Enhanced)"@en ;
    rdfs:subClassOf oversea:OverseasSupervision ;
    rdfs:comment
        "2号文第十八条：逐步将境外单位重大意向合作·投资·产权·采购·工程·资金·薪酬等纳入数据采集，穿透监督境外重大经营投资活动的合规性。"@zh ,
        "Art.18: gradually bring overseas unit major intended cooperation, investment, property rights, procurement, engineering, funds, and compensation into data collection; penetrate supervision of overseas major business activities."@en .

fakedet:OverseasDataCollectionScope
    a owl:Class ;
    rdfs:label "境外数据采集范围"@zh , "Overseas Data Collection Scope"@en ;
    rdfs:subClassOf fakedet:OverseasPenetrationEnhancement ;
    rdfs:comment "按能采尽采原则，在遵守中国和所在国法律法规前提下，采集：重大意向合作·投资·产权·采购·工程·资金·薪酬·人员·资产安全。"@zh ,
                 "Per 'collect as much as possible' principle, within compliance with Chinese and host country laws: major cooperation intentions, investment, property rights, procurement, engineering, funds, compensation, personnel, and asset security."@en .

fakedet:OverseasSJYZDComplianceCheck
    a owl:Class ;
    rdfs:label "境外三重一大合规核查"@zh , "Overseas SJYZD Compliance Verification"@en ;
    rdfs:subClassOf fakedet:OverseasPenetrationEnhancement ;
    rdfs:comment "穿透监督境外重大经营投资活动的三重一大集体决策合规性·招标投标·物资采购·资金支付·薪酬管理合规。"@zh ,
                 "Penetration supervision of overseas major business activities: SJYZD collective decision compliance, bidding, materials procurement, fund payment, and compensation management."@en .

fakedet:OverseasRisksSpecificProblems
    a owl:Class ;
    rdfs:label "境外特定违规问题识别"@zh , "Overseas-Specific Violation Problem Detection"@en ;
    rdfs:subClassOf fakedet:OverseasPenetrationEnhancement .

fakedet:BlindOverseasMnA        a fakedet:OverseasRisksSpecificProblems , owl:NamedIndividual ;
    rdfs:label "盲目境外投资并购"@zh , "Blind Overseas Investment M&A"@en .
fakedet:OverseasViolationBidding a fakedet:OverseasRisksSpecificProblems , owl:NamedIndividual ;
    rdfs:label "违规招标采购（境外）"@zh , "Illegal Overseas Bidding and Procurement"@en .
fakedet:OverseasFinancialViolation a fakedet:OverseasRisksSpecificProblems , owl:NamedIndividual ;
    rdfs:label "违反财经纪律（境外）"@zh , "Violation of Financial Discipline (Overseas)"@en .
fakedet:OverseasCommissionViolation a fakedet:OverseasRisksSpecificProblems , owl:NamedIndividual ;
    rdfs:label "违规支付佣金（境外）"@zh , "Illegal Commission Payment (Overseas)"@en .

# ==============================================================================
# SHACL: New validation shapes for v4.4 requirements
# ==============================================================================

# DRP里程碑达标验证
mstn:MilestoneComplianceShape
    a sh:NodeShape ;
    sh:targetClass mstn:FinancialDigitalizationMilestone ;
    sh:property [
        sh:path mstn:hasMilestoneAchievementRate ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "里程碑完成率必须在0.0-1.0之间（2026年底目标：≥0.9）。"@zh ,
                   "Milestone achievement rate must be between 0.0-1.0 (2026 target: ≥0.9)."@en
    ] .

# 整改状态必须合法
rect:RectificationStatusShape
    a sh:NodeShape ;
    sh:targetClass rect:RectificationAccountabilityMechanism ;
    sh:property [
        sh:path rect:hasRectificationDeadlineDays ;
        sh:maxInclusive 30 ;
        sh:message "整改期限不得超过30天（重大问题7天，重要问题15天）。"@zh ,
                   "Rectification deadline must not exceed 30 days (major issues: 7 days, important: 15 days)."@en
    ] .

# 五个自动完成率
fvauto:FiveAutoCompletionShape
    a sh:NodeShape ;
    sh:targetClass fvauto:FiveAutoSupervisionLoop ;
    sh:property [
        sh:path fvauto:hasFiveAutoCompletionRate ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 1.0 ;
        sh:message "五个自动完成率须在0.0-1.0之间，建设目标≥0.85。"@zh ,
                   "Five-auto completion rate must be between 0.0-1.0; construction target ≥0.85."@en
    ] .

# 军品业务涉密等级声明
milpen:MilitaryClassificationShape
    a sh:NodeShape ;
    sh:targetClass milpen:MilitaryBusinessPenetrationSupervision ;
    sh:property [
        sh:path milpen:hasClassificationLevel ;
        sh:minCount 1 ;
        sh:message "军品业务穿透监管必须声明涉密等级。"@zh ,
                   "Military business penetration supervision must declare classification level."@en
    ] .

# ==============================================================================
# CROSS-MODULE INTEGRATION PROPERTIES (v4.4)
# ==============================================================================

sasac:hasDRPSystem            a owl:ObjectProperty ; rdfs:label "DRP系统状态"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range drp:DigitalizedResourceManagementPlatform .
sasac:hasMilestoneStatus      a owl:ObjectProperty ; rdfs:label "里程碑状态"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range mstn:FinancialDigitalizationMilestone .
sasac:hasBFASIntegration      a owl:ObjectProperty ; rdfs:label "业财审一体化"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range bfas:BusinessFinanceAuditIntegration .
sasac:hasFourFlowIntegration  a owl:ObjectProperty ; rdfs:label "四流合一"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range foflow:FourFlowIntegration .
sasac:hasFiveAutoLoop         a owl:ObjectProperty ; rdfs:label "五个自动闭环"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range fvauto:FiveAutoSupervisionLoop .
sasac:hasInvestPenetration    a owl:ObjectProperty ; rdfs:label "投资穿透监管"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range invpen:InvestmentPenetrationSupervision .
sasac:hasPropertyQCPenetration a owl:ObjectProperty ; rdfs:label "产权穿透监管"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range propqc:PropertyRightsPenetrationControl .
sasac:hasAccountingPenetration a owl:ObjectProperty ; rdfs:label "会计穿透监管"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range acpen:AccountingPenetrationSupervision .
sasac:hasSalaryPenetration    a owl:ObjectProperty ; rdfs:label "薪酬穿透监管"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range salpen:CompensationPenetrationSupervision .
sasac:hasFinancialRiskPenetration a owl:ObjectProperty ; rdfs:label "金融风险穿透"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range finpen:FinancialRiskPenetrationSupervision .
sasac:hasSupplyChainPenetration a owl:ObjectProperty ; rdfs:label "采购供应链穿透"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range supch:SupplyChainPenetrationSupervision .
sasac:hasContractPenetration  a owl:ObjectProperty ; rdfs:label "合同穿透监管"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range conpen:ContractPenetrationSupervision .
sasac:hasPrivacyComputing     a owl:ObjectProperty ; rdfs:label "隐私计算"@zh ; rdfs:domain drp:DigitalizedResourceManagementPlatform ; rdfs:range priv:PrivacyComputingFramework .
sasac:hasBlockchainAntiTamper a owl:ObjectProperty ; rdfs:label "区块链防篡改"@zh ; rdfs:domain drp:DigitalizedResourceManagementPlatform ; rdfs:range chain:BlockchainAntiTamperSystem .
sasac:hasRectificationMechanism a owl:ObjectProperty ; rdfs:label "整改追责机制"@zh ; rdfs:domain ent:CentralSOE ; rdfs:range rect:RectificationAccountabilityMechanism .

# Key instances
drp:SASACDRPStandard
    a drp:DigitalizedResourceManagementPlatform , owl:NamedIndividual ;
    rdfs:label "国资委DRP建设标准"@zh , "SASAC DRP Construction Standard"@en ;
    drp:hasDRPReadinessLevel "1"^^xsd:integer .

fvauto:StandardFiveAutoLoop
    a fvauto:FiveAutoSupervisionLoop , owl:NamedIndividual ;
    rdfs:label "标准五个自动监管闭环配置"@zh , "Standard Five-Auto Supervision Loop Config"@en ;
    fvauto:hasFiveAutoCompletionRate "0.0"^^xsd:decimal .

rect:StandardRectificationPolicy
    a rect:TimeLimitedRectification , owl:NamedIndividual ;
    rdfs:label "标准整改期限政策（一般问题30天）"@zh , "Standard Rectification Policy (General: 30 days)"@en ;
    rect:hasRectificationDeadlineDays "30"^^xsd:integer .

